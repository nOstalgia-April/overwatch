playervar Number HealthState = 2;
globalvar Color[] HealthColor = [Color.Red, Color.Yellow, Color.Green];
rule: '队伍HUD显示'
{
    for(i_ = 0; i_ < 5; i_++){
        Number i : EvaluateOnce(i_);
        CreateHudText(
            VisibleTo: HasSpawned(PlayersInSlot(i,Team.Team2))?AllPlayers():null,
            Header: <'        \n   <0>   \n ',HeroIconString(HeroOf(PlayersInSlot(i,Team.Team2)))>,
            Subheader: IconString(Icon.Happy)+'                                        ',
            Text: <'<1>\n\n容量：<0>',PlayersInSlot(i,Team.Team2).battery.Capacity,PlayersInSlot(i,Team.Team2).battery.Name>,
            Location: Location.Left,
            SortOrder: i==SlotOf(LocalPlayer())?-100:i,
            HeaderColor: HealthColor[PlayersInSlot(i,Team.Team2).HealthState],
            TextColor: Color.White,
            SubheaderColor: Color.White,
            Reevaluation: HudTextRev.VisibleToSortOrderStringAndColor,
            Spectators: Spectators.DefaultVisibility
        );
    }
    CreateHudText(
        VisibleTo: AllPlayers(),
        Text: '\n\n\n\n\n\n\n\n\n\n\n\n',
        Location: Location.Left,
        SortOrder: -101,
    );
    CreateHudText(
        VisibleTo: AllPlayers(),
        Text: '\n\n',
        Location: Location.Left,
        SortOrder: -99,
    );
}
