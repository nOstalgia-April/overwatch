规则("装备槽0的属性赋值")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		事件玩家.slot_unlocked[0] == 1;
 		已重生(事件玩家) == 1;
		全局.GameState == 2;
	}

	动作
	{
		If(数量(事件玩家.slot_equipped[0]) > 0);
			For 玩家变量(事件玩家, slot_for, 0, 数量(事件玩家.slot_equipped[0]), 1);
				事件玩家.slot_nowShuxing = 全局.equipment_Shuxing[数组值的索引(全局.equipment_Name, 事件玩家.slot_equipped[0][事件玩家.slot_for])];
				For 玩家变量(事件玩家, slot_Shuxingadd_for, 0, 6, 1);
					事件玩家.Shuxing[事件玩家.slot_Shuxingadd_for] += 事件玩家.slot_nowShuxing[事件玩家.slot_Shuxingadd_for];
					等待(0.016, 无视条件);
				End;
				等待(0.016, 无视条件);
			End;
			等待直到(全局.GameState == 3, 99999);
			For 玩家变量(事件玩家, slot_for, 0, 数量(事件玩家.slot_equipped[0]), 1);
				事件玩家.slot_nowShuxing = 全局.equipment_Shuxing[数组值的索引(全局.equipment_Name, 事件玩家.slot_equipped[0][事件玩家.slot_for])];
				For 玩家变量(事件玩家, slot_Shuxingadd_for, 0, 6, 1);
					事件玩家.Shuxing[事件玩家.slot_Shuxingadd_for] -= 事件玩家.slot_nowShuxing[事件玩家.slot_Shuxingadd_for];
					等待(0.016, 无视条件);
				End;
				等待(0.016, 无视条件);
			End;
		End;
		调用子程序(Agility);
	}
}

