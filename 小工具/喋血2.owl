}
规则("初始化--关闭隐藏各种")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 1;
	}

	动作
	{
		等待(0.500, 无视条件);
		关闭游戏预设复生模式(事件玩家);
		关闭游戏预设计分模式;
		关闭游戏预设通告模式;
		关闭游戏预设完成条件;
		关闭游戏预设音乐模式;
		隐藏消灭提示(事件玩家);
		禁用 隐藏姓名板(事件玩家, 所有玩家(所有队伍));
		隐藏游戏模式地图UI(事件玩家);
		隐藏游戏模式HUD(事件玩家);
		等待(99999, 无视条件);
	}
}
