规则("——雷霆回响-暴击触发")
{
	事件
	{
		玩家造成伤害;
		双方;
		全部;
	}
	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(攻击方.slot_equipped[当前数组元素], 自定义字符串("雷霆回响")) && 攻击方.slot_unlocked[当前数组元素] == 1) == 1;
		事件暴击 == 真;
	}
	动作
	{
		伤害(范围内玩家(被攻击方, 2, 队伍1, 表面), 攻击方, 5 * 攻击方.Shuxing[5]);
		If(攻击方.Shuxing[5] > 10);
			设置状态(范围内玩家(被攻击方, 2, 队伍1, 表面),事件玩家,击晕, 0.5);
		End;
		播放效果(事件玩家, 有害爆炸, 颜色(蓝色), 被攻击方, 2);
		播放效果(事件玩家, 爆炸声音, 颜色(蓝色), 被攻击方, 150);
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义字符串("装备 雷霆"));
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 5 * 攻击方.Shuxing[5]);
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义颜色(44, 58, 248, 255));
	}
}

