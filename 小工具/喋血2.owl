规则("子程序YG_type_bool")
{
	事件
	{
		子程序;
		YG_type_bool;
	}

	动作
	{
				If(对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("耀光")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1);
		事件玩家._Bool_Yaoguang = 1;
		Else If(对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("冰与火之歌")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1);
			If(事件玩家.Shuxing[1] >= 10 && 事件玩家.Shuxing[5]>= 10);
			事件玩家._Draw_Bingyuhuozhige = 自定义字符串("冰冻并燃烧");
			Else;
			事件玩家._Draw_Bingyuhuozhige = 数组随机取值(数组(自定义字符串("燃烧"),自定义字符串("冰冻")));
			End;
		End;
		等待(3, 当为“真”时重新开始);
		事件玩家._Bool_Yaoguang = 0;
		事件玩家._Draw_Bingyuhuozhige = 0;
	}
}

