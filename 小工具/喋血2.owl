		攻击方 != 事件玩家;
	}

	动作
	{
		伤害(范围内玩家(事件玩家, 6, 队伍1, 表面及敌方屏障), 空, 事件伤害);
		播放效果(所有玩家(所有队伍), 环状爆炸, 颜色(玫红), 事件玩家, 6.750);
		等待(5, 无视条件);
	}
}
规则("——炸弹小子-召唤炸弹")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("炸弹小子")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
	}

	动作
	{
		If(事件玩家.level < 8 || 数量((范围内玩家(事件玩家, 15, 队伍1, 表面))) == 0);
		创建弹道(球弹道, 事件玩家, 眼睛位置(事件玩家), 上, 至地图, 伤害, 队伍1, 8*(事件玩家.Shuxing[0]+事件玩家.Shuxing[3]), 1, 3, 有害爆炸, 爆炸声音, 0, 5, 6, 0, 3, 10);
		Else;
		创建弹道(球弹道, 事件玩家, 眼睛位置(事件玩家), 方向(眼睛位置(事件玩家), 眼睛位置(数组随机取值(范围内玩家(事件玩家, 15, 队伍1, 表面))))+上*2, 至地图, 伤害, 队伍1, 8*(事件玩家.Shuxing[0]+事件玩家.Shuxing[3]), 1, 3, 有害爆炸, 爆炸声音, 0, 15, 6, 0, 1, 5);
		End;
		等待(2, 无视条件);
		如条件为“真”则循环;
	}
}
// 装备池初始化 - 传奇（更新）
规则("\\\装备池初始化-传奇")
{
	事件
	{
		持续 - 全局;
	}
	动作
	{
		全局.equipment_pool[2] =
		 数组(
			数组(自定义字符串("精准打击"), 数组(0,0,0,2,2,0), 自定义字符串("当你的法强>10 || 攻击>10\r\n 你的攻击会有（5*敏捷+10）%概率造成暴击\r\n伤害倍率为1.5"), 2),
			数组(自定义字符串("掠夺者之剑"), 数组(0,0,0,0,0,0), 自定义字符串("每造成一次击杀\r\n获得+1法强+1攻击\r\n上限为3*level\r\n护甲+2魔抗+2"), 2),
			数组(自定义字符串("风暴之眼"), 数组(0,1,0,0,0,3), 自定义字符串("每释放3次技能，召唤一道雷电打击距离鼠标最近的敌人\r\n造成10*（攻击+敏捷）的范围伤害\r\n若敏捷>12，雷电伤害提升至15*（攻击+敏捷）\r\n并有50%概率眩晕敌人1秒\r\n法强+1，敏捷+3"), 2),
			数组(自定义字符串("不灭之握"), 数组(0,0,0,0,0,0), 自定义字符串("每用近战击杀一名敌人\r\n获得+2生命\r\n最多叠加3*level层"), 2),
			数组(自定义字符串("末日铁拳的拳套"), 数组(0, 5, 0, 0, 0, 0), 自定义字符串("近战攻击V变为冷却时间12秒的{0}上勾拳{1}\r\n造成15+法强*5点伤害\r\n法强+5", 英雄图标字符串(英雄(末日铁拳)), 图标字符串(箭头：向上)), 2),
			数组(自定义字符串("反伤刺甲"), 数组(0, 0, 0, 0, 0,0), 自定义字符串("受到伤害时\r\n你会反弹0.2*事件伤害+（护甲+魔抗）*1点伤害\r\n若你的生命值≤50%\r\n则反弹伤害翻倍"), 2), 
			数组(自定义字符串("能源转换器"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("受到攻击时，你会获得4%终极技能能量"), 2), 
			数组(自定义字符串("残暴之爪"), 数组(0, 0, 0, 2, 2, 0), 自定义字符串("你对敌人造成暴击伤害时，会在0.5秒后\r\n再次对该敌人造成（0.75*事件伤害)的伤害量"),2), 
			数组(自定义字符串("引爆器"), 数组(0, 0, 0, 2, 2, 0), 自定义字符串("击杀一名敌人后，会在敌人死亡处引爆，对范围5M内敌人造成\r\n（最后一击伤害量）的伤害，每点法强会增加5%的伤害。"), 2), 
			数组(自定义字符串("飞镖发射器"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("使用主要武器时，将会向前发射一枚飞镖\r\n造成（5+攻击力*2）点伤害，如玩家攻击力≥20点时\r\n将会额外发射两枚飞镖"), 2),
			数组(自定义字符串("腐朽之木"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("受到治疗时，会发射两发追踪子弹\r\n每发伤害为10*(生命*2+魔抗)"), 2), 
			数组(自定义字符串("祈祷项链"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("受到≥自身最大生命值10%的伤害后\r\n会恢复该伤害值50%的生命"), 2), 
			数组(自定义字符串("狙击手的灵魂"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("当你使用主要武器造成伤害，且与敌人距离≥4M时\r\n你主要武器造成的伤害都会\r\n额外造成（距离*0.1）的伤害"), 2),
			数组(自定义字符串("恐螯之心"), 数组(0, 0, 4, 0, 0, 0), 自定义字符串("每秒治愈你2.5%的最大生命值\r\n生命+4"), 2), 
			数组(自定义字符串("恶魔恩赐"), 数组(1, 1, 1, 1, 1, 1), 自定义字符串("每受到(1000-敏捷*10)点伤害\r\n随机属性永久+1\r\n全属性+1"), 2),
			数组(自定义字符串("弱点共鸣"), 数组(0, 2, 0, 0, 0, 0), 自定义字符串("对冰冻,眩晕,击倒敌人造成暴击伤害\r\n暴击倍率为150%\r\n八级以后，倍率改为200%\r\n法强+2"), 2),
			数组(自定义字符串("霜狱震壁"), 数组(0, 2, 0, 0, 0, 0), 自定义字符串("可对冰冻敌人施加击退\r\n若敌人在击退途中撞墙\r\n清除冰冻效果并附加15*法强的伤害\r\n攻击>10后，不再清除冰冻效果\r\n攻击+2"), 2),
			数组(自定义字符串("闪电链"), 数组(2, 0, 0, 0, 0, 0), 自定义字符串("五级以后\r\n你的攻击伤害会对附近的一名敌人\r\n施加(5*迅捷+2*生命)伤害的闪电链\r\n敏捷＞10以后，改为附近两名敌人\r\n攻击+2"), 2),
			数组(自定义字符串("召唤雷电"), 数组(0, 2, 0, 2, 0, 0), 自定义字符串("十级以后\r\n周期性地在身边召唤落雷\r\n造成8*(魔抗+法强)的伤害,并造成击倒\r\n魔抗+2,法强+2"), 2),
			数组(自定义字符串("炽焰油迹"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("使用技能后的下一次攻击\r\n会在目标处留下一滩存在3s的油\r\n造成每秒(攻击+法强)的dot伤害\r\n如果油内有敌人处于燃烧状态\r\n点燃油，转而造成10*(攻击+法强)的爆炸伤害"), 2), 
			数组(自定义字符串("绝对领域"), 数组(0, 3, 0, 0, 0, 0), 自定义字符串("满血时，随身一个半径为(法强)m的区域\r\n对靠近的怪物造成眩晕,附加10*双抗的伤害(CD:1s)\r\n法强+3"), 2), 
			数组(自定义字符串("雷霆回响"), 数组(0, 0, 0, 0, 0, 3), 自定义字符串("每次暴击，释放雷霆冲击\r\n对目标及附近2米敌人造成(5*敏捷)伤害（CD 2秒）\r\n敏捷>10时，冲击附带0.5秒晕眩\r\n敏捷+3"), 2), 
			数组(自定义字符串("末日铁拳的西装"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("你造成伤害时会获得（0.05*伤害*(护甲+魔抗)）的护甲\r\n最高不可超过你40%的最大生命值"), 2)
			);
	}
}

规则("——精准打击-造成伤害消耗充能")
{
	事件
	{
		玩家造成伤害;
		双方;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(攻击方.slot_equipped[当前数组元素], 自定义字符串("精准打击")) && 攻击方.slot_unlocked[当前数组元素] == 1) == 1;
		(事件玩家.Shuxing[0] > 10 && 事件玩家.Shuxing[1] >10) == 真;
	}

	动作
	{
		If(随机整数(1,100) <= 10+5*事件玩家.Shuxing[5]);
			创建弹道(球弹道, 空, 眼睛位置(被攻击方), 空, 至地图, 伤害, 所有队伍, 20, 1, 0, 有害爆炸, 爆炸声音, 0, 10, 5, 0, 0, 0);
			伤害(被攻击方, 事件玩家, 0.5*事件伤害);
		End;
	}
}

规则("——掠夺者之剑-杀人叠加层数")
{
	事件
	{
		玩家造成最后一击;
		双方;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("掠夺者之剑")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
	}

	动作
	{
		If(3*事件玩家.level > 事件玩家._stacks_Lueduozhezhijian+1);
		播放效果(事件玩家, 正面状态施加声音, 颜色(白色), 所选位置(事件玩家), 100);
		事件玩家._stacks_Lueduozhezhijian = 较小(3*事件玩家.level, 事件玩家._stacks_Lueduozhezhijian+1);
		事件玩家.Shuxing[0] += 1;
		事件玩家.Shuxing[1] += 1;
		End;
	}
}

规则("——掠夺者之剑-激活")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("掠夺者之剑")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
	}

	动作
	{
		事件玩家._stacks_Lueduozhezhijian = 0;
		等待直到(全局.GameState == 3, 99999);
		事件玩家.Shuxing[0] -= 事件玩家._stacks_Lueduozhezhijian;
		事件玩家.Shuxing[1] -= 事件玩家._stacks_Lueduozhezhijian;
		事件玩家._stacks_Lueduozhezhijian = 0;
	}
}

