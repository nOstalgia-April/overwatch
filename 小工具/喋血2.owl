		事件玩家.Shuxing[4] -= 5;
	}
}
规则("——共鸣恩泽-受到治疗加敏捷")
{
	事件
	{
		玩家受到治疗;
		队伍2;
		全部;
	}
	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(受治疗者.slot_equipped[当前数组元素], 自定义字符串("共鸣恩泽")) && 受治疗者.slot_unlocked[当前数组元素] == 1) == 1;
		事件玩家 != 治疗者;
	}
	动作
	{
		If(受治疗者.Shuxing[3] > 10 || 受治疗者.Shuxing[4] > 10);
			受治疗者.Shuxing[5] += 4;
			治疗者.Shuxing[5] += 4;
			调用子程序(Agility);
			等待(1, 无视条件);
			受治疗者.Shuxing[5] -= 4;
			治疗者.Shuxing[5] -= 4;
			调用子程序(Agility);
		Else;
			受治疗者.Shuxing[5] += 1;
			治疗者.Shuxing[5] += 1;
			调用子程序(Agility);
			等待(1, 无视条件);
			受治疗者.Shuxing[5] -= 1;
			治疗者.Shuxing[5] -= 1;
			调用子程序(Agility);
		End;
		播放效果(所有玩家(所有队伍), 正面状态施加声音, 颜色(白色), 受治疗者, 100);
	}
}

