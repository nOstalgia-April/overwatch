		"下翻"
		禁用 Else If(事件玩家.MenuLoop == 3);
		If(事件玩家.OK != 1);
			事件玩家.OK = 1;
			小字体信息(事件玩家, 自定义字符串("已准备，等待所有人准备即可开始游戏", 英雄图标字符串(所用英雄(事件玩家)), 事件玩家));
		Else;
			小字体信息(事件玩家, 自定义字符串("你取消了准备，不要让队友等待太久！", 英雄图标字符串(所用英雄(事件玩家)), 事件玩家));
			事件玩家.OK = 0;
		End;
	}
}

规则("Click4-22-24")//选中奖券
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 4;
		事件玩家.MenuLoop >= 22;
		已重生(事件玩家) == 真;
		事件玩家.MenuLoop <= 24;
		事件玩家.Draw_Result == 0;
	}

	动作
	{

		If(事件玩家.MenuLoop == 22);
			事件玩家.Used_Ticket_ID = 0;
		Else If(事件玩家.MenuLoop == 23);
			事件玩家.Used_Ticket_ID = 1;
		Else If(事件玩家.MenuLoop == 24);
			事件玩家.Used_Ticket_ID = 2;
		End;

		If(事件玩家.tickets[事件玩家.Used_Ticket_ID] == 0);
			播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			小字体信息(事件玩家, 自定义字符串("你没有该种类型的抽奖券了，请闯关获得"));
		Else;
			播放效果(事件玩家, 状态爆炸声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			小字体信息(事件玩家, 自定义字符串("已选中{0}抽奖券",数组(自定义字符串("普通"),自定义字符串("稀有"),自定义字符串("传奇"))[事件玩家.Used_Ticket_ID]));
		End;

	}
}

规则("Click4-25")//装备抽奖
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 4;
		事件玩家.MenuLoop == 25;
		已重生(事件玩家) == 真;
		事件玩家.Draw_Result == 0;
	}

	动作
	{
		If(事件玩家.tickets[事件玩家.Used_Ticket_ID] > 0);
			事件玩家.tickets[事件玩家.Used_Ticket_ID] += -1;
			播放效果(事件玩家, 状态爆炸声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			调用子程序(Draw_equipment);
			事件玩家.Draw_type = 1;
			播放效果(事件玩家, 有益爆炸, 颜色(黄色), 最后(事件玩家.MenuCameraNow), 0.5);
		Else;
			播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			小字体信息(事件玩家, 自定义字符串("该种类型的抽奖券用完了，请重新选择"));
		End;
	}
}

