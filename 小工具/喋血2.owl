规则("局内时，不断按照spawnlist生成怪物")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.spawnlist != 0;
		全局.GameState == 2;
		全局.Quitting_stage < 3;
		数量(所有玩家(队伍1)) < 7;
	}

	动作
	{
		全局.Spawnlist_now = 空数组;
		For 全局变量(for_spawnlist, 0, 数量(全局.spawnlist), 1);//先根据spawnlist创建一个一维的怪物生成名单
			While(数量(已过滤的数组(全局.Spawnlist_now, 当前数组元素 == 全局.spawnlist[全局.for_spawnlist][0])) < 全局.spawnlist[全局.for_spawnlist][1]);//如果该对局中该种类型的怪物没有达到上限
			修改全局变量(Spawnlist_now, 添加至数组, 全局.spawnlist[全局.for_spawnlist][0]);
			等待(0.016, 无视条件);
			End;
		End;//再进行生成，期间为了平均每种怪物，进行一次打乱处理
			全局.Spawnlist_now = 随机数组(全局.Spawnlist_now);
		While(数量(全局.Spawnlist_now) > 0 && 服务器负载峰值 < 150 && 数量(所有玩家(队伍1)) < 7);
			生成机器人(英雄(回声), 队伍1, -1, 数组随机取值(已过滤的数组(全局.nodes_location, (相距距离(数组随机取值(所有存活玩家(队伍2)), 当前数组元素) <= 30) && (相距距离(数组随机取值(所有存活玩家(队伍2)), 当前数组元素) >= 10))),矢量(0, 0, 0));
			最后创建的实体.bot_name = 全局.Spawnlist_now[0];
			修改全局变量(Spawnlist_now, 根据索引从数组中移除, 0);
			等待(随机实数(2, 3), 无视条件);
		End;
		等待(5, 无视条件);
		如条件为“真”则循环;
	}
}


