规则("菜单 钥匙插进去了吗")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.MenuActive >= 1;
		禁用 事件玩家.MenuActive <= 5;
	}

	动作
	{

		For 玩家变量(事件玩家, MenuPage, 0, 数量(全局.Menu_BottonAllay[事件玩家.MenuActive]), 1);
			If(绝对值(水平朝向角度(事件玩家) / 事件玩家.MenuCursorSensibility - 首个(全局.MenuBottonCoordinate[事件玩家.MenuLoop]))
				< 全局.MenuBottonWidth[事件玩家.MenuActive] && 绝对值(垂直朝向角度(事件玩家) / 事件玩家.MenuCursorSensibility - 最后(
				全局.MenuBottonCoordinate[事件玩家.MenuLoop])) < 全局.MenuBottonHeight[事件玩家.MenuActive]);
				中断;
			End;
			事件玩家.MenuLoop = 全局.Menu_BottonAllay[事件玩家.MenuActive][事件玩家.MenuPage];
		End;
		等待(0.025, 无视条件);
		如条件为“真”则循环;
	}
}

