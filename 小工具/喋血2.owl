规则("规则297")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.GameState == 2;
		按钮被按下(主机玩家, 按钮(主要攻击模式)) == 1;
		按钮被按下(主机玩家, 按钮(辅助攻击模式)) == 1;
	}

	动作
	{
		等待(1, 当为“假”时中止);
		生成机器人(英雄(安娜), 队伍2, -1, 主机玩家, 矢量(0, 0, 0));
		生成机器人(英雄(安娜), 队伍2, -1, 主机玩家, 矢量(0, 0, 0));
		生成机器人(英雄(安娜), 队伍2, -1, 主机玩家, 矢量(0, 0, 0));
	}
}

