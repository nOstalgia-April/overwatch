规则("—1-1 金蝉脱壳")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.GameState == 2;
		全局.CurrentRoom == 自定义字符串("金蝉脱壳");
	}

	动作
	{
			全局.leveladd = 0;
			For 全局变量(for_leveladd, 0, 数量(所有玩家(队伍2)), 1);
				全局.leveladd += 此栏位的玩家(全局.for_leveladd, 队伍2).level;
				等待(0.016, 无视条件);
			End;
			全局.leveladd = 全局.leveladd/数量(所有玩家(队伍2));
			If(全局.leveladd <= 4 && 全局.Quitting_stage == 0);
				全局.spawnlist = 数组(数组(自定义字符串("僵尸托比昂"), 6));
			Else If(全局.leveladd <= 7 && 全局.Quitting_stage == 1);
				全局.spawnlist = 数组(数组(自定义字符串("钩子路霸"),较大(2, 存活玩家数量(队伍2)/2)),数组(自定义字符串("僵尸托比昂"), 3));
			Else If(全局.leveladd <= 10 && 全局.Quitting_stage >= 2);
				全局.spawnlist = 数组(数组(自定义字符串("钩子路霸"),4),数组(自定义字符串("僵尸托比昂"), 2));
			End;
		等待(5, 无视条件);
		如条件为“真”则循环;
	}
}

