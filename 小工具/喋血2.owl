	动作
	{
		创建弹道(源氏“镖”, 事件玩家, 空, 与此角度的相对方向(随机整数(0, 1), 逐帧更新(垂直朝向角度(事件玩家)) + 随机整数(0, 1)), 至玩家, 伤害, 队伍1, 5 + 事件玩家.Shuxing[0] * 2, 1, 0, 有害爆炸,
			爆炸声音, 0, 60, 4, 0, 0, 0);
		If(事件玩家.Shuxing[0] >= 20);
			创建弹道(源氏“镖”, 事件玩家, 空, 与此角度的相对方向(随机整数(0, 1), 逐帧更新(垂直朝向角度(事件玩家)) + 随机整数(0, 1)), 至玩家, 伤害, 队伍1, 5 + 事件玩家.Shuxing[0] * 2, 1, 0, 有害爆炸,
				爆炸声音, 0, 60, 4, 0, 0, 0);
			创建弹道(源氏“镖”, 事件玩家, 空, 与此角度的相对方向(随机整数(0, 1), 逐帧更新(垂直朝向角度(事件玩家)) + 随机整数(0, 1)), 至玩家, 伤害, 队伍1, 5 + 事件玩家.Shuxing[0] * 2, 1, 0, 有害爆炸,
				爆炸声音, 0, 60, 4, 0, 0, 0);
		End;
		等待(0.10, 无视条件);
		如条件为“真”则循环;
	}
}

