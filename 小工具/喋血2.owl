规则("——冰与火之歌-造成伤害消耗充能")
{
	事件
	{
		玩家造成伤害;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(攻击方.slot_equipped[当前数组元素], 自定义字符串("冰与火之歌")) && 攻击方.slot_unlocked[当前数组元素] == 1) == 1;
		事件玩家._Draw_Bingyuhuozhige != 0;
	}

	动作
	{
		If(事件玩家._Draw_Bingyuhuozhige == 自定义字符串("冰冻"));
		设置状态(被攻击方, 事件玩家, 冰冻, 1);
		Else If(事件玩家._Draw_Bingyuhuozhige == 自定义字符串("燃烧"));
		设置状态(被攻击方, 事件玩家, 燃烧, 1);
		开始持续伤害(被攻击方, 事件玩家, 1, 75);
		Else If(事件玩家._Draw_Bingyuhuozhige == 自定义字符串("冰冻并燃烧"));
		设置状态(被攻击方, 事件玩家, 燃烧, 1);
		开始持续伤害(被攻击方, 事件玩家, 1, 75);
		设置状态(被攻击方, 事件玩家, 冰冻, 1);
		End;
		事件玩家._Draw_Bingyuhuozhige = 0;
	}
}

