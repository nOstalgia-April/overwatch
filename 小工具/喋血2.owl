	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(攻击方.slot_equipped[当前数组元素], 自定义字符串("风暴之眼")) && 攻击方.slot_unlocked[当前数组元素] == 1) == 1;
		事件玩家._count_Fengbaozhiyan == 3;
	}

	动作
	{
		播放效果(所有玩家(所有队伍), “秩序之光”传送面板重现效果, 颜色(白色), 距离准星最近的玩家(事件玩家,队伍1), 1);
		播放效果(所有玩家(所有队伍), “回声”黏性炸弹爆炸效果, 颜色(白色), 距离准星最近的玩家(事件玩家,队伍1), 1);
		播放效果(所有玩家(所有队伍), “回声”黏性炸弹爆炸效果, 颜色(白色), 距离准星最近的玩家(事件玩家,队伍1), 1);
		If(事件玩家.Shuxing[5] <= 12);
		伤害(范围内玩家(被攻击方, 3, 队伍1, 表面), 事件玩家, 10*(事件玩家.Shuxing[1]+事件玩家.Shuxing[5]));
		Else;
		伤害(范围内玩家(被攻击方, 3, 队伍1, 表面), 事件玩家, 15*(事件玩家.Shuxing[1]+事件玩家.Shuxing[5]));
		设置状态(范围内玩家(被攻击方, 3, 队伍1, 表面), 空, 击倒, 1);
		End;
		事件玩家._count_Fengbaozhiyan = 0;
	}
}

