规则("——灵敏步伐-激活")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("灵敏步伐")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
	}

	动作
	{
		取消与玩家的移动碰撞(事件玩家);
		调用子程序(Agility);
		创建效果(所有玩家(所有队伍), “士兵：76”疾跑效果, 颜色(白色), 事件玩家, 1, 可见，位置和半径);
		事件玩家._ID_Lingminbufa = 最后创建的实体;
		等待直到(全局.GameState == 3, 99999);
		调用子程序(Agility);
		消除效果(事件玩家._ID_Lingminbufa);
		开启与玩家的移动碰撞(事件玩家);

	}
}

规则("——猎风弹匣-击杀敌人回复弹药")
{
