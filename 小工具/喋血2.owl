	{
		持续 - 全局;
	}

	条件
	{
	}

	动作
	{
	}
}

规则("初始化为3次重生")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	动作
	{
		事件玩家.revive_time = 3;
	}
}

规则("每次通关加1次")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.GameState == 3;
	}

	动作
	{
		所有玩家(队伍2).revive_time += 1;
		小字体信息(所有玩家(队伍2), 自定义字符串("你的复活次数增加一次"));
	}
}

规则("死亡后复活")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		死亡(事件玩家) == 真;
	}

	动作
	{
		If(事件玩家.revive_time == 0);
			小字体信息(事件玩家, 自定义字符串("很可惜你的复活次数已经用完\r\n请等待这关结束吧！"));
		Else;
			小字体信息(所有玩家(所有队伍), 自定义字符串("{0}{1}正在复活......3s",英雄图标字符串(所用英雄(事件玩家)),事件玩家));
			等待(1, 当为“假”时中止);
			小字体信息(所有玩家(所有队伍), 自定义字符串("{0}{1}正在复活......2s",英雄图标字符串(所用英雄(事件玩家)),事件玩家));
			等待(1, 当为“假”时中止);
			小字体信息(所有玩家(所有队伍), 自定义字符串("{0}{1}正在复活......1s",英雄图标字符串(所用英雄(事件玩家)),事件玩家));
			等待(1, 当为“假”时中止);
			大字体信息(所有玩家(所有队伍), 自定义字符串("{0}{1}已复活！",英雄图标字符串(所用英雄(事件玩家)),事件玩家));
			复活(事件玩家);
			事件玩家.revive_time -= 1;
			设置状态(事件玩家, 空, 相移, 4);
		End;
	}
}

规则("地形杀传送")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		死亡(事件玩家) == 真;
		事件为环境事件 == 真;
	}

	动作
	{
		传送(事件玩家, 最近的可行走位置(事件玩家));
	}
}
