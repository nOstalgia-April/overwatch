规则("子程序 JSTBA 僵尸托比昂")
{
	事件
	{
		子程序;
		JSTBA;
	}

	动作
	{
		设置武器(事件玩家, 2);
		While(事件玩家.Pathing_Bool == 0);
		按下按键(事件玩家, 按钮(技能2));
		开始按下按钮(事件玩家, 按钮(主要攻击模式));
		等待(1.5, 无视条件);
		停止按下按钮(事件玩家, 按钮(主要攻击模式));
		等待(0.5, 无视条件);
		End;
	}
}

规则("子程序 GZLB 钩子路霸")
{
	事件
	{
		子程序;
		GZLB;
	}

	动作
	{
		While(事件玩家.Pathing_Bool == 0);
		设置技能冷却(事件玩家, 按钮(技能1), 0);
		按下按键(事件玩家, 按钮(技能1));
		等待(6, 无视条件);
		End;
	}
}

规则("子程序 WZHS 蚊子回声")
{
	事件
	{
		子程序;
		WZHS;
	}

	动作
	{
		事件玩家.bot_wenzi_The1 = 已过滤的数组(所有存活玩家(队伍2), 相距距离(当前数组元素, 事件玩家) <= 20 && 在视线内(事件玩家, 当前数组元素, 屏障不会阻挡视线));
		等待(0.016, 无视条件);
		事件玩家.bot_wenzi_The1 = 首个(已排序的数组(事件玩家.bot_wenzi_The1, 相距距离(当前数组元素, 事件玩家)));
		开始朝向(事件玩家, 方向(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_wenzi_The1)), 10000, 至地图, 方向及角速率);
		绑定玩家(事件玩家, 事件玩家.bot_wenzi_The1, 矢量(单次赋值(随机实数(-0.8, 0.8)), 单次赋值(随机实数(-0.500, 0.8)), 单次赋值(随机实数(0.5, 1.4))));
		开始调整玩家大小(事件玩家, 0.400, 真);
		While(事件玩家.Pathing_Bool == 0);
		设置技能冷却(事件玩家, 按钮(技能2), 0);
		按下按键(事件玩家, 按钮(技能2));
		等待(5, 无视条件);
		End;
	}
}

规则("子程序 MYL 莫伊拉")
{
	事件
	{
		子程序;
		MYL;
	}

	动作
	{
		开始按下按钮(事件玩家, 按钮(技能1));
		While(存活(事件玩家) == 1 && 正在使用终极技能(事件玩家) != 真);
			While(真);
			设置技能冷却(事件玩家, 按钮(技能1), 0);
			等待(随机实数(0.5, 2), 无视条件);
			If(随机整数(0, 1) == 0);
			中断;
			End;
			End;
		调用子程序(bot_facing_update);
		设置终极技能充能(事件玩家, 100);
		按下按键(事件玩家, 按钮(终极技能));
		等待(随机实数(5, 7), 无视条件);
		End;
	}
}

