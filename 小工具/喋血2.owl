	{
		玩家造成最后一击;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("猎风弹匣")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
	}

	动作
	{
		设置弹药(事件玩家, 0, 弹药(事件玩家, 0)+事件玩家.Shuxing[5]/2);
		设置弹药(事件玩家, 1, 弹药(事件玩家, 1)+事件玩家.Shuxing[5]/2);
		修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义字符串("装备 子弹+"));
		修改玩家变量(事件玩家, Damage_list, 添加至数组, 1);
		修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义颜色(211, 239, 235, 255));
	}
}

规则("——法愈共鸣-治疗时用法强加成")
{
	事件
	{
		玩家造成治疗;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("法愈共鸣")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
	}

	动作
	{
		If(事件玩家.level < 5);
		治疗(受治疗者, 空, 事件治疗 * (1 + 0.5 * ((1 + 0.5*事件玩家.Shuxing[1])^0.5 - 1)));
		Else;
		治疗(受治疗者, 空, 事件治疗 * (1 + 0.5 * ((1 + 1*事件玩家.Shuxing[1])^0.5 - 1)));
		End;
	}
}

