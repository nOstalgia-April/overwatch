规则("子程序Draw_attribute 抽奖-属性Draw_Result生成")
{
	事件
	{
		子程序;
		Draw_attribute;
	}

	动作
	{
		//生成一个属性抽奖的结果
		事件玩家.Draw_pool = 数组(数组分割(随机数组(数组(0,1,2,3,4,5)), 0, 3),数组(随机整数(全局.attribute_pool[事件玩家.Used_Ticket_ID][0], 全局.attribute_pool[事件玩家.Used_Ticket_ID][1]),随机整数(全局.attribute_pool[事件玩家.Used_Ticket_ID][0], 全局.attribute_pool[事件玩家.Used_Ticket_ID][1]),随机整数(全局.attribute_pool[事件玩家.Used_Ticket_ID][0], 全局.attribute_pool[事件玩家.Used_Ticket_ID][1])));
		事件玩家.Draw_pool = 映射的数组(数组(0,1,2), 数组(事件玩家.Draw_pool[0][当前数组元素], 事件玩家.Draw_pool[1][当前数组元素]));
		事件玩家.Draw_Result = 映射的数组(事件玩家.Draw_pool, 自定义字符串("{0} {1}",全局.Shuxing_Name[当前数组元素[0]],当前数组元素[1]));
	}
}

规则("子程序Draw_equipment 抽奖-装备Draw_Result生成")
{
	事件
	{
		子程序;
		Draw_equipment;
	}

	动作
	{
		事件玩家.Draw_pool = 随机数组(映射的数组(全局.equipment_pool[事件玩家.Used_Ticket_ID], 当前数组元素[0]));
		事件玩家.Draw_pool = 已过滤的数组(事件玩家.Draw_pool, 数组包含(事件玩家.bags, 当前数组元素) != 真);
		事件玩家.Draw_Result = 数组分割(事件玩家.Draw_pool, 0, 较小(数量(事件玩家.Draw_pool), 3));//防止玩家已经拥有了所有的装备，那么就别生成pool了。
	}
}

