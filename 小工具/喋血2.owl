{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}
	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("狂战之力")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
	}
	动作
	{
		If(事件玩家.level < 5);
			事件玩家.Shuxing[0] += 3;
			等待直到(事件玩家.level >= 5, 99999);
			事件玩家.Shuxing[0] += 2;
		Else;
			事件玩家.Shuxing[0] += 5;
		End;
			等待直到(全局.GameState == 3, 99999);
			事件玩家.Shuxing[0] -= 5;
	}
}

