		事件玩家.Shuxing[5] % 2 == 1;
	}
	动作
	{
		设置技能冷却(事件玩家, 按钮(技能1), 较小(1, 技能冷却时间(事件玩家, 按钮(技能1))));
		设置技能冷却(事件玩家, 按钮(技能2), 较小(1, 技能冷却时间(事件玩家, 按钮(技能2))));
		小字体信息(事件玩家, 自定义字符串("迅捷节律已触发！"));
		等待(0.1, 无视条件);
	}
}

