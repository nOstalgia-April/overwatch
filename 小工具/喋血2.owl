规则("打开菜单 子程序MenuOpen")
{
	事件
	{
		子程序;
		MenuOpen;
	}

	动作
	{
		调用子程序(MenuBase);
		设置瞄准速度(事件玩家, 0.500);
		禁用 设置瞄准速度(事件玩家, 10);
		事件玩家.MenuCursorSensibility = 5;
		事件玩家.MenuCursorVisable = 0;
		事件玩家.AnchorPos = 所选位置(事件玩家);
		事件玩家.AnchorFacing = 面朝方向(事件玩家);
		隐藏英雄HUD(事件玩家);
		事件玩家.MenuBottonCoordinate = 全局.MenuBottonCoordinate;
		开始限制阈值(事件玩家, 0, 0, 0, 0, 0, 0);
		等待(0.100, 无视条件);
		设置朝向(事件玩家, 矢量(0, 0, 1), 至地图);
		开始镜头(事件玩家, 首个(事件玩家.MenuCameraNow), 最后(事件玩家.MenuCameraNow), 25);
		事件玩家.MenuCursorVisable = 1;
		事件玩家.CanInteract = 1;
		禁用按钮(事件玩家, 按钮(主要攻击模式));
		禁用按钮(事件玩家, 按钮(辅助攻击模式));
		禁用按钮(事件玩家, 按钮(装填));
		禁用按钮(事件玩家, 按钮(跳跃));
		禁用按钮(事件玩家, 按钮(技能2));
		禁用按钮(事件玩家, 按钮(技能1));
		禁用按钮(事件玩家, 按钮(蹲下));
		可用按钮(事件玩家, 按钮(终极技能));
		设置状态(事件玩家, 空, 相移, 9999);
		取消与玩家的移动碰撞(事件玩家);
	}
}

规则("关闭菜单 子程序MenuClose")
{
	事件
	{
		子程序;
		MenuClose;
	}

	动作
	{
		事件玩家.MenuCursorVisable = 0;
		事件玩家.MenuActive = 0;
		停止限制阈值(事件玩家);
		停止镜头(事件玩家);
		显示英雄HUD(事件玩家);
		设置朝向(事件玩家, 事件玩家.AnchorFacing, 至地图);
		等待(0.100, 无视条件);
		可用按钮(事件玩家, 按钮(主要攻击模式));
		可用按钮(事件玩家, 按钮(辅助攻击模式));
		可用按钮(事件玩家, 按钮(跳跃));
		可用按钮(事件玩家, 按钮(蹲下));
		可用按钮(事件玩家, 按钮(技能1));
		可用按钮(事件玩家, 按钮(技能2));
		可用按钮(事件玩家, 按钮(终极技能));
		可用按钮(事件玩家, 按钮(装填));
		清除状态(事件玩家, 相移);
		开启与玩家的移动碰撞(事件玩家);
		设置瞄准速度(事件玩家, 100);
	}
}

规则("求基底 子程序MenuBase")
{
	事件
	{
		子程序;
		MenuBase;
	}

	动作
	{
		事件玩家.MenuCameraNow = 数组(首个(事件玩家.MenuCameraNow), 首个(事件玩家.MenuCameraNow) + 方向(首个(事件玩家.MenuCameraNow), 最后(事件玩家.MenuCameraNow)));
		"基底1"
		事件玩家.MenuFlatBase1 = 矢量积(上, 方向(首个(事件玩家.MenuCameraNow), 最后(事件玩家.MenuCameraNow)));
		"基底1"
		事件玩家.MenuFlatBase1 = 归一化(事件玩家.MenuFlatBase1);
		"基底1"
		事件玩家.MenuFlatBase2 = 矢量积(事件玩家.MenuFlatBase1, 方向(首个(事件玩家.MenuCameraNow), 最后(事件玩家.MenuCameraNow)));
		"基底2"
		事件玩家.MenuFlatBase2 = 归一化(事件玩家.MenuFlatBase2);
	}
}

