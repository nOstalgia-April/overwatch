规则("——致命稳定器-设置弹药")
{
	事件
	{
		玩家造成伤害;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0, 1, 2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("致命稳定器")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
		正在使用主要武器(事件玩家) == 真;
		被攻击方 != 事件玩家;
		数组包含(数组(按钮(主要攻击模式)), 事件技能) == 真;

	}

	动作
	{
		If(随机整数(0, 100) >= 75);
			If(弹药(事件玩家, 0) >= 0.500 * 最大弹药(事件玩家, 0));
			设置弹药(事件玩家, 0, 弹药(事件玩家, 0) - 最大弹药(事件玩家, 0) * 0.500);
			伤害(被攻击方, 事件玩家, 0.500 * 事件伤害);
			等待(0.500, 无视条件);
			End;
		Else;
			设置弹药(事件玩家, 0, 弹药(事件玩家, 0) + 1);
			修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义字符串("装备 子弹+"));
			修改玩家变量(事件玩家, Damage_list, 添加至数组, 1);
			修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义颜色(211, 239, 235, 255));
		End;
	}
}

