规则("\\\装备池初始化-稀有")
{
	事件
	{
		持续 - 全局;
	}
	动作
	{
		全局.equipment_pool[1] =
		 数组(
			数组(自定义字符串("完美主义"), 数组(2,0,0,0,0,0), 自定义字符串("获得+3攻击+3法强，直到你受到伤害\r\n攻击+2"), 1),
			数组(自定义字符串("先发制人"), 数组(0,0,0,2,1,0), 自定义字符串("你对敌人造成的第一次伤害\r\n附加10*(护甲+魔抗)的伤害\r\n5级后，还会造成短暂眩晕\r\n护甲+2魔抗+1"), 1),
			数组(自定义字符串("猫火"), 数组(0,0,0,0,0,2), 自定义字符串("当你的生命低于25%的时候（燃烧）\r\n获得+5攻击/+5法强\r\n若敏捷>10，改为+10攻击+10法强\r\n敏捷+2"), 1),
			数组(自定义字符串("耀光"), 数组(0,0,0,0,0,0), 自定义字符串("在你使用技能后的下一次近身攻击\r\n造成10*（攻击+法强）的伤害"), 1),
			数组(自定义字符串("冰与火之歌"), 数组(0,0,0,0,0,0), 自定义字符串("每次使用技能后\r\n你的下一次伤害会附加一个持续1s的元素状态\r\n（随机为燃烧、冻结）\r\n若你的法强 && 迅捷 ≥ 10\r\n则同时附加两种状态"), 1),
			数组(自定义字符串("头颅刷新"), 数组(0,0,0,0,0,0), 自定义字符串("当你击杀敌人后\r\n将你的技能1CD降低为3s（若有必要）"), 1),
			数组(自定义字符串("战后余盾"), 数组(0,0,2,0,0,0), 自定义字符串("当你脱离战斗4s以后，临时获得10*生命的护盾\r\n当等级为7级以后，护盾改为临时护甲\r\n生命+2"), 1),
			数组(自定义字符串("躯骸刷新"), 数组(0,0,0,0,0,0), 自定义字符串("当你击杀敌人后\r\n将你的技能2CD降低为3s（若有必要）"), 1),
			数组(自定义字符串("荆棘反光"), 数组(0,0,0,1,2,0), 自定义字符串("对攻击你的敌人造成10*（护甲+魔抗）的伤害\r\n内置CD1s\r\n护甲+1，魔抗+2"), 1),
			数组(自定义字符串("生焰光环"), 数组(0,0,3,0,0,0), 自定义字符串("每秒对周围5m的敌人造成10*生命的伤害\r\n生命+3"), 1),
			数组(自定义字符串("共鸣恩泽"), 数组(0,0,0,0,0,0), 自定义字符串("如果受到治疗\r\n你和治疗者获得敏捷+1\r\n持续1s\r\n若你的护甲/魔抗>10，改为获得敏捷+4"), 1),
			数组(自定义字符串("震地壁垒"), 数组(0,0,0,0,0,0), 自定义字符串("当你造成击退时\r\n获得+5护甲+5魔抗，持续2s\r\n5级以后\r\n还会回复自身(护甲*生命)生命值"), 1),
			数组(自定义字符串("残敌汲取"), 数组(1,1,0,0,0,0), 自定义字符串("每对一个半血以下敌人造成伤害时\r\n回复4*（攻击+法强）的生命值\r\n法强+1，攻击+1"), 1),
			数组(自定义字符串("雷霆震慑"), 数组(0,0,0,0,0,0), 自定义字符串("当你造成暴击时，会有50%概率击倒敌人\r\n五级后，改为100%概率"), 1),
			数组(自定义字符串("星矢追魂"), 数组(1,1,0,0,0,0), 自定义字符串("你指针方向的第一个敌人\r\n受到5*(攻击+法强）的伤害，每秒两次\r\n攻击+1,法强+1"), 1),
			数组(自定义字符串("灵魂谐振"), 数组(0,0,0,0,0,0), 自定义字符串("每次治疗他人时，你和目标获得+2法强，持续3秒\r\n若目标生命低于50%，改为+5法强\r\n8级后，改为获得+4法强，+7法强"), 1),
			数组(自定义字符串("陨地冲击"), 数组(0,0,0,0,0,0), 自定义字符串("陨地冲击：当你着陆时\r\n会对周围5m的敌人造成伤害\r\n数值等于你的（生命）% 的最大生命值\r\n8级后，范围扩大至8m"), 1),
			数组(自定义字符串("米凯尔面具"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("你的攻击获得(3*法强)%的吸血效果"), 1),
			数组(自定义字符串("巨人护符"), 数组(0, 0, 5, 0, 0, 0), 自定义字符串("你的体型会随着【生命】而改变\r\n每点【生命】会为你提供5%的最大体型\r\n生命+5"), 1),
			数组(自定义字符串("君士坦丁之盾"), 数组(0, 0, 5, 0, 0, 0), 自定义字符串("你的屏障大小会随着【生命】而改变\r\n每点【生命】会为你提供5%的屏障大小\r\n生命+5"), 1),
			数组(自定义字符串("致命稳定器"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("使用主要武器造成伤害时，有25%概率\r\n消耗你50%最大弹药额外造成（0.5*事件伤害）的\r\n伤害（如果你弹药足够的话），若未能触发\r\n则为你补充一枚弹药"), 1),
			数组(自定义字符串("善恶天平"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("当你治疗其他队友时，你也会获得\r\n此次治疗量的(20+5*法强)%治疗"), 1),
			数组(自定义字符串("爆能抑制器"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("你使用主要武器造成伤害时，有20%概率（随攻击提升）\r\n将你该次伤害变为持续伤害\r\n5秒内共造成1.5倍伤害"), 1),
			数组(自定义字符串("闪避护符"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("你受到攻击时\r\n有(10+敏捷*2)%的概率\r\n规避此次伤害"), 1),
			数组(自定义字符串("崔佛的皮靴"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("你造成击退时，会对该敌人\r\n造成（5*[攻击*法强]）点伤害"), 1),
			数组(自定义字符串("贪婪戒指"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("你的敏捷每达到\r\n5的倍数\r\n获得等额的攻击\r\n直到关卡结束"), 1),
			数组(自定义字符串("血包小子"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("你拾取急救包以后\r\n获得(魔抗+敏捷)*5的临时护盾"), 1),
			数组(自定义字符串("碎颅战锤"), 数组(0, 0, 5, 0, 0, 0), 自定义字符串("每隔3秒，你的下次主要武器攻击\r\n会附带（生命*10)的伤害\r\n生命值+5"), 1),
			数组(自定义字符串("肉块"), 数组(0, 0, 3, 0, 0, 0), 自定义字符串("召唤一个小肉块进行协同攻击\r\n每秒造成10*护甲的伤害\r\n若同时激活绷带\r\n伤害改为每秒20*护甲\r\n护甲+3"), 1),
			数组(自定义字符串("绷带"), 数组(0, 0, 0, 3, 0, 0), 自定义字符串("召唤一个小绷带进行协同攻击\r\n每秒造成10*魔抗的伤害\r\n若同时激活肉块\r\n伤害改为每秒20*魔抗\r\n魔抗+3"), 1),
			数组(自定义字符串("多面手"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("此装备激活时，你每有一项属性>0\r\n全属性+2"), 1),
			数组(自定义字符串("炸弹小子"), 数组(0, 0, 0, 2, 0, 2), 自定义字符串("你会周期性地在身下放置炸弹\r\n一段延迟后爆炸,造成10*(护甲+攻击)的伤害\r\n若你的迅捷>10,改为周期性向怪物投掷炸弹\r\n护甲+2,敏捷+2"), 1),
			数组(自定义字符串("斧王之斧"), 数组(0, 0, 0, 0, 0, 0), 自定义字符串("每隔5秒，你受到下一次攻击时\r\n将会对自身周围6M的所有敌人造成\r\n该次的攻击伤害"), 1)
			);
	}
}

规则("——灵魂谐振-治疗加法强")
{
	事件
	{
		玩家受到治疗;
		队伍2;
		全部;
	}
	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(治疗者.slot_equipped[当前数组元素], 自定义字符串("灵魂谐振")) && 治疗者.slot_unlocked[当前数组元素] == 1) == 1;
		事件玩家 != 治疗者;
	}
	动作
	{
		If(事件玩家.level < 8);
			If(标准化生命值(受治疗者) <= 0.5);
				治疗者.Shuxing[1] += 5;
				受治疗者.Shuxing[1] += 5;
				等待(3, 无视条件);
				治疗者.Shuxing[1] -= 5;
				受治疗者.Shuxing[1] -= 5;
			Else;
				治疗者.Shuxing[1] += 2;
				受治疗者.Shuxing[1] += 2;
				等待(3, 无视条件);
				治疗者.Shuxing[1] -= 2;
				受治疗者.Shuxing[1] -= 2;
			End;
		Else;
			If(标准化生命值(受治疗者) <= 0.5);
				治疗者.Shuxing[1] += 7;
				受治疗者.Shuxing[1] += 7;
				等待(3, 无视条件);
				治疗者.Shuxing[1] -= 7;
				受治疗者.Shuxing[1] -= 7;
			Else;
				治疗者.Shuxing[1] += 4;
				受治疗者.Shuxing[1] += 4;
				等待(3, 无视条件);
				治疗者.Shuxing[1] -= 4;
				受治疗者.Shuxing[1] -= 4;
			End;
		End;
		播放效果(所有玩家(所有队伍), 正面状态施加声音, 颜色(白色), 受治疗者, 100);
	}
}

规则("——星矢追魂-指针方向伤害")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}
	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("星矢追魂")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
		存活(射线命中玩家(眼睛位置(事件玩家), 眼睛位置(事件玩家)+50*面朝方向(事件玩家), 所有玩家(队伍1), 事件玩家, 真)) == 真;
	}
	动作
	{
		伤害(射线命中玩家(眼睛位置(事件玩家), 眼睛位置(事件玩家)+50*面朝方向(事件玩家), 所有玩家(队伍1), 事件玩家, 真), 事件玩家, 5 * (事件玩家.Shuxing[0] + 事件玩家.Shuxing[1]));
		播放效果(所有玩家(所有队伍), 有害选择效果, 颜色(天蓝色), 射线命中玩家(眼睛位置(事件玩家), 眼睛位置(事件玩家)+50*面朝方向(事件玩家), 所有玩家(队伍1), 事件玩家, 真), 0.5);
		修改玩家变量(射线命中玩家(眼睛位置(事件玩家), 眼睛位置(事件玩家)+50*面朝方向(事件玩家), 所有玩家(队伍1), 事件玩家, 真), Damage_list, 添加至数组, 自定义字符串("装备 {0}",图标字符串(箭矢)));
