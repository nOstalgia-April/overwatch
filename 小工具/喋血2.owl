	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		事件玩家.bot_name != 0;
		数量(事件玩家.path) > 0;
		事件玩家.Pathing_Bool == 1;
		对任意为“真”(所有存活玩家(队伍2), 在视线内(事件玩家, 当前数组元素, 屏障不会阻挡视线) == 1) != 1;
	}

	动作
	{
		等待(3, 当为“假”时中止);
		设置移动速度(事件玩家, 400);
		等待直到(对任意为“真”(所有存活玩家(队伍2), 在视线内(事件玩家, 当前数组元素, 屏障不会阻挡视线) == 1) == 1, 5);
		设置移动速度(事件玩家, 100);
		如条件为“真”则循环;
		
	}
}

规则("机器人初始化")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 真;
		是否是机器人(事件玩家) == 真;
	}

	动作
	{
		事件玩家.bot_ballistic_velocity = -0.003;
		事件玩家.bot_aming_accuracy = 0;
		追踪玩家变量频率(事件玩家, update_timer, 0, 1, 速率及最终值);
		事件玩家.Pathing_Bool = 0;
	}
}

规则("沿路径移动")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		事件玩家.bot_name != 0;
		数量(事件玩家.path) > 0;
		事件玩家.Pathing_Bool == 1;
	}

	动作
	{
		禁用 传送(事件玩家, 事件玩家.start);
		等待(0.250, 无视条件);
		停止定向阈值(事件玩家);
		停止限制阈值(事件玩家);
		开始定向阈值(事件玩家, 方向(眼睛位置(事件玩家), 首个(事件玩家.path)), 1, 至地图, 替换现有阈值, 方向和幅度);
	}
}

规则("沿路径移动防卡死")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		速度(事件玩家) <= 1;
		数量(事件玩家.path) > 0;
		事件玩家.bot_name != 0;
		事件玩家.Pathing_Bool == 1;
		标准化生命值(事件玩家) == 1;
	}

	动作
	{
		等待(3, 当为“假”时中止);
		传送(事件玩家, 事件玩家.path[0]);
	}
}

规则("移除路径中已到达的节点")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		数量(事件玩家.path) > 0;
		相距距离(眼睛位置(事件玩家), 矢量(X方向分量(首个(事件玩家.path)), Y方向分量(眼睛位置(事件玩家)), Z方向分量(首个(事件玩家.path)))) < 1;
		事件玩家.bot_name != 0;
		事件玩家.Pathing_Bool == 1;
	}

	动作
	{
		修改玩家变量(事件玩家, path, 根据索引从数组中移除, 0);
		If(数量(事件玩家.path) == 0);
			停止定向阈值(事件玩家);
		End;
	}
}

规则("机器人-寻找有效目标")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		服务器负载峰值 < 150;
		是否是机器人(事件玩家) == 真;
		存活(事件玩家) == 真;
		事件玩家.bot_name != 0;
	}

	动作
	{
		事件玩家.bot_targetArray = 已过滤的数组(所有存活玩家(队伍2), 事件玩家 != 当前数组元素 && 已重生(当前数组元素) && !是否是机器人(当前数组元素) && 在视线内(事件玩家, 当前数组元素, 屏障不会阻挡视线));
		If(数量(事件玩家.bot_targetArray) > 0);
			事件玩家.bot_targetPlayer = 首个(已排序的数组(事件玩家.bot_targetArray, 相距距离(事件玩家, 当前数组元素) * 标准化生命值(当前数组元素)));
		End;
		等待(1, 无视条件);
		如条件为“真”则循环;
	}
}


规则("——无垢巨人-寻路调用")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		事件玩家.update_timer == 0;
		服务器负载峰值 < 150;
		数量(已过滤的数组(范围内玩家(事件玩家, 8, 队伍2, 表面), 存活(当前数组元素) && 在视线内(事件玩家, 眼睛位置(当前数组元素), 屏障不会阻挡视线))) == 0;
		已重生(事件玩家) == 真;
		事件玩家.bot_state == 自定义字符串("无垢巨人");
		事件玩家.bot_name != 0;
	}

	动作
	{
		等待(随机实数(0.7, 1.2), 当为“假”时中止);
		If(数量(事件玩家.path) == 0 || 相距距离(事件玩家.Tracing_target, 事件玩家.end) >= 20 || 死亡(事件玩家.Tracing_target) == 1);
		事件玩家.start = 首个(已排序的数组(事件玩家.nodes_location, 相距距离(事件玩家, 当前数组元素)));
		事件玩家.Tracing_target = 首个(已排序的数组(所有存活玩家(队伍2), 相距距离(事件玩家, 当前数组元素)));
		事件玩家.end = 首个(已排序的数组(事件玩家.nodes_location, 相距距离(事件玩家.Tracing_target, 当前数组元素)));
		事件玩家.Pathing_Bool = 1;
		调用子程序(Start_Dijstra);
		End;
		If(对任意为“真”(所有存活玩家(队伍2), 在视线内(眼睛位置(当前数组元素), 事件玩家, 屏障不会阻挡视线) == 1));//如果就在玩家眼皮子底下，那么就快点更新
		事件玩家.update_timer = 1;
		Else;
		事件玩家.update_timer = 随机实数(1, 3);
		End;
	}
}
规则("——无垢巨人 触发")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		数量(已过滤的数组(范围内玩家(事件玩家, 12, 队伍2, 表面), 存活(当前数组元素) && 当前数组元素 == 事件玩家.bot_targetPlayer)) >= 1;
		已重生(事件玩家) == 真;
		事件玩家.bot_targetPlayer != 0;
		事件玩家.bot_name != 0;
		事件玩家.bot_state == 自定义字符串("无垢巨人");
		
	}

	动作
	{
		等待(随机实数(0.1, 0.4), 当为“假”时中止);
		事件玩家.path = 空数组;
		事件玩家.Pathing_Bool = 0;
		开始朝向(事件玩家, 方向(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_targetPlayer)), 200, 至地图, 方向及角速率);
		停止定向阈值(事件玩家);
		开始限制阈值(事件玩家, 0.700, 1, 0, 1, 0, 1);
		事件玩家.update_timer = 随机实数(3, 5);
		If(事件玩家.bot_name == 自定义字符串("僵尸托比昂"));
			调用子程序(JSTBA);
		End;
		If(事件玩家.bot_name == 自定义字符串("钩子路霸"));
			调用子程序(GZLB);
		End;
		If(事件玩家.bot_name == 自定义字符串("蚊子回声"));
			调用子程序(WZHS);
		End;
		If(事件玩家.bot_name == 自定义字符串("莫伊拉"));
			调用子程序(MYL);
		End;
		If(事件玩家.bot_name == 自定义字符串("死神"));
			调用子程序(SS);
		End;
	}
}
规则("规则301")
{
	事件
	{
		子程序;
		Sub65;
	}

	动作
	{
		For 玩家变量(事件玩家, tp_for, 0, 存活玩家数量(队伍2), 1);//开始检索一个所有玩家都看不到的近点
		事件玩家.tp_location = 已过滤的数组(全局.nodes_location, 在视线内(所有存活玩家(队伍2)[事件玩家.tp_for], 当前数组元素, 屏障不会阻挡视线));
		等待(0.016, 无视条件);
		End;
		事件玩家.tp_location = 首个(已排序的数组(事件玩家.tp_location, 相距距离(数组随机取值(所有存活玩家(队伍2)), 当前数组元素)));
		传送(事件玩家, 事件玩家.tp_location);
	}
}



