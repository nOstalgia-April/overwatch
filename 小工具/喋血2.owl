}



规则("子程序 bot_facing_update 机器人朝向")
{
	事件
	{
		子程序;
		bot_facing_update;
	}

	动作
	{
		If(事件玩家.bot_targetPlayer == -1);
			开始朝向(事件玩家, 方向(眼睛位置(事件玩家), 矢量(X方向分量(事件玩家.nodes_location[事件玩家.path[0]]), Y方向分量(眼睛位置(事件玩家)), Z方向分量(
			事件玩家.nodes_location[事件玩家.path[0]]))), 300, 至地图, 方向及角速率);
		Else;
			开始朝向(事件玩家, 方向(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_targetPlayer) + 下 * 相距距离(事件玩家, 事件玩家.bot_targetPlayer) * 0.010 + 速率(事件玩家.bot_targetPlayer)
				* (相距距离(事件玩家, 事件玩家.bot_targetPlayer) * 事件玩家.bot_ballistic_velocity + 0.200) + 与此角度的相对方向(水平朝向角度(事件玩家) + 随机实数(相距距离(事件玩家,
				事件玩家.bot_targetPlayer) * 绝对值(事件玩家.bot_aming_accuracy) * -1, 相距距离(事件玩家, 事件玩家.bot_targetPlayer) * 绝对值(事件玩家.bot_aming_accuracy)),
				垂直朝向角度(事件玩家) + 随机实数(相距距离(事件玩家, 事件玩家.bot_targetPlayer) * 绝对值(事件玩家.bot_aming_accuracy) * 0.250 * -1, 相距距离(事件玩家,
				事件玩家.bot_targetPlayer) * 绝对值(事件玩家.bot_aming_accuracy) * 0.250)) * 1), 1000, 至地图, 方向及角速率);
		End;
	}
}

