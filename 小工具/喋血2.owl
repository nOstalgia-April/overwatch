		全局.GameState == 2;
		对任意为“真”(数组(0, 1, 2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("闪避护符")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
	}

	动作
	{
		If(随机整数(0, 100) < (10+事件玩家.Shuxing[5]*2));
			修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义字符串("装备 闪避！"));
			修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义字符串(""));
			修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义颜色(154, 155, 154, 255));
			治疗(事件玩家, 事件玩家, 事件伤害);
			等待(0.250, 无视条件);
		End;
	}
}

