规则("——撤离庇护-在撤离点内回复")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("撤离庇护")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
		全局.Quitting_stage < 3;
		相距距离(全局.Quitting_Locations[全局.Quitting_stage], 事件玩家) <= 4;
	}

	动作
	{
		If(事件玩家.level < 5);
		治疗(事件玩家, 事件玩家, 5*事件玩家.Shuxing[2]);
		修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义字符串("装备 +"));
		修改玩家变量(事件玩家, Damage_list, 添加至数组, 5*事件玩家.Shuxing[2]);
		修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义颜色(79, 216, 138, 255));
		Else;
		治疗(事件玩家, 事件玩家, 10*事件玩家.Shuxing[2]);
		修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义字符串("装备 +"));
		修改玩家变量(事件玩家, Damage_list, 添加至数组, 10*事件玩家.Shuxing[2]);
		修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义颜色(79, 216, 138, 255));
		End;
		等待(1, 无视条件);
		如条件为“真”则循环;
	}
}


规则("——战后余盾-脱战临时护盾")
{
	事件
	{
		玩家受到伤害;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("战后余盾")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
	}

	动作
	{
		等待(5, 当为“假”时中止);
		小字体信息(事件玩家, 自定义字符串("战后余盾 已刷新"));
		移除玩家的生命池(事件玩家._PoolID_Zhanhouyudun);
		If(事件玩家.level < 7);
		为玩家添加生命池(事件玩家, 生命值, 100, 假, 真);
		Else;
		为玩家添加生命池(事件玩家, 护甲, 100, 假, 真);
		End;
		事件玩家._PoolID_Zhanhouyudun = 最后创建的生命池;
		播放效果(事件玩家, 布丽吉塔恢复包护甲声音, 颜色(白色), 事件玩家, 175);
		播放效果(所有玩家(所有队伍), 布丽吉塔恢复包护甲效果, 颜色(白色), 事件玩家, 1);
	}
}

