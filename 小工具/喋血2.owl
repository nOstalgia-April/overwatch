	{
		伤害(被攻击方, 事件玩家, 10*事件玩家.Shuxing[2]);
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义字符串("碎颅"));
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 0.100 * 最大生命值(事件玩家));
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义颜色(141, 29, 29, 255));
		等待(3, 无视条件);
	}
}
规则("——贪婪戒指-激活")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0, 1, 2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("贪婪戒指")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
	}

	动作
	{
		事件玩家.Shuxing[0] += 取整(事件玩家.Shuxing[5] * 0.200, 下);
		等待直到 (全局.GameState == 3, 99999);
		事件玩家.Shuxing[0] -= 取整(事件玩家.Shuxing[5] * 0.200, 下);
	}
}

规则("——斧王之斧-受到伤害激活")
{
