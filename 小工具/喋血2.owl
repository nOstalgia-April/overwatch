			治疗(事件玩家, 事件玩家, 事件玩家.Shuxing[3] * 事件玩家.Shuxing[2]);
			播放效果(事件玩家, 治疗目标激活效果, 颜色(队伍2), 事件玩家, 1);
		End;
		播放效果(事件玩家, 布丽吉塔恢复包护甲声音, 颜色(白色), 事件玩家, 100);
		等待(2, 无视条件);
