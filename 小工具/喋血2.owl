规则("Click1-3 下")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 1;
		事件玩家.MenuLoop == 3;
	}

	动作
	{
		播放效果(事件玩家, “士兵：76”疾跑开始声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
		"下翻"
			事件玩家.bags_show4 = 较小(事件玩家.bags_show4 + 3, 数量(事件玩家.bags) - 3);
		End;
	}
}

规则("Click1-2 上")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 1;
		事件玩家.MenuLoop == 2;
	}

	动作
	{
		播放效果(事件玩家, “士兵：76”疾跑开始声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			事件玩家.bags_show4 = 较大(0, 事件玩家.bags_show4 - 3);
	}
}

规则("Click1-456 选中/取消")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 1;
		数组包含(数组(4, 5, 6), 事件玩家.MenuLoop) == 真;
	}

	动作
	{
		播放效果(事件玩家, “士兵：76”疾跑开始声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
		
		If(事件玩家.MenuLoop == 4);
			If(事件玩家.bags_the1 == 事件玩家.bags[事件玩家.bags_show4]);
				If(对任意为“真”(事件玩家.slot_equipped, 数组包含(当前数组元素, 事件玩家.bags_the1)) == 0); //前提是这个装备还没有被分配
				事件玩家.the_holding_equipment = 事件玩家.bags_the1;
				Else;
				小字体信息(事件玩家, 自定义字符串("若想要更改装备在装备槽的位置，请点击卸载按钮"));
				End;
			Else;
				事件玩家.bags_the1 = 事件玩家.bags[事件玩家.bags_show4 + 0];
			End;
		Else If(事件玩家.MenuLoop == 5);
			If(事件玩家.bags_the1 == 事件玩家.bags[1 + 事件玩家.bags_show4]);
				If(对任意为“真”(事件玩家.slot_equipped, 数组包含(当前数组元素, 事件玩家.bags_the1)) == 0); //前提是这个装备还没有被分配
				事件玩家.the_holding_equipment = 事件玩家.bags_the1;
				Else;
				小字体信息(事件玩家, 自定义字符串("若想要更改装备在装备槽的位置，请点击卸载按钮"));
				End;
			Else;
				事件玩家.bags_the1 = 事件玩家.bags[事件玩家.bags_show4 + 1];
			End;
		
		Else If(事件玩家.MenuLoop == 6);
			If(事件玩家.bags_the1 == 事件玩家.bags[2 + 事件玩家.bags_show4]);
				If(对任意为“真”(事件玩家.slot_equipped, 数组包含(当前数组元素, 事件玩家.bags_the1)) == 0); //前提是这个装备还没有被分配
				事件玩家.the_holding_equipment = 事件玩家.bags_the1;
				Else;
				小字体信息(事件玩家, 自定义字符串("若想要更改装备在装备槽的位置，请点击卸载按钮"));
				End;
			Else;
				事件玩家.bags_the1 = 事件玩家.bags[事件玩家.bags_show4 + 2];
			End;
		End;
	}
}

规则("Drag1-drop当没有按左键的时候 进入slot/重置holding_equipment")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) != 真;
		事件玩家.MenuActive == 1;
		事件玩家.the_holding_equipment != 0;
	}

	动作
	{
		If(事件玩家.MenuLoop == 41);
			If(事件玩家.slot_size[0] == 5);
				小字体信息(事件玩家, 自定义字符串("错误：该等级装备槽槽位已满"));
				播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			Else If(5-事件玩家.slot_size[0] < 数组(1,2,3)[已过滤的数组(数组(0,1,2), 数组包含(全局.equipment_name[当前数组元素], 事件玩家.the_holding_equipment))]);
				小字体信息(事件玩家, 自定义字符串("错误：槽位容量不够塞下这件装备"));
				播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			Else;
				事件玩家.slot_equipped[0] = 添加至数组(事件玩家.slot_equipped[0], 事件玩家.the_holding_equipment);
				事件玩家.slot_size[0] += 数组(1,2,3)[已过滤的数组(数组(0,1,2), 数组包含(全局.equipment_name[当前数组元素], 事件玩家.the_holding_equipment))];
				小字体信息(事件玩家, 自定义字符串("添加 {0} 到装备槽 1 成功！！", 事件玩家.the_holding_equipment));
				事件玩家.the_holding_equipment = 0;
				播放效果(事件玩家, 正面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			End;
		Else If(事件玩家.MenuLoop == 42);
			If(事件玩家.slot_size[1] == 4);
				小字体信息(事件玩家, 自定义字符串("错误：该等级装备槽槽位已满"));
				播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			Else If(4-事件玩家.slot_size[1] < 数组(1,2,3)[已过滤的数组(数组(0,1,2), 数组包含(全局.equipment_name[当前数组元素], 事件玩家.the_holding_equipment))]);
				小字体信息(事件玩家, 自定义字符串("错误：槽位容量不够塞下这件装备"));
				播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			Else;
				事件玩家.slot_equipped[1] = 添加至数组(事件玩家.slot_equipped[1], 事件玩家.the_holding_equipment);
				小字体信息(事件玩家, 自定义字符串("添加 {0} 到装备槽 2 成功！！", 事件玩家.the_holding_equipment));
				事件玩家.slot_size[1] += 数组(1,2,3)[已过滤的数组(数组(0,1,2), 数组包含(全局.equipment_name[当前数组元素], 事件玩家.the_holding_equipment))];
				事件玩家.the_holding_equipment = 0;
				播放效果(事件玩家, 正面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			End;
		Else If(事件玩家.MenuLoop == 43);
			If(事件玩家.slot_size[2] == 3);
				小字体信息(事件玩家, 自定义字符串("错误：该等级装备槽槽位已满"));
				播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			Else If(3-事件玩家.slot_size[2] < 数组(1,2,3)[已过滤的数组(数组(0,1,2), 数组包含(全局.equipment_name[当前数组元素], 事件玩家.the_holding_equipment))]);
				小字体信息(事件玩家, 自定义字符串("错误：槽位容量不够塞下这件装备"));
				播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			Else;
				事件玩家.slot_equipped[2] = 添加至数组(事件玩家.slot_equipped[2], 事件玩家.the_holding_equipment);
				事件玩家.slot_size[2] += 数组(1,2,3)[已过滤的数组(数组(0,1,2), 数组包含(全局.equipment_name[当前数组元素], 事件玩家.the_holding_equipment))];
				小字体信息(事件玩家, 自定义字符串("添加 {0} 到装备槽 3 成功！！", 事件玩家.the_holding_equipment));
				事件玩家.the_holding_equipment = 0;
				播放效果(事件玩家, 正面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			End;
		Else;
			事件玩家.the_holding_equipment = 0;
		End;
		调用子程序(slot_word_);
	}
}

