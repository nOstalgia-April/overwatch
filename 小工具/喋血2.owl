规则("——末日铁拳的拳套-释放")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		技能冷却时间(事件玩家, 按钮(技能1)) == 0;
		按钮被按下(事件玩家, 按钮(近身攻击)) == 真;
		对任意为“真”(数组(0, 1, 2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("末日铁拳的拳套")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
	}

	动作
	{
		禁用按钮(事件玩家, 按钮(近身攻击));
		设置启用近战攻击(事件玩家, 假);
		播放效果(所有玩家(所有队伍), “末日铁拳”上勾重拳跳跃声音, 颜色(白色), 事件玩家, 100);
		播放效果(所有玩家(所有队伍), “末日铁拳”上勾重拳击中声音, 颜色(白色), 范围内玩家(射线命中位置(眼睛位置(事件玩家), 眼睛位置(事件玩家) + 面朝方向(事件玩家) * 2.500, 所有玩家(队伍2), 事件玩家, 真), 3.500, 队伍2,
			表面), 100);
		小字体信息(事件玩家, 自定义字符串("{0}{1}：上勾拳{2}！", 英雄图标字符串(所用英雄(事件玩家)), 事件玩家, 图标字符串(箭头：向上)));
		伤害(范围内玩家(射线命中位置(眼睛位置(事件玩家), 眼睛位置(事件玩家) + 面朝方向(事件玩家) * 2.500, 所有玩家(队伍1), 事件玩家, 3.500), 0, 队伍1, 表面), 事件玩家, 15 + 事件玩家.Shuxing[1] * 5);
		施加推力(范围内玩家(射线命中位置(眼睛位置(事件玩家), 眼睛位置(事件玩家) + 面朝方向(事件玩家) * 2.500, 所有玩家(所有队伍), 事件玩家, 真), 3.500, 所有队伍, 表面), 上, 15, 至地图, 取消相反运动);
		设置状态(范围内玩家(射线命中位置(眼睛位置(事件玩家), 眼睛位置(事件玩家) + 面朝方向(事件玩家) * 2.500, 所有玩家(队伍1), 事件玩家, 3.500), 0, 队伍1, 关闭), 事件玩家, 击晕, 0.750);
		等待(12, 无视条件);
		设置启用近战攻击(事件玩家, 真);
		可用按钮(事件玩家, 按钮(近身攻击));
	}
}

规则("——反伤刺甲-反伤")
{
	事件
	{
		玩家受到伤害;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0, 1, 2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("反伤刺甲")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
		攻击方 != 事件玩家;
	}

	动作
	{
		If(标准化生命值(事件玩家) <= 0.5);
			伤害(攻击方, 事件玩家, 0.400 * 事件伤害 + (事件玩家.Shuxing[4] + 事件玩家.Shuxing[3]) * 2);
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义字符串("装备 反伤"));
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 0.400 * 事件伤害 + (事件玩家.Shuxing[4] + 事件玩家.Shuxing[3]) * 2);
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义颜色(250, 139, 48, 255));
			播放效果(所有玩家(所有队伍), 有害爆炸, 颜色(红色), 攻击方, 0.300);
			等待(1, 无视条件);
		Else;
			伤害(攻击方, 事件玩家, 0.200 * 事件伤害 + (事件玩家.Shuxing[3] + 事件玩家.Shuxing[4]) * 1);
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义字符串("装备 反伤"));
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 0.200 * 事件伤害 + (事件玩家.Shuxing[3] + 事件玩家.Shuxing[4]) * 1);
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义颜色(250, 139, 48, 255));
			播放效果(所有玩家(所有队伍), 有害爆炸, 颜色(红色), 攻击方, 0.300);
			等待(1, 无视条件);
		End;
	}
}
规则("——恶魔恩赐-积累受伤")
{
	事件
	{
		玩家受到伤害;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		对任意为“真”(数组(0, 1, 2), 数组包含(事件玩家.slot_equipped[当前数组元素], 自定义字符串("恶魔恩赐")) && 事件玩家.slot_unlocked[当前数组元素] == 1) == 1;
		攻击方 != 事件玩家;
	}

	动作
	{
		事件玩家._hurt_EMEC += 事件伤害;
		If(事件玩家._hurt_EMEC >= 1000-事件玩家.Shuxing[5]*10);
			播放效果(事件玩家, 有益选择效果, 颜色(黑色), 事件玩家, 1);
			事件玩家._hurt_EMEC = 随机整数(0, 5);
			事件玩家.Shuxing[事件玩家._hurt_EMEC] += 1; 
			修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义字符串("装备 恶魔恩赐"));
			修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义字符串("{0}+1",全局.Shuxing_Name[事件玩家._hurt_EMEC]));
			修改玩家变量(事件玩家, Damage_list, 添加至数组, 自定义颜色(4, 4, 4, 255));
			等待(0.250, 无视条件);
			事件玩家._hurt_EMEC = 0;
		End;
	}
}
