		开始调整玩家大小(事件玩家, 1.2, 真);
		事件玩家._boss_Mengsichuo_Shift_Position = 0;
		创建效果(事件玩家._boss_Mengsichuo_Shift_Position != 0 ? 所有玩家(所有队伍) : 空, 环, 颜色(红色), 事件玩家._boss_Mengsichuo_Shift_Position, 4, 可见，位置和半径);
		创建效果(事件玩家._boss_Mengsichuo_Shift_Position != 0 ? 所有玩家(所有队伍) : 空, 火花声音, 颜色(白色), 事件玩家._boss_Mengsichuo_Shift_Position, 200, 可见，位置和半径);
		事件玩家.Shuxing[1] = 4;//让它的shift痛一点！
		为玩家添加生命池(事件玩家, 生命值, 较大(4000, 3000*玩家数量(队伍2)), 真, 真);
		为玩家添加生命池(事件玩家, 护甲, 较大(3000, 2000*玩家数量(队伍2)), 真, 真);
		开始按下按钮(事件玩家, 按钮(终极技能));
		创建地图文本(所有玩家(所有队伍), 自定义字符串("{0} {1}%",技能图标字符串(英雄(温斯顿), 按钮(终极技能)),逐帧更新(终极技能充能百分比(事件玩家))), 眼睛位置(事件玩家) + 矢量(0, 1.5, 0), 2, 根据表面截取, 可见，位置和字符串, 颜色(白色), 默认可见度);
		设置终极技能充能(事件玩家, 40);
	}
}
		
规则("——暴怒猩猩-寻路调用")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		事件玩家.update_timer == 0;
		服务器负载峰值 < 150;
		已重生(事件玩家) == 真;
		事件玩家.bot_name == 自定义字符串("暴怒猩猩");
		数量(事件玩家.bot_targetArray) == 0;
	}

	动作
	{
		等待(0.250, 当为“假”时中止);
		等待(随机实数(0.7, 1.2), 当为“假”时中止);
		事件玩家.start = 首个(已排序的数组(事件玩家.nodes_location, 相距距离(事件玩家, 当前数组元素)));
		事件玩家.Tracing_target = 首个(已排序的数组(所有存活玩家(队伍2), 相距距离(事件玩家, 当前数组元素)));
		事件玩家.end = 首个(已排序的数组(事件玩家.nodes_location, 相距距离(事件玩家.Tracing_target, 当前数组元素)));
		事件玩家.Pathing_Bool = 1;
		调用子程序(Start_Dijstra);
		事件玩家.update_timer = 0.25;
	}
}

