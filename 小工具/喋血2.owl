	{
		While(存活(事件玩家) == 1 && 正在使用技能 1(事件玩家) != 1);
		设置技能冷却(事件玩家, 按钮(技能1), 0);
		开始按下按钮(事件玩家, 按钮(技能1));
		等待(1.5, 无视条件);
		停止按下按钮(事件玩家, 按钮(技能1));
		等待(0.5, 无视条件);
		End;
