规则("——————小怪变异系统")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 真;
		事件玩家 != 全局.boss;
	}

	动作
	{
		If(随机整数(0, 100) <= 30);
		事件玩家.Mutant_draw = 数组随机取值(数组(数组(0,7),数组(1,7),数组(2,15),数组(3,10),数组(4,10),数组(5,5)));
		事件玩家.Shuxing[事件玩家.Mutant_draw[0]] += 事件玩家.Mutant_draw[1] + 全局.RoomLayer;
		调用子程序(Agility);
		创建地图文本(所有玩家(所有队伍), 自定义字符串("变异体:{0}+{1}",全局.Shuxing_Name[事件玩家.Mutant_draw[0]],事件玩家.Mutant_draw[1] + 全局.RoomLayer), 眼睛位置(事件玩家)+矢量(0, 0.7, 0), 1.5, 根据表面截取, 可见，位置和字符串, 颜色(玫红), 默认可见度);
		创建效果(所有玩家(所有队伍), 环, 颜色(玫红), 事件玩家, 1, 可见，位置和半径);
		End;
	}
}