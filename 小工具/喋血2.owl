规则("优化 提示重置鼠标 100")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		"确定按钮 - 0"
		全局.MenuBottonCoordinate[100] = 数组(0.800, 0.700);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive > 0 && 真), 自定义字符串("按下{0}重置光标", 输入绑定字符串(按钮(近身攻击))), 最后(本地玩家.MenuCameraNow) + 首个(
			全局.MenuBottonCoordinate[100]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[100]) * 本地玩家.MenuFlatBase2, 2, 不要截取,
			可见，位置，字符串和颜色, 本地玩家.MenuLoop == -1 ? 颜色(橙色) : 颜色(白色), 默认可见度);
	}
}
