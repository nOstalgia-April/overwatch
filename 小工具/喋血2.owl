规则("优化-平均负载HUD")
{
	事件
	{
		持续 - 全局;
	}


	动作
	{
		创建HUD文本(所有玩家(所有队伍), 服务器负载平均值, 空, 空, 右边, 0, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 默认可见度);
		创建HUD文本(所有玩家(所有队伍), 服务器负载峰值, 空, 空, 右边, 0, 颜色(黄色), 颜色(白色), 颜色(白色), 可见和字符串, 默认可见度);
		创建HUD文本(所有玩家(所有队伍), 服务器负载, 空, 空, 右边, 0, 颜色(橙色), 颜色(白色), 颜色(白色), 可见和字符串, 默认可见度);
	}
}
