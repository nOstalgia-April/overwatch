规则("Click1-44 卸载")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 1;
		事件玩家.MenuLoop == 44;
	}

	动作
	{
		
		
		If(对任意为“真”(事件玩家.slot_equipped, 数组包含(当前数组元素, 事件玩家.bags_the1)) != 1);
			播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			小字体信息(事件玩家, 自定义字符串("该装备还未安装在装备槽之中！无法卸载！"));
		Else;
			播放效果(事件玩家, 正面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			事件玩家.slot_equipped_ID_temp = 已过滤的数组(数组(0,1,2), 数组包含(事件玩家.slot_equipped[当前数组元素], 事件玩家.bags_the1));
			事件玩家.slot_equipped[事件玩家.slot_equipped_ID_temp] = 已过滤的数组(事件玩家.slot_equipped[事件玩家.slot_equipped_ID_temp], 当前数组元素 != 事件玩家.bags_the1);
			事件玩家.slot_size[事件玩家.slot_equipped_ID_temp] -= 数组(1,2,3)[已过滤的数组(数组(0,1,2), 数组包含(全局.equipment_name[当前数组元素], 事件玩家.bags_the1))];
			播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			小字体信息(事件玩家, 自定义字符串("已卸载装备{0}", 事件玩家.bags_the1));
			调用子程序(slot_word_);
		End;
	}
}

规则("1-自动触发一次slot_word_")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.MenuActive == 1;
	}

	动作
	{
		调用子程序(slot_word_);
	}
}

规则("1-子程序slot_word_  不断更新装备槽文本")
{
	事件
	{
		子程序;
		slot_word_;
	}

	动作
	{
		For 玩家变量(事件玩家, for1, 0, 数量(事件玩家.slot_equipped), 1);
			事件玩家.slot_word[事件玩家.for1] = 自定义字符串("{0}lv{1}.{2}--\r\n\r",截取字符串(自定义字符串("~~~"), 0, 事件玩家.for1),较大(1, 5*事件玩家.for1),自定义字符串("[{0}/{1}]",事件玩家.slot_size[事件玩家.for1], 数组(5,4,3)[事件玩家.for1]));	
			For 玩家变量(事件玩家, for2, 0, 数量(事件玩家.slot_equipped[事件玩家.for1]), 1);
				事件玩家.slot_word[事件玩家.for1] = 自定义字符串("{0} /{1},",事件玩家.slot_word[事件玩家.for1],事件玩家.slot_equipped[事件玩家.for1][事件玩家.for2]);	
			End;
		End;
	}
}

规则("Click（1~5）-101 右翻")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuLoop == 101;
		事件玩家.MenuActive >= 1;
		事件玩家.MenuActive <= 5;
	}

	动作
	{
		播放效果(事件玩家, “士兵：76”疾跑开始声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
		If(事件玩家.MenuActive == 5);
			事件玩家.MenuActive = 1;
		Else;
			事件玩家.MenuActive += 1;
		End;
		等待(0.250, 无视条件);
	}
}

