规则("玩家初始化")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 真;
	}

	动作
	{
		事件玩家.bags = 空数组;
		//槽位初始化

		事件玩家.slot_equipped = 数组(空数组,空数组,空数组); 
		事件玩家.slot_size = 数组(0,0,0); 
		事件玩家.slot_unlocked = 数组(0,0,0); 
		//抽奖券初始化（初始给两个普通两个稀有券）
		事件玩家.tickets = 数组(2,2,1);
		If(事件玩家 == 主机玩家);
		事件玩家.tickets = 数组(10,10,10);
		End;
		等待(99999, 无视条件);
	}
}

