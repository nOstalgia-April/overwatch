		事件玩家.Damage_list = 空数组;
		事件玩家.Damage_Image_ID = 空数组;
	}
}

规则("队伍1-伤害文本创建")
{
	事件
	{
		玩家受到伤害;
		队伍1;
		全部;
	}

	条件
	{
		数量(事件玩家.Damage_list) > 0;
	}

	动作
	{
		If(数组包含(数组(自定义字符串("攻击"),自定义字符串("法强")), 事件玩家.Damage_list[0]));
			事件玩家.DamageImage_Group = 数组(自定义字符串(""),事件伤害+事件玩家.Damage_list[1],事件玩家.Damage_list[2]);//前缀//伤害数值//颜色
		Else If(字符串包含(事件玩家.Damage_list[0], 自定义字符串("装备")));
			事件玩家.DamageImage_Group = 数组(截取字符串(事件玩家.Damage_list[0], 2, 787),事件玩家.Damage_list[1],事件玩家.Damage_list[2]);//前缀//伤害数值//颜色
		End;
		事件玩家.DamageImage_RollPosition_1cixing = 矢量(随机实数(-1.200, 1.200), 随机实数(-1, 1), 随机实数(-0.800, 0.800));
		创建地图文本(攻击方, 自定义字符串("{0}{1}",事件玩家.DamageImage_Group[0],事件玩家.DamageImage_Group[1]), 眼睛位置(事件玩家) + 事件玩家.DamageImage_RollPosition_1cixing, 较大(较小(
			3.400, (事件玩家.DamageImage_Group[1] * 0.100) ^ 0.200), 1), 根据表面截取, 可见, 事件玩家.Damage_list[2], 默认可见度);
		修改玩家变量(事件玩家, Damage_Image_ID, 添加至数组, 上一个文本ID);
		If(数量(事件玩家.Damage_Image_ID) > 3);
		消除地图文本(首个(事件玩家.Damage_Image_ID));
		修改玩家变量(事件玩家, Damage_Image_ID, 根据索引从数组中移除, 0);
		End;
		播放效果(攻击方, 有害爆炸, 事件暴击 ? 颜色(红色) : 颜色(白色), 眼睛位置(被攻击方) + 事件玩家.DamageImage_RollPosition_1cixing, 0.100);
		修改玩家变量(事件玩家, Damage_list, 根据索引从数组中移除, 0);
		修改玩家变量(事件玩家, Damage_list, 根据索引从数组中移除, 0);
		修改玩家变量(事件玩家, Damage_list, 根据索引从数组中移除, 0);
		等待(0.05, 无视条件);
		如条件为“真”则循环;
	}
}

规则("双方-状态文本创建")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		数量(事件玩家.Damage_list) > 0;
		字符串包含(事件玩家.Damage_list[0], 自定义字符串("装备")) == 真;
	}

	动作
	{
		事件玩家.DamageImage_Group = 数组(截取字符串(事件玩家.Damage_list[0], 2, 787),事件玩家.Damage_list[1],事件玩家.Damage_list[2]);//前缀//数值//颜色
		事件玩家.DamageImage_RollPosition_1cixing = 矢量(随机实数(-0.7, 0.7), 随机实数(0.3, 1.2), 随机实数(0.6, 1.2));
		创建地图文本(所在队伍(事件玩家) == 队伍1 ? 所有玩家(所有队伍) : 事件玩家, 自定义字符串("{0}{1}",事件玩家.DamageImage_Group[0],事件玩家.DamageImage_Group[1]), 逐帧更新(眼睛位置(事件玩家) + 单次赋值(事件玩家.DamageImage_RollPosition_1cixing) - 矢量(0, 较小(0.4,0.4*(单次赋值(总计消耗时间)-总计消耗时间)), 0)), 2, 不要截取, 可见和位置, 事件玩家.Damage_list[2], 默认可见度);
		修改玩家变量(事件玩家, Damage_Image_ID, 添加至数组, 上一个文本ID);
		If(数量(事件玩家.Damage_Image_ID) > 3);
		消除地图文本(首个(事件玩家.Damage_Image_ID));
		修改玩家变量(事件玩家, Damage_Image_ID, 根据索引从数组中移除, 0);
		End;
		修改玩家变量(事件玩家, Damage_list, 根据索引从数组中移除, 0);
		修改玩家变量(事件玩家, Damage_list, 根据索引从数组中移除, 0);
		修改玩家变量(事件玩家, Damage_list, 根据索引从数组中移除, 0);
		等待(0.05, 无视条件);
		如条件为“真”则循环;
	}
}
规则("文本-自动删除")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		数量(事件玩家.Damage_Image_ID) >= 1;
	}

	动作
	{
		等待(数量(事件玩家.Damage_Image_ID) > 随机整数(2, 4) ? 0.016 : 1, 无视条件);
		消除地图文本(首个(事件玩家.Damage_Image_ID));
		修改玩家变量(事件玩家, Damage_Image_ID, 根据索引从数组中移除, 0);
		如条件为“真”则循环;
	}
}

规则("左上角属性HUD")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		创建HUD文本(已过滤的数组(所有玩家(所有队伍), 全局.GameState == 2),
		空,
		空, 
		自定义字符串("{0}等级Lv.{1}/10  \r\n\r\n攻击 {2}",自定义字符串("{0} {1}", 英雄图标字符串(所用英雄(本地玩家)), 图标字符串(火焰)), 本地玩家.level, 
			自定义字符串("{0}     法强 {1}\r\n生命 {2}",
			 本地玩家.Shuxing[0], 本地玩家.Shuxing[1],
			自定义字符串("{0}     护甲 {1}\r\n魔抗 {2}",
				 本地玩家.Shuxing[2], 本地玩家.Shuxing[3],
				自定义字符串("{0}     敏捷 {1}\r\n————\r\n剩余复活次数{2}                                                                                                        ",
					 本地玩家.Shuxing[4], 本地玩家.Shuxing[5],自定义字符串("{0}{1}",技能图标字符串(英雄(天使), 按钮(终极技能)),本地玩家.revive_time)))))
					 , 左边, -999, 颜色(白色), 颜色(白色), 本地玩家.level < 5?颜色(白色):(本地玩家.level < 10 ? 颜色(蓝色):颜色(橙色)), 可见，字符串和颜色, 默认可见度);
	}
}

规则("玩家变量初始化 生命池 全局变量初始化（属性名）")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 真;
	}

	动作
	{
		等待(1, 无视条件);
		根据条件跳过(所在队伍(事件玩家) == 队伍1, 1);
		//0"攻击"
		//1"法强"
		//2"生命"
		//3"护甲"
		//4"魔抗"
		//5"敏捷"
		事件玩家.Shuxing = 数组(0,0,0,0,0,0);
		为玩家添加生命池(事件玩家, 生命值, 100 + 35 * 事件玩家.Shuxing[2], 真, 真);
		全局.Shuxing_Name = 数组(自定义字符串("攻击"), 自定义字符串("法强"), 自定义字符串("生命"), 自定义字符串("护甲"), 自定义字符串("魔抗"), 自定义字符串("敏捷"));
		全局.Shuxing_DEScr = 数组(自定义字符串("增加左右键的伤害"),自定义字符串("增加原生技能的伤害"),自定义字符串("获得额外生命值"),自定义字符串("抵抗敌人的左右键攻击"),自定义字符串("抵抗敌人的技能伤害"),自定义字符串("增加移动速度"));
		等待(99999, 无视条件);
	}
}

规则("攻击力")
{
	事件
	{
		玩家造成伤害;
		双方;
		全部;
	}

	条件
	{
		数组包含(数组(按钮(主要攻击模式), 按钮(辅助攻击模式), 按钮(近身攻击)), 事件技能) == 真;
	}

	动作
	{
		If(所在队伍(被攻击方) == 队伍1);
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义字符串("攻击"));
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 事件伤害+事件伤害 * (((1 + 事件玩家.Shuxing[0])^0.5)) * (1-(被攻击方.Shuxing[3] / (15 + 被攻击方.Shuxing[3]))));
		End;
		If(事件暴击 == 1);
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义颜色(255, 60, 60, 255));
		Else;
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义颜色(162, 60, 60, 255));
		End;
		伤害(被攻击方, 事件玩家, 事件伤害 * ((1 + 事件玩家.Shuxing[0])^0.5) * (1-(被攻击方.Shuxing[3] / (15 + 被攻击方.Shuxing[3]))));
	}
}

规则("法术强度")
{
	事件
	{
		玩家造成伤害;
		双方;
		全部;
	}

	条件
	{
		数组包含(数组(按钮(技能1), 按钮(技能2), 按钮(终极技能), 按钮(蹲下), 按钮(跳跃)), 事件技能) == 真;
	}

	动作
	{
		If(所在队伍(被攻击方) == 队伍1);
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义字符串("法强"));
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 事件伤害+事件伤害 * ((1 + 事件玩家.Shuxing[1])^0.5) * (1-(被攻击方.Shuxing[4] / (15 + 被攻击方.Shuxing[4]))));
		修改玩家变量(被攻击方, Damage_list, 添加至数组, 自定义颜色(49, 120, 244, 255));
		End;
		伤害(被攻击方, 事件玩家, 事件伤害 * ((1 + 事件玩家.Shuxing[1])^0.5) * (1-(被攻击方.Shuxing[4] / (15 + 被攻击方.Shuxing[4]))));
	}
}

规则("护甲")
{
	事件
	{
		玩家受到伤害;
		双方;
		全部;
	}

	条件
	{
		(事件技能 == 按钮(主要攻击模式) || 事件技能 == 按钮(辅助攻击模式) || 事件技能 == 按钮(近身攻击)) == 真;
	}

	动作
	{
		治疗(事件玩家, 事件玩家, 事件伤害 * (事件玩家.Shuxing[3] / (15 + 事件玩家.Shuxing[3])));
	}
}

规则("魔抗")
{
	事件
	{
		玩家受到伤害;
		双方;
		全部;
	}

	条件
	{
		数组包含(数组(按钮(技能1), 按钮(技能2), 按钮(终极技能), 按钮(蹲下), 按钮(跳跃)), 事件技能) == 真;
	}

	动作
	{
		治疗(事件玩家, 事件玩家, 事件伤害 * (事件玩家.Shuxing[4] / (10 + 事件玩家.Shuxing[4])));
	}
}

