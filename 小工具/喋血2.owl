规则("Click4-28-30")//选中奖品
{	
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 4;
		事件玩家.MenuLoop >= 28;
		已重生(事件玩家) == 真;
		事件玩家.MenuLoop <= 30;
	}

	动作
	{
		播放效果(事件玩家, “士兵：76”疾跑开始声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
		If(事件玩家.MenuLoop == 28 && 事件玩家.Draw_Result[0] != 0);
		事件玩家.Draw_Choosing_ID = 0;
		Else If(事件玩家.MenuLoop == 29 && 事件玩家.Draw_Result[1] != 0);
		事件玩家.Draw_Choosing_ID = 1;
		Else If(事件玩家.MenuLoop == 30 && 事件玩家.Draw_Result[2] != 0);
		事件玩家.Draw_Choosing_ID = 2;
		End;
	}
}

规则("-Click4-28-30")//确认奖品
{	
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(互动)) == 真;
		事件玩家.MenuActive == 4;
		事件玩家.Draw_Result[事件玩家.Draw_Choosing_ID] != 0;
		已重生(事件玩家) == 真;
	}

	动作
	{
		等待(0.250, 当为“假”时中止);
		播放效果(事件玩家, 有益爆炸, 颜色(黄色), 最后(事件玩家.MenuCameraNow), 0.5);
			If(事件玩家.Draw_type == 1);//说明此次是装备抽签
				修改玩家变量(事件玩家, bags, 添加至数组, 事件玩家.Draw_Result[事件玩家.Draw_Choosing_ID]);
				小字体信息(事件玩家, 自定义字符串("已获取 {0}",事件玩家.Draw_Result[事件玩家.Draw_Choosing_ID]));
				播放效果(事件玩家, 状态爆炸声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			Else If(事件玩家.Draw_type == 2);//说明此次是属性抽签
				事件玩家.Shuxing[事件玩家.Draw_pool[事件玩家.Draw_Choosing_ID][0]] += 事件玩家.Draw_pool[事件玩家.Draw_Choosing_ID][1];
				小字体信息(事件玩家, 自定义字符串("已获取 {0}",事件玩家.Draw_Result[事件玩家.Draw_Choosing_ID]));
				播放效果(事件玩家, 状态爆炸声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			End;
			等待(0.250, 无视条件);
			事件玩家.Draw_Result = 0;
		End;
	}
}

