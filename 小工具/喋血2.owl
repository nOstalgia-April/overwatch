规则("子程序 VictoryCartoon")
{
	事件
	{
		子程序;
		VictoryCartoon;
	}

	动作
	{
		等待直到 (在地面上(事件玩家), 1);
		大字体信息(事件玩家, 自定义字符串("任务胜利！\n\n                        即将返回"));
		开始镜头(事件玩家, 眼睛位置(事件玩家) + 地图矢量(矢量(-0.500, -0.200, 2), 事件玩家, 旋转), 眼睛位置(事件玩家), 20);
		播放效果(事件玩家, 有害爆炸, 颜色(白色), 地图矢量(矢量(随机实数(-1, 1), -1, 随机实数(-1, -2)), 事件玩家, 旋转并转换), 1);
		播放效果(事件玩家, 有害爆炸, 颜色(白色), 地图矢量(矢量(随机实数(-1, 1), -1, 随机实数(-1, -2)), 事件玩家, 旋转并转换), 1);
		播放效果(事件玩家, 有害爆炸, 颜色(白色), 地图矢量(矢量(随机实数(-1, 1), -1, 随机实数(-1, -2)), 事件玩家, 旋转并转换), 1);
		播放效果(事件玩家, “黑影”标志声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(事件玩家, “黑影”标志声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		等待(0.300, 无视条件);
		播放效果(事件玩家, “破坏球”地雷禁区爆炸声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(事件玩家, 半藏音初始脉冲声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(事件玩家, 半藏音初始脉冲声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		等待(6, 无视条件);
		复活(事件玩家);
		传送(事件玩家, 最近的可行走位置(事件玩家));
		禁用 传送(事件玩家, 上);
		停止镜头(事件玩家);
	}
}

规则("玩家-全准备后")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		
		(假 || 对全部为“真”(所有玩家(队伍2), 当前数组元素.OK && 已重生(当前数组元素))) == 真;
		玩家数量(队伍2) > 0;
	}

	动作
	{
			调用子程序(MenuClose);
			调用子程序(LoadingCartoon);
			调用子程序(Agility);
	}
}

规则("全局-全准备后")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		(假 || 对全部为“真”(所有玩家(队伍2), 当前数组元素.OK && 已重生(当前数组元素))) == 真;
		总计消耗时间 > 10;
		玩家数量(队伍2) > 0;
	}

	动作
	{
			全局.CurrentRoom = 0;
			全局.CurrentRoom = 全局.RoomAll[全局.RoomLayer];
			全局.GameState = 1; //加载
			传送(所有玩家(队伍2), 数组随机取值(全局.nodes_location));
			等待(5, 无视条件);
			全局.GameState = 2; //关卡

	}
}

规则("默认那么-杀完所有人以后&&撤离完成开始下一关")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		玩家数量(队伍1) == 0;
		全局.GameState == 2;
		玩家数量(队伍2) > 0;
		全局.Quitting_stage >= 3;
	}

	动作
	{
		等待(3, 当为“假”时中止);
		全局.RoomLayer += 1;
		全局.GameState = 3;
		全局.CurrentRoom = 0;
	}
}



规则("重生 第一次")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		游戏正在进行中 == 真;
		已重生(事件玩家) == 真;
	}

	动作
	{
		禁用 等待(3, 无视条件);
		If(全局.GameState > 0);
			传送(事件玩家, 数组随机取值(事件玩家.nodes_location));
		Else;
			事件玩家.MenuActive = 5;
			调用子程序(MenuOpen);
		End;
		等待(99999, 无视条件);
	}
}



规则("玩家 胜利后 vicory&open")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 3;
	}

	动作
	{
		事件玩家.level = 0;
		调用子程序(VictoryCartoon);
		事件玩家.MenuActive = 5;
		调用子程序(MenuOpen);
	}
}

规则("全局 胜利后 初始化")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 3;
	}

	动作
	{
		等待(1, 无视条件);
		全局.GameState = 0;
		所有玩家(队伍2).OK = 0;
		全局.Timestart = 90;
		追踪全局变量频率(Timestart, 0, 1, 速率及最终值);
	}
}

规则("全局 胜利后 发放奖励券")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.GameState == 3;
	}

	动作
	{
		If(全局.RoomLayer % 3 == 1);
			所有玩家(所有队伍).tickets[0] += 1;
			小字体信息(所有玩家(所有队伍), 自定义字符串("已发放普通抽奖券"));
		Else If(全局.RoomLayer % 3 == 2);
			所有玩家(所有队伍).tickets[1] += 1;
			小字体信息(所有玩家(所有队伍), 自定义字符串("已发放稀有抽奖券"));
		Else If(全局.RoomLayer % 3 == 0);
			所有玩家(所有队伍).tickets[2] += 1;
			小字体信息(所有玩家(所有队伍), 自定义字符串("已发放传奇抽奖券"));
		End;
	}
}

规则("中途加入的玩家补偿奖励券")
{
	事件
	{
		玩家加入比赛;
		双方;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 真;
		全局.RoomLayer > 0;
	}

	动作
	{
		事件玩家.tickets[0] = 取整(全局.RoomLayer/3, 上);
		事件玩家.tickets[1] = 取整(全局.RoomLayer+1/3, 下);
		事件玩家.tickets[2] = 取整(全局.RoomLayer/3, 下);
		小字体信息(所有玩家(所有队伍), 自定义字符串("因为你中途加入，我们贴心地为你补发了抽奖券"));
	}
}




规则("——————经验池——————")
{
	事件
	{
		持续 - 全局;
	}
}

规则("经验初始化，每个玩家")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		全局.GameState == 2;
		已重生(事件玩家) == 真;
	}

	动作
	{
		事件玩家.level = 0;
	}
}

规则("经验池不断生成-关卡中时")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.GameState == 2;
		数量(全局.EXP_location) <= 数量(所有玩家(队伍2));
	}

	动作
	{
		
		修改全局变量(EXP_location, 添加至数组, 数组随机取值(全局.nodes_location));
		修改全局变量(EXP_stacks, 添加至数组, 随机整数(1, 2));
		等待(随机实数(15, 35), 无视条件);
		如条件为“真”则循环;
	}

		

}

规则("经验池初始化，每关开始")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.GameState == 2;
	}

	动作
	{
		全局.EXP_location = 空数组;
		全局.EXP_stacks = 空数组;
	}
}

规则("经验池全局初始化")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		For 全局变量(EXP_for, 0, 6, 1);//数量最多6个
		创建效果(与(全局.GameState == 2, 全局.EXP_location[单次赋值(全局.EXP_for)] != 0) ?所有玩家(所有队伍):空, 环, 颜色(青绿色), 数组中的值(全局.EXP_location, 单次赋值(全局.EXP_for)), 2, 可见，位置和半径);
		//绿色或橙色经验球球显示
		创建图标(与(全局.GameState == 2, 全局.EXP_location[单次赋值(全局.EXP_for)] != 0) ?所有玩家(所有队伍):空, 全局.EXP_location[单次赋值(全局.EXP_for)] +矢量(0, 1.5, 0), 火焰, 可见和位置, 全局.EXP_stacks[单次赋值(全局.EXP_for)] >= 2 ?颜色(橙色):颜色(绿色), 假);
		创建地图文本(与(全局.GameState == 2, 全局.EXP_location[单次赋值(全局.EXP_for)] != 0) ?所有玩家(所有队伍):空, 自定义字符串("{0}",全局.EXP_stacks[单次赋值(全局.EXP_for)])
		, 全局.EXP_location[单次赋值(全局.EXP_for)] +矢量(0, 1, 0), 1.5, 根据表面截取, 可见，位置和字符串, 颜色(白色), 默认可见度);
		//图标提示玩家这里有经验矿
		End;
	}

}

规则("玩家按蹲拾取升级")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		正在蹲下(事件玩家) == 真;
		在地面上(事件玩家) == 真;
		事件玩家.level < 10;
		全局.GameState == 2;
	}

	动作
	{
		If(对任意为“真”(全局.EXP_location, 相距距离(当前数组元素, 事件玩家) <= 2) == 真);
		事件玩家.EXP_ID = 数组值的索引(全局.EXP_location, 首个(已排序的数组(全局.EXP_location, 相距距离(当前数组元素, 事件玩家))));
		事件玩家.level = 较小(10, 事件玩家.level + 全局.EXP_stacks[事件玩家.EXP_ID]);
		修改全局变量(EXP_location, 根据索引从数组中移除, 事件玩家.EXP_ID);
		修改全局变量(EXP_stacks, 根据索引从数组中移除, 事件玩家.EXP_ID);
		播放效果(事件玩家, 布丽吉塔恢复包护甲声音, 颜色(白色), 所选位置(事件玩家), 150);
		播放效果(所有玩家(所有队伍), 有益选择效果, 颜色(绿色), 事件玩家, 1);
		小字体信息(事件玩家, 自定义字符串("升级成功！你目前的等级是{0}",事件玩家.level));
		设置状态(事件玩家, 空, 击晕, 0.5);
		End;
	}
}

规则("——————撤离点模块——————")
{
	事件
	{
		持续 - 全局;
	}
}

规则("当前撤离进度HUD全局初始化")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		创建HUD文本(已过滤的数组(所有玩家(所有队伍), 全局.GameState == 2), 全局.Quitting_percent_stage == 0?自定义字符串("            \r\n      {0}      \r\n",自定义字符串("激活撤离点！")):全局.Quitting_stage == 3?自定义字符串("            \r\n      清扫剩余怪物！      \r\n"):自定义字符串("            \r\n        撤离已激活       \r\n        :{0}%\r\n",全局.Quitting_percent_stage, 全局.Quitting_stage, 3), 全局.CurrentRoom, 自定义字符串("{0}/{1}", 全局.Quitting_stage, 3), 顶部, -1, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 默认可见度);
	}
}

规则("撤离点特效初始化")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		创建效果((全局.GameState == 2 && 全局.Quitting_percent_stage > 0 ) ?所有玩家(所有队伍):空, 球体, 颜色(红色), 全局.Quitting_Locations[全局.Quitting_stage], 全局.Cage_Large, 可见，位置和半径);
		//撤离点
		创建效果((全局.GameState == 2 && 全局.Quitting_stage <= 2) ?所有玩家(所有队伍):空, 环, 颜色(白色), 全局.Quitting_Locations[全局.Quitting_stage], 4.2, 可见，位置和半径);
		创建效果((全局.GameState == 2 && 全局.Quitting_stage <= 2) ?所有玩家(所有队伍):空, 球体, 颜色(白色), 全局.Quitting_Locations[全局.Quitting_stage], 4, 可见，位置和半径);
		//进入环内的互动提示以及进度条提示
		创建进度条地图文本((全局.GameState == 2 && 全局.Quitting_stage <= 2) ? 已过滤的数组(所有玩家(所有队伍), 相距距离(全局.Quitting_Locations[全局.Quitting_stage], 当前数组元素) <= 4):空, 全局.Quitting_percent_stage, 自定义字符串("待在撤离点之中可以加速撤离"), 眼睛位置(本地玩家) + 10 * 面朝方向(本地玩家) + 地图矢量(矢量(0, -2, 0), 本地玩家, 旋转), 2, 不要截取, 自定义颜色(220 + 0.350 * 全局.Quitting_percent_stage, 20 + 1.450 * 全局.Quitting_percent_stage,
		60 + -0.600 * 全局.Quitting_percent_stage, 255), 颜色(白色), 可见，值和颜色, 默认可见度);
		//图标提示玩家这里是撤离点	
		创建图标(已过滤的数组(所有玩家(所有队伍), (在视线内(全局.Quitting_Locations[全局.Quitting_stage], 眼睛位置(当前数组元素), 屏障不会阻挡视线) != 真) && 全局.GameState == 2 && 全局.Quitting_stage <= 2), 全局.Quitting_Locations[全局.Quitting_stage], 箭头：向下, 可见，位置和颜色, 
		(取整(总计消耗时间, 上) % 2 == 1)&&(全局.Quitting_percent_stage == 0) ? 颜色(红色) : (全局.Quitting_percent_stage == 0 ? 颜色(蓝色) : 颜色(绿色)),真);
	}
}

规则("撤离点重置初始化（every 准备阶段）")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.GameState == 1;
	}

	动作
	{
		全局.Quitting_Locations[0] = 数组随机取值(全局.nodes_location);
		全局.Quitting_Locations[1] = 数组随机取值(已过滤的数组(全局.nodes_location, 相距距离(当前数组元素, 全局.Quitting_Locations[0]) >= 40));
		全局.Quitting_Locations[2] = 数组随机取值(已过滤的数组(全局.nodes_location, 相距距离(当前数组元素, 全局.Quitting_Locations[0]) >= 40 && 相距距离(当前数组元素, 全局.Quitting_Locations[1]) >= 40));
		全局.Quitting_percent_stage = 0;
		全局.Quitting_stage = 0;
	}
}

规则("撤离点加进度-自动")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		数量(已过滤的数组(所有存活玩家(队伍2), 相距距离(全局.Quitting_Locations[全局.Quitting_stage], 当前数组元素) <= 4)) >= 1;
		全局.GameState == 2;
		全局.Quitting_Locations[全局.Quitting_stage] != 0;
	}

	动作
	{
		全局.Cage_Large = 0;
		持续追踪全局变量(Cage_Large, 200, 2.5, 终点及持续时间);
		While(全局.Quitting_percent_stage < 100);
		全局.Quitting_percent_stage += 0.05;
		等待(0.05, 无视条件);
		End;
	}
}

规则("撤离点加进度-玩家")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		相距距离(全局.Quitting_Locations[全局.Quitting_stage], 事件玩家) <= 4;
		存活(事件玩家) == 真;
	}

	动作
	{
		全局.Quitting_percent_stage += 0.05*4/较小(玩家数量(队伍2),3);
		等待(0.05, 无视条件);
		如条件为“真”则循环;
	}
}
规则("当撤离点被激活的时候触发升级")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		全局.Quitting_percent_stage > 0;
		全局.GameState == 2;
	}

	动作
	{
		等待(0.250, 当为“假”时中止);
		事件玩家.level = 较小(10, 事件玩家.level + 数组(2,3,5)[全局.Quitting_stage]);//根据撤离点顺序加不同的等级
		播放效果(事件玩家, 状态爆炸声音, 颜色(白色), 所选位置(事件玩家), 150);
		播放效果(所有玩家(所有队伍), 有益选择效果, 颜色(绿色), 事件玩家, 1);
		大字体信息(事件玩家, 自定义字符串("当前撤离已开始\r\n  请抵抗来临的怪物！"));
		小字体信息(事件玩家, 自定义字符串("因为撤离点被激活，等级来到了{0}级",事件玩家.level));

	}
}

规则("撤离点进度满了就clear切stage")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.Quitting_percent_stage >= 100;
		全局.GameState == 2;
	}

	动作
	{
		等待(0.250, 无视条件);

		全局.Quitting_percent_stage = 0;
		全局.Quitting_stage += 1;
		播放效果(所有玩家(所有队伍), 半藏音初始脉冲效果, 颜色(队伍2), 全局.Quitting_Locations[全局.Quitting_stage], 1);
		播放效果(所有玩家(所有队伍), 半藏音初始脉冲效果, 颜色(队伍2), 全局.Quitting_Locations[全局.Quitting_stage], 1);
		播放效果(所有玩家(所有队伍), 半藏音初始脉冲效果, 颜色(队伍2), 全局.Quitting_Locations[全局.Quitting_stage], 1);
		播放效果(所有玩家(所有队伍), 半藏音初始脉冲效果, 颜色(队伍2), 全局.Quitting_Locations[全局.Quitting_stage], 1);
		播放效果(所有玩家(所有队伍), “破坏球”地雷禁区爆炸声音, 颜色(队伍2), 全局.Quitting_Locations[全局.Quitting_stage], 125);
		If(全局.Quitting_stage == 3);
		中止;
		End;
		等待(0.250, 无视条件);
		If(全局.Quitting_stage < 2);
		大字体信息(所有玩家(所有队伍), 自定义字符串("请前往下一个撤离点！\n                       {0}/3", 全局.Quitting_stage));
		End;
	}
}

