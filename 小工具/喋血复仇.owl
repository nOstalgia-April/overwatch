规则("初始化")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.distance_preset = 空数组;
		全局.prev_node_preset = 空数组;
		全局.nodes_index_preset = 空数组;
		For 全局变量(loop_1, 0, 数量(全局.nodes_location), 1);
			修改全局变量(distance_preset, 添加至数组, 9999);
			修改全局变量(prev_node_preset, 添加至数组, -1);
			修改全局变量(nodes_index_preset, 添加至数组, 全局.loop_1);
		End;
		全局.nodes_basic_distance = 空数组;
		For 全局变量(loop_1, 0, 数量(全局.nodes_location), 1);
			全局.nodes_basic_distance[全局.loop_1] = 空数组;
			全局.checking_nodes = 全局.nodes_link[全局.loop_1];
			For 全局变量(loop_2, 0, 数量(全局.checking_nodes), 1);
				在索引处修改全局变量(nodes_basic_distance, 全局.loop_1, 添加至数组, 相距距离(全局.nodes_location[全局.loop_1],
					全局.nodes_location[全局.checking_nodes[全局.loop_2]]));
			End;
		End;
	}
}

禁用 规则("左键生成机器人")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		总计消耗时间 > 10;
		按钮被按下(主机玩家, 按钮(终极技能)) == 真;
		已重生(主机玩家) == 真;
	}

	动作
	{
		生成机器人(英雄(莫伊拉), 队伍1, -1, 数组随机取值(主机玩家.bot_nodes_location), 矢量(0, 0, 0));
		最后创建的实体.Mname = 自定义字符串("莫伊拉");
	}
}

规则("——————菜单——————")
{
	事件
	{
		持续 - 全局;
	}
}

规则("创建指针")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		创建地图文本(已过滤的数组(本地玩家, 当前数组元素.MenuCursorVisable == 1), 自定义字符串("(+)"), 逐帧更新(最后(本地玩家.MenuCameraNow) + 水平朝向角度(本地玩家)
			/ 本地玩家.MenuCursorSensibility * 本地玩家.MenuFlatBase1 + 垂直朝向角度(本地玩家) / 本地玩家.MenuCursorSensibility * 本地玩家.MenuFlatBase2), 2, 不要截取,
			可见，位置，字符串和颜色, 颜色(白色), 默认可见度);
	}
}

规则("重置指针")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(近身攻击)) == 1;
		事件玩家.MenuActive > 0;
	}

	动作
	{
		设置朝向(事件玩家, 矢量(0, 0, 1), 至地图);
	}
}

规则("打开菜单 子程序MenuOpen")
{
	事件
	{
		子程序;
		MenuOpen;
	}

	动作
	{
		调用子程序(MenuBase);
		设置瞄准速度(事件玩家, 0.500);
		禁用 设置瞄准速度(事件玩家, 10);
		事件玩家.MenuCursorSensibility = 5;
		事件玩家.MenuCursorVisable = 0;
		事件玩家.AnchorPos = 所选位置(事件玩家);
		事件玩家.AnchorFacing = 面朝方向(事件玩家);
		隐藏英雄HUD(事件玩家);
		事件玩家.MenuBottonCoordinate = 全局.MenuBottonCoordinate;
		开始限制阈值(事件玩家, 0, 0, 0, 0, 0, 0);
		等待(0.100, 无视条件);
		设置朝向(事件玩家, 矢量(0, 0, 1), 至地图);
		开始镜头(事件玩家, 首个(事件玩家.MenuCameraNow), 最后(事件玩家.MenuCameraNow), 25);
		事件玩家.MenuCursorVisable = 1;
		If(事件玩家.Caninteract == 1);
		End;
		禁用按钮(事件玩家, 按钮(主要攻击模式));
		禁用按钮(事件玩家, 按钮(辅助攻击模式));
		禁用按钮(事件玩家, 按钮(装填));
		禁用按钮(事件玩家, 按钮(跳跃));
		禁用按钮(事件玩家, 按钮(技能2));
		禁用按钮(事件玩家, 按钮(技能1));
		禁用按钮(事件玩家, 按钮(蹲下));
		可用按钮(事件玩家, 按钮(终极技能));
		设置状态(事件玩家, 空, 相移, 9999);
		取消与玩家的移动碰撞(事件玩家);
	}
}

规则("关闭菜单 子程序MenuClose")
{
	事件
	{
		子程序;
		MenuClose;
	}

	动作
	{
		事件玩家.MenuCursorVisable = 0;
		事件玩家.MenuActive = 0;
		停止限制阈值(事件玩家);
		停止镜头(事件玩家);
		显示英雄HUD(事件玩家);
		设置朝向(事件玩家, 事件玩家.AnchorFacing, 至地图);
		等待(0.100, 无视条件);
		事件玩家.Caninteract = 1;
		可用按钮(事件玩家, 按钮(主要攻击模式));
		可用按钮(事件玩家, 按钮(辅助攻击模式));
		可用按钮(事件玩家, 按钮(跳跃));
		可用按钮(事件玩家, 按钮(蹲下));
		可用按钮(事件玩家, 按钮(技能1));
		可用按钮(事件玩家, 按钮(技能2));
		可用按钮(事件玩家, 按钮(终极技能));
		可用按钮(事件玩家, 按钮(装填));
		清除状态(事件玩家, 相移);
		开启与玩家的移动碰撞(事件玩家);
		设置瞄准速度(事件玩家, 100);
	}
}

规则("求基底 子程序MenuBase")
{
	事件
	{
		子程序;
		MenuBase;
	}

	动作
	{
		事件玩家.MenuCameraNow = 数组(首个(事件玩家.MenuCameraNow), 首个(事件玩家.MenuCameraNow) + 方向(首个(事件玩家.MenuCameraNow), 最后(事件玩家.MenuCameraNow)));
		"基底1"
		事件玩家.MenuFlatBase1 = 矢量积(上, 方向(首个(事件玩家.MenuCameraNow), 最后(事件玩家.MenuCameraNow)));
		"基底1"
		事件玩家.MenuFlatBase1 = 归一化(事件玩家.MenuFlatBase1);
		"基底1"
		事件玩家.MenuFlatBase2 = 矢量积(事件玩家.MenuFlatBase1, 方向(首个(事件玩家.MenuCameraNow), 最后(事件玩家.MenuCameraNow)));
		"基底2"
		事件玩家.MenuFlatBase2 = 归一化(事件玩家.MenuFlatBase2);
	}
}

规则("——————选择英雄——————")
{
	事件
	{
		持续 - 全局;
	}
}

规则("菜单 钥匙插进去了吗")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.MenuActive >= 1;
		禁用 事件玩家.MenuActive <= 4;
	}

	动作
	{

		For 玩家变量(事件玩家, MenuPage, 0, 数量(全局.Menu_BottonAllay[事件玩家.MenuActive]), 1);
			If(绝对值(水平朝向角度(事件玩家) / 事件玩家.MenuCursorSensibility - 首个(全局.MenuBottonCoordinate[事件玩家.MenuLoop]))
				< 全局.MenuBottonWidth[事件玩家.MenuActive] && 绝对值(垂直朝向角度(事件玩家) / 事件玩家.MenuCursorSensibility - 最后(
				全局.MenuBottonCoordinate[事件玩家.MenuLoop])) < 全局.MenuBottonHeight[事件玩家.MenuActive]);
				中断;
			End;
			事件玩家.MenuLoop = 全局.Menu_BottonAllay[事件玩家.MenuActive][事件玩家.MenuPage];
		End;
		等待(0.025, 无视条件);
		如条件为“真”则循环;
	}
}

