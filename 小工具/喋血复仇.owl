规则("Click2-12-16")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 2;
		事件玩家.MenuLoop >= 11;
		已重生(事件玩家) == 真;
		事件玩家.MenuLoop <= 16;
		事件玩家.TF_Point > 0;
	}

	动作
	{
		播放效果(事件玩家, 状态爆炸声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
		If(事件玩家.MenuLoop == 11);
			事件玩家.Attack += 1;
		Else If(事件玩家.MenuLoop == 12);
			事件玩家.SpellPower += 1;
		Else If(事件玩家.MenuLoop == 13);
			事件玩家.Health += 1;
		Else If(事件玩家.MenuLoop == 14);
			事件玩家.Armor += 1;
		Else If(事件玩家.MenuLoop == 15);
			事件玩家.SpellResis += 1;
		Else If(事件玩家.MenuLoop == 16);
			事件玩家.Agility += 1;
		End;
		事件玩家.TF_Point += -1;
		等待(0.100, 无视条件);
	}
}

