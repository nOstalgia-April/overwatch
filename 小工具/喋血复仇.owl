规则("2-20")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		"确定按钮 - 0"
		全局.MenuBottonCoordinate[20] = 数组(0.300, 0.600);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 2 && 当前数组元素.MenuActive <= 4), 自定义字符串("当前点数：{0}", 本地玩家.TF_Point), 最后(
			本地玩家.MenuCameraNow) + 首个(全局.MenuBottonCoordinate[20]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[20])
			* 本地玩家.MenuFlatBase2, 4, 不要截取, 可见，位置，字符串和颜色, 本地玩家.MenuLoop == -1 ? 颜色(橙色) : 颜色(白色), 默认可见度);
