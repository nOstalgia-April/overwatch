规则("TF紧急医疗")
{
	事件
	{
		玩家造成治疗;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.level >= 全局.Fibonacci[数组值的索引(事件玩家.TF_Player, 自定义字符串("紧急医疗"))];
		数组包含(事件玩家.TF_Player, 自定义字符串("紧急医疗")) == 真;
		标准化生命值(受治疗者) <= 0.500;
	}

	动作
	{
		治疗(受治疗者, 空, 事件治疗 * 0.010 * (事件玩家.SpellPower * 2 + 事件玩家.SpellResis * 2));
	}
}

