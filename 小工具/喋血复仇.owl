规则("TF巨人化")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.level >= 全局.Fibonacci[数组值的索引(事件玩家.TF_Player, 自定义字符串("巨人化"))];
		数组包含(事件玩家.TF_Player, 自定义字符串("巨人化")) == 真;
		存活(事件玩家) == 真;
	}

	动作
	{
		开始调整玩家大小(事件玩家, 2, 真);
		事件玩家.Attack += 10;
		事件玩家.Agility += -10;
		调用子程序(Shuxing);
		等待直到 (事件玩家.level < 全局.Fibonacci[数组值的索引(事件玩家.TF_Player, 自定义字符串("巨人化"))], 99999);
		开始调整玩家大小(事件玩家, 1, 真);
		事件玩家.Attack += -10;
		事件玩家.Agility += 10;
		调用子程序(Shuxing);
	}
}

