规则("子程序 find path 玩家")
{
	事件
	{
		子程序;
		find_path;
	}

	动作
	{
		根据条件中止(死亡(事件玩家));
		事件玩家.bot_passed_node = 空数组;
		事件玩家.bot_path = 空数组;
		修改玩家变量(事件玩家, bot_passed_node, 添加至数组, 事件玩家.bot_start);
		修改玩家变量(事件玩家, bot_path, 添加至数组, 事件玩家.bot_end);
		事件玩家.bot_distance[事件玩家.bot_start] = 0;
		While(!数组包含(事件玩家.bot_passed_node, 事件玩家.bot_end) && 存活(事件玩家));
			事件玩家.bot_current_node = 最后(事件玩家.bot_passed_node);
			事件玩家.bot_checking_nodes = 事件玩家.bot_nodes_link[事件玩家.bot_current_node];
			事件玩家.bot_checking_nodes = 已过滤的数组(事件玩家.bot_checking_nodes, !数组包含(事件玩家.bot_passed_node, 当前数组元素));
			调用子程序(update_distance);
			事件玩家.bot_nodes_index = 已排序的数组(事件玩家.bot_nodes_index, 事件玩家.bot_distance[当前数组元素] * 1);
			事件玩家.bot_nodes_index = 已过滤的数组(事件玩家.bot_nodes_index, !数组包含(事件玩家.bot_passed_node, 当前数组元素));
			修改玩家变量(事件玩家, bot_passed_node, 添加至数组, 首个(事件玩家.bot_nodes_index));
			等待(0.020, 无视条件);
		End;
		While(最后(事件玩家.bot_path) != 事件玩家.bot_start && 存活(事件玩家));
			修改玩家变量(事件玩家, bot_path, 添加至数组, 事件玩家.bot_prev_node[最后(事件玩家.bot_path)]);
			If(数组包含(事件玩家.bot_path, -1));
				禁用 小字体信息(所有玩家(所有队伍), 自定义字符串("{0}{1}:路径索引包含-1，寻路失败", 栏位(事件玩家), 所用英雄(事件玩家)));
				事件玩家.bot_path = 空数组;
				中止;
			End;
			等待(0.020, 无视条件);
		End;
		事件玩家.bot_path = 已排序的数组(事件玩家.bot_path, 当前数组索引 * -1);
	}
}

