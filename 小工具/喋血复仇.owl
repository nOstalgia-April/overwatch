规则("M僵尸 触发追击")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		托比昂;
	}

	条件
	{
		事件玩家.Mname == 自定义字符串("僵尸");
		对任意为“真”(所有存活玩家(队伍2), 在视线内(当前数组元素, 事件玩家, 屏障不会阻挡视线) && 相距距离(当前数组元素, 事件玩家) <= 10) == 真;
	}

	动作
	{
		开始按下按钮(事件玩家, 按钮(技能2));
		事件玩家.Bot_AIBOOl = 0;
		禁用 停止朝向(事件玩家);
		开始朝向(事件玩家, 方向(眼睛位置(事件玩家), 眼睛位置(首个(已排序的数组(所有存活玩家(队伍2), 相距距离(当前数组元素, 事件玩家))))), 200, 至地图, 方向及角速率);
		禁用 调用子程序(bot_facing_update);
		停止定向阈值(事件玩家);
		开始限制阈值(事件玩家, 0.700, 1, 0, 1, 0, 1);
		设置武器(事件玩家, 2);
		等待(0.250, 无视条件);
		开始按下按钮(事件玩家, 按钮(主要攻击模式));
		如条件为“真”则循环;
	}
}

规则("M僵尸 失去目标")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		托比昂;
	}

	条件
	{
		事件玩家.Mname == 自定义字符串("僵尸");
		对任意为“真”(所有存活玩家(队伍2), 在视线内(当前数组元素, 事件玩家, 屏障不会阻挡视线) && 相距距离(当前数组元素, 事件玩家) <= 8) != 真;
	}

	动作
	{
		等待(5, 当为“假”时中止);
		禁用 开始调整玩家大小(事件玩家, 1.500, 真);
		停止朝向(事件玩家);
		停止限制阈值(事件玩家);
		禁用 开始按下按钮(事件玩家, 按钮(技能2));
		传送(事件玩家, 首个(已排序的数组(事件玩家.bot_nodes_location, 相距距离(当前数组元素, 事件玩家))));
		事件玩家.Bot_AIBOOl = 1;
		禁用 调用子程序(bot_new_path);
		事件玩家.bot_targetPlayer = 首个(已排序的数组(所有存活玩家(队伍2), 相距距离(当前数组元素, 事件玩家)));
		禁用 调用子程序(Sub0);
		禁用 调用子程序(bot_facing_update);
	}
}

