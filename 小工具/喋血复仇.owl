规则("Click3-19 准备/取消准备")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 3;
		事件玩家.MenuLoop == 19;
		已重生(事件玩家) == 真;
	}

	动作
	{
		播放效果(事件玩家, 状态爆炸声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
		"下翻"
		禁用 Else If(事件玩家.MenuLoop == 3);
		If(事件玩家.OK != 1);
			事件玩家.OK = 1;
			小字体信息(事件玩家, 自定义字符串("已准备，等待所有人准备即可开始游戏", 英雄图标字符串(所用英雄(事件玩家)), 事件玩家));
		Else;
			小字体信息(事件玩家, 自定义字符串("你取消了准备，不要让队友等待太久！", 英雄图标字符串(所用英雄(事件玩家)), 事件玩家));
			事件玩家.OK = 0;
		End;
	}
}

规则("流程//子程序L﻿oadingCartoon 任务加载镜头")
{
	事件
	{
		子程序;
		LoadingCartoon;
	}

	动作
	{
		事件玩家.bot_area = 全局.Room_Area;
		调用子程序(bot_area_allot);
		"找出队友在的"
		禁用 事件玩家.bot_nodes_onlytargetSee = 已过滤的数组(事件玩家.bot_nodes_location, 相距距离(当前数组元素, 数组随机取值(所有存活玩家(队伍2))) <= 20);
		传送(事件玩家, 数组随机取值(事件玩家.bot_nodes_location));
		事件玩家.LoadingVisable1 = 0;
		持续追踪玩家变量(事件玩家, LoadingVisable1, 1, 5, 终点及持续时间);
		隐藏英雄HUD(事件玩家);
		开始镜头(事件玩家, 矢量(14.400, 1, 19), 矢量(14, 1.400, 20), 25);
		设置状态(事件玩家, 空, 定身, 6);
		While(事件玩家.LoadingVisable1 < 1);
			播放效果(所有玩家(所有队伍), “死神”幽灵形态声音, 颜色(白色), 矢量(14, 1.400, 20), 较大(40, 事件玩家.LoadingVisable1 * 170));
			"plan A"
			播放效果(所有玩家(所有队伍), “士兵：76”疾跑开始声音, 颜色(白色), 矢量(14, 1.400, 20), 较大(40, 事件玩家.LoadingVisable1 * 170));
			等待(0.200, 无视条件);
		End;
		停止追踪玩家变量(事件玩家, LoadingVisable1);
		事件玩家.LoadingVisable1 = 0;
		等待(0.300, 无视条件);
		事件玩家.LoadingVisable2 = 0;
		持续追踪玩家变量(事件玩家, LoadingVisable2, 1, 5, 终点及持续时间);
		停止镜头(事件玩家);
		播放效果(事件玩家, 莫伊拉消散消失声音, 颜色(白色), 事件玩家, 200);
		播放效果(事件玩家, 莫伊拉消散消失声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		等待直到 (事件玩家.LoadingVisable2 == 1, 4);
		停止追踪玩家变量(事件玩家, LoadingVisable2);
		事件玩家.LoadingVisable2 = 0;
		显示英雄HUD(事件玩家);
		设置终极技能充能(事件玩家, 0);
	}
}

