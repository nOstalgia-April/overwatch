规则("流程//子程序 VictoryCartoon")
{
	事件
	{
		子程序;
		VictoryCartoon;
	}

	动作
	{
		等待直到 (在地面上(事件玩家), 1);
		大字体信息(事件玩家, 自定义字符串("任务胜利！\n\n                        即将返回"));
		开始镜头(事件玩家, 眼睛位置(事件玩家) + 地图矢量(矢量(-0.500, -0.200, 2), 事件玩家, 旋转), 眼睛位置(事件玩家), 20);
		播放效果(事件玩家, 有害爆炸, 颜色(白色), 地图矢量(矢量(随机实数(-1, 1), -1, 随机实数(-1, -2)), 事件玩家, 旋转并转换), 1);
		播放效果(事件玩家, 有害爆炸, 颜色(白色), 地图矢量(矢量(随机实数(-1, 1), -1, 随机实数(-1, -2)), 事件玩家, 旋转并转换), 1);
		播放效果(事件玩家, 有害爆炸, 颜色(白色), 地图矢量(矢量(随机实数(-1, 1), -1, 随机实数(-1, -2)), 事件玩家, 旋转并转换), 1);
		播放效果(事件玩家, “黑影”标志声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(事件玩家, “黑影”标志声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		等待(0.300, 无视条件);
		播放效果(事件玩家, “破坏球”地雷禁区爆炸声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(事件玩家, 半藏音初始脉冲声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(事件玩家, 半藏音初始脉冲声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		等待(6, 无视条件);
		复活(事件玩家);
		传送(事件玩家, 最近的可行走位置(事件玩家));
		禁用 传送(事件玩家, 上);
		停止镜头(事件玩家);
	}
}

规则("流程//玩家-全准备后")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		对全部为“真”(所有玩家(队伍2), 当前数组元素.OK == 1) == 真;
		对全部为“真”(所有玩家(队伍2), 已重生(当前数组元素)) == 真;
		玩家数量(队伍2) > 0;
		禁用 全局.AllStart_ == 0;
	}

	动作
	{
		调用子程序(MenuClose);
		禁用 全局.AllStart_ = 1;
		调用子程序(Plyaer_Restart);
		调用子程序(LoadingCartoon);
	}
}

规则("流程//全局-全准备后")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		对全部为“真”(所有玩家(队伍2), 当前数组元素.OK == 1) == 真;
		对全部为“真”(所有玩家(队伍2), 已重生(当前数组元素)) == 真;
		总计消耗时间 > 10;
		禁用 全局.Preing_Bool == 1;
		玩家数量(队伍2) > 0;
		禁用 全局.AllStart_ == 0;
	}

	动作
	{
		消除所有效果;
		全局.TodayGoal = 0;
		全局.EXPBalls = 空数组;
		全局.EXPBalls_ID = 空数组;
		禁用 等待(1, 当为“假”时中止);
		全局.Room1 = 0;
		全局.Room1 = 数组随机取值(全局.RoomAll);
		全局.AllStart_ = 2;
		全局.Preing_Bool = 0;
		等待(5, 无视条件);
		全局.AllStart_ = 1;
	}
}

规则("流程//关卡内-HUD置顶当前关卡")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		创建HUD文本(已过滤的数组(所有玩家(所有队伍), 全局.AllStart_ == 1), 空, 空, 全局.Room1, 顶部, -999, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 默认可见度);
	}
}

规则("流程//子程序 Player_Restart")
{
	事件
	{
		子程序;
		Plyaer_Restart;
	}

	动作
	{
		调用子程序(bot_area_allot);
		事件玩家.level = 0;
		设置启用技能 1(事件玩家, 假);
		设置启用技能 2(事件玩家, 假);
		设置启用终极技能(事件玩家, 假);
	}
}

规则("流程//默认那么-杀完所有人以后开始下一关")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		玩家数量(队伍1) == 0;
		全局.AllStart_ == 1;
		玩家数量(队伍2) > 0;
		全局.TodayGoal == 0;
	}

	动作
	{
		等待(3, 当为“假”时中止);
		修改全局变量(RoomAll, 根据值从数组中移除, 全局.Room1);
		全局.Preing_Bool = 1;
		全局.RoomLayer += 1;
		创建HUD文本(所有玩家(所有队伍), 自定义字符串("12421"), 空, 空, 右边, 0, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 默认可见度);
		全局.AllStart_ = 0;
		全局.Room1 = 0;
		禁用 调用子程序(NextRound);
	}
}

规则("流程//重生 第一次")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		游戏正在进行中 == 真;
		已重生(事件玩家) == 真;
	}

	动作
	{
		禁用 等待(3, 无视条件);
		If(全局.AllStart_ > 0);
			事件玩家.bot_area = 全局.Room_Area;
			调用子程序(bot_area_allot);
			传送(事件玩家, 数组随机取值(事件玩家.bot_nodes_location));
		Else;
			调用子程序(OpenThatMenu);
	}
}

规则("流程//队伍的RoomAll初始化")
{
