		全局.TF_DEScr[4] = 数组(自定义字符串("技能2"), 自定义字符串("技能2：\r\n解锁技能2"));
		全局.TF_DEScr[5] = 数组(自定义字符串("终极技能"), 自定义字符串("终极技能：\r\n解锁终极技能"));
