		等待直到 (事件玩家.level < 全局.Fibonacci[数组值的索引(事件玩家.TF_Player, 自定义字符串("复仇"))], 99999);
		事件玩家.Attack -= 30;
		事件玩家.SpellPower -= 30;
		事件玩家.Health -= 30;
		事件玩家.Armor -= 30;
		事件玩家.Agility -= 30;
		事件玩家.SpellResis -= 30;
		调用子程序(Shuxing);
	}
}

