		全局.TF_DEScr[103] = 数组(自定义字符串("夺命之拉"), 自定义字符串(" 夺命之拉{0}：\r\n伤害拉回路径中的敌人", 技能图标字符串(英雄(生命之梭), 按钮(技能2))));
