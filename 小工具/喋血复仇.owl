规则("优化-死完重开")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		对全部为“真”(所有玩家(队伍2), 死亡(当前数组元素)) == 真;
		对全部为“真”(所有玩家(队伍2), 已重生(当前数组元素)) == 真;
		禁用 全局.AllStart_ == 1;
		总计消耗时间 > 10;
	}

	动作
	{
		等待(1, 当为“假”时中止);
		宣告队伍胜利(队伍1);
		等待(3, 无视条件);
		重新开始比赛;
	}
}

