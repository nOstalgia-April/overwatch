规则("等级//升级后指南")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.level >= 全局.Fibonacci[数组值的索引(事件玩家.TF_Player, 数组值的索引(全局.nodes_location, 0))];
		数组包含(全局.Fibonacci, 事件玩家.level) == 真;
	}

	动作
	{
		If(事件玩家.level < 全局.Fibonacci[数量(事件玩家.TF_Player) - 1]);
			大字体信息(事件玩家, 自定义字符串("{0}   \r\n           已解锁", 事件玩家.TF_Player[数组值的索引(全局.Fibonacci, 事件玩家.level)]));
			等待(9999, 当为“真”时重新开始);
	}
}

