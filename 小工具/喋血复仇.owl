规则("机器人-初始化")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		禁用 事件玩家.bot_path_bool == 1;
	}

	动作
	{
		事件玩家.bot_targetPlayer = -1;
		事件玩家.bot_ballistic_velocity = -0.003;
		事件玩家.bot_aming_accuracy = 0;
		事件玩家.bot_path = 空数组;
		事件玩家.bot_lastposition_5group = 空数组;
		事件玩家.Bot_AIBOOl = 1;
		禁用 事件玩家.bot_path_bool = 1;
		取消与玩家的移动碰撞(事件玩家);
		事件玩家.bot_area = 全局.Room_Area;
		调用子程序(bot_area_allot);
	}
}

规则("机器人-状态机-初始化")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
	}

	动作
	{
		禁用 事件玩家.bot_state = 2;
		事件玩家.bot_stateTime = 0;
		事件玩家.bot_stateNext = 1;
		事件玩家.bot_state = 1;
	}
}

规则("机器人-状态机-进入")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		禁用 已重生(事件玩家) == 真;
		事件玩家.Bot_AIBOOl == 1;
		事件玩家.bot_stateTime == 0;
	}

	动作
	{
		If(事件玩家.bot_targetPlayer == -1 && 事件玩家.bot_stateNext == 0);
			调用子程序(bot_state_idle);
		Else If(事件玩家.bot_targetPlayer == -1 && 事件玩家.bot_stateNext == 1);
			调用子程序(bot_state_wander);
		Else If(事件玩家.bot_targetPlayer != -1);
			调用子程序(bot_state_chase);
		End;
		禁用 小字体信息(所有玩家(所有队伍), 自定义字符串("{0}{1}当前状态：{2}", 栏位(事件玩家), 所用英雄(事件玩家), 事件玩家.bot_state));
		等待(1, 无视条件);
		如条件为“真”则循环;
	}
}

规则("机器人-状态机-退出")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		禁用 已重生(事件玩家) == 真;
		事件玩家.Bot_AIBOOl == 1;
		总计消耗时间 >= 事件玩家.bot_stateTime;
	}

	动作
	{
		事件玩家.bot_stateTime = 0;
		禁用 If(事件玩家.bot_state == 1);
		禁用 事件玩家.bot_stateNext = 取整(随机实数(0, 1), 至最近);
		禁用 Else If(事件玩家.bot_state == 2);
		禁用 事件玩家.bot_stateNext = 取整(随机实数(0, 1), 至最近);
		禁用 Else If(事件玩家.bot_state == 3);
		禁用 End;
		禁用 小字体信息(所有玩家(所有队伍), 自定义字符串("{0}{1}状态结束：{2}", 栏位(事件玩家), 所用英雄(事件玩家), 事件玩家.bot_state));
		事件玩家.bot_stateNext = 1;
	}
}

