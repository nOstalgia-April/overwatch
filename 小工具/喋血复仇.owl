规则("M蚊子 触发追击")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		事件玩家.Mname == 自定义字符串("蚊子");
		对任意为“真”(所有存活玩家(队伍2), 在视线内(当前数组元素, 事件玩家, 屏障不会阻挡视线) && 相距距离(当前数组元素, 事件玩家) <= 20) == 真;
		事件玩家.Bot_AIBOOl == 1;
		具有状态(事件玩家, 击晕) != 真;
	}

	动作
	{
		等待(1, 当为“假”时中止);
		开始调整玩家大小(事件玩家, 0.400, 真);
		开始按下按钮(事件玩家, 按钮(技能2));
		事件玩家.Bot_AIBOOl = 0;
		事件玩家.Mwenzi_The1 = 已过滤的数组(所有存活玩家(队伍2), 相距距离(当前数组元素, 事件玩家) <= 20 && 在视线内(事件玩家, 当前数组元素, 屏障不会阻挡视线));
		事件玩家.Mwenzi_The1 = 首个(已排序的数组(事件玩家.Mwenzi_The1, 相距距离(当前数组元素, 事件玩家)));
		开始朝向(事件玩家, 方向(眼睛位置(事件玩家), 眼睛位置(事件玩家.Mwenzi_The1)), 10000, 至地图, 方向及角速率);
		禁用 开始强制设置玩家位置(事件玩家, 地图矢量(矢量(单次赋值(随机实数(-1, 1)), 单次赋值(随机实数(0.500, 1.500)), 单次赋值(随机实数(0.500, 1))), 事件玩家.Mwenzi_The1, 旋转并转换), 真);
		禁用 开始强制设置玩家位置(事件玩家, 逐帧更新(眼睛位置(事件玩家.Mwenzi_The1) + 地图矢量(矢量(单次赋值(随机实数(-1, 1)), 单次赋值(随机实数(-0.500, 0.500)), 单次赋值(随机实数(0.500, 1))), 事件玩家,
			旋转)), 真);
		绑定玩家(事件玩家, 事件玩家.Mwenzi_The1, 矢量(单次赋值(随机实数(-1, 1)), 单次赋值(随机实数(-0.500, 1)), 单次赋值(随机实数(1, 2))));
		如条件为“真”则循环;
	}
}

