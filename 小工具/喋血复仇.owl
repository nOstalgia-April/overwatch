规则("等级//捡经验球")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		对任意为“真”(映射的数组(全局.EXPBalls, 首个(当前数组元素)), 相距距离(当前数组元素, 事件玩家) <= 2) == 真;
		空数组 != 全局.EXPBalls;
		存活(事件玩家) == 真;
		已重生(事件玩家) == 真;
		按钮被按下(事件玩家, 按钮(蹲下)) == 真;
		事件玩家.PickedBall == 0;
	}

	动作
	{
		事件玩家.PickedBall = 首个(已排序的数组(全局.EXPBalls, 相距距离(当前数组元素, 事件玩家)));
		播放效果(事件玩家, “秩序之光”传送面板重现声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(事件玩家, “黑影”位移传动材料效果, 颜色(队伍1), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(事件玩家, 正面状态施加声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		事件玩家.level += 1;
		小字体信息(事件玩家, 自定义字符串("已升级！！"));
		等待(0.250, 无视条件);
		禁用 如条件为“真”则循环;
	}
}

