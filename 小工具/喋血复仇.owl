规则("玩家变量初始化 生命池 全局变量初始化（属性名）")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 真;
	}

	动作
	{
		等待(1, 无视条件);
		禁用 根据条件跳过(所在队伍(事件玩家) == 队伍1, 7);
		"攻击"
		事件玩家.Attack = 1;
		"法强"
		事件玩家.SpellPower = 1;
		"生命"
		事件玩家.Health = 1;
		"护甲"
		事件玩家.Armor = 1;
		"魔抗"
		事件玩家.SpellResis = 1;
		"敏捷"
		事件玩家.Agility = 1;
		"幸运"
		事件玩家.Luck = 1;
		为玩家添加生命池(事件玩家, 生命值, 30 * 事件玩家.Health ^ 1.400, 真, 真);
		全局.Shuxing_Name = 数组(自定义字符串("攻击力"), 自定义字符串("法术强度"), 自定义字符串("生命"), 自定义字符串("护甲"), 自定义字符串("魔抗"), 自定义字符串("敏捷"), 自定义字符串("幸运"));
		调用子程序(Shuxing);
	}
}

规则("攻击力")
{
	事件
	{
		玩家造成伤害;
		双方;
		全部;
	}

	条件
	{
		数组包含(数组(按钮(主要攻击模式), 按钮(辅助攻击模式), 按钮(近身攻击)), 事件技能) == 真;
	}

