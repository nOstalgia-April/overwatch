	{
		全局.RandomCase == 自定义字符串("吸血鬼诅咒");
		相距距离(地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 射线命中位置(地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 地图矢量(矢量(0, 30, 0), 事件玩家, 旋转并转换), 空, 事件玩家, 真)) >= 30;
	}

	动作
	{
		设置状态(事件玩家, 空, 燃烧, 1);
		伤害(事件玩家, 空, 25);
		等待(1, 无视条件);
		如条件为“真”则循环;
	}
}

