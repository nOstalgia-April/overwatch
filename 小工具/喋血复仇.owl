规则("救人//初始化")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.level >= 全局.Fibonacci[数组值的索引(事件玩家.TF_Player, 自定义字符串("复活"))];
		数组包含(事件玩家.TF_Player, 自定义字符串("复活")) == 真;
	}

	动作
	{
		创建效果(死亡(事件玩家) && 事件玩家.level >= 全局.Fibonacci[数组值的索引(事件玩家.TF_Player, 自定义字符串("复活"))] ? 所有玩家(所有队伍) : 空数组, 环, 颜色(橙色), 所选位置(事件玩家), 3,
			可见，位置和半径);
		事件玩家.HealPercent = 0;
		创建进度条地图文本(死亡(事件玩家) && 事件玩家.level >= 全局.Fibonacci[数组值的索引(事件玩家.TF_Player, 自定义字符串("复活"))] ? 范围内玩家(事件玩家, 3, 队伍2, 关闭) : 空数组,
			事件玩家.HealPercent, 自定义字符串("正在救助{0}{1}", 英雄图标字符串(所用英雄(事件玩家)), 事件玩家), 地图矢量(矢量(0, -2, 3), 本地玩家, 旋转并转换) + 眼睛位置(本地玩家) + 面朝方向(事件玩家),
			3, 不要截取, 自定义颜色(178 + -1.280 * 事件玩家.HealPercent, 34 + 1.710 * 事件玩家.HealPercent, 34 + 0.160 * 事件玩家.HealPercent, 255), 颜色(橙色),
			可见，位置，值和颜色, 默认可见度);
	}
}

规则("救人//加进度")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		数量(已过滤的数组(范围内玩家(事件玩家, 3, 队伍2, 关闭), 存活(当前数组元素))) >= 1;
		死亡(事件玩家) == 1;
		事件玩家.level >= 全局.Fibonacci[数组值的索引(事件玩家.TF_Player, 自定义字符串("复活"))];
		数组包含(事件玩家.TF_Player, 自定义字符串("复活")) == 真;
	}

	动作
	{
		等待(0.200, 无视条件);
		追踪玩家变量频率(事件玩家, HealPercent, 100, 20, 速率及最终值);
		播放效果(所有玩家(所有队伍), 布丽吉塔流星飞锤范围治疗声音, 颜色(白色), 事件玩家, 50);
		如条件为“真”则循环;
		停止追踪玩家变量(事件玩家, HealPercent);
	}
}

规则("1救人//完成")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.HealPercent >= 100;
		事件玩家.level >= 全局.Fibonacci[数组值的索引(事件玩家.TF_Player, 自定义字符串("复活"))];
		数组包含(事件玩家.TF_Player, 自定义字符串("复活")) == 真;
	}

	动作
	{
		复活(事件玩家);
		事件玩家.HealPercent = 0;
		播放效果(所有玩家(所有队伍), 治疗目标激活效果, 颜色(队伍2), 事件玩家, 1);
		创建效果(所有玩家(所有队伍), 治疗目标效果, 颜色(队伍2), 事件玩家, 1, 可见，位置和半径);
		事件玩家.HealID = 最后创建的实体;
		设置状态(事件玩家, 空, 无敌, 2);
		等待(2, 无视条件);
		消除效果(事件玩家.HealID);
	}
}

