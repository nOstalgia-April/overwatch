{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		事件玩家.Bot_AIBOOl == 1;
		数量(事件玩家.bot_path) > 0;
		相距距离(眼睛位置(事件玩家), 矢量(X方向分量(事件玩家.bot_nodes_location[事件玩家.bot_path[0]]), Y方向分量(眼睛位置(事件玩家)), Z方向分量(
			事件玩家.bot_nodes_location[事件玩家.bot_path[0]]))) < 1;
		禁用 事件玩家.bot_path_bool == 1;
	}

	动作
	{
		修改玩家变量(事件玩家, bot_path, 根据索引从数组中移除, 0);
		If(数量(事件玩家.bot_path) == 0);
			停止定向阈值(事件玩家);
			事件玩家.bot_stateTime = 0;
		End;
	}
}

规则("机器人-寻找有效目标")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		存活(事件玩家) == 真;
		事件玩家.Bot_AIBOOl == 1;
	}

	动作
	{
		事件玩家.bot_targetArray = 已过滤的数组(所有存活玩家(队伍2), 事件玩家 != 当前数组元素 && 已重生(当前数组元素) && !是否是机器人(当前数组元素) && 在视线内(事件玩家, 当前数组元素, 屏障不会阻挡视线));
		If(数量(事件玩家.bot_targetArray) > 0);
			事件玩家.bot_targetPlayer = 首个(已排序的数组(事件玩家.bot_targetArray, 相距距离(事件玩家, 当前数组元素) * 标准化生命值(当前数组元素)));
		End;
		等待(1, 当为“假”时中止);
		如条件为“真”则循环;
	}
}

规则("机器人-更新距离目标最近的节点")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		存活(事件玩家) == 真;
		事件玩家.Bot_AIBOOl == 1;
		事件玩家.bot_targetPlayer != -1;
		在视线内(事件玩家, 事件玩家.bot_targetPlayer, 屏障不会阻挡视线) == 真;
		禁用 事件玩家.bot_path == 空数组;
	}

	动作
	{
		禁用 事件玩家.bot_nodes_onlytargetSee = 已过滤的数组(事件玩家.bot_nodes_location, 在视线内(当前数组元素, 事件玩家.bot_targetPlayer, 屏障不会阻挡视线) == 真);
		禁用 If(数组值的索引(事件玩家.bot_nodes_location, 首个(已排序的数组(事件玩家.bot_nodes_onlytargetSee, 相距距离(当前数组元素, 事件玩家)))) != 事件玩家.bot_end);
		If(数组值的索引(事件玩家.bot_nodes_location, 已排序的数组(已过滤的数组(事件玩家.bot_nodes_location, 在视线内(事件玩家.bot_targetPlayer, 当前数组元素, 屏障不会阻挡视线)), 相距距离(
			所选位置(事件玩家.bot_targetPlayer), 当前数组元素))) != 事件玩家.bot_end);
			停止定向阈值(事件玩家);
			事件玩家.bot_stateTime = 0;
			禁用 调用子程序(bot_new_path);
			等待(5, 无视条件);
		End;
		等待(1, 当为“假”时中止);
		如条件为“真”则循环;
	}
}

规则("机器人-瞄准目标")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		存活(事件玩家) == 真;
		事件玩家.Bot_AIBOOl == 1;
		事件玩家.bot_targetPlayer != -1;
		在视线内(事件玩家, 事件玩家.bot_targetPlayer, 屏障不会阻挡视线) == 真;
		具有状态(事件玩家, 击倒) == 假;
		具有状态(事件玩家, 沉睡) == 假;
		具有状态(事件玩家, 冰冻) == 假;
		具有状态(事件玩家, 击晕) == 假;
	}

	动作
	{
		调用子程序(bot_facing_update);
	}
}

规则("机器人-丢失目标")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		存活(事件玩家) == 真;
		事件玩家.Bot_AIBOOl == 1;
		事件玩家.bot_targetPlayer != -1;
		在视线内(事件玩家, 事件玩家.bot_targetPlayer, 屏障不会阻挡视线) == 假;
	}

	动作
	{
		禁用 小字体信息(所有玩家(所有队伍), 自定义字符串("{0}{1}丢失玩家：{2}", 栏位(事件玩家), 所用英雄(事件玩家), 事件玩家.bot_targetPlayer));
		停止朝向(事件玩家);
		等待直到 (数量(事件玩家.bot_path) == 0, 10);
		禁用 小字体信息(所有玩家(所有队伍), 自定义字符串("{0}{1}不再将{2}视为目标", 栏位(事件玩家), 所用英雄(事件玩家), 事件玩家.bot_targetPlayer));
		事件玩家.bot_targetPlayer = -1;
		事件玩家.bot_stateTime = 0;
		禁用 调用子程序(bot_new_path);
	}
}

规则("子程序 update distance 玩家")
{
	事件
	{
		子程序;
		update_distance;
	}

	动作
	{
		For 玩家变量(事件玩家, bot_loop_1, 0, 数量(事件玩家.bot_checking_nodes), 1);
			事件玩家.bot_node_index = 事件玩家.bot_checking_nodes[事件玩家.bot_loop_1];
			If(数组包含(事件玩家.bot_passed_node, 事件玩家.bot_node_index));
				继续;
			End;
			事件玩家.bot_score = 事件玩家.bot_nodes_basic_distance[事件玩家.bot_current_node][数组值的索引(事件玩家.bot_nodes_link[事件玩家.bot_current_node],
				事件玩家.bot_node_index)];
			事件玩家.bot_score += 相距距离(事件玩家.bot_nodes_location[事件玩家.bot_end], 事件玩家.bot_nodes_location[事件玩家.bot_node_index]);
			事件玩家.bot_score += 事件玩家.bot_distance[事件玩家.bot_current_node];
			事件玩家.bot_score += 事件玩家.bot_nodes_weight[事件玩家.bot_node_index];
			If(事件玩家.bot_score < 事件玩家.bot_distance[事件玩家.bot_node_index]);
				事件玩家.bot_distance[事件玩家.bot_node_index] = 事件玩家.bot_score;
				事件玩家.bot_prev_node[事件玩家.bot_node_index] = 事件玩家.bot_current_node;
			End;
		End;
	}
}

规则("子程序 bot_facing_update 机器人朝向")
{
	事件
	{
		子程序;
		bot_facing_update;
	}

	动作
	{
		If(事件玩家.bot_targetPlayer == -1);
			开始朝向(事件玩家, 方向(眼睛位置(事件玩家), 矢量(X方向分量(事件玩家.bot_nodes_location[事件玩家.bot_path[0]]), Y方向分量(眼睛位置(事件玩家)), Z方向分量(
				事件玩家.bot_nodes_location[事件玩家.bot_path[0]]))), 300, 至地图, 方向及角速率);
		Else;
			开始朝向(事件玩家, 方向(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_targetPlayer) + 下 * 相距距离(事件玩家, 事件玩家.bot_targetPlayer) * 0.010 + 速率(事件玩家.bot_targetPlayer)
				* (相距距离(事件玩家, 事件玩家.bot_targetPlayer) * 事件玩家.bot_ballistic_velocity + 0.200) + 与此角度的相对方向(水平朝向角度(事件玩家) + 随机实数(相距距离(事件玩家,
				事件玩家.bot_targetPlayer) * 绝对值(事件玩家.bot_aming_accuracy) * -1, 相距距离(事件玩家, 事件玩家.bot_targetPlayer) * 绝对值(事件玩家.bot_aming_accuracy)),
				垂直朝向角度(事件玩家) + 随机实数(相距距离(事件玩家, 事件玩家.bot_targetPlayer) * 绝对值(事件玩家.bot_aming_accuracy) * 0.250 * -1, 相距距离(事件玩家,
				事件玩家.bot_targetPlayer) * 绝对值(事件玩家.bot_aming_accuracy) * 0.250)) * 1), 1000, 至地图, 方向及角速率);
		End;
	}
}

规则("子程序 bot_new_path 机器人移动起点终点")
{
	事件
	{
		子程序;
		bot_new_path;
	}

	动作
	{
		调用子程序(bot_area_allot);
		事件玩家.bot_start = 数组值的索引(事件玩家.bot_nodes_location, 已排序的数组(事件玩家.bot_nodes_location, 相距距离(所选位置(事件玩家), 当前数组元素)));
		If(事件玩家.bot_targetPlayer == -1);
			事件玩家.bot_end = 数组值的索引(事件玩家.bot_nodes_location, 数组随机取值(已过滤的数组(事件玩家.bot_nodes_location, 当前数组索引 != 事件玩家.bot_start)));
		Else;
			禁用 事件玩家.bot_nodes_onlytargetSee = 已过滤的数组(事件玩家.bot_nodes_location, 在视线内(当前数组元素, 事件玩家.bot_targetPlayer, 屏障不会阻挡视线) == 1);
			事件玩家.bot_end = 数组值的索引(事件玩家.bot_nodes_location, 已排序的数组(已过滤的数组(事件玩家.bot_nodes_location, 在视线内(事件玩家.bot_targetPlayer, 当前数组元素,
				屏障不会阻挡视线)), 相距距离(所选位置(事件玩家.bot_targetPlayer), 当前数组元素)));
		End;
		调用子程序(find_path);
	}
}

规则("子程序 bot_area_allot 分区赋值")
{
	事件
	{
		子程序;
		bot_area_allot;
	}

	动作
	{
		If(事件玩家.bot_area == 1);
			事件玩家.bot_area_index = 0;
			事件玩家.bot_area_count = 68;
		Else If(事件玩家.bot_area == 2);
			事件玩家.bot_area_index = 68;
			事件玩家.bot_area_count = 49;
		Else If(事件玩家.bot_area == 3);
			事件玩家.bot_area_index = 117;
			事件玩家.bot_area_count = 51;
		End;
		事件玩家.bot_nodes_location = 数组分割(全局.nodes_location, 事件玩家.bot_area_index, 事件玩家.bot_area_count);
		事件玩家.bot_nodes_link = 数组分割(全局.nodes_link, 事件玩家.bot_area_index, 事件玩家.bot_area_count);
		事件玩家.bot_nodes_index_preset = 数组分割(全局.nodes_index_preset, 事件玩家.bot_area_index, 事件玩家.bot_area_count);
		事件玩家.bot_distance = 数组分割(全局.distance_preset, 事件玩家.bot_area_index, 事件玩家.bot_area_count);
		事件玩家.bot_prev_node = 数组分割(全局.prev_node_preset, 事件玩家.bot_area_index, 事件玩家.bot_area_count);
		事件玩家.bot_nodes_basic_distance = 数组分割(全局.nodes_basic_distance, 事件玩家.bot_area_index, 事件玩家.bot_area_count);
		事件玩家.bot_nodes_index = 数组分割(全局.nodes_index_preset, 0, 事件玩家.bot_area_count);
	}
}

