		修改全局变量(EXPBalls, 添加至数组, 数组随机取值(已过滤的数组(事件玩家.bot_nodes_location, !在视线内(当前数组元素, 事件玩家, 屏障不会阻挡视线) && 相距距离(当前数组元素, 事件玩家) > 8)));
		创建效果(已过滤的数组(所有玩家(所有队伍), 数组包含(全局.EXPBalls, 单次赋值(最后(全局.EXPBalls))) == 1), 球, 颜色(绿色), 最后(全局.EXPBalls), 1, 可见);
		修改全局变量(EXPBalls_ID, 添加至数组, 最后创建的实体);
		修改全局变量(EXPBalls, 添加至数组, 数组随机取值(已过滤的数组(事件玩家.bot_nodes_location, !在视线内(当前数组元素, 事件玩家, 屏障不会阻挡视线) && 相距距离(当前数组元素, 事件玩家) > 8)));
		创建效果(已过滤的数组(所有玩家(所有队伍), 数组包含(全局.EXPBalls, 单次赋值(最后(全局.EXPBalls))) == 1), 球, 颜色(绿色), 最后(全局.EXPBalls), 1, 可见);
