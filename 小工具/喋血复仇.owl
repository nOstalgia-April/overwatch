}

规则("优化 怪物出生自己传送一次")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 真;
		事件玩家.M_DontTP != 真;
	}

	动作
	{
		事件玩家.bot_area = 全局.Room_Area;
		调用子程序(bot_area_allot);
		禁用 传送(事件玩家, 数组随机取值(已过滤的数组(事件玩家.bot_nodes_location, !在视线内(当前数组元素, 事件玩家.bot_targetPlayer, 屏障不会阻挡视线))));
		等待(0.250, 无视条件);
		传送(事件玩家, 数组随机取值(事件玩家.bot_nodes_location));
		开始为机器人强制设置名称(事件玩家, 总计消耗时间);
		事件玩家.OK = 总计消耗时间;
	}
}

