	条件
	{
		对全部为“真”(事件玩家.TF_Chizi, 数组包含(事件玩家.TF_Player, 当前数组元素)) != 真;
	}

	动作
	{
		If(数组包含(数组(1, 3), 随机整数(0, 10)));
			修改玩家变量(事件玩家, TF_Player, 添加至数组, 数组随机取值(已过滤的数组(事件玩家.TF_Chizi, 数组包含(事件玩家.TF_Player, 当前数组元素) != 真)));
			播放效果(所有玩家(所有队伍), 有益爆炸, 颜色(橙色), 事件玩家, 1);
			播放效果(事件玩家, 布丽吉塔恢复包护甲声音, 颜色(橙色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 125);
			播放效果(事件玩家, “黑影”位移传动材料效果, 颜色(队伍1), 事件玩家, 125);
			大字体信息(事件玩家, 自定义字符串("幸运！得到新天赋 [{0}]", 最后(事件玩家.TF_Player)));
			事件玩家.DescVar_See = 1;
			等待(5, 无视条件);
			事件玩家.DescVar_See = 0;
		End;
		等待(30, 无视条件);
	}
}

