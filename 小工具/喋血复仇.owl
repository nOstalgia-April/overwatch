规则("商店-自动刷新一次")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	动作
	{
		事件玩家.Shop_3Now = 数组分割(随机数组(已过滤的数组(事件玩家.TF_Chizi, !数组包含(事件玩家.TF_Player, 当前数组元素))), 0, 3);
	}
}

规则("Click4-22-24")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 4;
		事件玩家.MenuLoop >= 22;
		已重生(事件玩家) == 真;
		事件玩家.MenuLoop <= 24;
		禁用 事件玩家.TF_Point > 0;
	}

	动作
	{
		If(事件玩家.TF_Point >= 3);
			播放效果(事件玩家, 状态爆炸声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			If(事件玩家.MenuLoop == 22);
				If(事件玩家.Shop_3Now[0] != 0);
					事件玩家.TF_Point += -3;
					修改玩家变量(事件玩家, TF_Player, 添加至数组, 首个(事件玩家.Shop_3Now));
					修改玩家变量(事件玩家, Shop_3Now, 根据索引从数组中移除, 0);
				End;
			Else If(事件玩家.MenuLoop == 23);
				If(事件玩家.Shop_3Now[1] != 0);
					修改玩家变量(事件玩家, TF_Player, 添加至数组, 事件玩家.Shop_3Now[1]);
					事件玩家.TF_Point += -3;
					修改玩家变量(事件玩家, Shop_3Now, 根据索引从数组中移除, 1);
				End;
			Else If(事件玩家.MenuLoop == 24);
				If(事件玩家.Shop_3Now[2] != 0);
					修改玩家变量(事件玩家, TF_Player, 添加至数组, 最后(事件玩家.Shop_3Now));
					修改玩家变量(事件玩家, Shop_3Now, 根据索引从数组中移除, 2);
					事件玩家.TF_Point += -3;
				End;
			End;
			等待(0.250, 无视条件);
		Else;
			播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			小字体信息(事件玩家, 自定义字符串("你没有足够的点数支付！！"));
		End;
	}
}

规则("Click4-25")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 4;
		事件玩家.MenuLoop == 25;
		已重生(事件玩家) == 真;
		禁用 事件玩家.TF_Point > 0;
	}

	动作
	{
		If(事件玩家.TF_Point >= 1);
			事件玩家.TF_Point += -1;
			播放效果(事件玩家, 状态爆炸声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			事件玩家.Shop_3Now = 数组分割(随机数组(已过滤的数组(事件玩家.TF_Chizi, !数组包含(事件玩家.TF_Player, 当前数组元素))), 0, 3);
		Else;
			播放效果(事件玩家, 负面状态施加声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
			小字体信息(事件玩家, 自定义字符串("你没有足够的点数支付！！"));
	}
}

