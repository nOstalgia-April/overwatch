	事件
	{
		持续 - 全局;
	}

	动作
	{
		创建地图文本(已过滤的数组(所有玩家(队伍2), 当前数组元素.LoadingVisable1 > 0), 自定义字符串("正在加载任务{0}", 截取字符串(自定义字符串("......"), 0, 总计消耗时间 % 6)), 矢量(14, 1.400,
			20), 4, 不要截取, 可见，位置，字符串和颜色, 自定义颜色(139 + 101 * 本地玩家.LoadingVisable1, 134 + 121 * 本地玩家.LoadingVisable1,
			130 + 125 * 本地玩家.LoadingVisable1, 255), 默认可见度);
		创建地图文本(已过滤的数组(所有玩家(队伍2), 当前数组元素.LoadingVisable2 > 0), 自定义字符串("——————求生开始——————\n\n                        {0}", 全局.Room1), 逐帧更新(
			眼睛位置(本地玩家) + 面朝方向(本地玩家) * 10), 4, 不要截取, 可见，位置，字符串和颜色, 自定义颜色(178, 34, 34, 255 * (1 - 本地玩家.LoadingVisable2)), 默认可见度);
		创建地图文本(已过滤的数组(所有玩家(队伍2), 当前数组元素.DefeatVisable3 > 0), 自定义字符串("任务失败{0}", 图标字符串(剧毒)), 矢量(14, 1.400, 20), 4, 不要截取, 可见，位置，字符串和颜色, 颜色(
			红色), 默认可见度);
	}
}

