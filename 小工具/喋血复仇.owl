规则("TF天赋池子初始化")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	动作
	{
		事件玩家.TF_Chizi = 空数组;
		事件玩家.TF_Chizi = 映射的数组(数组分割(全局.TF_DEScr, 0, 38), 首个(当前数组元素));
		禁用 修改玩家变量(事件玩家, TF_Chizi, 添加至数组, 数组分割(映射的数组(全局.TF_DEScr, 首个(当前数组元素)), 9, 1111));
	}
}

规则("优化-显示等级")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		创建HUD文本(已过滤的数组(所有玩家(所有队伍), 全局.AllStart_ == 1), 空, 自定义字符串("等级：{0}", 本地玩家.level), 空, 顶部, 111, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 默认可见度);
		创建HUD文本(已过滤的数组(所有玩家(所有队伍), 全局.AllStart_ == 1), 空, 自定义字符串("下个解锁天赋等级：{0}", 首个(已过滤的数组(全局.Fibonacci, 本地玩家.level < 当前数组元素))), 空, 左边,
			-1000, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 默认可见度);
	}
}

规则("优化-队伍一承伤率")
{
	事件
	{
		持续 - 全局;
	}
}

规则("TF初始化天赋 描述")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.TF_DEScr[0] = 数组(自定义字符串("永不停歇"), 自定义字符串("永不停歇{0}：\r\n前进时，敏捷+5", 技能图标字符串(英雄(士兵：76), 按钮(技能1))));
		全局.TF_DEScr[1] = 数组(自定义字符串("一板一眼"), 自定义字符串("一板一眼{0}：\r\n在爆头后\r\n回复(力量*5)的生命", 图标字符串(X)));
		全局.TF_DEScr[2] = 数组(自定义字符串("青春活力"), 自定义字符串("青春活力{0}：\r\n获得（5+生命x1/s）的持续回血", 图标字符串(加号)));
		禁用 全局.TF_DEScr[3] = 数组(自定义字符串("剔骨削皮"), 自定义字符串("剔骨削皮{0}：\r\n你的攻击有可能触及敌人的伤口\r\n造成额外（敏捷x1+力量x1）的伤害", 技能图标字符串(英雄(渣客女王), 按钮(辅助攻击模式))));
		禁用 全局.TF_DEScr[4] = 数组(自定义字符串("热烈鼓舞"), 自定义字符串("热烈鼓舞{0}：\r\n在击杀敌人后，敏捷+2，持续2s", 图标字符串(旗帜)));
