规则("````随机事件//在关卡的时候抽取随机事件")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.AllStart_ == 1;
	}

	动作
	{
		If(随机整数(0, 7) == 3);
			全局.RandomCase = 数组随机取值(数组(自定义字符串("吸血鬼诅咒"), 自定义字符串("恐惧"), 自定义字符串("易碎"), 自定义字符串("奖励关"), 自定义字符串("火力全开")));
			等待(2, 无视条件);
			大字体信息(所有玩家(所有队伍), 全局.RandomCase);
	}
}

