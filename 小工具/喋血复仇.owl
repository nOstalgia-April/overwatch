规则("初始化-给玩家添加天赋")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	动作
	{
		事件玩家.TF_Player = 空数组;
		禁用 修改玩家变量(事件玩家, TF_Player, 添加至数组, 自定义字符串("永不停歇"));
		禁用 修改玩家变量(事件玩家, TF_Player, 添加至数组, 自定义字符串("一板一眼"));
		禁用 修改玩家变量(事件玩家, TF_Player, 添加至数组, 自定义字符串("青春活力"));
		禁用 修改玩家变量(事件玩家, TF_Player, 添加至数组, 自定义字符串("剔骨削皮"));
		禁用 修改玩家变量(事件玩家, TF_Player, 添加至数组, 自定义字符串("热烈鼓舞"));
		修改玩家变量(事件玩家, TF_Player, 添加至数组, 数组随机取值(数组(自定义字符串("技能1"), 自定义字符串("终极技能"), 自定义字符串("技能2"))));
		禁用 修改玩家变量(事件玩家, TF_Player, 添加至数组, 自定义字符串("技能2"));
		禁用 修改玩家变量(事件玩家, TF_Player, 添加至数组, 自定义字符串("终极技能"));
	}
}

规则("Click1-3 下")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 1;
		事件玩家.MenuLoop == 3;
	}

	动作
	{
		播放效果(事件玩家, “士兵：76”疾跑开始声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
		"下翻"
		禁用 Else If(事件玩家.MenuLoop == 3);
		If(事件玩家.TF_the1 > 0);
			"如果后置到底部，跳转到最顶端"
			If(最后(事件玩家.TF_Player) == 事件玩家.TF_the1);
				事件玩家.TF_Player = 添加至数组(最后(事件玩家.TF_Player), 数组分割(事件玩家.TF_Player, 0, 数组值的索引(事件玩家.TF_Player, 事件玩家.TF_the1)));
				事件玩家.TFshow4 = 0;
			Else;
				"如果在3个中垫底"
				If(事件玩家.TF_Player[事件玩家.TFshow4 + 2] == 事件玩家.TF_the1);
					事件玩家.TFshow4 = 较小(事件玩家.TFshow4 + 1, 数量(事件玩家.TF_Player) - 3);
				End;
				事件玩家.TF_Player = 添加至数组(添加至数组(添加至数组(数组分割(事件玩家.TF_Player, 0, 数组值的索引(事件玩家.TF_Player, 事件玩家.TF_the1)), 事件玩家.TF_Player[数组值的索引(
					事件玩家.TF_Player, 事件玩家.TF_the1) + 1]), 事件玩家.TF_the1), 数组分割(事件玩家.TF_Player, 数组值的索引(事件玩家.TF_Player, 事件玩家.TF_the1) + 2, 9999));
			End;
		Else;
			事件玩家.TFshow4 = 较小(事件玩家.TFshow4 + 1, 数量(事件玩家.TF_Player) - 3);
		End;
	}
}

规则("Click1-2 上")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 1;
		事件玩家.MenuLoop == 2;
	}

	动作
	{
		播放效果(事件玩家, “士兵：76”疾跑开始声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
		"下翻"
		禁用 Else If(事件玩家.MenuLoop == 3);
		If(事件玩家.TF_the1 > 0);
			"如果上置到顶部，跳转到最底端"
			If(首个(事件玩家.TF_Player) == 事件玩家.TF_the1);
				事件玩家.TFshow4 = 数量(事件玩家.TF_Player) - 3;
				事件玩家.TF_Player = 添加至数组(数组分割(事件玩家.TF_Player, 1, 99999), 首个(事件玩家.TF_Player));
				禁用 事件玩家.TFshow4 = 数量(事件玩家.TF_Player) - 1;
			Else;
				"如果在3个中置顶"
				If(事件玩家.TF_Player[事件玩家.TFshow4 + 0] == 事件玩家.TF_the1);
					事件玩家.TFshow4 = 较大(0, 事件玩家.TFshow4 - 1);
				End;
				事件玩家.TF_Player = 添加至数组(添加至数组(添加至数组(数组分割(事件玩家.TF_Player, 0, 数组值的索引(事件玩家.TF_Player, 事件玩家.TF_the1) - 1), 事件玩家.TF_the1),
					事件玩家.TF_Player[数组值的索引(事件玩家.TF_Player, 事件玩家.TF_the1) - 1]), 数组分割(事件玩家.TF_Player, 数组值的索引(事件玩家.TF_Player, 事件玩家.TF_the1) + 1,
					9999));
			End;
		Else;
			事件玩家.TFshow4 = 较大(0, 事件玩家.TFshow4 - 1);
		End;
	}
}

规则("Click1-456 选中/取消")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
		事件玩家.MenuActive == 1;
		数组包含(数组(4, 5, 6), 事件玩家.MenuLoop) == 真;
	}

	动作
	{
		播放效果(事件玩家, “士兵：76”疾跑开始声音, 颜色(白色), 首个(事件玩家.MenuCameraNow), 175);
		"下翻"
		If(事件玩家.MenuLoop == 4);
			If(事件玩家.TF_the1 == 事件玩家.TF_Player[事件玩家.TFshow4]);
				事件玩家.TF_the1 = -1;
			Else;
				事件玩家.TF_the1 = 事件玩家.TF_Player[事件玩家.TFshow4 + 0];
			End;
		"下翻"
		Else If(事件玩家.MenuLoop == 5);
			If(事件玩家.TF_the1 == 事件玩家.TF_Player[1 + 事件玩家.TFshow4]);
				事件玩家.TF_the1 = -1;
			Else;
				事件玩家.TF_the1 = 事件玩家.TF_Player[事件玩家.TFshow4 + 1];
			End;
		"下翻"
		Else If(事件玩家.MenuLoop == 6);
			If(事件玩家.TF_the1 == 事件玩家.TF_Player[2 + 事件玩家.TFshow4]);
				事件玩家.TF_the1 = -1;
			Else;
				事件玩家.TF_the1 = 事件玩家.TF_Player[事件玩家.TFshow4 + 2];
			End;
		End;
	}
}

