	{
		持续 - 全局;
	}
}

规则("选人菜单 钥匙插进去了吗")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.MenuActive >= 1;
		事件玩家.MenuActive <= 4;
	}

	动作
	{
		For 玩家变量(事件玩家, MenuLoop, 0, 5, 1);
			If(绝对值(水平朝向角度(事件玩家) / 事件玩家.MenuCursorSensibility - 首个(全局.MenuBottonCoordinate[事件玩家.MenuLoop]))
				< 全局.MenuBottonWidth[事件玩家.MenuActive] && 绝对值(垂直朝向角度(事件玩家) / 事件玩家.MenuCursorSensibility - 最后(
				全局.MenuBottonCoordinate[事件玩家.MenuLoop])) < 全局.MenuBottonHeight[事件玩家.MenuActive]);
				中断;
			End;
		End;
		等待(0.025, 无视条件);
		如条件为“真”则循环;
	}
}

规则("选人菜单 重生便打开")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 1;
		是否是机器人(事件玩家) == 假;
	}

	动作
	{
		等待(0.100, 无视条件);
		预加载英雄(事件玩家, 英雄(黑百合));
		开始强制玩家选择英雄(事件玩家, 英雄(黑百合));
		传送(事件玩家, 矢量(8, 32, -40));
		事件玩家.MenuActive = 1;
		设置朝向(事件玩家, 矢量(0, 0, 1), 至地图);
		等待(0.500, 无视条件);
		事件玩家.MenuCameraNow = 数组(地图矢量(矢量(0.100, -0.500, 1), 事件玩家, 旋转) + 眼睛位置(事件玩家), 地图矢量(矢量(-0.100, 0, 0), 事件玩家, 旋转) + 眼睛位置(事件玩家));
		事件玩家.MenuBottonCoordinate = 全局.MenuBottonCoordinate;
		事件玩家.MenuBottonHeight = 全局.MenuBottonHeight[1];
		事件玩家.MenuBottonWidth = 全局.MenuBottonWidth[1];
		调用子程序(MenuOpen);
	}
}

规则("选人菜单 初始化 Active-Coordinate- 1-4")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		"确定按钮 - 0"
		全局.MenuBottonCoordinate[0] = 数组(0.500, 0.400);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive >= 1 && 当前数组元素.MenuActive <= 4), 自定义字符串("确认选择"), 最后(本地玩家.MenuCameraNow) + 首个(首个(
			全局.MenuBottonCoordinate)) * 本地玩家.MenuFlatBase1 + 最后(首个(全局.MenuBottonCoordinate)) * 本地玩家.MenuFlatBase2, 4, 不要截取, 可见，位置，字符串和颜色,
			本地玩家.MenuLoop == 0 ? 颜色(橙色) : 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"切换按钮 - 1"
		全局.MenuBottonCoordinate[1] = 数组(0.500, 0.600);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive >= 1 && 当前数组元素.MenuActive <= 4), 自定义字符串("切换"), 最后(本地玩家.MenuCameraNow) + 首个(
			全局.MenuBottonCoordinate[1]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[1]) * 本地玩家.MenuFlatBase2, 4, 不要截取, 可见，位置，字符串和颜色,
			本地玩家.MenuLoop == 1 ? 颜色(橙色) : 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		全局.MenuBottonWidth[1] = 0.300;
		全局.MenuBottonHeight[1] = 0.100;
		全局.MenuBottonWidth[2] = 0.300;
		全局.MenuBottonHeight[2] = 0.100;
		全局.MenuBottonWidth[3] = 0.300;
		全局.MenuBottonHeight[3] = 0.100;
		全局.MenuBottonWidth[4] = 0.300;
		全局.MenuBottonHeight[4] = 0.100;
	}
}

规则("选人菜单 点击")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 1;
		事件玩家.MenuActive > 0;
		事件玩家.MenuActive <= 4;
	}

	动作
	{
		If(事件玩家.MenuLoop == 0);
			传送(事件玩家, 全局.Spawn1);
			事件玩家.MenuCameraNow = 数组(地图矢量(矢量(-0.100, 1, -1), 事件玩家, 旋转) + 眼睛位置(事件玩家), 眼睛位置(事件玩家));
			等待(0.200, 无视条件);
			调用子程序(MenuClose);
			停止按下按钮(事件玩家, 按钮(终极技能));
		Else If(事件玩家.MenuLoop == 1);
			事件玩家.MenuActive = 事件玩家.MenuActive == 4 ? 1 : 事件玩家.MenuActive + 1;
			传送(事件玩家, 最后(全局.MenuCameras[事件玩家.MenuActive]));
			预加载英雄(事件玩家, 数组(空, 英雄(探奇), 英雄(伊拉锐), 英雄(索杰恩), 英雄(奥丽莎))[事件玩家.MenuActive]);
			开始强制玩家选择英雄(事件玩家, 数组(空, 英雄(探奇), 英雄(伊拉锐), 英雄(索杰恩), 英雄(奥丽莎))[事件玩家.MenuActive]);
			事件玩家.MenuCameraNow = 数组(首个(事件玩家.MenuCameraNow), 地图矢量(矢量(-0.100, 0, 0), 事件玩家, 旋转) + 眼睛位置(事件玩家));
			等待(0.100, 无视条件);
			事件玩家.MenuCameraNow = 数组(地图矢量(矢量(0.100, -0.500, 1), 事件玩家, 旋转) + 眼睛位置(事件玩家), 地图矢量(矢量(-0.100, 0, 0), 事件玩家, 旋转) + 眼睛位置(事件玩家));
			"黑百合"
			If(事件玩家.MenuActive == 1);
				可用按钮(事件玩家, 按钮(终极技能));
				设置终极技能充能(事件玩家, 100);
				等待(1.200, 无视条件);
				开始按下按钮(事件玩家, 按钮(终极技能));
				禁用按钮(事件玩家, 按钮(终极技能));
			"索杰恩"
			Else If(事件玩家.MenuActive == 3);
				可用按钮(事件玩家, 按钮(终极技能));
				设置终极技能充能(事件玩家, 100);
				等待(1.200, 无视条件);
				开始按下按钮(事件玩家, 按钮(终极技能));
				禁用按钮(事件玩家, 按钮(终极技能));
			"奥丽莎"
			Else If(事件玩家.MenuActive == 4);
				可用按钮(事件玩家, 按钮(技能1));
				设置技能冷却(事件玩家, 按钮(技能1), 0);
				等待(1.200, 无视条件);
				开始按下按钮(事件玩家, 按钮(技能1));
				禁用按钮(事件玩家, 按钮(技能1));
	}
}

