规则("debug 玩家重生初始化装备")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 假;
		地图工坊设置开关(自定义字符串("Debug"), 自定义字符串("获取所有装备"), 真, 0) == 真;
	}

	动作
	{
		事件玩家.EquipBox = 映射的数组(全局.Equip, 当前数组元素[7]);
		事件玩家.EquipBag = 数组(0, 1, 2, 3, 4);
	}
}

规则("-Debug————解锁全部任务")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		地图工坊设置开关(自定义字符串("解锁所有任务"), 自定义字符串("开启"), 真, 0) == 真;
	}

	动作
	{
		事件玩家.DesksHave_ID = 映射的数组(全局.Task_Name, 数组值的索引(全局.Task_Name, 当前数组元素));
	}
}

规则("优化- 伤害数字跳动-文本创建")
{
	事件
	{
		玩家受到伤害;
		队伍1;
		全部;
	}

	动作
	{
		事件玩家.DamageImage_RollPosition_1cixing = 矢量(随机实数(-1.200, 1.200), 随机实数(-1, 1), 随机实数(-0.800, 0.800));
		创建地图文本(攻击方, 自定义字符串("{0}{1}", 事件伤害, 事件暴击 ? 自定义字符串("！") : 自定义字符串("")), 眼睛位置(事件玩家) + 事件玩家.DamageImage_RollPosition_1cixing, 较大(较小(
			3.400, (事件伤害 * 0.100) ^ 0.200), 1), 不要截取, 可见, 事件暴击 ? 自定义颜色(176, 23, 31, 255) : 自定义颜色(255, 250, 250, 255), 默认可见度);
		修改玩家变量(事件玩家, DamageImage_Group, 添加至数组, 上一个文本ID);
		播放效果(攻击方, 有害爆炸, 事件暴击 ? 颜色(红色) : 颜色(白色), 眼睛位置(被攻击方) + 事件玩家.DamageImage_RollPosition_1cixing, 0.100);
		等待(0.250, 无视条件);
	}
}

规则("优化-伤害数字跳动-删除文本")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		数量(事件玩家.DamageImage_Group) >= 真;
	}

	动作
	{
		等待(数量(事件玩家.DamageImage_Group) > 随机整数(4, 5) ? 0.016 : 2, 无视条件);
		消除地图文本(首个(事件玩家.DamageImage_Group));
		修改玩家变量(事件玩家, DamageImage_Group, 根据索引从数组中移除, 0);
		如条件为“真”则循环;
	}
}

