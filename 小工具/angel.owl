规则("sub Tracer")
{
	事件
	{
		子程序;
		Tracer;
	}

	动作
	{
		While(数量(事件玩家.bot_target_array) > 0);
			按下按键(事件玩家, 按钮(技能1));
			开始按下按钮(事件玩家, 按钮(主要攻击模式));
			等待(0.500, 无视条件);
			If(标准化生命值(事件玩家) < 0.500);
				按下按键(事件玩家, 按钮(技能2));
			End;
			If(终极技能充能百分比(事件玩家) == 100 && 相距距离(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_target_player)) <= 10);
				按下按键(事件玩家, 按钮(终极技能));
			End;
		End;
		停止按下按钮(事件玩家, 按钮(主要攻击模式));
		按下按键(事件玩家, 按钮(装填));
		按下按键(事件玩家, 按钮(技能1));
	}
}

