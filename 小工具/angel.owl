规则("参与任务菜单 初始化 Active 6 Coordinate 14-18")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.MenuBottonWidth[6] = 0.300;
		全局.MenuBottonHeight[6] = 0.070;
		"关卡1"
		全局.MenuBottonCoordinate[14] = 数组(0.600, -0.400);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 6 && 此栏位的玩家(0, 队伍2).Desk_CarringNow_ID != -1 && 已重生(此栏位的玩家(0, 队伍2))), 自定义字符串(
			"{0} {1}", 全局.Task_Name[此栏位的玩家(0, 队伍2).Desk_CarringNow_ID], 英雄图标字符串(所用英雄(此栏位的玩家(0, 队伍2)))), 最后(本地玩家.MenuCameraNow) + 首个(
			全局.MenuBottonCoordinate[14]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[14]) * 本地玩家.MenuFlatBase2, 4, 不要截取,
			可见，位置，字符串和颜色, 本地玩家.MenuLoop == 14 ? 颜色(灰绿色) : 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"关卡2 如果page+1的位置没有任务了 不显示"
		全局.MenuBottonCoordinate[15] = 数组(0.600, -0.250);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 6 && 此栏位的玩家(1, 队伍2).Desk_CarringNow_ID != -1 && 已重生(此栏位的玩家(1, 队伍2))), 自定义字符串(
			"{0} {1}", 全局.Task_Name[此栏位的玩家(1, 队伍2).Desk_CarringNow_ID], 英雄图标字符串(所用英雄(此栏位的玩家(1, 队伍2)))), 最后(本地玩家.MenuCameraNow) + 首个(
			全局.MenuBottonCoordinate[15]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[15]) * 本地玩家.MenuFlatBase2, 4, 不要截取,
			可见，位置，字符串和颜色, 本地玩家.MenuLoop == 15 ? 颜色(灰绿色) : 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"关卡3 如果page+2的位置没有任务了 不显示"
		全局.MenuBottonCoordinate[16] = 数组(0.600, -0.100);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 6 && 此栏位的玩家(2, 队伍2).Desk_CarringNow_ID != -1 && 已重生(此栏位的玩家(2, 队伍2))), 自定义字符串(
			"{0} {1}", 全局.Task_Name[此栏位的玩家(2, 队伍2).Desk_CarringNow_ID], 英雄图标字符串(所用英雄(此栏位的玩家(2, 队伍2)))), 最后(本地玩家.MenuCameraNow) + 首个(
			全局.MenuBottonCoordinate[16]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[16]) * 本地玩家.MenuFlatBase2, 4, 不要截取,
			可见，位置，字符串和颜色, 本地玩家.MenuLoop == 16 ? 颜色(灰绿色) : 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"关卡3 如果page+2的位置没有任务了 不显示"
		全局.MenuBottonCoordinate[17] = 数组(0.600, 0.050);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 6 && 此栏位的玩家(3, 队伍2).Desk_CarringNow_ID != -1 && 已重生(此栏位的玩家(3, 队伍2))), 自定义字符串(
			"{0} {1}", 全局.Task_Name[此栏位的玩家(3, 队伍2).Desk_CarringNow_ID], 英雄图标字符串(所用英雄(此栏位的玩家(3, 队伍2)))), 最后(本地玩家.MenuCameraNow) + 首个(
			全局.MenuBottonCoordinate[17]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[17]) * 本地玩家.MenuFlatBase2, 4, 不要截取,
			可见，位置，字符串和颜色, 本地玩家.MenuLoop == 17 ? 颜色(灰绿色) : 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"承接按钮 -17"
		全局.MenuBottonCoordinate[18] = 数组(-0.500, 0.400);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive >= 6 && 当前数组元素.MenuActive <= 6), 自定义字符串("加入任务"), 最后(本地玩家.MenuCameraNow) + 首个(
			全局.MenuBottonCoordinate[18]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[18]) * 本地玩家.MenuFlatBase2, 4, 不要截取,
			可见，位置，字符串和颜色, 本地玩家.MenuLoop == 18 ? 颜色(橙色) : 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"关卡1"
		全局.MenuBottonCoordinate[19] = 数组(-0.500, 0.500);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 6 && 真 && 已重生(此栏位的玩家(0, 队伍2))), 自定义字符串("退出菜单"), 最后(本地玩家.MenuCameraNow) + 首个(
			全局.MenuBottonCoordinate[19]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[19]) * 本地玩家.MenuFlatBase2, 4, 不要截取,
			可见，位置，字符串和颜色, 本地玩家.MenuLoop == 19 ? 颜色(橙色) : 颜色(白色), 默认可见度);
	}
}

规则("加入任务 入口创建")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		"0-区域1 1-区域2"
		全局.TaskJoinPos = 数组(矢量(-64.770, 8.140, 12.731), 矢量(-59.102, 7.977, 13.886), 矢量(-52.749, 7.910, 15.002));
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.Desk_CarringNow_ID == -1), 自定义字符串("加入任务\n     {0}", 输入绑定字符串(按钮(互动))), 首个(全局.TaskJoinPos), 2,
			根据表面截取, 可见，位置和字符串, 颜色(橙色), 默认可见度);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.Desk_CarringNow_ID == -1), 自定义字符串("加入任务\n     {0}", 输入绑定字符串(按钮(互动))), 全局.TaskJoinPos[1], 2,
			根据表面截取, 可见，位置和字符串, 颜色(橙色), 默认可见度);
		创建效果(已过滤的数组(所有玩家(所有队伍), 当前数组元素.Desk_CarringNow_ID == -1), 环, 颜色(橙色), 首个(全局.TaskJoinPos), 4, 可见，位置和半径);
		创建效果(已过滤的数组(所有玩家(所有队伍), 当前数组元素.Desk_CarringNow_ID == -1), 环, 颜色(橙色), 全局.TaskJoinPos[1], 4, 可见，位置和半径);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.Desk_CarringNow_ID == -1), 自定义字符串("加入任务\n     {0}", 输入绑定字符串(按钮(互动))), 最后(全局.TaskJoinPos), 2,
			根据表面截取, 可见，位置和字符串, 颜色(橙色), 默认可见度);
		创建效果(已过滤的数组(所有玩家(所有队伍), 当前数组元素.Desk_CarringNow_ID == -1), 环, 颜色(橙色), 最后(全局.TaskJoinPos), 4, 可见，位置和半径);
	}
}

规则("打开参与任务菜单 TaskTemporary2")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(互动)) == 1;
		事件玩家.Desk_CarringNow_ID == -1;
		"没有其他菜单"
		事件玩家.MenuActive == 0;
		是否是机器人(事件玩家) == 假;
		对任意为“真”(全局.TaskJoinPos, 相距距离(事件玩家, 当前数组元素) <= 4) == 1;
	}

	动作
	{
		If(对全部为“真”(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID == -1));
			小字体信息(事件玩家, 自定义字符串("错误：没有正在进行的任务"));
			播放效果(事件玩家, 查莉娅粒子炮爆炸声音, 颜色(白色), 最后(事件玩家.MenuCameraNow), 160);
		Else;
			事件玩家.MenuActive = 6;
			"抽取幸运儿"
			事件玩家.TaskTemporary2 = 数组随机取值(已过滤的数组(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID != -1));
			事件玩家.MenuCameraNow = 数组(首个(全局.MenuCameras[事件玩家.TaskTemporary2.Desk_CarringNow_ID + 5]), 最后(
				全局.MenuCameras[事件玩家.TaskTemporary2.Desk_CarringNow_ID + 5]));
			设置朝向(事件玩家, 矢量(0, 0, 1), 至地图);
			事件玩家.MenuCursorSensibility = 3;
			"好像没用"
			事件玩家.MenuBottonCoordinate = 全局.MenuBottonCoordinate;
			事件玩家.DeskNow_Description = 全局.Task_Description[事件玩家.TaskTemporary2.Desk_CarringNow_ID];
			调用子程序(MenuOpen);
			播放效果(事件玩家, “秩序之光”传送面板重现声音, 颜色(白色), 最后(事件玩家.MenuCameraNow), 200);
	}
}

规则("参与任务菜单 点击")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 1;
		事件玩家.MenuActive == 6;
		事件玩家.MenuLoop != 数量(事件玩家.MenuBottonCoordinate);
		是否是机器人(事件玩家) == 假;
	}

	动作
	{
		"承接按钮"
		If(事件玩家.MenuLoop == 18);
			事件玩家.TaskTemporary3 = 已过滤的数组(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID == 此栏位的玩家(事件玩家.DeskPage, 队伍2).Desk_CarringNow_ID);
			If(数量(事件玩家.TaskTemporary3) < 最后(全局.Task_NumberOfPeople_Min_Max[此栏位的玩家(事件玩家.DeskPage, 队伍2).Desk_CarringNow_ID]));
				事件玩家.Desk_CarringNow_ID = 此栏位的玩家(事件玩家.DeskPage, 队伍2).Desk_CarringNow_ID;
				播放效果(事件玩家, “猎空”闪回消失效果, 颜色(白色), 最后(事件玩家.MenuCameraNow), 200);
				调用子程序(MenuClose);
				调用子程序(LoadingCartoon);
			Else;
				小字体信息(事件玩家, 自定义字符串("任务人数已达上限"));
				播放效果(事件玩家, 查莉娅粒子炮爆炸声音, 颜色(白色), 最后(事件玩家.MenuCameraNow), 160);
				播放效果(事件玩家, 查莉娅粒子炮爆炸声音, 颜色(白色), 最后(事件玩家.MenuCameraNow), 160);
				事件玩家.Desk_CarringNow_ID = -1;
			End;
		Else If(事件玩家.MenuLoop == 19);
			调用子程序(MenuClose);
	}
}

规则("参与任务菜单 切换镜头")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.MenuActive == 6;
	}

	动作
	{
		"关卡1"
		If(事件玩家.MenuLoop == 14 && 已重生(此栏位的玩家(0, 队伍2)) && 此栏位的玩家(0, 队伍2).Desk_CarringNow_ID != -1);
			等待(0.100, 无视条件);
			根据条件跳过(事件玩家.MenuLoop != 14 || 此栏位的玩家(0, 队伍2).Desk_CarringNow_ID != -1, 4);
			"设置deskpage为栏位0"
			事件玩家.DeskPage = 0;
			事件玩家.MenuCameraNow = 数组(首个(全局.MenuCameras[此栏位的玩家(0, 队伍2).Desk_CarringNow_ID + 5]), 首个(全局.MenuCameras[此栏位的玩家(0, 队伍2)
				.Desk_CarringNow_ID + 5]) + 方向(首个(全局.MenuCameras[此栏位的玩家(0, 队伍2).Desk_CarringNow_ID + 5]), 最后(全局.MenuCameras[此栏位的玩家(0, 队伍2)
				.Desk_CarringNow_ID + 5])));
			调用子程序(MenuBase);
			事件玩家.DeskNow_Description = 全局.Task_Description[此栏位的玩家(0, 队伍2).Desk_CarringNow_ID];
		"关卡2"
		Else If(事件玩家.MenuLoop == 15 && 此栏位的玩家(1, 队伍2).Desk_CarringNow_ID != -1 && 已重生(此栏位的玩家(1, 队伍2)));
			等待(0.100, 无视条件);
			事件玩家.DeskPage = 1;
			根据条件跳过(事件玩家.MenuLoop != 15 || 此栏位的玩家(1, 队伍2).Desk_CarringNow_ID == -1, 4);
			事件玩家.MenuCameraNow = 数组(首个(全局.MenuCameras[此栏位的玩家(1, 队伍2).Desk_CarringNow_ID + 5]), 首个(全局.MenuCameras[此栏位的玩家(1, 队伍2)
				.Desk_CarringNow_ID + 5]) + 方向(首个(全局.MenuCameras[此栏位的玩家(1, 队伍2).Desk_CarringNow_ID + 5]), 最后(全局.MenuCameras[此栏位的玩家(1, 队伍2)
				.Desk_CarringNow_ID + 5])));
			调用子程序(MenuBase);
			事件玩家.DeskNow_Description = 全局.Task_Description[此栏位的玩家(事件玩家.DeskPage, 队伍2).Desk_CarringNow_ID];
		"关卡3"
		Else If(事件玩家.MenuLoop == 16 && 事件玩家.Desk_CarringNow_ID != -1 && 已重生(此栏位的玩家(2, 队伍2)));
			等待(0.100, 无视条件);
			根据条件跳过(事件玩家.MenuLoop != 16 || 事件玩家.Desk_CarringNow_ID == -1, 4);
			事件玩家.DeskPage = 2;
			事件玩家.MenuCameraNow = 数组(首个(全局.MenuCameras[此栏位的玩家(2, 队伍2).Desk_CarringNow_ID + 5]), 首个(全局.MenuCameras[此栏位的玩家(2, 队伍2)
				.Desk_CarringNow_ID + 5]) + 方向(首个(全局.MenuCameras[此栏位的玩家(2, 队伍2).Desk_CarringNow_ID + 5]), 最后(全局.MenuCameras[此栏位的玩家(2, 队伍2)
				.Desk_CarringNow_ID + 5])));
			调用子程序(MenuBase);
			事件玩家.DeskNow_Description = 全局.Task_Description[事件玩家.DeskPage.Desk_CarringNow_ID];
		"关卡4"
		Else If(事件玩家.MenuLoop == 17 && 事件玩家.Desk_CarringNow_ID != -1 && 已重生(此栏位的玩家(3, 队伍2)));
			等待(0.100, 无视条件);
			事件玩家.DeskPage = 3;
			根据条件跳过(事件玩家.MenuLoop != 17 || 事件玩家.Desk_CarringNow_ID == -1, 4);
			事件玩家.MenuCameraNow = 数组(首个(全局.MenuCameras[此栏位的玩家(3, 队伍2).Desk_CarringNow_ID + 5]), 首个(全局.MenuCameras[此栏位的玩家(3, 队伍2)
				.Desk_CarringNow_ID + 5]) + 方向(首个(全局.MenuCameras[此栏位的玩家(3, 队伍2).Desk_CarringNow_ID + 5]), 最后(全局.MenuCameras[此栏位的玩家(3, 队伍2)
				.Desk_CarringNow_ID + 5])));
			调用子程序(MenuBase);
			事件玩家.DeskNow_Description = 全局.Task_Description[事件玩家.DeskPage.Desk_CarringNow_ID];
		End;
		等待(0.025, 无视条件);
		如条件为“真”则循环;
	}
}

