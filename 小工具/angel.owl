			可见，位置，字符串和颜色, 本地玩家.MenuLoop == 22 ? 颜色(灰色) : 全局.Equip[数组值的索引(映射的数组(全局.Equip, 当前数组元素[7]), 本地玩家.EquipBox[本地玩家.EquipBag[2]])][10],
			默认可见度);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 7 && 当前数组元素.EquipBox[当前数组元素.EquipBag[3]] != 0), 自定义字符串("{1} {0}",
			本地玩家.EquipBox[本地玩家.EquipBag[3]], 本地玩家.EquipPage == 3 ? 图标字符串(箭头：向右) : 自定义字符串("")), 最后(本地玩家.MenuCameraNow) + 首个(
			全局.MenuBottonCoordinate[23]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[23]) * 本地玩家.MenuFlatBase2, 4, 不要截取,
			可见，位置，字符串和颜色, 本地玩家.MenuLoop == 23 ? 颜色(灰色) : 全局.Equip[数组值的索引(映射的数组(全局.Equip, 当前数组元素[7]), 本地玩家.EquipBox[本地玩家.EquipBag[3]])][10],
			默认可见度);
		"检测此位置装备不为0"
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 7 && 当前数组元素.EquipBox[当前数组元素.EquipBag[当前数组元素.EquipPage]] != 0), 本地玩家.EquipWord, 最后(
			本地玩家.MenuCameraNow) + 0.600 * 本地玩家.MenuFlatBase1 + 0.300 * 本地玩家.MenuFlatBase2, 3, 不要截取, 可见，位置，字符串和颜色, 自定义颜色(202, 235, 216,
			255), 默认可见度);
	}
}

