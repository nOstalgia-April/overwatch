}

规则("任务1——————特产熔岩球 玩家 拾取")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.Desk_CarringNow_ID == 1;
		相距距离(事件玩家, 全局.Task_Funtions[1][2]) <= 2;
		"球的位置已刷新 不为0"
		全局.Task_Funtions[1][2] != 0;
		数量(已过滤的数组(所有玩家(队伍2), 当前数组元素.Task1CarringBool == 1)) == 0;
		事件玩家.Task1CarringBool == 0;
	}

	动作
	{
		事件玩家.Task1CarringBool = 1;
		大字体信息(事件玩家, 自定义字符串("已拾取！\n护送并归还至指定区域{0}", 图标字符串(旗帜)));
		播放效果(已过滤的数组(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID == 1), 正面状态施加声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(已过滤的数组(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID == 1), 卢西奥音障施放效果, 颜色(白色), 事件玩家, 200);
		全局.Task_Funtions_Temporary = 全局.Task_Funtions[1];
		全局.Task_Funtions_Temporary[2] = 矢量(0, 1000, 0);
		全局.Task_Funtions[1] = 全局.Task_Funtions_Temporary;
	}
}

规则("任务1——————特产熔岩球 玩家 归还")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.Desk_CarringNow_ID == 1;
		相距距离(事件玩家, 首个(全局.Task_Funtions[1])) <= 3;
		事件玩家.Task1CarringBool == 1;
		数量(已过滤的数组(所有玩家(队伍2), 当前数组元素.Task1CarringBool == 1)) == 1;
	}

	动作
	{
		事件玩家.Task1CarringBool = 0;
		播放效果(已过滤的数组(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID == 1), 正面状态施加声音, 颜色(白色), 首个(全局.Task_Funtions[1]), 200);
		播放效果(已过滤的数组(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID == 1), “黑影”位移传动材料效果, 颜色(白色), 事件玩家, 200);
		全局.Task_Funtions_Temporary = 全局.Task_Funtions[1];
		全局.Task_Funtions_Temporary[1] += 1;
		全局.Task_Funtions_Temporary[2] = 数组随机取值(全局.Nodes_total[1]);
		全局.Task_Funtions[1] = 全局.Task_Funtions_Temporary;
		等待(1, 无视条件);
		大字体信息(所有玩家(所有队伍), 自定义字符串("已归还\n  剩余{0}/10个", 全局.Task_Funtions[1][1]));
	}
}

