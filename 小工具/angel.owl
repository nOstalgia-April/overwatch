规则("-Debug————菜单loop Active")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		地图工坊设置开关(自定义字符串("Debug"), 自定义字符串("菜单loop Active"), 假, 0) == 真;
	}

	动作
	{
		创建HUD文本(所有玩家(所有队伍), 自定义字符串("loop{1} act{0}", 事件玩家.MenuActive, 逐帧更新(事件玩家.MenuLoop)), 空, 空, 右边, 0, 颜色(绿色), 颜色(白色), 颜色(白色), 可见和字符串,
			默认可见度);
		事件玩家.DesksHave_ID = 映射的数组(全局.Task_Name, 数组值的索引(全局.Task_Name, 当前数组元素));
	}
}

