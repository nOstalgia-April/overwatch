规则("打开装备检视菜单")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		"没有任务"
		事件玩家.Desk_CarringNow_ID == -1;
		禁用 按钮被按下(事件玩家, 按钮(蹲下)) == 1;
		存活(事件玩家) == 1;
		速度(事件玩家) < 0.100;
		正在站立(事件玩家) == 1;
		"没有其他菜单"
		事件玩家.MenuActive == 0;
		正在使用表情交流(事件玩家) == 真;
	}

	动作
	{
		If(对全部为“真”(事件玩家.EquipBag, 当前数组元素 == 0) == 1);
			播放效果(事件玩家, 查莉娅粒子炮爆炸声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
			小字体信息(事件玩家, 自定义字符串("错误：目前没有装备"));
		Else;
			事件玩家.MenuActive = 7;
			事件玩家.EquipPage = 0;
			设置朝向(事件玩家, 矢量(0, 0, 1), 至地图);
			事件玩家.MenuCursorSensibility = 3;
			"好像没用"
			事件玩家.MenuBottonCoordinate = 全局.MenuBottonCoordinate;
			事件玩家.MenuCameraNow = 数组(眼睛位置(事件玩家), 地图矢量(矢量(-0.100, 0, 0), 事件玩家, 旋转) + 眼睛位置(事件玩家));
			调用子程序(MenuOpen);
			播放效果(事件玩家, “秩序之光”传送面板重现声音, 颜色(白色), 最后(事件玩家.MenuCameraNow), 200);
			等待(0.100, 无视条件);
			事件玩家.MenuCameraNow = 数组(地图矢量(矢量(0.100, -0.500, 1), 事件玩家, 旋转) + 眼睛位置(事件玩家), 地图矢量(矢量(-0.300, 0.100, 0), 事件玩家, 旋转) + 眼睛位置(事件玩家));
			调用子程序(MenuOpen);
			事件玩家.EquipChosenID = 事件玩家.EquipBag[事件玩家.EquipPage];
			调用子程序(EquipWord);
	}
}

规则("装备检视菜单 点击")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 1;
		事件玩家.MenuActive == 7;
		事件玩家.MenuLoop != 数量(事件玩家.MenuBottonCoordinate);
	}

	动作
	{
		播放效果(事件玩家, “士兵：76”疾跑开始声音, 颜色(白色), 最后(事件玩家.MenuCameraNow), 100);
		"承接按钮"
		If(事件玩家.MenuLoop == 20);
			事件玩家.EquipPage = 0;
			事件玩家.EquipChosenID = 事件玩家.EquipBag[事件玩家.EquipPage];
			调用子程序(EquipWord);
		Else If(事件玩家.MenuLoop == 21);
			事件玩家.EquipPage = 1;
			事件玩家.EquipChosenID = 事件玩家.EquipBag[事件玩家.EquipPage];
			调用子程序(EquipWord);
		Else If(事件玩家.MenuLoop == 22);
			事件玩家.EquipPage = 2;
			事件玩家.EquipChosenID = 事件玩家.EquipBag[事件玩家.EquipPage];
			调用子程序(EquipWord);
		Else If(事件玩家.MenuLoop == 23);
			事件玩家.EquipPage = 3;
			事件玩家.EquipChosenID = 事件玩家.EquipBag[事件玩家.EquipPage];
			调用子程序(EquipWord);
		Else If(事件玩家.MenuLoop == 24);
			事件玩家.EquipPage = 4;
			事件玩家.EquipChosenID = 事件玩家.EquipBag[事件玩家.EquipPage];
			调用子程序(EquipWord);
		Else If(事件玩家.MenuLoop == 25);
			调用子程序(MenuClose);
			播放效果(事件玩家, “秩序之光”传送面板重现声音, 颜色(白色), 最后(事件玩家.MenuCameraNow), 200);
	}
}

