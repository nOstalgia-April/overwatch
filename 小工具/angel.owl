规则("玩家重生初始化 头顶个名")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) != 真;
	}

	动作
	{
		创建地图文本(所有玩家(所有队伍), 自定义字符串("{0}", 事件玩家), 事件玩家, 2, 根据表面截取, 可见，位置和字符串, 自定义颜色(160, 32, 240, 255), 默认可见度);
	}
}

规则("——————选择英雄——————")
{
