规则("承接任务菜单 钥匙插进去了吗")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.MenuActive == 5;
	}

	动作
	{
		For 玩家变量(事件玩家, MenuLoop, 5, 14, 1);
			If(绝对值(水平朝向角度(事件玩家) / 事件玩家.MenuCursorSensibility - 首个(全局.MenuBottonCoordinate[事件玩家.MenuLoop]))
				< 全局.MenuBottonWidth[事件玩家.MenuActive] && 绝对值(垂直朝向角度(事件玩家) / 事件玩家.MenuCursorSensibility - 最后(
				全局.MenuBottonCoordinate[事件玩家.MenuLoop])) < 全局.MenuBottonHeight[事件玩家.MenuActive]);
				中断;
			End;
		End;
		等待(0.025, 无视条件);
		如条件为“真”则循环;
	}
}

规则("子程序L﻿oadingCartoon 任务加载镜头")
{
	事件
	{
		子程序;
		LoadingCartoon;
	}

	动作
	{
		"筛选出同任务2玩家"
		事件玩家.TaskTemporary1 = 已过滤的数组(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID == 事件玩家.Desk_CarringNow_ID && 当前数组元素 == 事件玩家);
		If(数量(事件玩家.TaskTemporary1) > 1);
			"统一任务时间"
			事件玩家.TaskTime = 首个(已排序的数组(事件玩家.TaskTemporary1, 当前数组元素.TaskTime)).TaskTime;
		Else;
			事件玩家.TaskTime = 全局.Task_TimeLimit[事件玩家.Desk_CarringNow_ID];
		End;
		传送(事件玩家, 全局.Task_SpawnPos[事件玩家.Desk_CarringNow_ID]);
		事件玩家.LoadingVisable1 = 0;
		持续追踪玩家变量(事件玩家, LoadingVisable1, 1, 5, 终点及持续时间);
		隐藏英雄HUD(事件玩家);
		开始镜头(事件玩家, 矢量(14.400, 1, 19), 矢量(14, 1.400, 20), 25);
		设置状态(事件玩家, 空, 定身, 6);
		While(事件玩家.LoadingVisable1 < 1);
			播放效果(所有玩家(所有队伍), “死神”幽灵形态声音, 颜色(白色), 矢量(14, 1.400, 20), 较大(40, 事件玩家.LoadingVisable1 * 170));
			"plan A"
			播放效果(所有玩家(所有队伍), “士兵：76”疾跑开始声音, 颜色(白色), 矢量(14, 1.400, 20), 较大(40, 事件玩家.LoadingVisable1 * 170));
			等待(0.200, 无视条件);
		End;
		停止追踪玩家变量(事件玩家, LoadingVisable1);
		事件玩家.LoadingVisable1 = 0;
		等待(0.300, 无视条件);
		事件玩家.LoadingVisable2 = 0;
		持续追踪玩家变量(事件玩家, LoadingVisable2, 1, 5, 终点及持续时间);
		停止镜头(事件玩家);
		播放效果(事件玩家, 莫伊拉消散消失声音, 颜色(白色), 事件玩家, 200);
		播放效果(事件玩家, 莫伊拉消散消失声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		等待直到 (事件玩家.LoadingVisable2 == 1, 4);
		停止追踪玩家变量(事件玩家, LoadingVisable2);
		事件玩家.LoadingVisable2 = 0;
		追踪玩家变量频率(事件玩家, TaskTime, 0, 1, 速率及最终值);
		显示英雄HUD(事件玩家);
		设置终极技能充能(事件玩家, 0);
		"封禁该任务区域"
		全局.Task_AreaRAM[数组值的索引(全局.Task_District[事件玩家.Desk_CarringNow_ID], 1)] = 1;
	}
}

规则("任务加载HUD")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		创建地图文本(已过滤的数组(所有玩家(队伍2), 当前数组元素.LoadingVisable1 > 0), 自定义字符串("正在加载任务{0}", 截取字符串(自定义字符串("......"), 0, 总计消耗时间 % 6)), 矢量(14, 1.400,
			20), 4, 不要截取, 可见，位置，字符串和颜色, 自定义颜色(139 + 101 * 本地玩家.LoadingVisable1, 134 + 121 * 本地玩家.LoadingVisable1,
			130 + 125 * 本地玩家.LoadingVisable1, 255), 默认可见度);
		创建地图文本(已过滤的数组(所有玩家(队伍2), 当前数组元素.LoadingVisable2 > 0), 自定义字符串("——————任务开始——————\n\n                        {0}",
			全局.Task_Name[本地玩家.Desk_CarringNow_ID]), 逐帧更新(眼睛位置(本地玩家) + 面朝方向(本地玩家) * 10), 4, 不要截取, 可见，位置，字符串和颜色, 自定义颜色(178, 34, 34, 255 * (
			1 - 本地玩家.LoadingVisable2)), 默认可见度);
		创建地图文本(已过滤的数组(所有玩家(队伍2), 当前数组元素.DefeatVisable3 > 0), 自定义字符串("任务失败{0}", 图标字符串(剧毒)), 矢量(14, 1.400, 20), 4, 不要截取, 可见，位置，字符串和颜色, 颜色(
			红色), 默认可见度);
	}
}

规则("任务：玩家初始化 ：：没有正在进行的任务的玩家（已重生）的 id=-1")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 1;
	}

	动作
	{
		"没有正在进行的任务"
		事件玩家.Desk_CarringNow_ID = -1;
	}
}

规则("变量初始化")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.Task_Cameras = 空数组;
		全局.Task_Name = 空数组;
		全局.Task_NumberOfPeople_Min_Max = 空数组;
		全局.Task_SpawnPos = 空数组;
		全局.Task_TimeLimit = 空数组;
		全局.Task_Description = 空数组;
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 5), 自定义字符串("——————当前可选任务——————"), 最后(本地玩家.MenuCameraNow)
			+ 0.600 * 本地玩家.MenuFlatBase1 + -0.550 * 本地玩家.MenuFlatBase2, 4, 不要截取, 可见，位置，字符串和颜色, 颜色(橙色), 默认可见度);
		"显示任务描述，承接任务和参加任务均可见"
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive >= 5 && 当前数组元素.MenuActive <= 6), 本地玩家.DeskNow_Description, 最后(本地玩家.MenuCameraNow)
			+ -0.500 * 本地玩家.MenuFlatBase1 + 0.100 * 本地玩家.MenuFlatBase2, 3, 不要截取, 可见，位置，字符串和颜色, 颜色(亮紫色), 默认可见度);
		全局.Task_AreaRAM = 数组(0, 0, 0);
	}
}

