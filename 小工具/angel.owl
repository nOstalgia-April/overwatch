					"没超过人数"
					If(数量(事件玩家.TaskTemporary3) < 最后(全局.Task_NumberOfPeople_Min_Max[事件玩家.Desk_CarringNow_ID]));
						播放效果(事件玩家, “猎空”闪回消失效果, 颜色(白色), 最后(事件玩家.MenuCameraNow), 200);
