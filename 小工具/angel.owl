规则("sub 启用对应的区域")
{
	事件
	{
		子程序;
		area_switch;
	}

	动作
	{
		"Global.Nodes_total[0] = 区域1      Global.Nodes_total[1] = 区域2      Global.Nodes_total[2] = 区域3"
		全局.nodes = 全局.Nodes_total[首个(全局.areaArray)];
		全局.groups = 全局.Lines_total[首个(全局.areaArray)];
	}
}

禁用 规则("选择要启用的的区域")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		"Global.Nodes_total[0] = 区域1      Global.Nodes_total[1] = 区域2      Global.Nodes_total[2] = 区域3"
		全局.nodes = 首个(全局.Nodes_total);
		全局.groups = 首个(全局.Lines_total);
	}
}

禁用 规则("传送到节点")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 真;
	}
}

禁用 规则("设置起点")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 真;
	}

	动作
	{
		全局.start_end = 空数组;
		全局.start_end[0] = 首个(已排序的数组(全局.nodes, 相距距离(当前数组元素, 眼睛位置(事件玩家))));
	}
}

禁用 规则("设置终点")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(辅助攻击模式)) == 真;
	}

	动作
	{
		全局.start_end[1] = 首个(已排序的数组(全局.nodes, 相距距离(当前数组元素, 眼睛位置(事件玩家))));
	}
}

规则("sub 1")
{
	事件
	{
		子程序;
		Dijkstra;
	}

	动作
	{
		全局.Dijkstra = 空数组;
		修改全局变量(Dijkstra, 添加至数组, 首个(全局.start_end));
		"End the program if the Start and the End are linked."
		If(数组包含(全局.groups[数组值的索引(全局.nodes, 最后(全局.start_end))], 数组值的索引(全局.nodes, 首个(全局.start_end))));
			修改全局变量(Dijkstra, 添加至数组, 最后(全局.start_end));
			中止;
		End;
		For 全局变量(loop1, 0, 数量(全局.nodes), 1);
			全局.distance[全局.loop1] = 9999;
		End;
		全局.distance[数组值的索引(全局.nodes, 首个(全局.start_end))] = 0;
		For 全局变量(loop2, 0, 数量(全局.nodes) - 1, 1);
			调用子程序(dijk_mainLoop);
			等待(0.010, 无视条件);
		End;
		全局.tempVar_1 = 空数组;
		修改全局变量(tempVar_1, 添加至数组, 最后(全局.start_end));
		For 全局变量(loop1, 0, 数量(全局.nodes), 1);
			修改全局变量(tempVar_1, 添加至数组, 全局.previousPoint[数组值的索引(全局.nodes, 最后(全局.tempVar_1))]);
			If(最后(全局.tempVar_1) == 首个(全局.start_end));
				中断;
			End;
		End;
		全局.Dijkstra = 已排序的数组(全局.tempVar_1, 当前数组索引 * -1);
	}
}

规则("sub 2")
{
	事件
	{
		子程序;
		dijk_mainLoop;
	}

	动作
	{
		全局.regionStart = 全局.groups[数组值的索引(全局.nodes, 最后(全局.Dijkstra))];
		全局.tempVar_4 = 全局.distance[数组值的索引(全局.nodes, 最后(全局.Dijkstra))] == 9999 ? 0 : 全局.distance[数组值的索引(全局.nodes, 最后(全局.Dijkstra))];
		For 全局变量(loop1, 0, 数量(全局.regionStart), 1);
			全局.tempVar_1 = 全局.nodes[全局.regionStart[全局.loop1]];
			全局.tempVar_2 = 全局.regionStart[全局.loop1];
			全局.tempVar_3 = 相距距离(全局.tempVar_1, 最后(全局.Dijkstra)) + 全局.tempVar_4;
			If(全局.tempVar_3 < 全局.distance[全局.tempVar_2]);
				全局.distance[全局.tempVar_2] = 全局.tempVar_3;
				全局.previousPoint[全局.tempVar_2] = 最后(全局.Dijkstra);
			End;
		End;
		全局.tempVar_3 = 已过滤的数组(全局.nodes, !数组包含(全局.Dijkstra, 当前数组元素) && 全局.distance[当前数组索引] != 9999);
		If(数量(全局.tempVar_3) > 0);
			全局.tempVar_1 = 全局.distance[数组值的索引(全局.nodes, 首个(全局.tempVar_3))];
			全局.tempVar_2 = 0;
			For 全局变量(loop1, 0, 数量(全局.tempVar_3), 1);
				If(全局.distance[数组值的索引(全局.nodes, 全局.tempVar_3[全局.loop1])] < 全局.tempVar_1);
					全局.tempVar_1 = 全局.distance[数组值的索引(全局.nodes, 全局.tempVar_3[全局.loop1])];
					全局.tempVar_2 = 全局.loop1;
				End;
			End;
			修改全局变量(Dijkstra, 添加至数组, 全局.tempVar_3[全局.tempVar_2]);
		End;
	}
}

规则("机器人 初始化")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
	}

	动作
	{
		禁用 创建地图文本(所有玩家(所有队伍), 栏位(事件玩家), 所选位置(事件玩家), 2, 不要截取, 可见，位置和字符串, 颜色(白色), 默认可见度);
		事件玩家.bot_navi_switch = 真;
		事件玩家.bot_AI_switch = 真;
		事件玩家.bot_being_attack = 假;
		事件玩家.bot_route = 空数组;
		事件玩家.bot_target_array = 空数组;
		事件玩家.bot_target_player = -1;
		取消与玩家的移动碰撞(事件玩家);
	}
}

规则("机器人 寻找目标")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
	}

	动作
	{
		事件玩家.bot_target_array = 已过滤的数组(所有玩家(所有队伍), 事件玩家 != 当前数组元素 && !是否是机器人(当前数组元素) && 已重生(当前数组元素) && 存活(当前数组元素) && 在视线内(眼睛位置(事件玩家), 眼睛位置(
			当前数组元素), 屏障不会阻挡视线) && !具有状态(当前数组元素, 相移));
		If(数量(事件玩家.bot_target_array) > 0);
			事件玩家.bot_navi_switch = 假;
			事件玩家.bot_target_player = 首个(事件玩家.bot_target_array);
		End;
		等待(1, 无视条件);
		如条件为“真”则循环;
		事件玩家.bot_target_array = 已过滤的数组(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID == 事件玩家.Monster_Task_ID);
	}
}

规则("机器人 发现目标")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		数量(事件玩家.bot_target_array) > 0;
	}

	动作
	{
		If(所用英雄(事件玩家) == 英雄(士兵：76));
			停止定向阈值(事件玩家);
		Else;
			开始定向阈值(事件玩家, 方向(所选位置(事件玩家), 所选位置(事件玩家.bot_target_player)), 1, 至地图, 替换现有阈值, 方向和幅度);
		End;
		开始朝向(事件玩家, 方向(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_target_player)), 1000, 至地图, 方向及角速率);
		"怪物战斗模式为coolp"
		If(事件玩家.Monster_FightType == 1);
			调用子程序(call_bot_attack_behavior);
	}
}

规则("机器人 放弃目标")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		已重生(事件玩家) == 真;
		事件玩家.bot_target_player != -1;
		在视线内(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_target_player), 屏障不会阻挡视线) == 假;
	}

	动作
	{
		事件玩家.bot_navi_switch = 假;
		禁用 小字体信息(所有玩家(所有队伍), 自定义字符串("丢失目标"));
		等待(1, 无视条件);
		事件玩家.bot_start_end = 空数组;
		事件玩家.bot_start_end[0] = 首个(已排序的数组(全局.nodes, 相距距离(当前数组元素, 眼睛位置(事件玩家))));
		事件玩家.bot_start_end[1] = 首个(已排序的数组(全局.nodes, 相距距离(当前数组元素, 眼睛位置(事件玩家.bot_target_player))));
		修改全局变量(areaArray, 添加至数组, 事件玩家.bot_current_area);
		修改全局变量(botArray, 添加至数组, 栏位(事件玩家));
		等待(10, 无视条件);
		事件玩家.bot_target_player = -1;
		事件玩家.bot_route = 空数组;
		事件玩家.bot_navi_switch = 真;
	}
}

规则("全局 寻路排队")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		数量(全局.botArray) > 0;
	}

	动作
	{
		全局.start_end = 此栏位的玩家(首个(全局.botArray), 队伍1).bot_start_end;
		调用子程序(area_switch);
		调用子程序(Dijkstra);
		此栏位的玩家(首个(全局.botArray), 队伍1).bot_route = 全局.Dijkstra;
		修改全局变量(areaArray, 根据索引从数组中移除, 0);
		修改全局变量(botArray, 根据索引从数组中移除, 0);
		等待(1, 无视条件);
		如条件为“真”则循环;
	}
}

