规则("任务菜单 切换镜头")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		事件玩家.MenuActive == 5;
	}

	动作
	{
		"关卡1"
		If(事件玩家.MenuLoop == 5);
			等待(0.100, 无视条件);
			根据条件跳过(事件玩家.MenuLoop != 5, 3);
			事件玩家.MenuCameraNow = 数组(首个(全局.MenuCameras[事件玩家.MenuLoop + 事件玩家.DeskPage]), 最后(全局.MenuCameras[事件玩家.MenuLoop + 事件玩家.DeskPage]));
			调用子程序(MenuBase);
			事件玩家.DeskNow_Description = 全局.Task_Description[事件玩家.DeskPage];
		"关卡2"
		Else If(事件玩家.MenuLoop == 6 && 事件玩家.DesksHave_ID[事件玩家.DeskPage + 1] != 0);
			等待(0.100, 无视条件);
			根据条件跳过(事件玩家.MenuLoop != 6 || 事件玩家.DesksHave_ID[事件玩家.DeskPage + 1] == 0, 3);
			事件玩家.MenuCameraNow = 数组(首个(全局.MenuCameras[事件玩家.MenuLoop + 事件玩家.DeskPage]), 最后(全局.MenuCameras[事件玩家.MenuLoop + 事件玩家.DeskPage]));
			调用子程序(MenuBase);
			事件玩家.DeskNow_Description = 全局.Task_Description[事件玩家.DeskPage + 1];
		"关卡3"
		Else If(事件玩家.MenuLoop == 7 && 事件玩家.DesksHave_ID[事件玩家.DeskPage + 2] != 0);
			等待(0.100, 无视条件);
			根据条件跳过(事件玩家.MenuLoop != 7 || 事件玩家.DesksHave_ID[事件玩家.DeskPage + 2] == 0, 3);
			事件玩家.MenuCameraNow = 数组(首个(全局.MenuCameras[事件玩家.MenuLoop + 事件玩家.DeskPage]), 最后(全局.MenuCameras[事件玩家.MenuLoop + 事件玩家.DeskPage]));
			调用子程序(MenuBase);
			事件玩家.DeskNow_Description = 全局.Task_Description[事件玩家.DeskPage + 2];
		"关卡4"
		Else If(事件玩家.MenuLoop == 8 && 事件玩家.DesksHave_ID[事件玩家.DeskPage + 3] != 0);
			等待(0.100, 无视条件);
			根据条件跳过(事件玩家.MenuLoop != 8 || 事件玩家.DesksHave_ID[事件玩家.DeskPage + 3] == 0, 3);
			事件玩家.MenuCameraNow = 数组(首个(全局.MenuCameras[事件玩家.MenuLoop + 事件玩家.DeskPage]), 最后(全局.MenuCameras[事件玩家.MenuLoop + 事件玩家.DeskPage]));
			调用子程序(MenuBase);
			事件玩家.DeskNow_Description = 全局.Task_Description[事件玩家.DeskPage + 3];
		"关卡5"
		Else If(事件玩家.MenuLoop == 9 && 事件玩家.DesksHave_ID[事件玩家.DeskPage + 4] != 0);
			等待(0.100, 无视条件);
			根据条件跳过(事件玩家.MenuLoop != 9 || 事件玩家.DesksHave_ID[事件玩家.DeskPage + 4] == 0, 3);
			事件玩家.MenuCameraNow = 数组(首个(全局.MenuCameras[事件玩家.MenuLoop + 事件玩家.DeskPage]), 最后(全局.MenuCameras[事件玩家.MenuLoop + 事件玩家.DeskPage]));
			调用子程序(MenuBase);
			事件玩家.DeskNow_Description = 全局.Task_Description[事件玩家.DeskPage + 4];
		End;
		等待(0.025, 无视条件);
		如条件为“真”则循环;
	}
}

