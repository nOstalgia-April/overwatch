规则("┗---------[Pharah]")
{
	事件
	{
		子程序;
		Pharah;
	}

	动作
	{
		While(事件玩家.bot_target_array > 0);
			等待(1, 无视条件);
			按下按键(事件玩家, 按钮(技能2));
			按下按键(事件玩家, 按钮(主要攻击模式));
			If(终极技能充能百分比(事件玩家) == 100 && 相距距离(眼睛位置(事件玩家), 事件玩家.bot_target_player) <= 15);
				按下按键(事件玩家, 按钮(终极技能));
			End;
		End;
	}
}

规则("┗---------[Jump & crouch]法鸡")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		是否是机器人(事件玩家) == 真;
		存活(事件玩家) == 真;
		事件玩家.bot_target_array > 0;
	}

	动作
	{
		If(在地面上(事件玩家) == 真);
			停止按下按钮(事件玩家, 按钮(跳跃));
			按下按键(事件玩家, 按钮(技能1));
		Else;
			开始按下按钮(事件玩家, 按钮(跳跃));
			等待(随机实数(0.200, 0.500), 无视条件);
			停止按下按钮(事件玩家, 按钮(跳跃));
			等待(0.300, 无视条件);
		End;
		等待(0.100, 无视条件);
		如条件为“真”则循环;
	}
}

