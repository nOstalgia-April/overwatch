规则("任务1——————特产熔岩球 二维数组初始化 特效文本初始化")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		创建HUD文本(所有玩家(所有队伍), 自定义字符串(""), 空, 空, 左边, 0, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 默认可见度);
		"0-交货pos 1-交货进度"
		全局.Task_Funtions[1] = 数组(矢量(-98.500, -2.500, -48), 0, 数组随机取值(全局.Nodes_total[1]));
		创建效果(已过滤的数组(所有玩家(所有队伍), 当前数组元素.Desk_CarringNow_ID == 1), 环, 颜色(灰绿色), 首个(全局.Task_Funtions[1]), 3, 可见，位置和半径);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.Desk_CarringNow_ID == 1), 自定义字符串("  {0}\n{1}/10", 图标字符串(旗帜), 全局.Task_Funtions[1][1]), 矢量(0, 1, 0)
			+ 首个(全局.Task_Funtions[1]), 2, 不要截取, 可见，位置和字符串, 颜色(绿色), 默认可见度);
		"玩家需要收集的"
		创建效果(已过滤的数组(所有玩家(所有队伍), 当前数组元素.Desk_CarringNow_ID == 1), 温斯顿原始暴怒效果, 颜色(灰绿色), 全局.Task_Funtions[1][2], 3, 可见，位置和半径);
		创建地图文本(已过滤的数组(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID == 1), 自定义字符串("熔岩球"), 全局.Task_Funtions[1][2], 1.500, 根据表面截取, 可见，位置和字符串, 颜色(白色),
			默认可见度);
		"玩家需要收集的"
		创建效果(已过滤的数组(所有玩家(所有队伍), 当前数组元素.Desk_CarringNow_ID == 1 && 总计消耗时间 % 3 <= 2), 能量声音, 颜色(灰绿色), 全局.Task_Funtions[1][2], 150, 可见，位置和半径);
	}
}

规则("任务1——————特产熔岩球 玩家 任务目标提醒")
