规则("任务失败 中途退出/全部死亡/时间到了 任务开始后（满足需求人数）")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		事件玩家.Desk_CarringNow_ID != -1;
		(数量(已过滤的数组(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID == 事件玩家.Desk_CarringNow_ID)) < 首个(全局.Task_District[事件玩家.Desk_CarringNow_ID])
			|| 事件玩家.TaskTime == 0 || 数量(已过滤的数组(所有玩家(队伍2), 死亡(当前数组元素) && 事件玩家.Desk_CarringNow_ID == 当前数组元素.Desk_CarringNow_ID)) == 数量(
			已过滤的数组(所有玩家(队伍2), 当前数组元素.Desk_CarringNow_ID == 事件玩家.Desk_CarringNow_ID))) == 1;
		是否是机器人(事件玩家) == 假;
	}

	动作
	{
		等待(5, 当为“假”时中止);
		大字体信息(事件玩家, 自定义字符串("任务失败"));
		等待(1, 无视条件);
		调用子程序(DefeatCartoon);
		事件玩家.HealPercent = 100;
		事件玩家.Desk_CarringNow_ID = -1;
		复活(事件玩家);
		传送(事件玩家, 全局.Spawn1);
	}
}

规则("子程序 DefeatCartoon")
{
	事件
	{
		子程序;
		DefeatCartoon;
	}

	动作
	{
		开始镜头(事件玩家, 矢量(14.400, 1, 19), 矢量(14, 1.400, 20), 25);
		事件玩家.DefeatVisable3 = 1;
		等待(3, 无视条件);
		停止镜头(事件玩家);
		播放效果(事件玩家, 莫伊拉消散消失声音, 颜色(白色), 事件玩家, 200);
		播放效果(事件玩家, 莫伊拉消散消失声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		事件玩家.DefeatVisable3 = 0;
		"解禁该任务区域"
		全局.Task_AreaRAM[数组值的索引(全局.Task_District[事件玩家.Desk_CarringNow_ID], 1)] = 0;
	}
}

规则("子程序 VictoryCartoon")
{
	事件
	{
		子程序;
		VictoryCartoon;
	}

	动作
	{
		停止追踪玩家变量(事件玩家, TaskTime);
		等待直到 (在地面上(事件玩家), 1);
		大字体信息(事件玩家, 自定义字符串("任务胜利！\n\n                        即将返回"));
		开始镜头(事件玩家, 眼睛位置(事件玩家) + 地图矢量(矢量(-0.500, -0.200, 1), 事件玩家, 旋转), 眼睛位置(事件玩家), 20);
		播放效果(事件玩家, “破坏球”地雷禁区爆炸效果, 颜色(白色), 地图矢量(矢量(随机实数(-1, 1), -1, 随机实数(-1, -2)), 事件玩家, 旋转并转换), 1);
		播放效果(事件玩家, “破坏球”地雷禁区爆炸效果, 颜色(白色), 地图矢量(矢量(随机实数(-1, 1), -1, 随机实数(-1, -2)), 事件玩家, 旋转并转换), 1);
		播放效果(事件玩家, “破坏球”地雷禁区爆炸效果, 颜色(白色), 地图矢量(矢量(随机实数(-1, 1), -1, 随机实数(-1, -2)), 事件玩家, 旋转并转换), 1);
		播放效果(事件玩家, “破坏球”地雷禁区爆炸声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(事件玩家, “破坏球”地雷禁区爆炸声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		等待(0.300, 无视条件);
		播放效果(事件玩家, “破坏球”地雷禁区爆炸声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(事件玩家, 半藏音初始脉冲声音, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		播放效果(事件玩家, 半藏音初始脉冲效果, 颜色(白色), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转并转换), 200);
		事件玩家.Desk_CarringNow_ID = -1;
		等待(6, 无视条件);
		传送(事件玩家, 全局.Spawn1);
		停止镜头(事件玩家);
		"解禁该任务区域"
		全局.Task_AreaRAM[数组值的索引(全局.Task_District[事件玩家.Desk_CarringNow_ID], 1)] = 0;
	}
}

