规则("子程序 EquipWord")
{
	事件
	{
		子程序;
		EquipWord;
	}

	动作
	{
		事件玩家.EquipWord = 自定义字符串("{0}", 图标字符串(圆圈));
		事件玩家.EquipWord = 自定义字符串("{0} {1}————————\n ", 图标字符串(箭头：向右), 事件玩家.EquipBox[事件玩家.EquipChosenID]);
		For 玩家变量(事件玩家, EquipFor, 0, 7, 1);
			If(全局.Equip[事件玩家.EquipChosenID][事件玩家.EquipFor] != 0);
				事件玩家.EquipWord = 自定义字符串("{0}\n    -{2} {1}", 事件玩家.EquipWord, 全局.Equip[事件玩家.EquipChosenID][事件玩家.EquipFor],
					全局.Shuxing_Name[事件玩家.EquipFor]);
			End;
		End;
		事件玩家.EquipWord = 自定义字符串("{0}\n        ————————\n           套装效果（小）\n          -{1}\n            套装效果（大）\n          -{2}",
			事件玩家.EquipWord, 全局.Equip[事件玩家.EquipChosenID][8], 全局.Equip[事件玩家.EquipChosenID][9]);
	}
}

