规则("任务菜单 初始化 Active 5 Coordinate 5-13")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.MenuBottonWidth[5] = 0.300;
		全局.MenuBottonHeight[5] = 0.070;
		"关卡1"
		全局.MenuBottonCoordinate[5] = 数组(0.600, -0.400);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 5 && 当前数组元素.MenuActive <= 5), 全局.Task_Name[本地玩家.DesksHave_ID[本地玩家.DeskPage]], 最后(
			本地玩家.MenuCameraNow) + 首个(全局.MenuBottonCoordinate[5]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[5])
			* 本地玩家.MenuFlatBase2, 4, 不要截取, 可见，位置，字符串和颜色, 本地玩家.MenuLoop == 5 ? 颜色(橙色) : 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"关卡2 如果page+1的位置没有任务了 不显示"
		全局.MenuBottonCoordinate[6] = 数组(0.600, -0.250);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 5 && 当前数组元素.DesksHave_ID[当前数组元素.DeskPage + 1] != 0),
			全局.Task_Name[本地玩家.DesksHave_ID[本地玩家.DeskPage + 1]], 最后(本地玩家.MenuCameraNow) + 首个(全局.MenuBottonCoordinate[6])
			* 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[6]) * 本地玩家.MenuFlatBase2, 4, 不要截取, 可见，位置，字符串和颜色, 本地玩家.MenuLoop == 6 ? 颜色(橙色)
			: 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"关卡3 如果page+2的位置没有任务了 不显示"
		全局.MenuBottonCoordinate[7] = 数组(0.600, -0.100);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 5 && 当前数组元素.DesksHave_ID[当前数组元素.DeskPage + 2] != 0),
			全局.Task_Name[本地玩家.DesksHave_ID[本地玩家.DeskPage + 2]], 最后(本地玩家.MenuCameraNow) + 首个(全局.MenuBottonCoordinate[7])
			* 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[7]) * 本地玩家.MenuFlatBase2, 4, 不要截取, 可见，位置，字符串和颜色, 本地玩家.MenuLoop == 7 ? 颜色(橙色)
			: 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"关卡4 如果page+3的位置没有任务了 不显示"
		全局.MenuBottonCoordinate[8] = 数组(0.600, 0.050);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 5 && 当前数组元素.DesksHave_ID[当前数组元素.DeskPage + 3] != 0),
			全局.Task_Name[本地玩家.DesksHave_ID[本地玩家.DeskPage + 3]], 最后(本地玩家.MenuCameraNow) + 首个(全局.MenuBottonCoordinate[8])
			* 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[8]) * 本地玩家.MenuFlatBase2, 4, 不要截取, 可见，位置，字符串和颜色, 本地玩家.MenuLoop == 8 ? 颜色(橙色)
			: 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"关卡5 如果page+4的位置没有任务了 不显示"
		全局.MenuBottonCoordinate[9] = 数组(0.600, 0.200);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 5 && 当前数组元素.DesksHave_ID[当前数组元素.DeskPage + 4] != 0),
			全局.Task_Name[本地玩家.DesksHave_ID[本地玩家.DeskPage + 4]], 最后(本地玩家.MenuCameraNow) + 首个(全局.MenuBottonCoordinate[9])
			* 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[9]) * 本地玩家.MenuFlatBase2, 4, 不要截取, 可见，位置，字符串和颜色, 本地玩家.MenuLoop == 9 ? 颜色(橙色)
			: 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"下一页 - 10"
		全局.MenuBottonCoordinate[10] = 数组(0.400, 0.400);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 5 && 当前数组元素.DesksHave_ID[当前数组元素.DeskPage + 5] != 0), 自定义字符串("下一页"), 最后(
			本地玩家.MenuCameraNow) + 首个(全局.MenuBottonCoordinate[10]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[10])
			* 本地玩家.MenuFlatBase2, 4, 不要截取, 可见，位置，字符串和颜色, 本地玩家.MenuLoop == 10 ? 颜色(橙色) : 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"上一页 - 11"
		全局.MenuBottonCoordinate[11] = 数组(0.600, 0.400);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 5 && 当前数组元素.DesksHave_ID[当前数组元素.DeskPage + -1] != 0), 自定义字符串("上一页"), 最后(
			本地玩家.MenuCameraNow) + 首个(全局.MenuBottonCoordinate[11]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[11])
			* 本地玩家.MenuFlatBase2, 4, 不要截取, 可见，位置，字符串和颜色, 本地玩家.MenuLoop == 11 ? 颜色(橙色) : 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"承接按钮 -12"
		全局.MenuBottonCoordinate[12] = 数组(-0.500, 0.400);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive >= 5 && 当前数组元素.MenuActive <= 5), 自定义字符串("承接任务"), 最后(本地玩家.MenuCameraNow) + 首个(
			全局.MenuBottonCoordinate[12]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[12]) * 本地玩家.MenuFlatBase2, 4, 不要截取,
			可见，位置，字符串和颜色, 本地玩家.MenuLoop == 12 ? 颜色(橙色) : 颜色(白色), 默认可见度);
		等待(0.050, 无视条件);
		"关卡1"
		全局.MenuBottonCoordinate[13] = 数组(-0.500, 0.500);
		创建地图文本(已过滤的数组(所有玩家(所有队伍), 当前数组元素.MenuActive == 5 && 真 && 已重生(此栏位的玩家(0, 队伍2))), 自定义字符串("退出菜单"), 最后(本地玩家.MenuCameraNow) + 首个(
			全局.MenuBottonCoordinate[13]) * 本地玩家.MenuFlatBase1 + 最后(全局.MenuBottonCoordinate[13]) * 本地玩家.MenuFlatBase2, 4, 不要截取,
			可见，位置，字符串和颜色, 本地玩家.MenuLoop == 13 ? 颜色(橙色) : 颜色(白色), 默认可见度);
	}
}

规则("任务菜单 点击")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		按钮被按下(事件玩家, 按钮(主要攻击模式)) == 1;
		事件玩家.MenuActive == 5;
		事件玩家.MenuLoop != 数量(事件玩家.MenuBottonCoordinate);
	}

	动作
	{
		"上一页"
		If(事件玩家.MenuLoop == 11 && 数量(数组分割(事件玩家.DesksHave_ID, 事件玩家.DeskPage, 999)) >= 6);
			事件玩家.DeskPage += 5;
		Else If(事件玩家.MenuLoop == 13);
			调用子程序(MenuClose);
		"下一页"
		Else If(事件玩家.MenuLoop == 10);
			事件玩家.DeskPage = 较大(0, 事件玩家.DeskPage - 5);
		"承接按钮"
		Else If(事件玩家.MenuLoop == 12);
			"区域1被占用 如果所选的任务"
			If(首个(全局.Task_District[数组值的索引(全局.Task_Description, 事件玩家.DeskNow_Description)]) + 首个(全局.Task_AreaRAM) == 2);
				播放效果(事件玩家, 查莉娅粒子炮爆炸声音, 颜色(白色), 最后(事件玩家.MenuCameraNow), 160);
				小字体信息(事件玩家, 自定义字符串("错误：区域1正在被占用"));
			"区域2被占用"
			Else If(全局.Task_AreaRAM[1] + 全局.Task_District[数组值的索引(全局.Task_Description, 事件玩家.DeskNow_Description)][1] == 2);
				播放效果(事件玩家, 查莉娅粒子炮爆炸声音, 颜色(白色), 最后(事件玩家.MenuCameraNow), 160);
				小字体信息(事件玩家, 自定义字符串("错误：区域2正在被占用"));
			"区域3被占用"
			Else If(全局.Task_AreaRAM[2] + 全局.Task_District[数组值的索引(全局.Task_Description, 事件玩家.DeskNow_Description)][2] == 2);
				播放效果(事件玩家, 查莉娅粒子炮爆炸声音, 颜色(白色), 最后(事件玩家.MenuCameraNow), 160);
				小字体信息(事件玩家, 自定义字符串("错误：区域3正在被占用"));
			Else;
				事件玩家.TaskTemporary3 = 已过滤的数组(所有玩家(队伍2), 数组值的索引(全局.Task_Description, 事件玩家.DeskNow_Description) == 当前数组元素.Desk_CarringNow_ID);
				"达到最低人数要求"
				If(数量(已过滤的数组(所有玩家(队伍2), 当前数组元素.TaskTemporary3 == 事件玩家.TaskTemporary3)) >= 首个(全局.Task_NumberOfPeople_Min_Max[数组值的索引(
					全局.Task_Description, 事件玩家.DeskNow_Description)]));
					"没超过人数"
					If(数量(事件玩家.TaskTemporary3) < 最后(全局.Task_NumberOfPeople_Min_Max[数组值的索引(全局.Task_Description, 事件玩家.DeskNow_Description)]));
						播放效果(事件玩家, “猎空”闪回消失效果, 颜色(白色), 最后(事件玩家.MenuCameraNow), 200);
						事件玩家.Desk_CarringNow_ID = 数组值的索引(全局.Task_Description, 事件玩家.DeskNow_Description);
						禁用 已过滤的数组(所有玩家(队伍2), 当前数组元素.DeskNow_Description == 事件玩家.DeskNow_Description).Z = 事件玩家.Desk_CarringNow_ID;
						调用子程序(MenuClose);
						调用子程序(LoadingCartoon);
					Else;
						小字体信息(事件玩家, 自定义字符串("错误：任务承接人数已达上限"));
						事件玩家.Desk_CarringNow_ID = -1;
					End;
				Else;
					播放效果(事件玩家, 查莉娅粒子炮爆炸声音, 颜色(白色), 最后(事件玩家.MenuCameraNow), 160);
					小字体信息(事件玩家, 自定义字符串("已承接：正在等待足够人数玩家承接此任务"));
					事件玩家.Desk_CarringNow_ID = -1;
				End;
			End;
	}
}

