规则("sub Winston")
{
	事件
	{
		子程序;
		Winston;
	}

	动作
	{
		While(数量(事件玩家.bot_target_array) > 0);
			等待(0.500, 无视条件);
			If(相距距离(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_target_player)) < 9 || !正在使用主要武器(事件玩家));
				开始按下按钮(事件玩家, 按钮(主要攻击模式));
				停止按下按钮(事件玩家, 按钮(辅助攻击模式));
			Else;
				开始按下按钮(事件玩家, 按钮(辅助攻击模式));
				停止按下按钮(事件玩家, 按钮(主要攻击模式));
			End;
			If(相距距离(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_target_player)) < 40 && (相距距离(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_target_player)) > 15 || 绝对值(Y方向分量(所选位置(
				事件玩家)) - Y方向分量(眼睛位置(事件玩家.bot_target_player))) > 2));
				按下按键(事件玩家, 按钮(技能1));
			End;
			If(事件玩家.bot_being_attack == 真 && 在地面上(事件玩家));
				按下按键(事件玩家, 按钮(技能2));
			End;
			If(终极技能充能百分比(事件玩家) == 100 && 技能冷却时间(事件玩家, 按钮(技能1)) == 0 && 相距距离(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_target_player)) <= 5);
				按下按键(事件玩家, 按钮(技能1));
				等待(0.500, 无视条件);
				按下按键(事件玩家, 按钮(终极技能));
				等待(0.500, 无视条件);
				按下按键(事件玩家, 按钮(技能1));
			End;
		End;
		停止按下按钮(事件玩家, 按钮(主要攻击模式));
		停止按下按钮(事件玩家, 按钮(辅助攻击模式));
		按下按键(事件玩家, 按钮(装填));
	}
}

规则("sub soldier：76")
{
	事件
	{
		子程序;
		soldier76;
	}

	动作
	{
		While(数量(事件玩家.bot_target_array) > 0);
			等待(0.500, 无视条件);
			按下按键(事件玩家, 按钮(主要攻击模式));
			If(生命值(事件玩家.bot_target_player) < 50);
				按下按键(事件玩家, 按钮(辅助攻击模式));
			End;
			If(标准化生命值(事件玩家) < 0.500);
				按下按键(事件玩家, 按钮(技能2));
			End;
			If(终极技能充能百分比(事件玩家) == 100 && 相距距离(眼睛位置(事件玩家), 眼睛位置(事件玩家.bot_target_player)) <= 30);
				按下按键(事件玩家, 按钮(终极技能));
			End;
		End;
		停止按下按钮(事件玩家, 按钮(主要攻击模式));
		按下按键(事件玩家, 按钮(装填));
