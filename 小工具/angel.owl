规则("玩家变量初始化 生命池 全局变量初始化（属性名）")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		已重生(事件玩家) == 真;
	}

	动作
	{
		等待(1, 无视条件);
		根据条件跳过(所在队伍(事件玩家) == 队伍1, 7);
		"攻击"
		事件玩家.Attack = 1;
		"法强"
		事件玩家.SpellPower = 1;
		"生命"
		事件玩家.Health = 1;
		"护甲"
		事件玩家.Armor = 1;
		"魔抗"
		事件玩家.SpellResis = 1;
		"敏捷"
		事件玩家.Agility = 1;
		"幸运"
		事件玩家.Luck = 1;
		为玩家添加生命池(事件玩家, 生命值, 30 * 事件玩家.Health ^ 2, 真, 真);
		全局.Shuxing_Name = 数组(自定义字符串("攻击力"), 自定义字符串("法术强度"), 自定义字符串("生命"), 自定义字符串("护甲"), 自定义字符串("魔抗"), 自定义字符串("敏捷"), 自定义字符串("幸运"));
		调用子程序(Shuxing);
	}
}

规则("攻击力")
{
	事件
	{
		玩家造成伤害;
		双方;
		全部;
	}

	条件
	{
		事件技能 == 按钮(主要攻击模式);
	}

	动作
	{
		伤害(被攻击方, 事件玩家, 事件伤害 * 0.100 * 事件玩家.Attack);
	}
}

规则("法术强度")
{
	事件
	{
		玩家造成伤害;
		双方;
		全部;
	}

	条件
	{
		事件技能 == (首个(按钮(技能1)) || 首个(按钮(技能2)) || 首个(按钮(蹲下)) || 首个(按钮(终极技能)));
	}

	动作
	{
		伤害(被攻击方, 事件玩家, 事件伤害 * 0.200 * 事件玩家.SpellPower);
	}
}

规则("护甲")
{
	事件
	{
		玩家受到伤害;
		双方;
		全部;
	}

	条件
	{
		事件技能 == 按钮(主要攻击模式);
	}

	动作
	{
		治疗(事件玩家, 事件玩家, 事件伤害 * (事件玩家.Armor / (10 + 事件玩家.Armor)));
	}
}

规则("魔抗")
{
	事件
	{
		玩家受到伤害;
		双方;
		全部;
	}

	条件
	{
		事件技能 == (首个(按钮(技能1)) || 首个(按钮(技能2)) || 首个(按钮(蹲下)) || 首个(按钮(终极技能)));
	}

	动作
	{
		治疗(事件玩家, 事件玩家, 事件伤害 * (事件玩家.SpellResis / (10 + 事件玩家.SpellResis)));
	}
}

规则("子程序Shuxing——敏捷赋值")
{
	事件
	{
		子程序;
		Shuxing;
	}

	动作
	{
		设置移动速度(事件玩家, 100 + 125 * (事件玩家.Agility / (事件玩家.Agility + 15)));
	}
}

