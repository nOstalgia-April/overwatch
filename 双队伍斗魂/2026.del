import '双队伍斗魂菜单.del';
// ---- 测试模式开关 ----
Boolean TestMode: false;
// 派生参数
Number Flip_SlotPerTeam: TestMode ? 3 : 6;
Number Flip_MembersPerSquad: TestMode ? 1 : 2;
Agent GetAgent(in Player p){
    return Agents.Filter(t=>GetIdentity(p)==t.Identity).First;
}
class Agent {
    public Player Entity;
    public Any Identity;
    public Squad Squad;
    public Agent Teammate;
    public Hero Hero;
    public HexId[] Hexes;
    public ForgeRoll[] Forges;
    public HexId[] HexRoundOffers;
    public Number HexRoundOfferIndex;
    public Shuxing Shuxing;  // 新增
    public constructor(in Player p, in Any id) {
        Entity = p;
        Identity = GetIdentity(p);
        Agents += this;
        Hexes = [];
        Forges = [];
        HexRoundOffers = [];
        HexRoundOfferIndex = 0;
        Shuxing = new Shuxing();  // 新增

        p.IAgent = this;
    }

    public static void SyncIAgent(in Player p = EventPlayer()){
        p.IAgent = Agents.Filter(a=>a.Identity == GetIdentity(p)).First;
    }

    public void SyncTeammate(){
        Teammate = Squad == null ? null : Squad.Members.Filter(a=>a != this).First;
    }

    public void UpdateEntity(){
        Entity = AllPlayers().Filter(p=>GetIdentity(p) == Identity).First;
    }

    public static void InitEffects(in Agent a){
        CreateHudText(
            Header: <'<2>,Agent<0>,Squad<1>',Agents.IndexOf(a),a.Squad.ID,HeroIconString(a.Hero)>,
            SortOrder: a.Squad.ID,
            HeaderColor: a.Squad.Color,
            VisibleTo: true?AllPlayers():null,
            Reevaluation: HudTextRev.VisibleToSortOrderStringAndColor
        );
    }
}
