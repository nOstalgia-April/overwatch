enum ShuxingType {
    Attack,
    CoolDown,
    Speed,
    HealBoost,
    Health,
    Reduction,
    Drain,
    Armor,
    Shields
}

class Shuxing{
    public ShuxingBase Attack;
    public ShuxingBase CoolDown;
    public ShuxingBase Speed;
    public ShuxingBase HealBoost;
    public ShuxingBase Drain;
    public ShuxingBase Armor;
    public ShuxingBase Health;
    public ShuxingBase Shields;
    public ShuxingBase Reduction;
    public ShuxingBase Scale;
    public ShuxingBase JumpVerticalSpeed;

    public constructor(){
        Attack = new ShuxingBase();
        CoolDown = new ShuxingBase(abs: 0);
        Speed = new ShuxingBase();
        HealBoost = new ShuxingBase();
        Drain = new ShuxingBase(abs: 0);
        Armor = new ShuxingBase(abs: 0);
        Health = new ShuxingBase(abs: 0);
        Shields = new ShuxingBase(abs: 0);
        Reduction = new ShuxingBase(abs: 0);
        Scale = new ShuxingBase();
        JumpVerticalSpeed = new ShuxingBase();
    }
}
class ShuxingBase{
    public Number Abs;
    public Number Pct;
    public Number Forge;

    Number RealShuxing(in Player p! = EventPlayer()):
        Abs+Forge*p.Forge_Multiplier;

    Number RealShuxing_Local():
        Abs+Forge*LocalPlayer().Forge_Multiplier;

    Number VirtualShuxing(in Player p! = EventPlayer()):
        RealShuxing(p)*(1+Pct/100);

    Number VirtualShuxing_Local():
        RealShuxing_Local()*(1+Pct/100);
    
    public constructor(in Number abs=100){
        Abs = abs;
    }
}
void RevShuxing(Player p! = EventPlayer())'sub刷新属性'{
    SetMoveSpeed(p,p.IAgent.Shuxing.Speed.VirtualShuxing(p)); 
    SetDamageDealt(p,p.IAgent.Shuxing.Attack.VirtualShuxing(p));
    SetDamageReceived(p,Max(20,100*100/(100+1.5 *p.IAgent.Shuxing.Reduction.VirtualShuxing(p))));
    SetHealingDealt(p,p.IAgent.Shuxing.HealBoost.VirtualShuxing(p));

    SetJumpVerticalSpeed(p,p.IAgent.Shuxing.JumpVerticalSpeed.VirtualShuxing(p));
}
Number CooldownReductionPerTick : 0.5 * (IAgent.Shuxing.CoolDown / (100 + IAgent.Shuxing.CoolDown));
playervar Number last_halfsec_Damaged!;
playervar Number last_halfsec_Healed!;
globalvar Button[] Buttons = [Button.Ability1,Button.Ability2,Button.Jump,Button.SecondaryFire,Button.Crouch];
rule: '全能效果实现吸血效果'
Event.OngoingPlayer
Team.All
Player.All
if(IsAlive())
{
    Heal(EventPlayer(),EventPlayer(),(PlayerHeroStat(EventPlayer(),HeroOf(),PlayerHeroStat.AllDamageDealt)-last_halfsec_Damaged)*IAgent.Shuxing.Drain.VirtualShuxing()/100);

    last_halfsec_Damaged = PlayerHeroStat(EventPlayer(),HeroOf(),PlayerHeroStat.AllDamageDealt);

    last_halfsec_Healed = PlayerHeroStat(EventPlayer(),HeroOf(),PlayerHeroStat.HealingDealt);

    if(IAgent.Shuxing.CoolDown.VirtualShuxing()>0){
        foreach(Button b! in Buttons){
            if(!WrongButtons.Contains(b)){
                if(AbilityCooldown(EventPlayer(),b)>0){
                    SetAbilityCooldown(EventPlayer(),b,Max((AbilityCooldown(EventPlayer(),b)-CooldownReductionPerTick),0));
                }
            }
        }
    }
    Wait(0.5);
    LoopIfConditionIsTrue();
}

playervar Button[] WrongButtons = [];
playervar Number Forge_Multiplier! = 1;

void GameFlow()'GameFlow'{
    while(true){
        BigMessage(AllPlayers(), <'第 <0> 回合', MainTurnManager.Turn>);

        // Advance
        MainTurnManager.Advance(); // 内部做 Pair + Flip + EnterPrep

        // 等待 Preparation 结束
        Wait(PrepareDuration);

        // 进入 Combat
        EnterCombatPhase();

        // 等待所有 pair 结束（DetectEnd 会清空 CurrentRoundPairings）
        while(CurrentRoundPairings.Length > 0) Wait(0.5);

        // 回合结算完毕，循环
        FireRing_EndRound();
    }
}
