rule: 'Hex玩家初始化'
Event.OnPlayerJoin
Team.All
Player.All
{
    EventPlayer().ShuxingInitSynced = false;
    EventPlayer().Teammate = null;
    EventPlayer().ReviveUIInited = false;
    EventPlayer().RevivePercent = 0;
    EventPlayer().Revivable = false;
    EventPlayer().HexCurrentCooldowns = [];
    EventPlayer().Hex_BoliDapaoApplied = false;
    EventPlayer().Hex_CanbaoZhiliApplied = false;
    EventPlayer().Hex_TanhuangTiaoApplied = false;
    EventPlayer().Hex_TanhuangTiaoReduceOn = false;
    EventPlayer().Hex_HujiaFashengqiApplied = false;
    EventPlayer().Hex_JijiuYongjuApplied = false;
    EventPlayer().Hex_JurenShashouApplied = false;
    EventPlayer().Hex_KexueApplied = false;
    EventPlayer().Hex_ShoucaiApplied = false;
    EventPlayer().Hex_KongyuKexingActive = false;
    EventPlayer().Hex_SuoxiaoShexianActive = false;
    EventPlayer().Hex_YingjiXinpianActive = false;
    EventPlayer().Hex_WangcheYiweiLock = false;
    EventPlayer().Hex_ShibukedangLock = false;
    EventPlayer().Hex_ShandianYizhiqiEffectId = 0;
    EventPlayer().Hex_ShibukedangEffectId = 0;
    EventPlayer().Hex_ZhuangtianHuixueTime = 0;
    EventPlayer().Hex_WangcheYiweiSelfPos = Vector(0, 0, 0);
    EventPlayer().ForgeCursor_Average = 0;
    EventPlayer().ForgeCursor_Rare = 0;
    EventPlayer().ForgeCursor_Epic = 0;
    EventPlayer().ForgeOffers = [];
    EventPlayer().ForgeOfferIndex = 0;
    EventPlayer().CurrentSelectHudMode = SelectHudMode.none;
    if(EventPlayer().IAgent != null){
        EventPlayer().IAgent.HexRoundOffers = [];
        EventPlayer().IAgent.HexRoundOfferIndex = 0;
    }
}

rule: 'Hex冷却自动更新'
Event.OngoingPlayer
Team.All
Player.All
if(HasSpawned())
if(IAgent != null)
if(IAgent.Hexes.Length > 0)
{
    TickPlayerHexCooldowns(EventPlayer(), 0.25);
    Wait(0.25, WaitBehavior.IgnoreCondition);
    LoopIfConditionIsTrue();
}

rule: '海克斯-玻璃大炮'
