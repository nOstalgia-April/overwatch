enum ForgeQuality{
    average,
    rare,
    epic
}

single struct ForgeTemplate{
    public ForgeQuality Quality;
    public ShuxingType Type;
    public Number[] AbsRange;
}

single struct ForgeRoll{
    public ForgeQuality Quality;
    public ShuxingType Type;
    public Number AbsBonus;
}

globalvar ForgeTemplate[] ForgeTemplates! = [];
globalvar Number[][] ForgeRanges_Average! = [
    [12, 22],   // Attack
    [10, 20],   // CoolDown
    [6, 12],    // Speed
    [10, 18],   // HealBoost
    [100, 180], // Health
    [10, 20],   // Reduction
    [],         // Drain
    [],         // Armor
    []          // Shields
];
globalvar Number[][] ForgeRanges_Rare! = [
    [], [], [], [], [], [], [], [], []
];
globalvar Number[][] ForgeRanges_Epic! = [
    [40, 40],   // Attack
    [35, 35],   // CoolDown
    [35, 35],   // Speed
    [40, 40],   // HealBoost
    [],         // Health
    [35, 35],   // Reduction
    [20, 20],   // Drain
    [250, 250], // Armor
    [200, 200]  // Shields
];
globalvar ForgeRoll[][] ForgeSlots_Average! = [];
globalvar ForgeRoll[][] ForgeSlots_Rare! = [];
globalvar ForgeRoll[][] ForgeSlots_Epic! = [];
Number ForgeSlotCount!: 60;
globalvar Boolean ForgePoolsInitialized! = false;

Number[][] ForgeRangesByQuality(in ForgeQuality quality):
    quality == ForgeQuality.average ? ForgeRanges_Average : (quality == ForgeQuality.rare ? ForgeRanges_Rare : ForgeRanges_Epic);

ForgeTemplate[] ForgeTemplatesByQuality(in ForgeQuality quality):
    ForgeTemplates.Filter(t => t.Quality == quality);

ForgeRoll RollForge(in ForgeTemplate tpl):
    {Quality: tpl.Quality, Type: tpl.Type, AbsBonus: RandomInteger(tpl.AbsRange[0], tpl.AbsRange[1])};

void AppendGeneratedForgeSlot(in ForgeQuality quality){
    ForgeTemplate[] templates! = ForgeTemplatesByQuality(quality);
    if(templates.Length < 3)return;
    ForgeRoll[] slot! = [];
    ShuxingType[] usedTypes! = [];
    while(slot.Length < 3){
        ForgeTemplate tpl! = RandomValueInArray(templates);
        if(usedTypes.Contains(tpl.Type)){
            MinWait();
            continue;
        }
        usedTypes += tpl.Type;
        slot += RollForge(tpl);
        MinWait();
    }
    if(slot.Length != 3)return;
    switch(quality){
        case ForgeQuality.average:
            ForgeSlots_Average += slot;
            break;
        case ForgeQuality.rare:
            ForgeSlots_Rare += slot;
            break;
        case ForgeQuality.epic:
            ForgeSlots_Epic += slot;
            break;
    }
}

rule: 'Forge池初始化'
if(!ForgePoolsInitialized)
{
    ForgeTemplates = [];
    ForgeQuality[] initQualities! = [ForgeQuality.average, ForgeQuality.rare, ForgeQuality.epic];
    foreach(ForgeQuality quality! in initQualities){
        Number[][] ranges! = ForgeRangesByQuality(quality);
        for(define typeIndex! = 0; typeIndex < ranges.Length; typeIndex++){
            if(ranges[typeIndex].Length < 2)continue;
            ForgeTemplates += {
                Quality: quality,
                Type: <ShuxingType>typeIndex,
                AbsRange: ranges[typeIndex]
            };
            MinWait();
        }
    }

    ForgeSlots_Average = [];
    ForgeSlots_Rare = [];
    ForgeSlots_Epic = [];
    for(define i! = 0; i < ForgeSlotCount; i++){
        AppendGeneratedForgeSlot(ForgeQuality.average);
        AppendGeneratedForgeSlot(ForgeQuality.rare);
        AppendGeneratedForgeSlot(ForgeQuality.epic);
        MinWait();
    }
    ForgePoolsInitialized = true;
}

void GenerateForgeOffersForPlayer(in Player p, in ForgeQuality quality){
    ForgeRoll[][] pool!;
    Number cursor!;
    switch(quality){
        case ForgeQuality.average:
            pool = ForgeSlots_Average;
            cursor = p.ForgeCursor_Average;
            break;
        case ForgeQuality.rare:
            pool = ForgeSlots_Rare;
            cursor = p.ForgeCursor_Rare;
            break;
        case ForgeQuality.epic:
            pool = ForgeSlots_Epic;
            cursor = p.ForgeCursor_Epic;
            break;
    }
    if(pool.Length == 0){
        p.ForgeOffers = [];
        p.ForgeOfferIndex = 0;
        return;
    }
    Number index! = cursor % pool.Length;
    Number next! = (cursor + 1) % pool.Length;
    switch(quality){
        case ForgeQuality.average:
            p.ForgeCursor_Average = next;
            break;
        case ForgeQuality.rare:
            p.ForgeCursor_Rare = next;
            break;
        case ForgeQuality.epic:
            p.ForgeCursor_Epic = next;
            break;
    }
    p.ForgeOffers = pool[index];
    p.ForgeOfferIndex = 0;
}

ForgeQuality CurrentRoundForgeQuality():
    ForgeQuality.average;

SelectHudMode CurrentRoundSelectMode():
    MainTurnManager.Turn <= 1 ? SelectHudMode.none : (MainTurnManager.Turn % 2 == 0 ? SelectHudMode.forge : SelectHudMode.hex);

void GenerateHexOffersForPlayer(in Player p){
    if(p == null || p.IAgent == null)return;
    HexId[] pool! = HexDefs.Map(h=>h.Id);
    if(pool.Length == 0){
        p.IAgent.HexRoundOffers = [];
        p.IAgent.HexRoundOfferIndex = 0;
        return;
    }
    HexId[] shuffled! = pool.Randomize();
    Number take! = Min(3, shuffled.Length);
    p.IAgent.HexRoundOffers = shuffled.Slice(0, take);
    p.IAgent.HexRoundOfferIndex = 0;
}

void RoundReward() 'RoundReward'{
    SelectHudMode mode! = CurrentRoundSelectMode();
    foreach(Player p! in AllPlayers()){
        if(p == null || p.IAgent == null)continue;
        if(mode == SelectHudMode.forge){
            GenerateForgeOffersForPlayer(p, CurrentRoundForgeQuality());
            p.IAgent.HexRoundOffers = [];
            p.IAgent.HexRoundOfferIndex = 0;
            p.CurrentSelectHudMode = p.ForgeOffers.Length > 0 ? SelectHudMode.forge : SelectHudMode.none;
        }else if(mode == SelectHudMode.hex){
            GenerateHexOffersForPlayer(p);
            p.ForgeOffers = [];
            p.ForgeOfferIndex = 0;
            p.CurrentSelectHudMode = p.IAgent.HexRoundOffers.Length > 0 ? SelectHudMode.hex : SelectHudMode.none;
        }else{
            p.ForgeOffers = [];
            p.ForgeOfferIndex = 0;
            p.IAgent.HexRoundOffers = [];
            p.IAgent.HexRoundOfferIndex = 0;
            p.CurrentSelectHudMode = SelectHudMode.none;
        }
        MinWait();
    }
}

rule: '准备回合交互打开锻体菜单'
