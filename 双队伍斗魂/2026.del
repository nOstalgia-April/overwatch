// -------------------------------------------------------
// Flip v3 - Step(player, targetSide)
// -------------------------------------------------------
Number Flip_StepWait: 1;
struct FlipRosterEntry {
    public Any Identity;
    public Team TargetTeam;
}
globalvar FlipRosterEntry[] Flip_Roster! = [];
globalvar Squad[] Flip_PendingSquads! = [];
globalvar Boolean Flip_Executing! = false;

Boolean Flip_InScope(in Player p){
    return Flip_Roster.Map(entry => entry.Identity).Contains(GetIdentity(p));
}

Team Flip_DesiredTeam(in Player p){
    if(p == null || p.IAgent == null)return null;
    Number idx! = Flip_Roster.Map(entry => entry.Identity).IndexOf(p.IAgent.Identity);
    if(idx == -1)return null;
    return Flip_Roster[idx].TargetTeam;
}

Boolean Flip_RosterSatisfied(){
    for(define i! = 0; i < Flip_Roster.Length; i++){
        FlipRosterEntry entry! = Flip_Roster[i];
        Player p! = Flip_FindPlayerByIdentity(entry.Identity);
        if(p == null)return false;
        if(TeamOf(p) != entry.TargetTeam)return false;
    }
    return true;
}

Player Flip_FindPlayerByIdentity(in Any id){
    foreach(Player p! in AllPlayers()){
        if(p == null || p.IAgent == null)continue;
        if(p.IAgent.Identity == id)return p;
    }
    return null;
}

void Flip_BuildPendingFromPairings(in Squad[][] pairings){
    Flip_PendingSquads = [];
    foreach(Squad s! in Squads){
        if(s == null)continue;
        s.PendingSide = null;
    }

    foreach(Squad[] pairing! in pairings){
        if(pairing == null || pairing.Length < 2)continue;
        Squad home! = pairing[0];
        Squad away! = pairing[1];
        if(home == null || away == null)continue;
        if(home.Side != away.Side)continue;

        Squad mover!;
        if(home.FlipCount < away.FlipCount){
            mover = home;
        }else if(away.FlipCount < home.FlipCount){
            mover = away;
        }else{
            mover = home.ID <= away.ID ? home : away;
        }

        Team target! = OppositeTeamOf(mover.Side);
        if(target == null)continue;
        mover.PendingSide = target;

        if(!Flip_PendingSquads.Contains(mover)){
            Flip_PendingSquads += mover;
        }

    }
}

void Flip_BuildRosterFromPairings(in Squad[][] pairings){
    Flip_Roster = [];

    foreach(Squad[] pairing! in pairings){
        if(pairing == null || pairing.Length < 2)continue;
        Squad home! = pairing[0];
        Squad away! = pairing[1];
        if(home == null || away == null)continue;

        Team homeTarget! = (home.PendingSide != null && home.PendingSide != home.Side)
            ? home.PendingSide : home.Side;
        foreach(Agent a! in home.Members){
            if(a == null)continue;
            Flip_Roster += {
                Identity: a.Identity,
                TargetTeam: homeTarget
            };
        }

        Team awayTarget! = (away.PendingSide != null && away.PendingSide != away.Side)
            ? away.PendingSide : away.Side;
        foreach(Agent a! in away.Members){
            if(a == null)continue;
            Flip_Roster += {
                Identity: a.Identity,
                TargetTeam: awayTarget
            };
        }
    }

}

void Flip_OpenWindow(){
    Flip_Executing = true;
}

void Flip_CloseWindow(){
    Flip_Executing = false;
    Flip_Roster = [];
    Flip_PendingSquads = [];
}

void Flip_Step(in Player mover, in Team targetSide){
    if(mover == null || targetSide == null)return;

    while(TeamOf(mover) != targetSide){
        Team sourceSide! = TeamOf(mover);
        if(Flip_RosterSatisfied())break;

        foreach(Player other! in AllPlayers()){
            if(other == null || other == mover)continue;
            //if(!Flip_InScope(other))continue;     

            Team otherTarget! = Flip_DesiredTeam(other);
            //if(otherTarget == null)continue;
            if(otherTarget == targetSide)continue;
            if(TeamOf(other) != targetSide)continue;

            MovePlayerToTeam(other, sourceSide, -1);
            Wait(Flip_StepWait/2);
        }
        MovePlayerToTeam(mover, targetSide, -1);
        Wait(Flip_StepWait);
    }
}

void Flip_ExecuteRosterSteps(){
    for(define i! = 0; i < Flip_Roster.Length; i++){
        FlipRosterEntry entry! = Flip_Roster[i];
        Any id! = entry.Identity;
        Team target! = entry.TargetTeam;

        while(true){
            Player mover! = Flip_FindPlayerByIdentity(id);
            if(mover != null){
                Flip_Step(mover, target);
                break;
            }
            Wait(Flip_StepWait);
        }
    }
}

void Flip_CommitPendingSides(){
    foreach(Squad s! in Flip_PendingSquads){
        if(s == null)continue;
        if(s.PendingSide != null && s.PendingSide != s.Side){
            s.Side = s.PendingSide;
            s.FlipCount++;
        }
        s.PendingSide = null;
    }

    // 新增
    foreach(Squad[] pair! in Flip_CurrentPairings){
        if(pair == null || pair.Length < 2) continue;
        Squad.Match(pair[0], pair[1]);
    }
}

Number Flip_ScopeNeedForTeam(in Team t){
    Number need! = 0;
    foreach(Player p! in AllPlayers()){
        if(!Flip_InScope(p))continue;
        Team desired! = Flip_DesiredTeam(p);
        if(desired == null)continue;
        if(desired == t && TeamOf(p) != t){
            need++;
        }
    }
    return need;
}
globalvar Squad[][] Flip_CurrentPairings! = [];
void Flip_RequestAndExecute(Squad[][] pairings)''{
    Flip_CurrentPairings = pairings;
    Flip_BuildPendingFromPairings(pairings);

    if(Flip_PendingSquads.Length == 0){
        foreach(Squad[] pair! in pairings){
            if(pair == null || pair.Length < 2) continue;
            Squad.Match(pair[0], pair[1]);
        }
        return;
    }

    Flip_BuildRosterFromPairings(pairings);

    Flip_OpenWindow();
    Flip_ExecuteRosterSteps();
    Flip_CommitPendingSides();
    Flip_CloseWindow();
}

