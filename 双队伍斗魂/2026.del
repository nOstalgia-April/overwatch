rule: '锻体HUD-互动确认'
Event.OngoingPlayer
Team.All
Player.All
if(CurrentPhase == PhaseState.Preparation)
if(CurrentSelectHudMode != SelectHudMode.none)
if(IsButtonHeld(Button: Button.Interact))
{
    if(CurrentSelectHudMode == SelectHudMode.forge){
        if(ForgeOfferIndex >= ForgeOffers.Length) ForgeOfferIndex = 0;
        if(ForgeOffers.Length > 0){
            GrantSelectedForgeToPlayer(EventPlayer());
            ForgeOffers = [];
            ForgeOfferIndex = 0;
            CurrentSelectHudMode = SelectHudMode.none;
        }
    }else if(CurrentSelectHudMode == SelectHudMode.hex){
        if(IAgent == null){
            CurrentSelectHudMode = SelectHudMode.none;
        }else{
            if(IAgent.HexRoundOfferIndex >= IAgent.HexRoundOffers.Length) IAgent.HexRoundOfferIndex = 0;
            if(IAgent.HexRoundOffers.Length > 0){
                HexId picked! = IAgent.HexRoundOffers[IAgent.HexRoundOfferIndex];
                if(!AgentHasHex(IAgent, picked)){
                    GrantHexToPlayer(EventPlayer(), picked);
                }
                IAgent.HexRoundOffers = [];
                IAgent.HexRoundOfferIndex = 0;
                CurrentSelectHudMode = SelectHudMode.none;
            }
        }
    }
    CurrentSelectHudMode = SelectHudMode.none;
    MinWait();
}

void ApplyForgeRollToPlayer(in Player p, in ForgeRoll roll){
    switch(roll.Type){
        case ShuxingType.Attack:
            p.IAgent.Shuxing.Attack.Forge += roll.AbsBonus;
            break;
        case ShuxingType.CoolDown:
            p.IAgent.Shuxing.CoolDown.Forge += roll.AbsBonus;
            break;
        case ShuxingType.Speed:
            p.IAgent.Shuxing.Speed.Forge += roll.AbsBonus;
            break;
        case ShuxingType.HealBoost:
            p.IAgent.Shuxing.HealBoost.Forge += roll.AbsBonus;
            break;
        case ShuxingType.Drain:
            p.IAgent.Shuxing.Drain.Forge += roll.AbsBonus;
            break;
        case ShuxingType.Reduction:
            p.IAgent.Shuxing.Reduction.Forge += roll.AbsBonus;
            break;
        case ShuxingType.Armor:
            p.IAgent.Shuxing.Armor.Forge += roll.AbsBonus;
            break;
        case ShuxingType.Health:
            p.IAgent.Shuxing.Health.Forge += roll.AbsBonus;
            break;
        case ShuxingType.Shields:
            p.IAgent.Shuxing.Shields.Forge += roll.AbsBonus;
            break;
    }
    RevShuxing(p);
}

void GrantSelectedForgeToPlayer(in Player p){
    ForgeRoll selected! = p.ForgeOffers[p.ForgeOfferIndex];
    p.IAgent.Forges += selected;
    ApplyForgeRollToPlayer(p, selected);
}

globalvar String[] ForgeTypeNames! = [
    '造成伤害',
    '技能急速',
    '移动速度',
    '造成治疗',
    '生命值',
    '伤害抵抗',
    '吸血',
    '护甲',
    '护盾'
];
globalvar Color[][] ForgeQualityColors! = [
    [CustomColor(255, 255, 181, 255), CustomColor(255, 255, 181, 100)],
    [CustomColor(66, 176, 255, 255), CustomColor(66, 176, 255, 100)],
    [CustomColor(210, 126, 247, 255), CustomColor(210, 126, 247, 100)]
];

String ForgeTypeName(in ShuxingType type):
    ForgeTypeNames[<Number>type];

String ForgeOfferTitleLocal(in Number idx):
    LocalPlayer().ForgeOffers.Length <= idx ? '-' : <'<1><0>', ForgeTypeName(LocalPlayer().ForgeOffers[idx].Type), LocalPlayer().ForgeOfferIndex == idx ? IconString(Icon.ArrowRight) : ''>;

Color ForgeOfferColorLocal(in Number idx):
    LocalPlayer().ForgeOffers.Length <= idx ? Color.White : InteratableColor_Local(
        Default: ForgeQualityColors[<Number>LocalPlayer().ForgeOffers[idx].Quality][1],
        Hover: ForgeQualityColors[<Number>LocalPlayer().ForgeOffers[idx].Quality][0],
        Visible: LocalPlayer().ForgeOfferIndex == idx
    );

String ForgeOfferDesLocal():
    LocalPlayer().ForgeOffers.Length == 0 ? '暂无锻体选项' : <'<0>\n++<1>\n(<2>~<3>)', ForgeTypeName(LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].Type), LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].AbsBonus, ForgeRangesByQuality(LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].Quality)[<Number>LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].Type][0], ForgeRangesByQuality(LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].Quality)[<Number>LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].Type][1]>;

String ForgeOfferDescLine1Local():
    LocalPlayer().ForgeOffers.Length == 0 || LocalPlayer().ForgeOfferIndex >= LocalPlayer().ForgeOffers.Length ? '暂无锻体选项' : ForgeTypeName(LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].Type);

String ForgeOfferDescLine2Local():
    LocalPlayer().ForgeOffers.Length == 0 || LocalPlayer().ForgeOfferIndex >= LocalPlayer().ForgeOffers.Length ? '' : <'++<0>', LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].AbsBonus>;

String ForgeOfferDescLine3Local():
    LocalPlayer().ForgeOffers.Length == 0 || LocalPlayer().ForgeOfferIndex >= LocalPlayer().ForgeOffers.Length ? '' : <'(<0>~<1>)', ForgeRangesByQuality(LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].Quality)[<Number>LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].Type][0], ForgeRangesByQuality(LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].Quality)[<Number>LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].Type][1]>;

Color ForgeCurrentMenuColorLocal():
    LocalPlayer().ForgeOffers.Length == 0 || LocalPlayer().ForgeOfferIndex >= LocalPlayer().ForgeOffers.Length ? Color.White : ForgeQualityColors[<Number>LocalPlayer().ForgeOffers[LocalPlayer().ForgeOfferIndex].Quality][0];

String HexNameById(in HexId id):
    HexDefIndex(id) == -1 ? '未知海克斯' : HexDefs[HexDefIndex(id)].Name;

String HexDescById(in HexId id):
    HexDefIndex(id) == -1 ? '暂无描述' : HexDefs[HexDefIndex(id)].Description;

HexQuality HexQualityById(in HexId id):
    HexDefIndex(id) == -1 ? HexQuality.average : HexDefs[HexDefIndex(id)].Quality;

String HexQualityTag(in HexQuality q):
    q == HexQuality.average ? '普通' : (q == HexQuality.rare ? '稀有' : (q == HexQuality.epic ? '史诗' : '传说'));

Color HexQualityColor(in HexQuality q):
    q == HexQuality.average ? CustomColor(255, 255, 181, 255) : (q == HexQuality.rare ? CustomColor(66, 176, 255, 255) : (q == HexQuality.epic ? CustomColor(210, 126, 247, 255) : CustomColor(255, 180, 80, 255)));

String HexOfferTitleLocal(in Number idx):
    LocalPlayer().IAgent == null || LocalPlayer().IAgent.HexRoundOffers.Length <= idx ? '-' : <'<2>[<0>]<1>', HexQualityTag(HexQualityById(LocalPlayer().IAgent.HexRoundOffers[idx])), HexNameById(LocalPlayer().IAgent.HexRoundOffers[idx]), LocalPlayer().IAgent.HexRoundOfferIndex == idx ? IconString(Icon.ArrowRight) : ''>;

String HexOfferDescLine1Local():
