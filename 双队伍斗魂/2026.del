if(CurrentPhase == PhaseState.Combat)
if(IsAlive())
if(Teammate != null)
if(IsDead(Teammate))
if(Teammate.Revivable)
if(DistanceBetween(EventPlayer(), Teammate) <= 5)
if(InSameActivePair(EventPlayer(), Teammate))
{
        Teammate.RevivePercent += 3.5;
        Wait(0.25);
