// -------------------------------------------------------
// FireRing
// -------------------------------------------------------
Number FireRingTickInterval: 1;
Number FireRingShrinkInterval: 5;
Number FireRingShrinkAmount: 3;
Number FireRingBaseDamage: 50;
Number FireRingDamagePerTick: 20;
Color FireRingVisualColor: Color.Blue;

globalvar Boolean FireRingActive! = false;
globalvar Boolean FireRingShrinkLoopRunning! = false;
globalvar Boolean FireRingVisualInited! = false;
globalvar Number FireRingTickCount! = 0;
globalvar Number[] FireRingsRadius! = [];

void FireRing_InitPlayerToggles(in Player p){
    p.FireRingToggles = [];
    for(define i! = 0; i < Areas_static.Length; i++){
        p.FireRingToggles[p.FireRingToggles.Length] = false;
    }
}

void FireRing_ResetPlayerToggles(Player p){
    if(p.FireRingToggles.Length != Areas_static.Length){
        FireRing_InitPlayerToggles(p);
        return;
    }
    for(define i! = 0; i < p.FireRingToggles.Length; i++){
        p.FireRingToggles[i] = false;
    }
}

Boolean FireRing_LocalVisible(in Number areaIndex){
    return LocalPlayer().FireRingToggles[areaIndex];
}

void FireRing_CreateVisuals(){
    if(FireRingsRadius.Length != Areas_static.Length){
        FireRingsRadius = Areas_static.Map(a=>a.Radius);
    }

    for(define i! = 0; i < Areas_static.Length; i++){
        CreateEffect(
            VisibleTo: FireRingActive && FireRing_LocalVisible(EvaluateOnce(i)) ? LocalPlayer() : null,
            Type: Effect.Sphere,
            Color: FireRingVisualColor,
            Position: Areas_static[EvaluateOnce(i)].Center,
            Radius: FireRingsRadius[EvaluateOnce(i)],
            Reevaluation: EffectRev.VisibleToPositionRadiusAndColor
        );
        MinWait();
    }
}

void FireRing_SyncPlayerToggles(Player p)''{
    FireRing_ResetPlayerToggles(p);
    Number areaIndex! = FireRing_GetAreaIndex(p);
    if(areaIndex != -1){
        p.FireRingToggles[areaIndex] = true;
    }
}

void FireRing_SyncAllPlayersToggles(){
    foreach(Player p! in AllPlayers()){
        FireRing_SyncPlayerToggles(p);
    }
}

void FireRing_EndRound(){
    FireRingActive = false;
    foreach(Squad s! in Squads){
        if(s == null)continue;
        s.CurAreaIndex = -1;
    }
    FireRing_SyncAllPlayersToggles();
}

void FireRing_BeginRound(){
    FireRingTickCount = 0;
    FireRingsRadius = Areas_static.Map(a=>a.Radius);

    Boolean hasAssignedArea! = false;
    foreach(Squad s! in Squads){
        if(s == null)continue;
        if(s.CurAreaIndex >= 0){
            hasAssignedArea = true;
            break;
        }
    }
    if(!hasAssignedArea)return;

    FireRingActive = true;
    FireRing_SyncAllPlayersToggles();
    async! FireRing_StartShrinkLoop();
}

void FireRing_StartShrinkLoop()"FireRing_ShrinkLoop"{
    if(FireRingShrinkLoopRunning)return;
    FireRingShrinkLoopRunning = true;

    while(FireRingActive){
        Wait(FireRingShrinkInterval);
        if(!FireRingActive)break;
        FireRing_ApplyShrink();
    }

    FireRingShrinkLoopRunning = false;
}

void FireRing_ApplyShrink(){
    FireRingTickCount++;
    if(FireRingShrinkAmount <= 0)return;
    for(define i! = 0; i < FireRingsRadius.Length; i++){
        if(FireRingsRadius[i] > 0){
            FireRingsRadius[i] = Max(0, FireRingsRadius[i] - FireRingShrinkAmount);
        }
    }
}

Number FireRing_CurrentDamage():
    FireRingBaseDamage + FireRingTickCount * FireRingDamagePerTick;

Number FireRing_GetAreaIndex(in Player p){
    Squad squad! = p.IAgent == null ? null : p.IAgent.Squad;
    if(squad == null)return -1;

    Number idx! = squad.CurAreaIndex;
    if(idx < 0)return -1;
    if(idx >= Areas_static.Length)return -1;
    if(idx >= FireRingsRadius.Length)return -1;
    return idx;
}

Boolean FireRing_PlayerOutside(in Player p, in Number areaIndex):
    DistanceBetween(p, Areas_static[areaIndex].Center) > FireRingsRadius[areaIndex];

Number FireRing_AssignedSquadCount():
    Squads.Filter(s=>s != null && s.CurAreaIndex >= 0).Length;

