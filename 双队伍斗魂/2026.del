}

globalvar Color[] SquadColors! = [Color.Red, Color.Blue, Color.Yellow, Color.Green, Color.Purple, Color.Orange, Color.Rose, Color.Black];
class Squad{
    public Number ID;
    public Agent[] Members;
    public Team Side;
    public Number Health;
    public Number ByeCount;
    public Team PendingSide;    // 新增
    public Number FlipCount;    // 新增
    public Number[] AreaHistory;
    public Number CurAreaIndex;
    public Color Color;
    public Squad OppSquad;
    public Squad[] OppHistory;

    public constructor(in Agent[] members = [], in Team side, in Number health = 100){
        Members = members;
        Health = health;
        ByeCount = 0;
        Side = side;
        AreaHistory = [];
        CurAreaIndex = -1;
        OppHistory = [];

        ID = Squads.Length+1;
        Color = SquadColors[ID-1];
        HUDcreater();

        Squads += this;

        SyncSquad();
    }

    public void SyncSquad(){
        foreach(Agent a! in Members){
            a.Squad = this;
            a.UpdateEntity();
            Agent mate! = Members.Filter(t=>t != a).First;
            a.Teammate = mate;
            a.Entity.Teammate = mate == null ? null : mate.Entity;
        }
    }

    public static void Match(in Squad a, in Squad b){
        a.OppSquad = b;
        b.OppSquad = a;

        a.OppHistory += b;
        b.OppHistory += a;
    }

    public void HUDcreater(){
        //<序号> 《生命值》：
    //人员1英雄头像+人员1
    //人员2英雄头像+人员2
    //——————————
    Squad that! : EvaluateOnce(this);
    CreateHudText(
        Text: 
        <'————\n队伍<0> 生命<1>:\n\n<2>\n<3>\n',
        that.ID,
        that.Health,
        that.Members.Length > 0 && that.Members[0] != null && EntityExists(that.Members[0].Entity)?<'<0><1>',HeroIconString(HeroOf(that.Members[0].Entity)),that.Members[0].Entity>:'',
        that.Members.Length > 1 && that.Members[1] != null && EntityExists(that.Members[1].Entity)?<'<0><1>',HeroIconString(HeroOf(that.Members[1].Entity)),that.Members[1].Entity>:''
        >,
        Location: Location.Right,
        TextColor: that.Color,
        Reevaluation: HudTextRev.VisibleToSortOrderStringAndColor,
        SortOrder: that.Health*-1
    );
    }
}

