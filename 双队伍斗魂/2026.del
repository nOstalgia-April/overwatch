void InitReviveUIForPlayer(in Player p){
    CreateEffect(
        VisibleTo: EntityExists(EvaluateOnce(p).Teammate) && IsDead(EvaluateOnce(p)) && EvaluateOnce(p).Revivable ? EvaluateOnce(p).Teammate : null,
        Type: Effect.Ring,
        Color: Color.Orange,
        Position: PositionOf(EvaluateOnce(p)),
        Radius: 5,
        Reevaluation: EffectRev.VisibleToPositionRadiusAndColor
    );
    CreateProgressBarInWorldText(
        VisibleTo: EntityExists(EvaluateOnce(p).Teammate) && IsDead(EvaluateOnce(p)) && EvaluateOnce(p).Revivable && IsAlive(EvaluateOnce(p).Teammate) && DistanceBetween(EvaluateOnce(p), EvaluateOnce(p).Teammate) <= 5 ? EvaluateOnce(p).Teammate : null,
        Value: EvaluateOnce(p).RevivePercent,
        Text: <'<0>复活进', HeroIconString(HeroOf(EvaluateOnce(p)))>,
        Position: PositionOf(EvaluateOnce(p)) + Vector(0, 1, 0),
        Scale: 1,
        Clipping: Clipping.DoNotClip,
        TextColor: Color.Orange,
        ProgressBarColor: GradientColor([54,133,2], [255,79,35], EvaluateOnce(p).RevivePercent / 100),
        Reevaluation: ProgressBarWorldEvaluation.VisibleToPositionValuesAndColor
    );
    CreateInWorldText(
        VisibleTo: EntityExists(EvaluateOnce(p).Teammate) && IsDead(EvaluateOnce(p)) && EvaluateOnce(p).Revivable ? EvaluateOnce(p).Teammate : null,
        Header: <'<2>-<0>: <1>%', HeroIconString(HeroOf(EvaluateOnce(p))), EvaluateOnce(p).RevivePercent, AbilityIconString(Hero.Mercy, Button.Ability2)>,
        Position: PositionOf(EvaluateOnce(p)) + Vector(0, 2, 0),
        Scale: 1.5,
        Clipping: Clipping.ClipAgainstSurfaces,
        Reevaluation: InworldTextRev.VisibleToPositionStringAndColor,
        TextColor: Color.Yellow
    );
}

