enum PhaseState{
    Idle,
    Preparation,
    Combat
}

globalvar PhaseState CurrentPhase = PhaseState.Idle;
globalvar Number PrepareDuration = 30;
globalvar Number CombatDuration = 40;
globalvar Number PhaseDeadline = 0;
globalvar Squad[][] CurrentRoundPairings = [];
globalvar Boolean DetectEnd_Running = false;
globalvar Boolean CombatOvertimeAnnounced = false;
globalvar Squad[] RoundEndedWinners = [];
globalvar Squad[] RoundEndedLosers = [];
globalvar Squad[][] RoundEndedDrawPairs = [];
Number RoundLoseHealthDeduct:
    15;

void EnterPreparationPhase(in Squad[][] pairings){
    RoundEndedWinners = [];
    RoundEndedLosers = [];
    RoundEndedDrawPairs = [];
    DetectEnd_Running = false;
    CombatOvertimeAnnounced = false;

    CurrentRoundPairings = pairings;
    CurrentPhase = PhaseState.Preparation;
    Resurrect(AllPlayers());
    FireRing_EndRound();
    Teleport(AllPlayers(), Hall);
    SetMatchTime(PrepareDuration);
    Wait(5);
    RoundReward();
}

void EnterCombatPhase(){
    CurrentPhase = PhaseState.Combat;
    CombatOvertimeAnnounced = false;
    AllPlayers().CurrentSelectHudMode = SelectHudMode.none;
    foreach(Player p! in AllPlayers()){
        if(p.isInMenu){
            CloseMenu(p);
        }
    }

    if(CurrentRoundPairings.Length == 0){
        CurrentPhase = PhaseState.Idle;
        SetMatchTime(0);
        return;
    }

    Resurrect(AllPlayers());
    AllPlayers().Revivable = true;
    AllPlayers().RevivePercent = 0;
    if(MainTurnManager.ByeSquad != null){
        BigMessage(VisibleTo: MainTurnManager.ByeSquad.Members.Map(t=>t.Entity), Header: 'Lucky 你这回合轮空');
        Kill(MainTurnManager.ByeSquad.Members.Map(t=>t.Entity));
    }
    MainTurnManager.AssignAreasAndTeleport(CurrentRoundPairings);
    FireRing_BeginRound();
    SetMatchTime(CombatDuration);
}

class TurnManager {
    public Number Turn;
    public Squad ByeSquad;
    public constructor() {
        Turn = 0;
        ByeSquad = null;
    }

    public void Advance()'Advance'{
        DebugLog(<'[Turn] AdvanceStart Turn(before)=<0> Queue=<1> Squads=<2>', Turn, LateJoinQueue.Length, Squads.Length>);
        Turn++;
        ProcessLateJoinQueue();
        CleanupDeadSquads();
        Squad[][] pairings! = PairSquads();
        DebugLog(<'[Turn] PairDone Turn=<0> Pairings=<1> ByeSquad=<2>', Turn, pairings.Length, ByeSquad == null ? -1 : ByeSquad.ID>);
        foreach(Squad[] pair! in pairings){
            if(pair == null || pair.Length < 2)continue;
            DebugLog(<'[Turn] Pair S<0> vs S<1> Side<2>-<3> HistOpp=<4>', pair[0].ID, pair[1].ID, pair[0].Side == Team.Team1 ? 1 : 2, pair[1].Side == Team.Team1 ? 1 : 2, CountOppMatches(pair[0], pair[1])>);
        }
        Flip_RequestAndExecute(pairings);
        if(RoundStartFlipSettleDelay > 0){
            Wait(RoundStartFlipSettleDelay);
        }
        EnterPreparationPhase(pairings);
    }

    public Number CountAreaVisits(in Squad s, in Number areaIndex){
        return s.AreaHistory.Filter(i=>i == areaIndex).Length;
    }

    public Number GetPairAreaPrimary(in Squad[] pair, in Number areaIndex){
        return Min(CountAreaVisits(pair[0], areaIndex), CountAreaVisits(pair[1], areaIndex));
    }

    public Number GetPairAreaSecondary(in Squad[] pair, in Number areaIndex){
        return CountAreaVisits(pair[0], areaIndex) + CountAreaVisits(pair[1], areaIndex);
    }

    public Number[] GetPairAreaScore(in Squad[] pair, in Number areaIndex){
        return [GetPairAreaPrimary(pair, areaIndex), GetPairAreaSecondary(pair, areaIndex)];
    }

    public Number PickAreaForPair(in Squad a, in Squad b){
        Number bestIndex! = 0;
        Number bestPrimary! = 99999;
        Number bestSecondary! = 99999;
        Squad[] pair! = [a, b];

        for(define i! = 0; i < Areas_static.Length; i++){
            Number primary! = GetPairAreaPrimary(pair, i);
            Number secondary! = GetPairAreaSecondary(pair, i);

            if(primary < bestPrimary){
                bestPrimary = primary;
                bestSecondary = secondary;
                bestIndex = i;
                continue;
            }
            if(primary == bestPrimary){
                if(secondary < bestSecondary){
                    bestSecondary = secondary;
                    bestIndex = i;
                    continue;
                }
                if(secondary == bestSecondary && i < bestIndex){
                    bestIndex = i;
                }
            }
        }
        return bestIndex;
    }

    public Number[] PickUniqueAreasForRound(in Squad[][] pairings){
        Number pairCount! = pairings.Length;
        Number areaCount! = Areas_static.Length;
        Number[] bestAssign! = [];
        Number bestPrimary! = 99999;
        Number bestSecondary! = 99999;

        if(pairCount == 0)return [];
        if(pairCount > areaCount){
            return [];
        }

        if(pairCount == 1){
            for(define i! = 0; i < areaCount; i++){
                Number primary! = GetPairAreaPrimary(pairings[0], i);
                Number secondary! = GetPairAreaSecondary(pairings[0], i);

                if(
                    bestAssign.Length == 0
                    || primary < bestPrimary
                    || (primary == bestPrimary && (secondary < bestSecondary || (secondary == bestSecondary && i < bestAssign[0])))
                ){
                    bestPrimary = primary;
                    bestSecondary = secondary;
                    bestAssign = [i];
                }
            }
            return bestAssign;
        }

        if(pairCount == 2){
            for(define i! = 0; i < areaCount; i++){
                for(define j! = 0; j < areaCount; j++){
                    if(j == i)continue;
                    Number primary! = GetPairAreaPrimary(pairings[0], i) + GetPairAreaPrimary(pairings[1], j);
                    Number secondary! = GetPairAreaSecondary(pairings[0], i) + GetPairAreaSecondary(pairings[1], j);

                    if(
                        bestAssign.Length == 0
                        || primary < bestPrimary
                        || (
                            primary == bestPrimary
                            && (
                                secondary < bestSecondary
                                || (
                                    secondary == bestSecondary
                                    && (
                                        i < bestAssign[0]
                                        || (i == bestAssign[0] && j < bestAssign[1])
                                    )
                                )
                            )
                        )
                    ){
                        bestPrimary = primary;
                        bestSecondary = secondary;
                        bestAssign = [i, j];
                    }
                }
            }
            return bestAssign;
        }

        if(pairCount == 3){
            for(define i! = 0; i < areaCount; i++){
                for(define j! = 0; j < areaCount; j++){
                    if(j == i)continue;
                    for(define k! = 0; k < areaCount; k++){
                        if(k == i || k == j)continue;

                        Number primary! = GetPairAreaPrimary(pairings[0], i) + GetPairAreaPrimary(pairings[1], j) + GetPairAreaPrimary(pairings[2], k);
                        Number secondary! = GetPairAreaSecondary(pairings[0], i) + GetPairAreaSecondary(pairings[1], j) + GetPairAreaSecondary(pairings[2], k);

                        if(
                            bestAssign.Length == 0
                            || primary < bestPrimary
                            || (
                                primary == bestPrimary
                                && (
                                    secondary < bestSecondary
                                    || (
                                        secondary == bestSecondary
                                        && (
                                            i < bestAssign[0]
                                            || (
                                                i == bestAssign[0]
                                                && (
                                                    j < bestAssign[1]
                                                    || (j == bestAssign[1] && k < bestAssign[2])
                                                )
                                            )
                                        )
                                    )
                                )
                            )
                        ){
                            bestPrimary = primary;
                            bestSecondary = secondary;
                            bestAssign = [i, j, k];
                        }
                    }
                }
            }
            return bestAssign;
        }

        return bestAssign;
    }

    public void TeleportPairToArea(in Squad[] pair, in Number areaIndex){
        Area area! = Areas_static[areaIndex];
        foreach(Player p! in pair[0].Members.Map(a=>a.Entity)){
            Teleport(p, area.SpawnPosition1);
            MinWait();
        }
        foreach(Player p! in pair[1].Members.Map(a=>a.Entity)){
            Teleport(p, area.SpawnPosition2);
            MinWait();
        }
    }

    public void AssignAreasAndTeleport(in Squad[][] pairings){
        Number[] areaAssignments! = PickUniqueAreasForRound(pairings);
        for(define pairIdx! = 0; pairIdx < pairings.Length; pairIdx++){
            Squad[] pair! = pairings[pairIdx];
            if(pair == null || pair.Length < 2)continue;
            if(areaAssignments.Length <= pairIdx){
                continue;
            }
            Number areaIndex! = areaAssignments[pairIdx];

            pair[0].CurAreaIndex = areaIndex;
            pair[1].CurAreaIndex = areaIndex;
            pair[0].AreaHistory += areaIndex;
            pair[1].AreaHistory += areaIndex;

            TeleportPairToArea(pair, areaIndex);
        }
    }

    public Squad[] GetActiveSquads(){
        Squad[] active! = [];
        DebugLog(<'[Pair] GetActiveSquads Start Total=<0>', Squads.Length>);
        foreach(Squad s! in Squads){
            if(s == null){
                DebugLog('[Pair] Skip null squad');
                continue;
            }
            CleanupSquadMembers(s);
            if(s.Members == null || s.Members.Length == 0){
                DebugLog(<'[Pair] Skip Squad<0> empty members', s.ID>);
                continue;
            }
            if(s.Health <= 0){
                DebugLog(<'[Pair] Skip Squad<0> dead health=<1>', s.ID, s.Health>);
                continue;
            }
            active += s;
            DebugLog(<'[Pair] Active Squad<0> Side=<1> Health=<2> Members=<3> Bye=<4> OppHist=<5>', s.ID, s.Side == Team.Team1 ? 1 : 2, s.Health, s.Members.Length, s.ByeCount, s.OppHistory.Length>);
        }
        DebugLog(<'[Pair] GetActiveSquads End Active=<0>', active.Length>);
        return active;
    }

    public Number CountOppMatches(in Squad a, in Squad b){
        return a.OppHistory.Filter(t=>t == b).Length;
    }

    public Squad SelectByeSquad(in Squad[] candidates){
        if(candidates == null || candidates.Length == 0)return null;
        Squad best! = candidates[0];
        DebugLog(<'[Pair] SelectBye Start Candidates=<0> First=S<1>', candidates.Length, best.ID>);
        foreach(Squad s! in candidates){
            DebugLog(<'[Pair] ByeCandidate S<0> Bye=<1> Health=<2> Side=<3>', s.ID, s.ByeCount, s.Health, s.Side == Team.Team1 ? 1 : 2>);
            if(s.ByeCount < best.ByeCount){
                best = s;
                DebugLog(<'[Pair] ByeBestUpdate S<0> reason=lowerBye', best.ID>);
                continue;
            }
            if(s.ByeCount == best.ByeCount && s.ID < best.ID){
                best = s;
                DebugLog(<'[Pair] ByeBestUpdate S<0> reason=lowerID', best.ID>);
            }
        }
        DebugLog(<'[Pair] SelectBye End Best=S<0> Bye=<1>', best.ID, best.ByeCount>);
        return best;
    }

    public Number ScorePairing(in Squad a, in Squad b){
        Number opp! = CountOppMatches(a, b);
        Number sameSidePenalty! = a.Side == b.Side ? 100 : 0;
        Number idPart! = a.ID + b.ID;
        Number score! = opp * 1000 + sameSidePenalty + idPart;
        DebugLog(<'[Pair][Score] S<0>-S<1> opp=<2> samePenalty=<3> idPart=<4> raw=<5>', a.ID, b.ID, opp, sameSidePenalty, idPart, score>);
        return score;
    }

    public Squad[][] EnumerateBestMatchings(in Squad[] squads){
        Number n! = squads.Length;
        DebugLog(<'[Pair] Enumerate Start N=<0>', n>);

        if(n == 0){
            DebugLog('[Pair] Enumerate N=0 return []');
            return [];
        }

        if(n == 2){
            DebugLog(<'[Pair] Enumerate N=2 => S<0> vs S<1>', squads[0].ID, squads[1].ID>);
            return [[squads[0], squads[1]]];
        }

        if(n == 4){
            Squad[][] candidates! = [
                [squads[0], squads[1]],
                [squads[0], squads[2]],
                [squads[0], squads[3]]
            ];
            Squad[][] partners! = [
                [squads[2], squads[3]],
                [squads[1], squads[3]],
                [squads[1], squads[2]]
            ];

            Number bestIdx! = 0;
            Number bestS! = 99999999;

            for(define i! = 0; i < 3; i++){
                Number scoreA! = ScorePairing(candidates[i][0], candidates[i][1]);
                Number scoreB! = ScorePairing(partners[i][0], partners[i][1]);
                Number s! = scoreA + scoreB;
                DebugLog(<'[Pair] Enumerate4 idx=<0> pairA=S<1>-S<2> scoreA=<3> pairB=S<4>-S<5> scoreB=<6> total=<7>', i, candidates[i][0].ID, candidates[i][1].ID, scoreA, partners[i][0].ID, partners[i][1].ID, scoreB, s>);
                if(s < bestS){
                    bestS = s;
                    bestIdx = i;
                    DebugLog(<'[Pair] Enumerate4 newBest idx=<0> score=<1>', bestIdx, bestS>);
                }
            }

            DebugLog(<'[Pair] Enumerate4 result idx=<0> S<1>-S<2> | S<3>-S<4>', bestIdx, candidates[bestIdx][0].ID, candidates[bestIdx][1].ID, partners[bestIdx][0].ID, partners[bestIdx][1].ID>);
            return [candidates[bestIdx], partners[bestIdx]];
        }

        if(n == 6){
            Number bestS! = 99999999;
            Squad[][] bestResult! = [];

            for(define i! = 1; i < 6; i++){
                Squad[] rem! = squads.Slice(1, squads.Length - 1).Filter(s=>s != squads[i]);
                Squad[][] subCands! = [
                    [rem[0], rem[1]],
                    [rem[0], rem[2]],
                    [rem[0], rem[3]]
                ];
                Squad[][] subParts! = [
                    [rem[2], rem[3]],
                    [rem[1], rem[3]],
                    [rem[1], rem[2]]
                ];

                for(define j! = 0; j < 3; j++){
                    Number scoreMain! = ScorePairing(squads[0], squads[i]);
                    Number scoreSub1! = ScorePairing(subCands[j][0], subCands[j][1]);
                    Number scoreSub2! = ScorePairing(subParts[j][0], subParts[j][1]);
                    Number s! = scoreMain + scoreSub1 + scoreSub2;
                    DebugLog(<'[Pair] Enumerate6 i=<0> j=<1> main=S<2>-S<3>(<4>) sub1=S<5>-S<6>(<7>) sub2=S<8>-S<9>(<10>) total=<11>', i, j, squads[0].ID, squads[i].ID, scoreMain, subCands[j][0].ID, subCands[j][1].ID, scoreSub1, subParts[j][0].ID, subParts[j][1].ID, scoreSub2, s>);
                    if(s < bestS){
                        bestS = s;
                        bestResult = [
                            [squads[0], squads[i]],
                            subCands[j],
                            subParts[j]
                        ];
                        DebugLog(<'[Pair] Enumerate6 newBest total=<0> main=S<1>-S<2>', bestS, squads[0].ID, squads[i].ID>);
                    }
                }
            }

            DebugLog(<'[Pair] Enumerate6 result best=<0> pairCount=<1>', bestS, bestResult.Length>);
            return bestResult;
        }

        DebugLog(<'[Pair] Enumerate unsupported N=<0> return []', n>);
        return [];
    }

    public Squad[][] PairSquads(){
        Squad[] activeSquads! = GetActiveSquads().Sort(s=>s.ID);
        ByeSquad = null;
        DebugLog(<'[Pair] PairSquads Start Active=<0>', activeSquads.Length>);
        foreach(Squad s! in activeSquads){
            DebugLog(<'[Pair] ActiveSorted S<0> Side=<1> Bye=<2> Health=<3> OppHist=<4>', s.ID, s.Side == Team.Team1 ? 1 : 2, s.ByeCount, s.Health, s.OppHistory.Length>);
        }

        if(activeSquads.Length < 2){
            DebugLog('[Pair] PairSquads active<2 return []');
            return [];
        }

        if(activeSquads.Length % 2 == 1){
            ByeSquad = SelectByeSquad(activeSquads);
            if(ByeSquad != null){
                ByeSquad.ByeCount++;
                activeSquads = activeSquads.Filter(s=>s != ByeSquad);
                DebugLog(<'[Pair] Bye selected S<0> ByeCountNow=<1> Remaining=<2>', ByeSquad.ID, ByeSquad.ByeCount, activeSquads.Length>);
            }
        }

        Squad[][] pairings! = EnumerateBestMatchings(activeSquads);
        DebugLog(<'[Pair] Pairings generated=<0>', pairings.Length>);

        Number idx! = 0;
        foreach(Squad[] pair! in pairings){
            if(pair == null || pair.Length < 2)continue;
            //Squad.Match(pair[0], pair[1]);

            Team sideA! = pair[0].Side;
            Team sideB! = pair[1].Side;
            if(sideA == sideB){
                Squad mover! = pair[0].ID <= pair[1].ID ? pair[0] : pair[1];
                if(mover == pair[0]){
                    sideA = OppositeTeamOf(sideA);
                }else{
                    sideB = OppositeTeamOf(sideB);
                }
            }

            DebugLog(<'[Pair] Final#<0> S<1>(Side<2>) vs S<3>(Side<4>) OppMatchCount=<5>', idx + 1, pair[0].ID, pair[0].Side == Team.Team1 ? 1 : 2, pair[1].ID, pair[1].Side == Team.Team1 ? 1 : 2, CountOppMatches(pair[0], pair[1])>);
            idx++;
        }

        DebugLog('[Pair] PairSquads End');
        return pairings;
    }
}

globalvar TurnManager MainTurnManager = new TurnManager();

rule: '回合目标描述'
Event.OngoingGlobal
{
    SetObjectiveDescription(
        Header: <'Turn <0> | Time --', MainTurnManager.Turn>
    );
}

Boolean SquadDefeated(Squad s)'SquadDefeated'{
    if(s == null)return true;
    if(s.Members == null || s.Members.Length == 0)return true;

    foreach(Agent a! in s.Members){
        if(a == null)continue;
        Player member! = AllPlayers().Filter(p=>GetIdentity(p) == a.Identity).First;
        if(member == null)continue;
        if(IsAlive(member)||!HasSpawned(member))return false;
    }

    return true;
}

Boolean PairEnded(in Squad[] pair){
    if(pair == null || pair.Length < 2)return false;
    return SquadDefeated(pair[0]) || SquadDefeated(pair[1]);
}

Boolean PairDoubleDefeated(in Squad[] pair){
    if(pair == null || pair.Length < 2)return false;
    return SquadDefeated(pair[0]) && SquadDefeated(pair[1]);
}

Squad PairWinner(in Squad[] pair){
    if(pair == null || pair.Length < 2)return null;

    Boolean leftDefeated! = SquadDefeated(pair[0]);
    Boolean rightDefeated! = SquadDefeated(pair[1]);

    if(leftDefeated && rightDefeated)return null;
    if(leftDefeated)return pair[1];
    if(rightDefeated)return pair[0];
    return null;
}

Boolean InSameActivePair(in Player a, in Player b){
    if(a == null || b == null)return false;
    if(a.IAgent == null || b.IAgent == null)return false;
    if(a.IAgent.Squad == null || b.IAgent.Squad == null)return false;
    for(define i! = 0; i < CurrentRoundPairings.Length; i++){
        Squad[] pair! = CurrentRoundPairings[i];
        if(pair == null || pair.Length < 2)continue;
        if((pair[0] == a.IAgent.Squad && pair[1] == b.IAgent.Squad) || (pair[1] == a.IAgent.Squad && pair[0] == b.IAgent.Squad)){
            return true;
        }
    }
    return false;
}

void HandleRoundEnd(in Squad winner, in Squad loser){
    if(winner == null || loser == null)return;

    RoundEndedWinners += winner;
    RoundEndedLosers += loser;
    loser.Health = Max(0, loser.Health - RoundLoseHealthDeduct);

    BigMessage(winner.Members.Map(t=>t.Entity).Append(loser.Members.Map(t=>t.Entity)), <'队伍 <0> 击败 队伍 <1>', winner.ID, loser.ID>);
    //BigMessage(AllPlayers(), <'队伍 <0> 本回合 -<1> 生命，剩余生命 <2>', loser.ID, RoundLoseHealthDeduct, loser.Health>);
}

void HandleRoundDraw(in Squad[] pair){
    if(pair == null || pair.Length < 2)return;
    if(pair[0] == null || pair[1] == null)return;

    RoundEndedDrawPairs += pair;
    BigMessage(AllPlayers(), <'队伍 <0> 与 队伍 <1> 同灭，记平局', pair[0].ID, pair[1].ID>);
}

void FinalizeRoundIfNoPairsLeft(){
    if(CurrentRoundPairings.Length > 0)return;
    
    FireRing_EndRound();
    CurrentPhase = PhaseState.Idle;
}

void DetectEnd()'DetectEnd'{
    if(DetectEnd_Running)return;
    if(CurrentPhase != PhaseState.Combat)return;

    DetectEnd_Running = true;

    for(define i! = 0; i < CurrentRoundPairings.Length; i++){
        Squad[] pair! = CurrentRoundPairings[i];
        if(pair == null || pair.Length < 2)continue;
        Boolean leftDefeated! = SquadDefeated(pair[0]);
        Boolean rightDefeated! = SquadDefeated(pair[1]);
        if(!leftDefeated && !rightDefeated)continue;

        if(leftDefeated && rightDefeated){
            HandleRoundDraw(pair);
            CurrentRoundPairings.ModRemoveByIndex(i);
            i--;
            continue;
        }

        Squad winner! = leftDefeated ? pair[1] : pair[0];
        Squad loser! = leftDefeated ? pair[0] : pair[1];
        HandleRoundEnd(winner, loser);
        CurrentRoundPairings.ModRemoveByIndex(i);
        if(CurrentRoundPairings.Length > 0){
            Kill(winner.Members.Map(t=>t.Entity));
            BigMessage(VisibleTo: winner.Members.Map(t=>t.Entity),'由于还有其他队伍在战斗\n进入观战');
        }
        i--;
    }

    FinalizeRoundIfNoPairsLeft();
    TryResolveGameOver();
    DetectEnd_Running = false;
}
void TryResolveGameOver(){
    if(Squads.Filter(t=>t.Health > 0).Length > 1) return;

    Squad winner! = Squads.Filter(t=>t.Health > 0).First;
    DeclareTeamVictory(winner.Members[0].Entity.Team()); 
    BigMessage(
        Header: <'恭喜 队伍<0> 获胜',winner.ID>
    );
}

