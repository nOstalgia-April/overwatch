rule: '海克斯-巨人杀手'
Event.OngoingPlayer
Team.All
Player.All
if(AgentHasHex(IAgent, HexId.JurenShashou))
if(!Hex_JurenShashouApplied)
{
    foreach(Player p! in AllPlayers().Filter(t => t != EventPlayer() && t != Teammate)){
        StartDamageModification(
            Receivers: EvaluateOnce(p),
            Damagers: EventPlayer(),
            DamagePercent: 100 + Max(75, 5 * Max((MaxHealth(EvaluateOnce(p)) - MaxHealth()) / 150, 0)),
            Reevaluation: DamageModificationRev.ReceiversDamagersAndDamagePercent
        );
        MinWait();
    }
    Hex_JurenShashouApplied = true;
}

