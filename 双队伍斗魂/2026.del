globalvar Team[] Teams! = [Team.Team1,Team.Team2];
globalvar Boolean SquadInit! = false;
globalvar Boolean StartTurnTriggered! = false;
void InitSquads(){
    Squads = [];
    foreach(Team t! in Teams){
        Agent[] agents! = GetAgentsByTeam(t);
        for(define i! = 0; i < agents.Length; i += Flip_MembersPerSquad){
            Agent[] chunk! = agents.Slice(i, Flip_MembersPerSquad).Filter(a=>a != null);
            if(chunk.Length == 0) continue;
            new Squad(chunk, t);
        }
    }
}

Agent[] GetAgentsByTeam(in Team t){
    Agent[] result! = [];
    foreach(Agent a! in Agents){
        if(a == null)continue;
        a.UpdateEntity();
        if(a.Entity == null)continue;
        if(!AllPlayers().Contains(a.Entity))continue;
        if(a.Entity.Team() != t)continue;
        if(result.Contains(a))continue;
        result += a;
    }
    return result;
}

void CleanupSquadMembers(in Squad s){
    if(s == null)return;
    Agent[] kept! = [];
    for(define i! = 0; i < s.Members.Length; i++){
        Agent a! = s.Members[i];
        if(a == null)continue;
        a.UpdateEntity();
        if(a.Entity == null)continue;
        if(!AllPlayers().Contains(a.Entity))continue;
        if(kept.Contains(a))continue;
        kept += a;
    }
    if(kept.Length != s.Members.Length){
        Number oldLen! = s.Members.Length;
        s.Members = kept;
        if(s.Members.Length > 0){
            s.SyncSquad();
        }
        DebugLog(<'[Squad] Cleanup S<0> Members <1> -> <2>', s.ID, oldLen, s.Members.Length>);
    }
}

void CleanupDeadSquads()''{
    Number before! = Squads.Length;
    Squad[] kept! = [];
    foreach(Squad s! in Squads){
        if(s == null)continue;
        CleanupSquadMembers(s);
        if(s.Members == null || s.Members.Length == 0){
            DebugLog(<'[Squad] RemoveEmpty S<0>', s.ID>);
            continue;
        }
        kept += s;
    }
    Squads = kept;
    if(before != Squads.Length){
        DebugLog(<'[Squad] CleanupDeadSquads <0> -> <1>', before, Squads.Length>);
    }
}

void ProcessLateJoinQueue()''{
    DebugLog(<'[LateJoin] Begin Queue=<0> Squads=<1>', LateJoinQueue.Length, Squads.Length>);
    SetSlowMotion(10);
    LateJoinQueue = LateJoinQueue.Filter(a => AllPlayers().Contains(a.Entity) && a.Squad == null);
    DebugLog(<'[LateJoin] AfterFilter Queue=<0>', LateJoinQueue.Length>);
    foreach(Squad s! in Squads){
        CleanupSquadMembers(s);
    }
    if(LateJoinQueue.Length > 0){
        foreach(Agent a! in LateJoinQueue){
            DebugLog(<'[LateJoin] Candidate Identity=<0> Entity=<1>', a.Identity, a.Entity>);
            Squad target! = Squads.Filter(s => s != null && s.Members.Length < Flip_MembersPerSquad).First;
            if(target != null){
                Number beforeLen! = target.Members.Length;
                target.Members += a;
                a.Squad = target;
                target.SyncSquad();
                DebugLog(<'[LateJoin] Fill Squad<0> Members <1> -> <2>', target.ID, beforeLen, target.Members.Length>);
            }else{
                new Squad([a], Team.Team1);
                DebugLog(<'[LateJoin] CreateNew Squad for Identity=<0> Side=1 Members=1', a.Identity>);
            }
        }
    }

    
    LateJoinQueue = [];
    foreach(Squad s! in Squads){
        DebugLog(<'[LateJoin] Squad<0> Side=<1> Health=<2> Members=<3> Bye=<4>', s.ID, s.Side == Team.Team1 ? 1 : 2, s.Health, s.Members.Length, s.ByeCount>);
    }
    DebugLog(<'[LateJoin] End Queue=<0> Squads=<1>', LateJoinQueue.Length, Squads.Length>);
    SetSlowMotion(100);
}

