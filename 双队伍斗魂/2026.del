rule: '海克斯-弹簧跳获得'
Event.OngoingPlayer
Team.All
Player.All
if(AgentHasHex(IAgent, HexId.TanhuangTiao))
if(!Hex_TanhuangTiaoApplied)
{
    IAgent.Shuxing.JumpVerticalSpeed.Abs += 100;
    RevShuxing();
    SmallMessage(EventPlayer(), '弹簧跳已获得');
    Hex_TanhuangTiaoApplied = true;
}

rule: '海克斯-弹簧跳减伤'
Event.OngoingPlayer
Team.All
Player.All
if(AgentHasHex(IAgent, HexId.TanhuangTiao))
if(IsJumping())
if(!Hex_TanhuangTiaoReduceOn)
{
    Hex_TanhuangTiaoReduceOn = true;
    IAgent.Shuxing.Reduction.Abs += 20;
    RevShuxing();
    WaitUntil(!IsJumping(), 10);
    IAgent.Shuxing.Reduction.Abs -= 20;
    RevShuxing();
    Hex_TanhuangTiaoReduceOn = false;
}

rule: '海克斯-爆裂射击'
Event.OnDamageDealt
Team.All
Player.All
if(AgentHasHex(IAgent, HexId.BaolieSheji))
if([Button.PrimaryFire, Button.SecondaryFire].Contains(EventAbility()))
if(PlayerHexReady(EventPlayer(), HexId.BaolieSheji))
{
    StartHexCooldown(EventPlayer(), HexId.BaolieSheji);
    Damage(PlayersWithinRadius(Victim(), 3, Team.All, RadiusLOS.SurfacesAndAllBarriers), EventPlayer(), 50);
    PlayEffect(AllPlayers(), PlayEffect.BadExplosion, Color.Red, Victim(), 3);
    Wait(0.1);
}

rule: '海克斯-断魂曲'
