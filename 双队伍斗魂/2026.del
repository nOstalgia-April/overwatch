Boolean Debug_InspectorLog!: true;

void DebugLog(Any msg)'debuglog'{
    if(Debug_InspectorLog){
        EnableInspectorRecording();
        LogToInspector(msg);
        MinWait();
        DisableInspectorRecording();
    }
}

enum HexQuality {
    average,
    rare,
    epic,
    legend
}

enum HexId {
    TiejiaPaiqikou,
    Tieyan,
    YidongHuixue,
    ZhuangtianHuixue,
    JingzhunDanmu,
    FanhuiZhanchang,
    BaolieSheji,
    BoliDapao,
    CanbaoZhili,
    ChaoyuanJuli,
    Dafamingjia,
    TanhuangTiao,
    Duanhunqu,
    Equwei,
    GangtieJuren,
    HujiaFashengqi,
    JijiuYongju,
    JurenShashou,
    Kexue,
    KongyuKexing,
    MianbaoNailao,
    ShandianYizhiqi,
    Shenshangxiansu,
    ShijianLiefeng,
    Shibukedang,
    Shoucai,
    SuoxiaoShexian,
    WangcheYiwei,
    YinliMaichong,
    YingjiXinpian,
    ZhizhuZhiyan,
    ZhongjiChongnengqi
}

// 默认 parallel struct，便于后续按字段筛选与映射。
struct HexDef {
    public HexId Id;
    public String Name;
    public String Description;
    public Hero[] AllowedHeroes;
    public HexQuality Quality;
    public Number Cooldown;
}

globalvar HexDef[] HexDefs = [];
globalvar HexId[] HexPool_Ids = [];
globalvar HexQuality[] HexPool_Qualities = [];
globalvar Boolean HexDataInitialized = false;

Number HexDefIndex(in HexId id):
    HexDefs.Map(h => h.Id).IndexOf(id);

Number AgentHexIndex(in Agent a, in HexId id):
    a == null ? -1 : a.Hexes.IndexOf(id);

Boolean AgentHasHex(in Agent a, in HexId id):
    AgentHexIndex(a, id) != -1;

Number HexBaseCooldown(in HexId id):
    HexDefIndex(id) == -1 ? 0 : HexDefs[HexDefIndex(id)].Cooldown;

Number PlayerHexCooldown(in Player p, in HexId id):
    p == null || p.IAgent == null || AgentHexIndex(p.IAgent, id) == -1 ? 0 : p.HexCurrentCooldowns[AgentHexIndex(p.IAgent, id)];

Boolean PlayerHexReady(in Player p, in HexId id):
    p != null && p.IAgent != null && AgentHexIndex(p.IAgent, id) != -1 && PlayerHexCooldown(p, id) <= 0;

void GrantHexToPlayer(in Player p, in HexId id){
    p.IAgent.Hexes += id;
    p.HexCurrentCooldowns += 0;
}

void StartHexCooldown(in Player p, in HexId id){
    Number idx : AgentHexIndex(p.IAgent, id);
    p.HexCurrentCooldowns[idx] = HexBaseCooldown(id);
}

void TickPlayerHexCooldowns(in Player p, in Number step = 0.25){
    for(define i! = 0; i < p.HexCurrentCooldowns.Length; i++){
        p.HexCurrentCooldowns[i] = Max(0, p.HexCurrentCooldowns[i] - step);
    }
}

void RebuildHexPools(){
    HexPool_Ids = HexDefs.Map(h => h.Id);
    HexPool_Qualities = HexDefs.Map(h => h.Quality);
}

HexId[] HexPoolByQuality(in HexQuality quality):
    HexPool_Ids.Filter(t => HexPool_Qualities[CurrentArrayIndex()] == quality);

