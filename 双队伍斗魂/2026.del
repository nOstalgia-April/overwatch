Team.All
Player.All
if(AgentHasHex(IAgent, HexId.BoliDapao))
if(!Hex_BoliDapaoApplied)
{
    IAgent.Shuxing.Health.Pct -= 70;
    IAgent.Shuxing.Attack.Abs += 50;
    IAgent.Shuxing.Attack.Pct += 15;
    RevShuxing();
    PlayEffect(AllPlayers(), PlayEffect.BadPickupEffect, Color.Red, EventPlayer(), 1);
    Hex_BoliDapaoApplied = true;
}

