import '塔防寻路.del';
import '塔防核心波数控制.del';
import '渐变颜色.del';
enum EnemyType{
    Null,
    Boomer,
    Archer,
    Winston,
    Mom,
    Shielder,
    Shaman,
    Pharah
}
enum ActionRole{
    Null,
    CoreAttacker,
    Harass,
    Elite,
    Boss,
    Walker
}

playervar EnemyType BotType;
playervar Player BotCombatTarget;
playervar Player[] BotTargetArray;
playervar Number BotAggroRange = 12;
playervar Number BotAttackRange = 5;
playervar ActionRole BotRole;



Boolean ReachedCore(){
    return DistanceBetween(EventPlayer(),CorePos)<=Core.Box;
}

rule: '自爆怪初始化'
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot())
if(HasSpawned())
if(BotType == EnemyType.Boomer)
{
    BotRole = ActionRole.CoreAttacker;
    DefaultSpeedPct = 60;
    CoreAttacker_Elite_DestroyAmount = 25;
    SetMaxHealth(HealthPercent: 50);
}
rule: '自爆怪抵达核心爆炸'
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot())
if(isAttackCore())
if(ReachedCore())
{
    StartForcingPlayerPosition(EventPlayer(),PositionOf());
    SetStatus(EventPlayer(),null,Status.Burning,3);
    Wait(2);
    while(IsAlive()){
        Kill(EventPlayer(),null);
        Core.HurtCore(CoreAttacker_Elite_DestroyAmount);
        Wait(0.25);
    }
}
