rule: '温斯顿初始化'
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot())
if(HasSpawned())
if(!IsGameInProgress())
if(BotType == EnemyType.Winston)
{
    BotRole = ActionRole.Harass;
    SetDamageDealt(DamageDealtPercent: 50);
}
rule: '温斯顿入战攻击'
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot())
if(HasSpawned())
if(BotType == EnemyType.Winston)
if(td_inCombat)
{
    Wait(0.500, WaitBehavior.IgnoreCondition);
    if(DistanceBetween(EyePosition(), EyePosition(EventPlayer().BotCombatTarget)) < 9 || !IsFiringPrimary(
        EventPlayer())){
            StartHoldingButton(EventPlayer(), Button.PrimaryFire);
            StopHoldingButton(EventPlayer(),Button.SecondaryFire);
            
        }
    else{
        StartHoldingButton(EventPlayer(), Button.SecondaryFire);
        StopHoldingButton(EventPlayer(),Button.PrimaryFire);
    }
    if(DistanceBetween(EyePosition(EventPlayer()), EyePosition(EventPlayer().BotCombatTarget)) < 3){
            PressButton(EventPlayer(),Button.Melee);
        }

    if(DistanceBetween(EyePosition(EventPlayer()), EyePosition(EventPlayer().BotCombatTarget)) < 40 && (DistanceBetween(
        EyePosition(EventPlayer()), EyePosition(EventPlayer().BotCombatTarget)) > 9 || AbsoluteValue(YOf(PositionOf(
        EventPlayer())) - YOf(EyePosition(EventPlayer().BotCombatTarget))) > 2) || IsUsingUltimate(EventPlayer())){
            PressButton(EventPlayer(), Button.Ability1);
        }
    
    if(UltimateChargePercent(EventPlayer()) == 100){
            PressButton(EventPlayer(), Button.Ability1);
            Wait(0.500, WaitBehavior.IgnoreCondition);
            PressButton(EventPlayer(), Button.Ultimate);
            Wait(0.500, WaitBehavior.IgnoreCondition);
            PressButton(EventPlayer(), Button.Ability1);
        }
    LoopIfConditionIsTrue();
    StopHoldingButton(EventPlayer(), Button.PrimaryFire);
    StopHoldingButton(EventPlayer(), Button.SecondaryFire);
    PressButton(EventPlayer(), Button.Reload);
}
