rule: '获取目标'
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot() && IsAlive())
if(BotAggroRange>0)
{
    BotTargetArray = AllPlayers(Team.Team2).Filter(t => IsInLineOfSight(t, EventPlayer()) && (DistanceBetween(t, EventPlayer()) <= BotAggroRange && AbsoluteValue(YOf(PositionOf(t))-YOf(PositionOf(EventPlayer())))<=3) && IsAlive(t) && HasSpawned(t)); // 筛选 12 米内可见敌人
    if (CountOf(BotTargetArray) > 0) {
        BotCombatTarget = BotTargetArray.Sort(t => DistanceBetween(t, EventPlayer()))
        .First;
    }
    Wait(0.25);
    LoopIfConditionIsTrue();
}

rule: '进入战斗后的移动控制'
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot() && IsAlive())
if(td_inCombat)
if(BotCombatTarget != null && IsAlive(BotCombatTarget))
{
    define distance : DistanceBetween(EventPlayer(), BotCombatTarget);
    StartThrottleInDirection(
        Player: EventPlayer(),
        Direction: Vector(
            distance > BotAttackRange ? 0 : EvaluateOnce(RandomValueInArray([-1,0,1])),
            0,
            distance > BotAttackRange ? 1 : EvaluateOnce(RandomValueInArray([-1,0,1]))
        ),
        Magnitude: 1,
        Relative: Relative.ToPlayer,
        Behavior: ThrottleBehavior.ReplaceExistingThrottle,
        Reevaluation: ThrottleRev.DirectionAndMagnitude
    );
    Wait(RandomReal(0.5,1), WaitBehavior.AbortWhenFalse);
    LoopIfConditionIsTrue();
}

// 规则：机器人进入战斗状态
rule: "机器人进入战斗状态"
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot() && IsAlive())
if(CountOf(BotTargetArray) > 0)
if(BotCombatTarget != null)
{
    if(BotRole==ActionRole.Harass){
        td_context = BotCombatTarget;
    }
    TowerPF_EnterCombat();
    Combat_UpdateFacing();
}
// 常量：机器人瞄准参数
Number bot_ballistic_velocity: -0.003; // 子弹轨迹补偿
Number bot_aming_accuracy: 0; // 瞄准精度（当前无随机偏移）
void Combat_UpdateFacing(){
    if(BotCombatTarget!=null){
        StartFacing(EventPlayer(),
            DirectionTowards(
                EyePosition(),
                EyePosition(BotCombatTarget) + Down() * DistanceBetween(EventPlayer(), BotCombatTarget) * 0.01 + VelocityOf(BotCombatTarget) * (DistanceBetween(EventPlayer(), BotCombatTarget) * bot_ballistic_velocity + 0.2)
                +
                DirectionFromAngles(
                    HorizontalFacingAngleOf() + RandomReal(
                        DistanceBetween(EventPlayer(), BotCombatTarget) * AbsoluteValue(bot_aming_accuracy) * -1,
                        DistanceBetween(EventPlayer(), BotCombatTarget) * AbsoluteValue(bot_aming_accuracy)
                    ),
                    VerticalFacingAngleOf() + RandomReal(
                        DistanceBetween(EventPlayer(), BotCombatTarget) * AbsoluteValue(bot_aming_accuracy) * 0.25 * -1,
                        DistanceBetween(EventPlayer(), BotCombatTarget) * AbsoluteValue(bot_aming_accuracy) * 0.25
                    )
                ) * 1
            ),
            1000,
            Relative.ToWorld,
            FacingRev.DirectionAndTurnRate
        ); // 调整机器人朝向，考虑目标速度和距离
    }
    
}
Number BotHateDuration : 10;
// 规则：机器人结束战斗，进入追踪
rule: "Harass机器人结束战斗，进入追踪"
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot() && IsAlive())
if(td_inCombat == true)
if(CountOf(BotTargetArray) == 0)
if(BotCombatTarget != null)
if(BotRole == ActionRole.Harass)
{
    Wait(1,WaitBehavior.AbortWhenFalse);
    td_inCombat = false;
    td_mode = TowerPF_Mode.PlayerHunt;
    td_context = BotCombatTarget;
    TowerPF_Recalculate();
    LoopIfConditionIsTrue();
}

rule: "AI_InitNavigation_ByRole"
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot())
if(HasSpawned())
{
    switch(BotRole)
    {
        case ActionRole.CoreAttacker:
            // 纯 coreThreat 怪（Boomer）
            TowerPF_NavigateToCore();
            DisableMovementCollisionWithPlayers(EventPlayer());
            BotAggroRange = 0;
            return;

        case ActionRole.Elite:
            // Elite：一开始也是往核心走（从当前出生点走最短路径）
            TowerPF_NavigateToCore();
            break;

        case ActionRole.Harass:
            TowerPF_NavigateToPlayer(AllLivingPlayers(Team.Team2).Random());
            break;
        // 第四种巡逻怪以后要做的话
         case ActionRole.Walker:
             TowerPF_StartRandomPatrol(); 
             break;
    }
    StartForcingPlayerOutlines(
        ViewedPlayers: EventPlayer(),
        ViewingPlayers: AllPlayers(),
        Visible: true,
        Color: Color.Orange,
        OutlineType: OutlineType.Default
    );
}

rule: 'Elite脱战回核心'
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot())
if(BotRole == ActionRole.Elite)
if(IsAlive())
if(td_inCombat)                          // 只在战斗态下检查
if(BotTargetArray.Length == 0)          // 视野内没有可攻击目标
{
    Wait(0.5, WaitBehavior.AbortWhenFalse);
    td_inCombat = false;                // 退出战斗
    BotCombatTarget = null;
    TowerPF_NavigateToCore();           // 直接回核心
    LoopIfConditionIsTrue();            // 按需：保持监测
}
playervar Number DefaultSpeedPct = 100;
playervar Number CoreAttacker_Elite_DestroyAmount;
rule: '调整移速'
Event.OngoingPlayer
Team.All
Player.All
if(DefaultSpeedPct!=100)
if(HasSpawned())
{
    SetMoveSpeed(MoveSpeedPercent: DefaultSpeedPct);
}

Boolean isAttackCore(){
    return BotRole == ActionRole.CoreAttacker || BotRole == ActionRole.Elite;
}