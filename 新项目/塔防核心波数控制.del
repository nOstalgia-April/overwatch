    ]);
    define wave9PhaseD0! = WaveDirector_CreatePhase(28, [
        WaveDirector_CreateSquad(EnemyType.Shielder, 1, 0, 0)
    ]);
    define wave9PhaseD1! = WaveDirector_CreatePhase(29, [
        WaveDirector_CreateSquad(EnemyType.Shielder, 1, 0, 3)
    ]);
