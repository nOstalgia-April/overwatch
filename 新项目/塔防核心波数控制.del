SquadConfig WaveDirector_CreateSquad(
    in EnemyType enemyType,
    in Number count,
    in Number interval,
    in Number routeId = -1
) {
    return {
        Archetype: enemyType,
        Count: count,
        Interval: interval,
        RouteId: routeId
    };
}

WavePhase WaveDirector_CreatePhase(Number startTime, SquadConfig[] squads)'��������' {
    return {
        StartTime: startTime,
        Squads: squads
    };
}
void WaveDirector_StartWave(Number waveIndex)'开始波次' {
    if(WaveConfigs.Length == 0) return;
    if(waveIndex >= WaveConfigs.Length) {
        DirectorState.IsActive = false;
        return;
    }
    define wave! = WaveConfigs[waveIndex];
    DirectorState.CurrentWaveIndex = waveIndex;
    DirectorState.CurrentPhaseIndex = 0;
    DirectorState.ActiveSquads = 0;
    DirectorState.InIntermission = false;
    DirectorState.IsActive = true;
    DirectorState.IsPaused = false;
    DirectorState.WaveCompleted = false;
    DirectorState.WaveStartTime = TotalTimeElapsed() + wave.StartDelay;
}

void WaveDirector_Update() {
    if(WaveConfigs.Length == 0) return;
    if(!DirectorState.IsActive) return;
    if(DirectorState.IsPaused) return;

    define now! = TotalTimeElapsed();

    if(DirectorState.InIntermission) {
        if(now >= DirectorState.IntermissionEndTime) {
            WaveDirector_StartWave(DirectorState.CurrentWaveIndex + 1);
        }
        return;
    }

    define wave! = WaveConfigs[DirectorState.CurrentWaveIndex];
    if(now < DirectorState.WaveStartTime) return;

    define elapsed! = now - DirectorState.WaveStartTime;

    if(DirectorState.CurrentPhaseIndex < wave.Phases.Length) {
        define phase! = wave.Phases[DirectorState.CurrentPhaseIndex];
        if(elapsed >= phase.StartTime) {
            WaveDirector_DispatchPhase(phase);
            DirectorState.CurrentPhaseIndex += 1;
        }
        return;
    }

    if(DirectorState.ActiveSquads <= 0) {
        DirectorState.WaveCompleted = true;
    }
}

void WaveDirector_DispatchPhase(in WavePhase phase) {
    foreach(SquadConfig squad in phase.Squads) {
        if(squad.Count <= 0) continue;
        Spawner_AddRequest(squad);
        DirectorState.ActiveSquads += 1;
    }
}

void WaveDirector_BeginIntermission(in Number duration) {
    if(duration <= 0) {
        DirectorState.IsActive = false;
        DirectorState.InIntermission = false;
        return;
    }
    DirectorState.InIntermission = true;
    DirectorState.IntermissionEndTime = TotalTimeElapsed() + duration;
}

void WaveDirector_OnSquadComplete() {
    if(DirectorState.ActiveSquads > 0) {
        DirectorState.ActiveSquads -= 1;
    }
}

rule: "WaveDirector Tick"
Event.OngoingGlobal
if(TD_ready)
{
    WaveDirector_Update();
    Wait(1, WaitBehavior.IgnoreCondition);
    LoopIfConditionIsTrue();
}

rule: "WaveDirector Debug Start"
Event.OngoingPlayer
Team.All
Player.All
if(EventPlayer() == HostPlayer())
if(IsButtonHeld(EventPlayer(), Button.Interact))
if(DirectorState.CurrentWaveIndex==-1)
{
    Wait(2,WaitBehavior.AbortWhenFalse);
    //WaveDirector_InitConfigs();
    WaveDirector_StartWave(0);
}

rule: '波数释放完毕，则队伍一死完了之后进入休息回合'
if(DirectorState.WaveCompleted == true)
if(NumberOfPlayers(Team.Team1) == 0)
{
    BigMessage(Header: '本关结束！进入休息阶段~');
    WaveDirector_BeginIntermission(WaveConfigs[DirectorState.CurrentWaveIndex].Intermission);
}

rule: '休息时间告示牌'
{
    CreateHudText(
        Header: '休息时间：'+(DirectorState.IntermissionEndTime-TotalTimeElapsed()).Round(),
        VisibleTo: DirectorState.InIntermission?AllPlayers():null,
        Location: Location.Top,
        Reevaluation: HudTextRev.VisibleToSortOrderStringAndColor
    );
}

rule: 'My Rule'
{
    CreateHudText(
        Header: '当前关: '+DirectorState.CurrentWaveIndex
    );
}
