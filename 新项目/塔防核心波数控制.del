void Spawner_OnSquadComplete(Number requestIndex) {
    if(requestIndex < ActiveSpawnRequests.Length){
        define req! = ActiveSpawnRequests[requestIndex];
    }
    WaveDirector_OnSquadComplete();
}

rule: "Spawner Tick"
Event.OngoingGlobal
if(TD_ready)
{
    Spawner_UpdateRequests();
    Wait(0.2, WaitBehavior.IgnoreCondition);
    LoopIfConditionIsTrue();
}

rule: "WaveDirector Bootstrap"
Event.OngoingGlobal
if(TD_ready)
{
    WaveDirector_InitConfigs();
    WaveDirector_ResetState();
}

// =========================
// WaveDirector
// =========================

void WaveDirector_InitConfigs() {
    if(WaveConfigs.Length > 0) return;

    define route0! = 0;
    define route1! = 1;
    define route2! = 2;
    define route3! = 3;
    define defaultInterval! = 0.7;
    define waveSet1! = WaveDirector_BuildWaveGroup1(route0, route1, route2, route3, defaultInterval);
    define waveSet2! = WaveDirector_BuildWaveGroup2(route0, route1, route2, route3, defaultInterval);
    define waveSet3! = WaveDirector_BuildWaveGroup3(route0, route1, route2, route3, defaultInterval);
    WaveConfigs = waveSet1 + waveSet2 + waveSet3;
}

WaveConfig[] WaveDirector_BuildWaveGroup1(
    Number route0!,
    Number route1!,
    Number route2!,
    Number route3!,
    Number defaultInterval!
)''{
        // Wave 1: introduce both paths separately, staggered push finishes with synced assault
        define wave1PhaseA1! = WaveDirector_CreatePhase(0, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 0)
        ]);
        define wave1PhaseA2! = WaveDirector_CreatePhase(1, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 0)
        ]);
        define wave1PhaseB1! = WaveDirector_CreatePhase(10, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 1)
        ]);
        define wave1PhaseB2! = WaveDirector_CreatePhase(11, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 1)
        ]);
        define wave1PhaseC1! = WaveDirector_CreatePhase(20, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 0)
        ]);
        define wave1PhaseC2! = WaveDirector_CreatePhase(21, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 0)
        ]);
        define wave1PhaseC3! = WaveDirector_CreatePhase(22, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 1)
        ]);
        define wave1PhaseC4! = WaveDirector_CreatePhase(23, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 1)
        ]);
        WaveConfig wave1! = {
            Id: 1,
            StartDelay: 2,
            Phases: [
                wave1PhaseA1,
                wave1PhaseA2,
                wave1PhaseB1,
                wave1PhaseB2,
                wave1PhaseC1,
                wave1PhaseC2,
                wave1PhaseC3,
                wave1PhaseC4
            ],
            Intermission: 18
        };

        // Wave 2: mixed pressure then staggered boomer reinforcements
        define wave2PhaseA1! = WaveDirector_CreatePhase(0, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 0),
            WaveDirector_CreateSquad(EnemyType.Archer, 1, defaultInterval, 0)
        ]);
        define wave2PhaseA2! = WaveDirector_CreatePhase(1, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 1)
        ]);
        define wave2PhaseB! = WaveDirector_CreatePhase(10, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 6, defaultInterval, 1),
            WaveDirector_CreateSquad(EnemyType.Archer, 2, defaultInterval, 1)
        ]);
        define wave2PhaseC1! = WaveDirector_CreatePhase(22, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 4, defaultInterval, 0)
        ]);
        define wave2PhaseC2! = WaveDirector_CreatePhase(23, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 4, defaultInterval, 0)
        ]);
        define wave2PhaseC3! = WaveDirector_CreatePhase(24, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 6, defaultInterval, 1)
        ]);
        define wave2PhaseC4! = WaveDirector_CreatePhase(25, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 6, defaultInterval, 1)
        ]);
        WaveConfig wave2! = {
            Id: 2,
            StartDelay: 3,
            Phases: [
                wave2PhaseA1,
                wave2PhaseA2,
                wave2PhaseB,
                wave2PhaseC1,
                wave2PhaseC2,
                wave2PhaseC3,
                wave2PhaseC4
            ],
            Intermission: 18
        };

        // Wave 3: ranged distraction, staggered boomer column, elite reinforcement
        define wave3PhaseA! = WaveDirector_CreatePhase(0, [
            WaveDirector_CreateSquad(EnemyType.Archer, 2, defaultInterval, 0),
            WaveDirector_CreateSquad(EnemyType.Boomer, 6, defaultInterval, 1)
        ]);
        define wave3PhaseB1! = WaveDirector_CreatePhase(10, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 4, defaultInterval, 0)
        ]);
        define wave3PhaseB2! = WaveDirector_CreatePhase(11, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 4, defaultInterval, 0)
        ]);
        define wave3PhaseB3! = WaveDirector_CreatePhase(12, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 6, defaultInterval, 1)
        ]);
        define wave3PhaseB4! = WaveDirector_CreatePhase(13, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 6, defaultInterval, 1)
        ]);
        define wave3PhaseC! = WaveDirector_CreatePhase(0, [
            WaveDirector_CreateSquad(EnemyType.Winston, 1, 0, 0)
        ]);
        WaveConfig wave3! = {
            Id: 3,
            StartDelay: 3,
            Phases: [
                wave3PhaseA,
                wave3PhaseB1,
                wave3PhaseB2,
                wave3PhaseB3,
                wave3PhaseB4,
                wave3PhaseC
            ],
            Intermission: 20
        };

        // Wave 4: synchronized mixed push, staggered heavy finale
        define wave4PhaseA1! = WaveDirector_CreatePhase(0, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 0),
            WaveDirector_CreateSquad(EnemyType.Archer, 1, defaultInterval, 0)
        ]);
        define wave4PhaseA2! = WaveDirector_CreatePhase(1, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 1),
            WaveDirector_CreateSquad(EnemyType.Archer, 1, defaultInterval, 1),
            WaveDirector_CreateSquad(EnemyType.Winston, 1, 0, 1)
        ]);
        define wave4PhaseB1! = WaveDirector_CreatePhase(12, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 6, defaultInterval, 0)
        ]);
        define wave4PhaseB2! = WaveDirector_CreatePhase(13, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 5, defaultInterval, 1),
            WaveDirector_CreateSquad(EnemyType.Archer, 2, defaultInterval, 1)
        ]);
        define wave4PhaseC1! = WaveDirector_CreatePhase(25, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 8, defaultInterval, 0)
        ]);
        define wave4PhaseC2! = WaveDirector_CreatePhase(26, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 8, defaultInterval, 1)
        ]);
        WaveConfig wave4! = {
            Id: 4,
            StartDelay: 3,
            Phases: [
                wave4PhaseA1,
                wave4PhaseA2,
                wave4PhaseB1,
                wave4PhaseB2,
                wave4PhaseC1,
                wave4PhaseC2
            ],
            Intermission: 25
        };

        // Wave 5: Winston harassment with staggered escort pressure
        define wave5PhaseA! = WaveDirector_CreatePhase(0, [
            WaveDirector_CreateSquad(EnemyType.Winston, 1, 0, 0),
            WaveDirector_CreateSquad(EnemyType.Boomer, 4, defaultInterval, 0)
        ]);
        define wave5PhaseB! = WaveDirector_CreatePhase(1, [
            WaveDirector_CreateSquad(EnemyType.Winston, 1, 0, 1),
            WaveDirector_CreateSquad(EnemyType.Boomer, 4, defaultInterval, 1)
        ]);
        define wave5PhaseC! = WaveDirector_CreatePhase(8, [
            WaveDirector_CreateSquad(EnemyType.Winston, 1, 0, 0)
        ]);
        define wave5PhaseD! = WaveDirector_CreatePhase(9, [
            WaveDirector_CreateSquad(EnemyType.Winston, 1, 0, 1),
            WaveDirector_CreateSquad(EnemyType.Archer, 1, defaultInterval, 1)
        ]);
        define wave5PhaseE! = WaveDirector_CreatePhase(15, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 5, defaultInterval, 0)
        ]);
        define wave5PhaseF! = WaveDirector_CreatePhase(16, [
            WaveDirector_CreateSquad(EnemyType.Boomer, 5, defaultInterval, 1)
        ]);
        define wave5PhaseG! = WaveDirector_CreatePhase(22, [
            WaveDirector_CreateSquad(EnemyType.Winston, 1, 0, 0),
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 0)
        ]);
        define wave5PhaseH! = WaveDirector_CreatePhase(23, [
            WaveDirector_CreateSquad(EnemyType.Winston, 1, 0, 1),
            WaveDirector_CreateSquad(EnemyType.Boomer, 3, defaultInterval, 1)
        ]);
        WaveConfig wave5! = {
            Id: 5,
            StartDelay: 4,
            Phases: [
                wave5PhaseA,
                wave5PhaseB,
                wave5PhaseC,
                wave5PhaseD,
                wave5PhaseE,
                wave5PhaseF,
                wave5PhaseG,
                wave5PhaseH
            ],
            Intermission: 30
        };

        return [wave1, wave2, wave3, wave4, wave5];
    }

WaveConfig[] WaveDirector_BuildWaveGroup2(
