        WaveDirector_CreateSquad(EnemyType.Mom, 1, 3, 0)
    ]);
    define wave9PhaseB0! = WaveDirector_CreatePhase(10, [
        WaveDirector_CreateSquad(EnemyType.Winston, 1, 0, 3)
    ]);
    define wave9PhaseB1! = WaveDirector_CreatePhase(11, [
        WaveDirector_CreateSquad(EnemyType.Shielder, 1, 0, 3)
    ]);
    define wave9PhaseB2! = WaveDirector_CreatePhase(12, [
        WaveDirector_CreateSquad(EnemyType.Boomer, 6, defaultInterval, 3),
        WaveDirector_CreateSquad(EnemyType.Archer, 1, defaultInterval, 3)
    ]);
    define wave9PhaseC0! = WaveDirector_CreatePhase(20, [
        WaveDirector_CreateSquad(EnemyType.Winston, 1, 0, 2)
