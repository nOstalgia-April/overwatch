import '塔防寻路.del';
import '塔防怪物.del';

globalvar CORE Core;
globalvar Number CoreHurtingIntervalTimeStamp;
class CORE {
    public Vector Pos;
    public Number Health;
    public Number Box;
    public constructor() {
        Pos = CorePos;
        Health = 2000;
        Box = 2;

        InitCoreEffect();
        InitCoreUI();
    }

    private void InitCoreEffect(){
        CreateIcon(
            Position: Pos,
            Icon: Icon.Flag,
            IconColor: Color.Green,
            ShowWhenOffscreen: false
        );
        CreateInWorldText(
            Header: Health,
            Position: Pos,
            Scale: 4,
        );
        CreateEffect(
            Type: Effect.Ring,
            Color: Color.Green,
            Position: Pos,
            Radius: Box
        );
    }
    private void InitCoreUI(){
        CreateHudText(
            Header: Health,
            Location: Location.Top,
            HeaderColor: Color.Aqua
        );
    }

    public void HurtCore(in Number value){
        Health -= value;
        OnHurt();
        Defeat();
    }

    public void Defeat()'游戏失败检测'{
        if(Health<=0){
            DeclareTeamVictory(Team.Team1);
        }
    }

    public void OnHurt()'核心受到攻击'{
        PlayEffect(
            Type: PlayEffect.BadExplosion,
            Color: Color.Red,
            Position: CorePos,
            Radius: Core.Box,
        );
        PlayEffect(
            Type: PlayEffect.DebuffImpactSound,
            Position: CorePos,
            Radius: 150,
        );
        if(CoreHurtingIntervalTimeStamp+4<TotalTimeElapsed()){
            BigMessage(Header: <'<0>核心正在被攻击<0>',IconString(Icon.Warning)>);
            CoreHurtingIntervalTimeStamp = TotalTimeElapsed();
        }
    }
}

rule: '初始化核心'
if(TD_ready)
{
    Core = new CORE();
}

    // Wave/Phase/Squad 配置结构
single struct SquadConfig {
    public EnemyType Archetype;
    public Number Count;
    public Number Interval;
    public Number RouteId;
}

single struct WavePhase {
    public Number StartTime;
    public SquadConfig[] Squads;
}

single struct WaveConfig {
    public Number Id;
    public Number StartDelay;
    public WavePhase[] Phases;
    public Number Intermission;
}

single struct SpawnRequest {
    public SquadConfig Config;
    public Number SpawnedCount;
    public Boolean IsComplete;
    public Number NextSpawnTime;
}

single struct WaveState {
    public Number CurrentWaveIndex;
    public Number CurrentPhaseIndex;
    public Number WaveStartTime;
    public Boolean IsActive;
    public Boolean InIntermission;
    public Number IntermissionEndTime;
    public Number ActiveSquads;
    public Boolean IsPaused;
    public Boolean WaveCompleted;
}

globalvar SpawnRequest[] ActiveSpawnRequests = [];
globalvar WaveConfig[] WaveConfigs = [];
globalvar WaveState DirectorState;

void WaveDirector_ResetState() {
    DirectorState.CurrentWaveIndex = -1;
    DirectorState.CurrentPhaseIndex = 0;
    DirectorState.WaveStartTime = 0;
    DirectorState.IsActive = false;
    DirectorState.InIntermission = false;
    DirectorState.IntermissionEndTime = 0;
    DirectorState.ActiveSquads = 0;
    DirectorState.IsPaused = false;
    DirectorState.WaveCompleted = false;
}

Number Spawner_AddRequest(in SquadConfig config) {
    define req! = {
        Config: config,
        SpawnedCount: 0,
        IsComplete: false,
        NextSpawnTime: TotalTimeElapsed()
    };
    ActiveSpawnRequests += req;
    return ActiveSpawnRequests.Length - 1;
}

void Spawner_UpdateRequests() {
    if(ActiveSpawnRequests.Length==0)return;
    define now! = TotalTimeElapsed();
    define idx! = 0;
    while(idx < ActiveSpawnRequests.Length)
    {
        define req! = ActiveSpawnRequests[idx];
        if(!req.IsComplete && now >= req.NextSpawnTime && NumberOfPlayers(Team.Team1)<24)
        {
            req = Spawner_SpawnImmediate(req, idx);
        }
        ActiveSpawnRequests[idx] = req;
        idx += 1;
        MinWait();
    }
}

SpawnRequest Spawner_SpawnImmediate(SpawnRequest req, in Number index) {
    define spawnPoint = TowerPF_GetSpawnPos(req.Config.RouteId);
    Spawner_SpawnEnemy(req.Config.Archetype, spawnPoint);
    req.SpawnedCount += 1;
    if(req.SpawnedCount >= req.Config.Count)
    {
        req.IsComplete = true;
        Spawner_OnSquadComplete(index);
    }
    else
    {
        req.NextSpawnTime = TotalTimeElapsed() + req.Config.Interval;
    }
    return req;
}

Player Spawner_SpawnEnemy(in EnemyType archetype, in Vector spawnPoint) {
    switch(archetype) {
        case EnemyType.Boomer:
            return Spawner_SpawnBoomer(spawnPoint);
        case EnemyType.Archer:
            return Spawner_SpawnArcher(spawnPoint);
        case EnemyType.Winston:
            return Spawner_SpawnWinston(spawnPoint);
        case EnemyType.Shielder:
            return Spawner_SpawnShielder(spawnPoint);
        case EnemyType.Mom:
            return Spawner_SpawnMom(spawnPoint);
        case EnemyType.Shaman:
            return Spawner_SpawnShaman(spawnPoint);
        case EnemyType.Pharah:
            return Spawner_SpawnPharah(spawnPoint);
        default:
            return null;
    }
}

Player Spawner_SpawnBoomer(in Vector spawnPoint) {
    define bot! = CreateDummyBot(
        Hero: Hero.Junkrat,
        Team: Team.Team1,
        Slot: -1,
        Position: spawnPoint
    );
    bot.BotType = EnemyType.Boomer;
    return bot;
}
