Number GetParam_by_index(in SkillType index){
    return Skill_Pool_Local[index].Params[Skill_Pool_Local[index].Level-1];
}
rule: '近战强化'
Event.OnDamageDealt
Team.All
Player.All
if(EventAbility()==Button.Melee)
if(Skill_Pool_Local[SkillType.MeleeBoost].Level>0)
{
    Damage(Victim(),EventPlayer(),GetParam_by_index(SkillType.MeleeBoost));
}

rule: '骚扰者流血'
Event.OnDamageDealt
Team.All
Player.All
if(EventWasCriticalHit())
if(Skill_Pool_Local[SkillType.HarassBleed].Level>0)
if(Victim().BotRole==ActionRole.CoreAttacker)
{
    StartDamageOverTime(
        Victim(),
        EventPlayer(),
        2,
        GetParam_by_index(SkillType.HarassBleed)
    );
    Wait(2,WaitBehavior.IgnoreCondition);
}

rule: '精英爆炸'
Event.OnFinalBlow
Team.All
Player.All
if(Skill_Pool_Local[SkillType.EliteExplosion].Level>0)
if(Victim().BotRole == ActionRole.Elite)
{
    Damage(
        PlayersWithinRadius(
            Center: Victim(),
            Radius: 3,
            Team: Team.Team1,
            LOSCheck: RadiusLOS.Surfaces
        ),
        EventPlayer(),
        GetParam_by_index(SkillType.EliteExplosion)
    );

    PlayEffect(
        Type: PlayEffect.BadExplosion,
        Color: Color.Red,
        Radius: 3,
        Position: Victim()
    );
}

rule: '致命强化'
Event.OnFinalBlow
Team.All
Player.All
if(Skill_Pool_Local[SkillType.CritBoost].Level>0)
if(EventWasCriticalHit())
{
    Damage(
        Victim(),
        EventPlayer(),
        GetParam_by_index(SkillType.CritBoost)
    );
}

rule: '弹匣提升'
Event.OngoingPlayer
Team.All
Player.All
if(Skill_Pool_Local[SkillType.AmmoIncrease].Level>0)
if(!IsReloading())
{
    SetMaxAmmo(EventPlayer(),0,DefaultAmmo[0]+DefaultAmmo[0]*GetParam_by_index(SkillType.AmmoIncrease)/100);
    SetMaxAmmo(EventPlayer(),1,DefaultAmmo[1]+DefaultAmmo[1]*GetParam_by_index(SkillType.AmmoIncrease)/100);
}
playervar Number[] DefaultAmmo;
rule: '弹匣提升'
Event.OngoingPlayer
Team.All
Player.All
if(HasSpawned())
{
    DefaultAmmo = [Ammo(EventPlayer(),0),Ammo(EventPlayer(),1)];
}

rule: '生命强化'
Event.OngoingPlayer
Team.All
Player.All
if(Skill_Pool_Local[SkillType.HealthBoost].Level>0)
{
    AddHealthPoolToPlayer(
        Player: EventPlayer(),
        HealthType: HealthType.Health,
        MaxHealth: GetParam_by_index(SkillType.HealthBoost),
        Recoverable: true,
        Reevaluation: true
    );
}

rule: '高速步伐'
Event.OngoingPlayer
Team.All
Player.All
if(Skill_Pool_Local[SkillType.MoveSpeedBoost].Level>0)
if(DefaultSpeedPct!=100+GetParam_by_index(SkillType.MoveSpeedBoost))
{
    DefaultSpeedPct = 100 + GetParam_by_index(SkillType.MoveSpeedBoost);
}

rule: '击杀回血'
Event.OnFinalBlow
Team.All
Player.All
if(Skill_Pool_Local[SkillType.KillRegen].Level>0)
{
    Heal(Player: EventPlayer(),EventPlayer(),GetParam_by_index(SkillType.KillRegen));
}

rule: '精英防御+骚扰者防御'
Event.OngoingPlayer
Team.All
Player.All
{
    StartDamageModification(
        Receivers: EventPlayer(),
        Damagers: AllPlayers(Team.Team1).Filter(t=>t.BotRole==ActionRole.Elite),
        DamagePercent: 100-GetParam_by_index(SkillType.EliteArmor),
        Reevaluation: DamageModificationRev.ReceiversDamagersAndDamagePercent
    );
    StartDamageModification(
        Receivers: EventPlayer(),
        Damagers: AllPlayers(Team.Team1).Filter(t=>t.BotRole==ActionRole.Harass),
        DamagePercent: 100-GetParam_by_index(SkillType.HarassArmor),
        Reevaluation: DamageModificationRev.ReceiversDamagersAndDamagePercent
    );
}