void InitCurrentSkills() {
    // ================================
    // 攻击分支（Aggressive）
    // ================================
    Skill_Pool += {
        ID: 0,
        Icon: PresetIcon.None,
        Name: "近战强化",
        Des: "你的近战伤害提高 10 / 20 / 30 / 40。",
        Level: 0,
        MaxLevel: 4,
        Hero: SkillHero.All,
        Requires: [],
        Params: [10,20,30,40]
    };

    Skill_Pool += {
        ID: 1,
        Icon: PresetIcon.None,
        Name: "骚扰者流血",
        Des: "你对【核心骚扰者】爆头时附带 20 / 30 / 40 / 50 流血（持续 2 秒）。",
        Level: 0,
        MaxLevel: 4,
        Hero: SkillHero.All,
        Requires: [0],
        Params: [20,30,40,50]
    };

    Skill_Pool += {
        ID: 2,
        Icon: PresetIcon.None,
        Name: "精英爆炸",
        Des: "你击败【精英怪】时会造成一次 20 / 40 / 60 范围爆炸伤害。",
        Level: 0,
        MaxLevel: 3,
        Hero: SkillHero.All,
        Requires: [0],
        Params: [20,40,60]
    };

    Skill_Pool += {
        ID: 3,
        Icon: PresetIcon.None,
        Name: "致命强化",
        Des: "你的爆头伤害附伤 5% / 10% / 15%。",
        Level: 0,
        MaxLevel: 3,
        Hero: SkillHero.All,
        Requires: [1],
        Params: [5,10,15]
    };

    Skill_Pool += {
        ID: 4,
        Icon: PresetIcon.None,
        Name: "弹匣提升",
        Des: "你的最大弹药提高 25% / 50% / 75% / 100%",
        Level: 0,
        MaxLevel: 3,
        Hero: SkillHero.All,
        Requires: [2],
        Params: [25,50,75,100]
    };

    Skill_Pool += {
        ID: 9,
        Icon: PresetIcon.None,
        Name: "战斗狂热",
        Des: "在你击杀敌人后的 3 秒内\n你的伤害提高 5 / 8 / 12%\n最多可叠加 3 层。",
        Level: 0,
        MaxLevel: 3,
        Hero: SkillHero.All,
        Requires: [3,4],
        Params: [5,8,12]
    };


    // ================================
    // 防御分支（Defensive）
    // ================================
    Skill_Pool += {
        ID: 5,
        Icon: PresetIcon.None,
        Name: "生命强化",
        Des: "你的生命值提高 50 / 100 / 200 / 300。",
        Level: 0,
        MaxLevel: 4,
        Hero: SkillHero.All,
        Requires: [],
        Params: [50,100,200,300]
    };

    Skill_Pool += {
        ID: 6,
        Icon: PresetIcon.None,
        Name: "高速步伐",
        Des: "你的移动速度提高 5 / 7 / 9 / 12%。",
        Level: 0,
        MaxLevel: 4,
        Hero: SkillHero.All,
        Requires: [5],
        Params: [5,7,9,12]
    };

    Skill_Pool += {
        ID: 7,
        Icon: PresetIcon.None,
        Name: "战斗续航",
        Des: "击杀一个目标会回复 3 / 5 / 8 点生命值。",
        Level: 0,
        MaxLevel: 3,
        Hero: SkillHero.All,
        Requires: [5],
        Params: [3,5,8]
    };

    Skill_Pool += {
        ID: 8,
        Icon: PresetIcon.None,
        Name: "满血护盾",
        Des: "在满血状态下持续了2s刷新 10% / 25% / 35% 临时生命值",
        Level: 0,
        MaxLevel: 3,
        Hero: SkillHero.All,
        Requires: [6,7],
        Params: [10,25,35]
    };

    Skill_Pool += {
        ID: 10,
        Icon: PresetIcon.None,
        Name: "精英防御",
        Des: "收到来自精英（例如毛妹）的伤害\n降低 10% / 15% / 30%",
        Level: 0,
        MaxLevel: 3,
        Hero: SkillHero.All,
        Requires: [6],
        Params: [10,15,30]
    };

    Skill_Pool += {
        ID: 11,
        Icon: PresetIcon.None,
        Name: "骚扰者防御",
        Des: "收到来自骚扰者（例如猩猩）的伤害\n降低 10% / 15% / 20% / 25% / 30%",
        Level: 0,
        MaxLevel: 5,
        Hero: SkillHero.All,
        Requires: [7],
        Params: [10,15,20,25,30]
    };
}


void AddCurrentSkillsButtons(){
    foreach(MenuButton_Data d in CurrentSkillButtons){
        ButtonData_Pool += d;
    }
}

