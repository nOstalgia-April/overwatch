// Rule Element Count: 321
rule("Initial Global")
{
    event
    {
        Ongoing - Global;
    }

    // Element Count: 320, Action Count: 55
    // Largest Action Index: 21 using 63 Elements
    actions
    {
        Set Global Variable(Agents, Empty Array);
        Set Global Variable(Squads, Empty Array);
        Set Global Variable At Index(_extendedGlobalCollection, 0, Empty Array);
        Set Global Variable(HexDefs_Id, Empty Array);
        Set Global Variable(HexDefs_Name, Empty Array);
        Set Global Variable(HexDefs_Description, Empty Array);
        Set Global Variable(HexDefs_AllowedHeroes, Empty Array);
        Set Global Variable(HexDefs_Quality, Empty Array);
        Set Global Variable(HexDefs_Cooldown, Empty Array);
        Set Global Variable(HexPool_Ids, Empty Array);
        Set Global Variable(HexPool_Qualities, Empty Array);
        Set Global Variable(HexDataInitialized, False);
        Set Global Variable At Index(_extendedGlobalCollection, 1, Empty Array);
        Set Global Variable At Index(_extendedGlobalCollection, 2, Array(Array(12, 22), Array(10, 20), Array(6, 12), Array(10, 18), Array(100, 180), Array(10, 20), Empty Array, Empty Array, Empty Array));
        Set Global Variable At Index(_extendedGlobalCollection, 3, Array(Empty Array, Empty Array, Empty Array, Empty Array, Empty Array, Empty Array, Empty Array, Empty Array, Empty Array));
        Set Global Variable At Index(_extendedGlobalCollection, 4, Array(Array(40, 40), Array(35, 35), Array(35, 35), Array(40, 40), Empty Array, Array(35, 35), Array(20, 20), Array(250, 250), Array(200, 200)));
        Set Global Variable At Index(_extendedGlobalCollection, 5, Empty Array);
        Set Global Variable At Index(_extendedGlobalCollection, 6, Empty Array);
        Set Global Variable At Index(_extendedGlobalCollection, 7, Empty Array);
        Set Global Variable At Index(_extendedGlobalCollection, 8, False);
        Set Global Variable At Index(_extendedGlobalCollection, 9, Array(Custom String("造成伤害"), Custom String("技能急速"), Custom String("移动速度"), Custom String("造成治疗"), Custom String("生命值"), Custom String("伤害抵抗"), Custom String("吸血"), Custom String("护甲"), Custom String("护盾")));
        Set Global Variable At Index(_extendedGlobalCollection, 10, Array(Array(Custom Color(255, 255, 181, 255), Custom Color(255, 255, 181, 100)), Array(Custom Color(66, 176, 255, 255), Custom Color(66, 176, 255, 100)), Array(Custom Color(210, 126, 247, 255), Custom Color(210, 126, 247, 100))));
        Set Global Variable At Index(_extendedGlobalCollection, 11, Array(Color(Red), Color(Blue), Color(Yellow), Color(Green), Color(Purple), Color(Orange), Color(Rose), Color(Black)));
        Set Global Variable At Index(_extendedGlobalCollection, 12, Array(Team 1, Team 2));
        Set Global Variable At Index(_extendedGlobalCollection, 13, False);
        Set Global Variable At Index(_extendedGlobalCollection, 14, False);
        Set Global Variable(CurrentPhase, 0);
        Set Global Variable(PrepareDuration, 30);
        Set Global Variable(CombatDuration, 40);
        Set Global Variable(PhaseDeadline, 0);
        Set Global Variable(CurrentRoundPairings, Empty Array);
        Set Global Variable(DetectEnd_Running, False);
        Set Global Variable(CombatOvertimeAnnounced, False);
        Set Global Variable(RoundEndedWinners, Empty Array);
        Set Global Variable(RoundEndedLosers, Empty Array);
        Set Global Variable(RoundEndedDrawPairs, Empty Array);
        Set Global Variable At Index(_classIndexes, 0, -1);
        Set Global Variable(MainTurnManager, Index Of Array Value(Global Variable(_classIndexes), 0));
        Set Global Variable(MainTurnManager, If-Then-Else(Compare(Global Variable(MainTurnManager), ==, -1), Count Of(Global Variable(_classIndexes)), Global Variable(MainTurnManager)));
        Set Global Variable At Index(_classIndexes, Global Variable(MainTurnManager), 3);
        Set Global Variable At Index(_objectVariable_0, Global Variable(MainTurnManager), 0);
        Set Global Variable At Index(_objectVariable_1, Global Variable(MainTurnManager), Null);
        Set Global Variable At Index(_extendedGlobalCollection, 15, False);
        Set Global Variable At Index(_extendedGlobalCollection, 16, False);
        Set Global Variable At Index(_extendedGlobalCollection, 17, False);
        Set Global Variable At Index(_extendedGlobalCollection, 18, 0);
        Set Global Variable At Index(_extendedGlobalCollection, 19, Empty Array);
        Set Global Variable(Flip_Roster_Identity, Empty Array);
        Set Global Variable(Flip_Roster_TargetTeam, Empty Array);
        Set Global Variable At Index(_extendedGlobalCollection, 20, Empty Array);
        Set Global Variable At Index(_extendedGlobalCollection, 21, False);
        Set Global Variable At Index(_extendedGlobalCollection, 22, Empty Array);
        Set Global Variable(Buttons, Array(Button(Ability 1), Button(Ability 2), Button(Jump), Button(Secondary Fire), Button(Crouch)));
        Set Global Variable At Index(_extendedGlobalCollection, 23, 2);
        Set Global Variable(func_group, Empty Array);
