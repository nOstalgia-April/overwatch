// Rule Element Count: 25
rule("Agent英雄初始化")
{
    event
    {
        Ongoing - Each Player;
        All;
        All;
    }

    // Element Count: 20, Condition Count: 3
    conditions
    {
        Player Variable(Event Player, IAgent) != Null;
        Has Spawned(Event Player) == True;
        Value In Array(Global Variable(_objectVariable_4), Player Variable(Event Player, IAgent)) == Null;
    }

    // Element Count: 4, Action Count: 1
    actions
    {
        Set Global Variable At Index(_objectVariable_4, Player Variable(Event Player, IAgent), Hero Of(Event Player));
    }
}

// Rule Element Count: 62
rule("中途加入检测")
{
    event
    {
        Ongoing - Each Player;
        All;
        All;
    }

    // Element Count: 39, Condition Count: 5
    conditions
    {
        Is Game In Progress == True;
        Value In Array(Global Variable(_objectVariable_0), Global Variable(MainTurnManager)) > 0;
        Player Variable(Event Player, IAgent) != Null;
        Value In Array(Global Variable(_objectVariable_2), Player Variable(Event Player, IAgent)) == Null;
        Not(Array Contains(First Of(Global Variable(_extendedGlobalCollection)), Player Variable(Event Player, IAgent))) == True;
    }

    // Element Count: 22, Action Count: 8
    // Largest Action Index: 4 using 9 Elements
    actions
    {
        Modify Global Variable At Index(_extendedGlobalCollection, 0, Append To Array, Player Variable(Event Player, IAgent));
        Kill(Event Player, Null);
        Teleport(Event Player, Global Variable(Hall));
        Set Status(Event Player, Null, Phased Out, 9999);
        While(Compare(Value In Array(Global Variable(_objectVariable_2), Player Variable(Event Player, IAgent)), ==, Null));
            Wait(0.5, Ignore Condition);
        End;
        Clear Status(Event Player, Phased Out);
    }
}

// Rule Element Count: 1445
rule("")
{
    event
    {
        Subroutine;
        ProcessLateJoinQueue;
    }

    // Element Count: 1444, Action Count: 143
    // Largest Action Index: 104 using 222 Elements
    actions
    {
        If(True);
            Enable Inspector Recording;
            Log To Inspector(Custom String("[LateJoin] Begin Queue={0} Squads={1}", Count Of(First Of(Global Variable(_extendedGlobalCollection))), Count Of(Global Variable(Squads))));
            Wait(0.016, Ignore Condition);
            Disable Inspector Recording;
        End;
        Set Slow Motion(10);
        Set Global Variable At Index(_extendedGlobalCollection, 0, Filtered Array(First Of(Global Variable(_extendedGlobalCollection)), And(Array Contains(All Players(All Teams), Value In Array(Global Variable(_objectVariable_0), Current Array Element)), Compare(Value In Array(Global Variable(_objectVariable_2), Current Array Element), ==, Null))));
        If(True);
            Enable Inspector Recording;
            Log To Inspector(Custom String("[LateJoin] AfterFilter Queue={0}", Count Of(First Of(Global Variable(_extendedGlobalCollection)))));
            Wait(0.016, Ignore Condition);
            Disable Inspector Recording;
