// Rule Element Count: 272
rule("救人")
{
    event
    {
        Ongoing - Each Player;
        All;
        All;
    }

    // Element Count: 50, Condition Count: 7
    conditions
    {
        Global Variable(CurrentPhase) == 2;
        Is Alive(Event Player) == True;
        Player Variable(Event Player, Teammate) != Null;
        Is Dead(Player Variable(Event Player, Teammate)) == True;
        Value In Array(Player Variable(Player Variable(Event Player, Teammate), _extendedPlayerCollection), 1) == True;
        Distance Between(Event Player, Player Variable(Event Player, Teammate)) <= 5;
        Player Variable(Event Player, returnValue_InSameActivePair) == True;
    }

    // Element Count: 221, Action Count: 33
    // Largest Action Index: 18 using 71 Elements
    actions
    {
        If(Or(Compare(Event Player, ==, Null), Compare(Player Variable(Event Player, Teammate), ==, Null)));
            Set Player Variable(Event Player, returnValue_InSameActivePair, False);
            Skip(22);
        End;
        If(Or(Compare(Player Variable(Event Player, IAgent), ==, Null), Compare(Player Variable(Player Variable(Event Player, Teammate), IAgent), ==, Null)));
            Set Player Variable(Event Player, returnValue_InSameActivePair, False);
            Skip(18);
        End;
        If(Or(Compare(Value In Array(Global Variable(_objectVariable_2), Player Variable(Event Player, IAgent)), ==, Null), Compare(Value In Array(Global Variable(_objectVariable_2), Player Variable(Player Variable(Event Player, Teammate), IAgent)), ==, Null)));
            Set Player Variable(Event Player, returnValue_InSameActivePair, False);
            Skip(14);
        End;
        Set Player Variable At Index(Event Player, _extendedPlayerCollection, 50, 0);
        While(Compare(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 50), <, Count Of(Global Variable(CurrentRoundPairings))));
            Set Player Variable At Index(Event Player, _extendedPlayerCollection, 51, Value In Array(Global Variable(CurrentRoundPairings), Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 50)));
            If(Or(Compare(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 51), ==, Null), Compare(Count Of(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 51)), <, 2)));
                Skip(5);
            End;
            If(Or(And(Compare(First Of(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 51)), ==, Value In Array(Global Variable(_objectVariable_2), Player Variable(Event Player, IAgent))), Compare(Value In Array(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 51), 1), ==, Value In Array(Global Variable(_objectVariable_2), Player Variable(Player Variable(Event Player, Teammate), IAgent)))), And(Compare(Value In Array(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 51), 1), ==, Value In Array(Global Variable(_objectVariable_2), Player Variable(Event Player, IAgent))), Compare(First Of(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 51)), ==, Value In Array(Global Variable(_objectVariable_2), Player Variable(Player Variable(Event Player, Teammate), IAgent))))));
                Set Player Variable(Event Player, returnValue_InSameActivePair, True);
                Skip(4);
            End;
            Modify Player Variable At Index(Event Player, _extendedPlayerCollection, 50, Add, 1);
        End;
        Set Player Variable(Event Player, returnValue_InSameActivePair, False);
        Modify Player Variable At Index(Player Variable(Event Player, Teammate), _extendedPlayerCollection, 0, Add, 3.5);
        Wait(0.25, Ignore Condition);
        Loop If Condition Is True;
        If(And(Compare(First Of(Player Variable(Player Variable(Event Player, Teammate), _extendedPlayerCollection)), >=, 100), Value In Array(Player Variable(Player Variable(Event Player, Teammate), _extendedPlayerCollection), 1)));
            Set Player Variable At Index(Player Variable(Event Player, Teammate), _extendedPlayerCollection, 1, False);
            Resurrect(Player Variable(Event Player, Teammate));
            Set Status(Player Variable(Event Player, Teammate), Null, Invincible, 1);
        End;
    }
}

