        Set Facing(Event Player, Player Variable(Event Player, AnchorFacing), To World);
    }
}

// Rule Element Count: 79
rule("按钮点击")
{
    event
    {
        Ongoing - Each Player;
        All;
        All;
    }

    // Element Count: 11, Condition Count: 1
    conditions
    {
        And(Player Variable(Event Player, isInMenu), Is Button Held(Event Player, Button(Primary Fire))) == True;
    }

    // Element Count: 67, Action Count: 7
    // Largest Action Index: 1 using 37 Elements
    actions
    {
        If(Compare(Player Variable(Event Player, MenuLoop), !=, 0));
            Set Player Variable At Index(Event Player, _extendedPlayerCollection, 68, First Of(Filtered Array(Global Variable(Button_Pool), And(And(Array Contains(Value In Array(Value In Array(Global Variable(_objectVariable_1), Current Array Element), 4), Player Variable(Event Player, menuactive)), Compare(Value In Array(Value In Array(Global Variable(_objectVariable_1), Current Array Element), 5), ==, Player Variable(Event Player, MenuLoop))), Value In Array(Value In Array(Global Variable(_objectVariable_1), Current Array Element), 3)))));
            If(Compare(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 68), !=, Null));
                Modify Global Variable(func_group, Append To Array, Array(Value In Array(Global Variable(_objectVariable_2), Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 68))));
                Call Subroutine(func_group);
            End;
        End;
    }
}

