// Rule Element Count: 100
rule("sub打开菜单")
{
    event
    {
        Subroutine;
        OpenMenu;
    }

    // Element Count: 99, Action Count: 13
    // Largest Action Index: 11 using 18 Elements
    actions
    {
        Set Player Variable(Value In Array(Global Variable(_extendedGlobalCollection), 225), menuactive, Global Variable(name));
        If(Not(Player Variable(Value In Array(Global Variable(_extendedGlobalCollection), 225), isInMenu)));
            Set Facing(Value In Array(Global Variable(_extendedGlobalCollection), 225), Direction From Angles(Horizontal Angle From Direction(Facing Direction Of(Value In Array(Global Variable(_extendedGlobalCollection), 225))), 0), To World);
            Set Player Variable(Value In Array(Global Variable(_extendedGlobalCollection), 225), AnchorFacing, Facing Direction Of(Value In Array(Global Variable(_extendedGlobalCollection), 225)));
            Set Player Variable(Value In Array(Global Variable(_extendedGlobalCollection), 225), isInMenu, True);
            Set Aim Speed(Value In Array(Global Variable(_extendedGlobalCollection), 225), 0.1);
            Set Primary Fire Enabled(Value In Array(Global Variable(_extendedGlobalCollection), 225), False);
            Set Secondary Fire Enabled(Value In Array(Global Variable(_extendedGlobalCollection), 225), False);
            Disable Hero HUD(Value In Array(Global Variable(_extendedGlobalCollection), 225));
            Disable Game Mode HUD(Value In Array(Global Variable(_extendedGlobalCollection), 225));
        End;
        Skip(Value In Array(Array(0, 0, 0), Add(Index Of Array Value(Array(0, 1), Global Variable(name)), 1)));
        Set Facing(Value In Array(Global Variable(_extendedGlobalCollection), 225), Player Variable(Value In Array(Global Variable(_extendedGlobalCollection), 225), AnchorFacing), To World);
    }
}

// Rule Element Count: 20
rule("lambda")
{
    event
    {
        Subroutine;
        func_group;
    }

    // Element Count: 19, Action Count: 2
    // Largest Action Index: 0 using 13 Elements
    actions
    {
        Skip(Value In Array(Array(0), Add(Index Of Array Value(Empty Array, First Of(Last Of(Global Variable(func_group)))), 1)));
        Modify Global Variable(func_group, Remove From Array By Index, Subtract(Count Of(Global Variable(func_group)), 1));
    }
}
