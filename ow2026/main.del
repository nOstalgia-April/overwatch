// Rule Element Count: 158
rule("准备回合交互打开锻体菜单")
{
    event
    {
        Ongoing - Each Player;
        All;
        All;
    }

    // Element Count: 23, Condition Count: 3
    conditions
    {
        Global Variable(CurrentPhase) == 1;
        Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 26) != 0;
        Is Button Held(Event Player, Button(Primary Fire)) == True;
    }

    // Element Count: 134, Action Count: 20
    // Largest Action Index: 15 using 19 Elements
    actions
    {
        If(Compare(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 26), ==, 1));
            If(Compare(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 25), >=, Count Of(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 24))));
                Set Player Variable At Index(Event Player, _extendedPlayerCollection, 25, 0);
            End;
            If(Compare(Count Of(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 24)), >, 0));
                Set Player Variable At Index(Event Player, _extendedPlayerCollection, 25, Modulo(Add(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 25), 1), Count Of(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 24))));
            End;
        Else If(Compare(Value In Array(Player Variable(Event Player, _extendedPlayerCollection), 26), ==, 2));
            If(Compare(Player Variable(Event Player, IAgent), ==, Null));
                Set Player Variable At Index(Event Player, _extendedPlayerCollection, 26, 0);
            Else;
                If(Compare(Value In Array(Global Variable(_objectVariable_8), Player Variable(Event Player, IAgent)), >=, Count Of(Value In Array(Global Variable(_objectVariable_7), Player Variable(Event Player, IAgent)))));
                    Set Global Variable At Index(_objectVariable_8, Player Variable(Event Player, IAgent), 0);
                End;
                If(Compare(Count Of(Value In Array(Global Variable(_objectVariable_7), Player Variable(Event Player, IAgent))), >, 0));
                    Set Global Variable At Index(_objectVariable_8, Player Variable(Event Player, IAgent), Modulo(Add(Value In Array(Global Variable(_objectVariable_8), Player Variable(Event Player, IAgent)), 1), Count Of(Value In Array(Global Variable(_objectVariable_7), Player Variable(Event Player, IAgent)))));
                End;
            End;
        End;
        Wait(0.016, Ignore Condition);
    }
}

