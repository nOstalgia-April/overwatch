playervar Player PrayTarget!;
playervar Any Pray_Effect!;
class Pray:Skill{  
    public constructor(){
        Name = '治愈真言';
        Des = '腾空到空中';
        ChannelTime = 2;
        ManaCost = 10;
        Cooldown = 0;
        Type = SkillType.Channeled;
    }
    protected override void OnChannelTick() {
        if(ChannelProgress%20<1){
            PlayEffect(Type: PlayEffect.HealTargetActiveEffect,Position: PrayTarget,Radius: 1);
            PlayEffect(Type: PlayEffect.BrigitteWhipShotHealAreaSound,Position: PrayTarget,Radius: 150,VisibleTo: PrayTarget);
            PrayTarget.HealQueue[PrayTarget.HealQueue] = {Amount:10,IsCritical:false,Source:EventPlayer(),Timestamp:TotalTimeElapsed(),Type:HealType.Both,IsSustained:true};
        }
        
    }

    protected override Boolean StartChannelCondition() {
        return IsAlive(GetObject(isTeam1: false))&&GetObject(isTeam1: false)!=0;
    }
    protected override void OnChannelComplete() {
        PlayEffect(Type: PlayEffect.HealTargetActiveEffect,Position: PrayTarget,Radius: 1);
        PlayEffect(Type: PlayEffect.BrigitteWhipShotHealAreaSound,Position: PrayTarget,Radius: 150,VisibleTo: EventPlayer());
        PlayEffect(Type: PlayEffect.BuffImpactSound,Position: PrayTarget,Radius: 150,VisibleTo: EventPlayer());
        PrayTarget.HealQueue[PrayTarget.HealQueue] = {Amount:50,IsCritical:false,Source:EventPlayer(),Timestamp:TotalTimeElapsed(),Type:HealType.Both,IsSustained:false};
    }
    protected override void OnChannelStart() {
        PrayTarget = GetObject(isTeam1: false);
    }
    protected override Boolean BreakChannelCondition(){
        return IsDead(PrayTarget)||!IsInViewAngle(EventPlayer(),PrayTarget,40);
    }
    protected override void OnChannelInterrupted() {
        SmallMessage(EventPlayer(), "治疗被打断");
    }
}
class PowerStrike : Skill {

    public constructor() {
        Name = "豪火术";
        ChannelTime = 2;
        Cooldown = 3;
        ManaCost = 10;
        Type = SkillType.Channeled;
    }
    
    protected override void OnChannelComplete() {
        PlayEffect(VisibleTo: AllPlayers(),Type: PlayEffect.AsheDynamiteExplosionEffect,Position: EyePosition()+FacingDirectionOf()*2,Radius: 1);
        ApplyImpulse(Player: EventPlayer(),Direction: -1*FacingDirectionOf(),Speed: 10);
        async! Haohuoshu();
    }

    protected void Haohuoshu()'sub 豪火树持续伤害'{
        define Time! = 0;
        define Center! = EyePosition()+FacingDirectionOf()*2;
        define Victims! = PlayersWithinRadius(Center,3,Team.Team1,RadiusLOS.SurfacesAndEnemyBarriers).Filter(t=>IsAlive(t));
        ApplyImpulse(Player: Victims,Direction: FacingDirectionOf(),Speed: 10);
        SetStatus(Assister: null,Status: Status.Burning,Duration: 2,Player: Victims);
        SetStatus(Assister: null,Status: Status.KnockedDown,Duration: 0.5,Player: Victims);
        while(Time<2){
            foreach(Player p in Victims){
                AddDamageEvent(amount: 5,target: p,issustained: true,source: EventPlayer(),type: DamageType.Magical);
            }
            Time+=0.2;
            Wait(0.2);
        }
    }
}
playervar Boolean isFrenzy;
playervar Any FrenzyEffectID!;
class Frenzy : Skill {
    public constructor() {
        Name = "狂化";
        Des = "狂暴状态持续4秒，结束后虚脱3秒";
        ManaCost = 1;
        Cooldown = 8;  // 实际冷却时间（不包括虚脱时间）
        Type = SkillType.Toggle; // 保持Toggle类型
    }

    // 核心修改：技能激活时禁止再次触发
    public override Boolean CanTrigger() {
        return !IsActive;
    }

    public override void OnToggleStart() {
        isFrenzy = true;
        // 属性提升
        Shuxings.Speed.Abs += 50;
        Shuxings.CriticalRate.Abs +=50;
        RevShuxing();
        // 无敌状态
        SetStatus(EventPlayer(),null, Status.Unkillable, 4);
        
        CreateEffect(Type: Effect.LucioSoundBarrierProtectedEffect, Position: EventPlayer());
        FrenzyEffectID = LastCreatedEntity();

        // 4秒后自动关闭
        async! AutoDeactivate();
    }

    private void AutoDeactivate()'sub自动关闭' {
        Wait(4);
            DestroyEffect(FrenzyEffectID);
            
            if(IsActive){
                ActiveToggleSkills = ActiveToggleSkills.Filter(s => s != this);
                IsActive = false; // 触发OnToggleEnd
                IsToggling = false;
                CurrentCooldown = Cooldown;
                OnToggleEnd();
            }       
    }

    public override void OnToggleEnd() {
        isFrenzy = false;
        // 移除加成
        Shuxings.Speed.Abs -= 50;
        Shuxings.CriticalRate.Abs -=50;
        RevShuxing();
             
        // 虚脱效果(3秒)
        SetStatus(EventPlayer(),null, Status.Hacked, 3);
        PlayEffect(Type: PlayEffect.SombraLogoEffect, Position: EventPlayer());
    }
}

playervar define CurrentPet!;
playervar define Spell_Value1;
playervar define For1!;
playervar define Spell_Effect1!;
playervar define Spell_Value2;
playervar define Tempvar!;
playervar define Spell_Value3;
playervar define Spell_Value4!;
playervar define Spell_Pos1;
playervar define Spell_Value5!;
playervar define Spell_Pos2!;
class Slash : Skill{
    public constructor() {
        Name = "爪击";
        Des = "啊";
        ManaCost = 10;
        Cooldown = 6;  // 实际冷却时间（不包括虚脱时间）
        Type = SkillType.Instant; // 保持Toggle类型
    }

    public override void Execute(){
            Spell_Effect1 = LastCreatedEntity();
            Wait(0.1, WaitBehavior.IgnoreCondition);
            Spell_Pos2 = [1, -1][RandomReal(0, 1)];
            Spell_Pos1 = Forward();
            ChaseVariableAtRate(Spell_Pos1, EyePosition(EventPlayer()) + FacingDirectionOf(EventPlayer()) * 3, 9999, RateChaseReevaluation.DestinationAndRate);
            Spell_Value1 = Forward();
            ChaseVariableAtRate(Spell_Value1, Normalize(CrossProduct(FacingDirectionOf(EventPlayer()), Up())), 9999, RateChaseReevaluation.DestinationAndRate);
            Spell_Value2 = Forward();
            ChaseVariableAtRate(Spell_Value2, Normalize(CrossProduct(Spell_Value1, FacingDirectionOf(EventPlayer()))), 9999, RateChaseReevaluation.DestinationAndRate);
            Spell_Value3 = false;
            ChaseVariableOverTime(Spell_Value3, 2, 0.4, TimeChaseReevaluation.DestinationAndDuration);
            for (For1 = false; 3; 1)
            {
                CreateBeamEffect(LocalPlayer(), BeamType.BadBeam, Spell_Pos1 + Spell_Pos2 * Spell_Value1 * (-4 + 8 * Min(1, Spell_Value3)) * (EvaluateOnce(For1) == 1 ? 0.9 : 0.8) + Spell_Value2 * ([0.5, 1.15, 1.5][EvaluateOnce(For1)] - Min(1, Spell_Value3) * [2.5, 2.3, 1.5][EvaluateOnce(For1)]), Spell_Pos1 + Spell_Pos2 * Spell_Value1 * (-4 + 8 * Max(0, Spell_Value3 - 1)) * (EvaluateOnce(For1) == 1 ? 1 : 0.8) + Spell_Value2 * ([0.5, 1.15, 1.5][EvaluateOnce(For1)] - Max(0, Spell_Value3 - 1) * [2.5, 2.3, 1.5][EvaluateOnce(For1)]), Color.Red, EffectRev.VisibleToPositionAndRadius);
                ModifyVariable(Spell_Effect1, Operation.AppendToArray, LastCreatedEntity());
            }
            Spell_Value4 = false;
            Spell_Value5 = [];
            while (Spell_Value4 < 0.4)
            {
                Tempvar = RemoveFromArray(FilteredArray(PlayersWithinRadius(EyePosition(EventPlayer()), 7, OppositeTeamOf(TeamOf(EventPlayer())), RadiusLOS.Off), EventPlayer() != ArrayElement() && IsInViewAngle(EventPlayer(), EyePosition(ArrayElement()), 80)), Append(CurrentPet, Spell_Value5));
                AddDamageEvent(amount: 70,target: Tempvar,source: EventPlayer(),type: DamageType.Physical);
                ModifyVariable(Spell_Value5, Operation.AppendToArray, Tempvar);
                Tempvar = false;
                Spell_Value4 += 0.048;
                Wait(0.048, WaitBehavior.IgnoreCondition);
            }
            DestroyEffect(RemoveFromArray(Spell_Effect1, FirstOf(Spell_Effect1)));
            Wait(0.2, WaitBehavior.IgnoreCondition);
            Spell_Pos1 = 500 * Up();
    }
}

