}
playervar Any JumpSkillID!;
class JumpSkill:Skill{  
    public constructor(){
        Name = '腾跃';
        Des = '腾空到空中';
        ManaCost = 35;
        Cooldown = 5;
        Type = SkillType.Instant;
    }

    public override void Execute(){
        PlayEffect(Type: PlayEffect.DoomfistRisingUppercutLeapSound,Position: PositionOf());
        CreateEffect(Position: EventPlayer(),Type: Effect.WreckingBallPiledriverFireEffect);
        JumpSkillID = LastCreatedEntity();
        ApplyImpulse(Player: EventPlayer(),Direction: Up(),Speed: 25);
        async Down();
    }

    private void Down()'sub腾跃'{
        DisableMovementCollisionWithPlayers();
        WaitUntil(SpeedOfInDirection(EventPlayer(),Vector(0,-1,0))<=0.5,10);
        SetGravity(EventPlayer(),200);
        WaitUntil(IsOnGround(),10);
        if(IsOnGround()){
            PlayEffect(Type: PlayEffect.DoomfistMeteorStrikeImpactEffect,Position: PositionOf());
            foreach(Player p in PlayersWithinRadius(PositionOf(),8,Team.Team1,RadiusLOS.SurfacesAndEnemyBarriers)){
            AddDamageEvent(amount: 75,target: p,source: EventPlayer(),type: DamageType.Physical);
            }
        }
        PlayEffect(Type: PlayEffect.DoomfistMeteorStrikeImpactSound,Position: EventPlayer(),Radius: 200);
        DestroyEffect(JumpSkillID);
        EnableMovementCollisionWithPlayers();
        SetGravity(GravityPercent: 100);
    }
}
