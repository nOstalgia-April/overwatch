rule: '机器人寻路管理-无垢巨人'
Event.OngoingPlayer
Team.All
Player.All
if(BotType.Zombie==bot_Aitype)
if(IsDummyBot() && IsAlive())
if(bot_target!=null)
{
    StartFacing(Player: EventPlayer(),Direction: DirectionTowards(EventPlayer(),EventPlayer().bot_target),TurnRate: 300);
    if(bot_target != null&&AbsoluteValue(YOf(PositionOf(bot_target))-YOf(PositionOf(EventPlayer())))<=3&&IsInLineOfSight(PositionOf(EventPlayer()),bot_target,BarrierLOS.NoBarriersBlock    )){
                    pf_pathfinding = false;
                    StartThrottleInDirection(Direction: DirectionTowards(EventPlayer(),bot_target),Magnitude: 1,Behavior: ThrottleBehavior.ReplaceExistingThrottle);
    }
    else if(Timer>=2){
                Timer = 0;
                pf_pathfinding = 1;
                pf_target = AllLivingPlayers(Team.Team2).Random();
    }
    Timer+=0.2;
    Wait(0.2);
    LoopIfConditionIsTrue();
}

