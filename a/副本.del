class SteelWill : Skill {
    public constructor() {
        Name = "钢铁意志";
        Des = "开启时大幅提升防御力\n减少受到的伤害";
        ManaCost = 2;
        Cooldown = 12;
        Type = SkillType.Toggle;
    }

    public override void OnToggleStart() {
        // 增加50%物理和魔法抗性
        Shuxings.Physic_Armor.Pct += 50;
        Shuxings.Magic_Resist.Pct += 50;
        PlayEffect(Type: PlayEffect.BrigitteRepairPackImpactSound, Position: PositionOf());
        PlayEffect(Type: PlayEffect.WreckingBallPiledriverImpactEffect, Position: PositionOf(), Radius: 200);
        SmallMessage(Header: '钢铁意志已生效');
    }

    public override void OnToggleEnd() {
        // 移除加成
        Shuxings.Physic_Armor.Pct -= 50;
        Shuxings.Magic_Resist.Pct -= 50;
        PlayEffect(Type: PlayEffect.DebuffImpactSound, Position: PositionOf(), Radius: 200);
        SmallMessage(Header: '钢铁意志已失效');
    }
}

class Whirlwind : Skill {
    public constructor() {
        Name = "旋风斩";
        Des = "快速旋转对周围敌人造成多次伤害";
        ManaCost = 40;
        Cooldown = 20;
        Type = SkillType.Channeled;
        ChannelTime = 2;
    }

    protected override void OnChannelStart() {
        // 开始旋转特效
        CreateEffect(Type: Effect.EchoCloningEffect, Position: PositionOf(), Radius: 3);
        PlayEffect(Type: PlayEffect.ReinhardtFireStrikeTargetImpactSound, Position: PositionOf(), Radius: 200);
        StartFacing(Player: EventPlayer(),Direction: CrossProduct(Up(),FacingDirectionOf()),TurnRate: 500);
    }

    protected override void OnChannelTick() {
        // 每0.2秒检测并伤害周围敌人
        if(ChannelProgress%10<2)
        foreach(Player p in PlayersWithinRadius(PositionOf(), 3, Team.Team1, RadiusLOS.SurfacesAndEnemyBarriers)) {
            p.DamageQueue[p.DamageQueue.Length] = {
                Amount: 15,
                IsCritical: false,
                Source: EventPlayer(),
                Timestamp: TotalTimeElapsed(),
                Type: DamageType.Physical,
                IsSustained: false
            };
        }
    }

    protected override void OnChannelComplete() {
        // 最终强力一击
        foreach(Player p in PlayersWithinRadius(PositionOf(), 3, Team.Team1, RadiusLOS.SurfacesAndEnemyBarriers)) {
            p.DamageQueue[p.DamageQueue.Length] = {
                Amount: 30,
                IsCritical: true,
                Source: EventPlayer(),
                Timestamp: TotalTimeElapsed(),
                Type: DamageType.Physical,
                IsSustained: false
            };
            SetStatus(p,null,Status.KnockedDown,1);
        }
        StopFacing();
        PlayEffect(Type: PlayEffect.ExplosionSound, Position: PositionOf(), Radius: 200);
    }
}

// 自动恢复系统
rule: "自动恢复系统 - 生命值"
Event.OngoingPlayer
Team.All
Player.All
if(IsAlive())
{   
    Number healthRegen = Shuxings.HealthGeneration.VirtualShuxing() * 5; // 每0.1秒恢复
    Number shieldRegen = Shuxings.ShieldsGeneration.VirtualShuxing() * 5; // 每0.1秒恢复
    // 生命值恢复
        Health = Min(Shuxings.MaxHealth.VirtualShuxing(), Health + healthRegen);
    // 护盾恢复
    
    Shields = Min(Shuxings.MaxShields.VirtualShuxing(), Shields + shieldRegen);
    if(Shuxings.MaxHealth.VirtualShuxing()<=Health){
        Shields = Min(Shuxings.MaxShields.VirtualShuxing(), Shields + healthRegen);
    }

    // 法力值恢复
    Number manaRegen = Shuxings.ManaGeneration.VirtualShuxing() * 5; // 每0.1秒恢复
    Mana = Min(Shuxings.MaxMana.VirtualShuxing(), Mana + manaRegen);
    
    Wait(5);
    LoopIfConditionIsTrue();
}

