{
    for(define i! = 0; i<9;i++){
        CreateInWorldText(
        VisibleTo: LocalPlayer().TextDatas[EvaluateOnce(i)]!=0?LocalPlayer():null,
        Header: <'<0><1>',LocalPlayer().TextDatas[EvaluateOnce(i)].Amount,LocalPlayer().TextDatas[EvaluateOnce(i)].isCritical?'!':''>,
        Position: Vector(0,0.15*((TotalTimeElapsed()-LocalPlayer().TextDatas[EvaluateOnce(i)].TimeStamp)),0)+LocalPlayer().TextDatas[EvaluateOnce(i)].Pos,
        Scale: 2,
