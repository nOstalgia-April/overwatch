rule: 'Boss堡垒近战'
Event.OnDamageTaken
Team.All
Player.All
if(EventAbility()==Button.Melee)
if(Attacker().bot_Aitype==BotType.Bastion)
{
    AddDamageEvent(amount:30,target: Victim(),iscritical: false,issustained: false,source: Attacker(),type: DamageType.Physical);
    AllPlayers().Filter(t=>t!=Victim()).ImpulseCount = 0;
    if(!HasStatus(Victim(),Status.KnockedDown)){
        Victim().ImpulseCount+=1;
        if(Victim().ImpulseCount>=5){
            SetStatus(Victim(),null,Status.KnockedDown,3);
            Victim().ImpulseCount = 0;
            AddDamageEvent(amount:100,target: Victim(),iscritical: false,issustained: false,source: Attacker(),type: DamageType.Real);
        }
    }
    Wait(5,WaitBehavior.RestartWhenTrue);
    Victim().ImpulseCount=0;
}

