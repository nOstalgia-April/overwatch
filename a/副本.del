}
playervar Number FloatTextIndex!;
void AddCombatText(in Any amount,in Number[] rgb, in Player target, in Boolean iscritical=false, in Boolean issustained=false, in Player source){
        source.FloatTextIndex++;
        source.TextDatas[source.FloatTextIndex%9] = {
        Amount: amount,
        isCritical: iscritical,
        IsSustained:iscritical,
        RGB:rgb,
        Pos: EyePosition(target)+WorldVectorOf(Localvector: Vector(RandomReal(Min: -1,1),RandomReal(Min: -0.5,1),RandomReal(Min: -1,1)),RelativePlayer: target,<LocalVector>Transformation.Rotation),
        TimeStamp: TotalTimeElapsed()};
}
void AddDamageEvent(in Any amount, in Player target, in Boolean iscritical=false, in Boolean issustained=false, in Player source = EventPlayer(),in DamageType type){
    target.DamageQueue[target.DamageQueue.Length] = {
        Amount: amount,
        IsCritical: iscritical,
        IsSustained: issustained,
        Source: source,
        Type: type,
        Timestamp: TotalTimeElapsed()
    };
    
}

void AddDHealEvent(in Any amount, in Player target, in Boolean iscritical=false, in Boolean issustained=false, in Player source,in HealType type){
    target.HealQueue[target.HealQueue.Length] = {
        Amount: amount,
        IsCritical: iscritical,
        IsSustained: issustained,
        Source: source,
        Type: type,
        Timestamp: TotalTimeElapsed()
    };
}

