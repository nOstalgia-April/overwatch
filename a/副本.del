enum DamageType{
    Physical,
    Magical,
    Real
}

class ShuxingBase{
    public Number Abs;
    public Number Pct;
    public Number Base;

    Number RealShuxing():
        Abs+Base;

    Number VirtualShuxing():
        RealShuxing()*(1+Pct/100);

    public constructor(in Number base=100){
        Base = base;
    }
}
class ShuxingSystem{
    public ShuxingBase MaxShields;
    public ShuxingBase MaxHealth;
    public ShuxingBase MaxMana;
    public ShuxingBase Attack;
    public ShuxingBase Power;
    public ShuxingBase CoolDown;
    public ShuxingBase Speed;
    public ShuxingBase HealModify;
    public ShuxingBase Drain;
    public ShuxingBase Physic_Armor;
    public ShuxingBase Magic_Resist;
    public ShuxingBase CriticalBonus;
    public ShuxingBase CriticalRate;

    public ShuxingBase HealthGeneration;
    public ShuxingBase ManaGeneration;
    public ShuxingBase ShieldsGeneration;
    public ShuxingBase ShieldsRecover;

    public constructor(
    in Number attack = 5,
    in Number power = 5,
    in Number maxMana = 100,
    in Number maxHealth = 100,
    in Number maxShields = 50,
    in Number coolDown = 0,
    in Number speed = 100,
    in Number healModify = 100,
    in Number drain = 0,
    in Number physicArmor = 30,
    in Number magicResist = 30,
    in Number criticalBonus = 1.5,
    in Number criticalRate = 1,
    in Number healthGeneration = 1,
    in Number manaGeneration = 2
) {
    Attack = new ShuxingBase(attack);
    Power = new ShuxingBase(power);
    MaxMana = new ShuxingBase(maxMana);
    MaxHealth = new ShuxingBase(maxHealth);
    MaxShields = new ShuxingBase(maxShields);
    CoolDown = new ShuxingBase(coolDown);
    Speed = new ShuxingBase(speed);
    HealModify = new ShuxingBase(healModify);
    Drain = new ShuxingBase(drain);
    Physic_Armor = new ShuxingBase(physicArmor);
    Magic_Resist = new ShuxingBase(magicResist);
    CriticalBonus = new ShuxingBase(criticalBonus);
    CriticalRate = new ShuxingBase(criticalRate);
    HealthGeneration = new ShuxingBase(healthGeneration);
    ManaGeneration = new ShuxingBase(manaGeneration);
}
}
// 暴击计算辅助方法
Number CalculateCriticalBonus(in Player source) {
    return RandomReal(0,1) < source.Shuxings.CriticalRate.VirtualShuxing() / 100 ? 1.5 + source.Shuxings.CriticalBonus.VirtualShuxing() / 100 : 1.0;
}

single struct DamageEvent {
    public Number Amount;
    public DamageType Type;
    public Any Source;
    public Boolean IsCritical;
    public Number Timestamp;
    public Boolean IsSustained;
}
// 扩展治疗类型枚举
enum HealType {
    HealthOnly,    // 仅治疗生命值
    ShieldOnly,    // 仅恢复护盾
    Both          // 同时治疗生命和护盾
}

single struct HealEvent {
    public Number Amount;
    public HealType Type;
    public Any Source;
    public Boolean IsCritical;
    public Boolean IsSustained;
    public Number Timestamp;
}

playervar HealEvent[] HealQueue = [];
playervar DamageEvent[] DamageQueue = [];
playervar Boolean isDamageTaken;
playervar ShuxingSystem Shuxings;
