Boolean ShouldForceInterrupt(in Player p = EventPlayer()):
    HasStatus(p,Status.Stunned)||HasStatus(p,Status.Frozen)||HasStatus(p,Status.Hacked)||HasStatus(p,Status.KnockedDown);
class Skill{
    public String Name;
    public String Des;
    public Number ManaCost;
    public Number Cooldown;
    public Number CurrentCooldown;
    public SkillType Type;
    public Boolean IsActive;  // 用于Toggle类型
    public Number ChannelTime;    // 引导技能所需时间(秒)

    public constructor(){
        Name = '测试';
    }

    public virtual Boolean CanTrigger(){
        return true;
    }
    public void Trigger() 'sub触发技能'{
        if(CurrentCooldown > 0 || Mana < ManaCost || !CanTrigger() || IsChanneling || HasStatus(Status: Status.Hacked)) return;
        PlayEffect(VisibleTo: EventPlayer(),Type: PlayEffect.DoomfistRisingUppercutImpactSound,Color.Aqua,PositionOf(),150);
        switch(Type) {
            case SkillType.Instant:
                InstantTrigger();
                break;
                
            case SkillType.Toggle:
                ToggleTrigger();
                break;
                
            case SkillType.Channeled:
                ChanneledTrigger();
                break;
        }
    }
    // 瞬时技能触发逻辑
    public void InstantTrigger() {
        Mana -= ManaCost;
        CurrentCooldown = Cooldown;
        Execute();
    }
    // 开关技能触发逻辑p
    public void ToggleTrigger() {
        if(IsActive) {
            // 从激活列表移除
            ActiveToggleSkills = ActiveToggleSkills.Filter(s => s != this);
            IsActive = false;
            IsToggling = false;
            CurrentCooldown = Cooldown;

            OnToggleEnd();
        } else{
            // 加入激活列表
            ActiveToggleSkills += this;
            IsToggling = true;
            IsActive = true;
            Mana -= ManaCost;
            OnToggleStart();
        }
    }
    // 引导技能触发逻辑
    protected void ChanneledTrigger() {
        IsActive = true;
        //IsChanneling = true;
        define TimeStamp! = TotalTimeElapsed()+3;
        if(!IsButtonHeld(Button: Button.SecondaryFire)&&CurrentButton!=Button.PrimaryFire){
            SmallMessage(VisibleTo: EventPlayer(),Header: '同时按住右键开始蓄力');
        }
        SetPrimaryFireEnabled(Enabled: false);
        if(CurrentButton!=Button.PrimaryFire){
            while(!IsButtonHeld(Button: Button.SecondaryFire)){
            Wait(0.1);
            if(TotalTimeElapsed()>TimeStamp){
                IsActive = false;
                Abort();
            }
            }
        }
        
        if(StartChannelCondition()){
        ChannelingSkill = this;
        }
        else{
            SmallMessage(EventPlayer(),'引导取消');
            IsActive = false;
            SetPrimaryFireEnabled(Enabled: true);
        }
    }
    // 开关技能更新循环
    public void ToggleUpdateLoop()'sub开关技能更新循环' {
        while(IsActive && IsAlive()) {
            if(Mana < ManaCost) {  // 按比例检查法力
                IsToggling = false;
                IsActive = false;
                break;
            }
            
            Mana -= ManaCost;
            OnToggleTick();
            Wait(0.2);
        }
        
        if(IsActive) {
            IsActive = false;
            IsToggling = false;
            CurrentCooldown = Cooldown;

        }
        OnToggleEnd();
    }

     /* 可重写的技能效果方法 */
    
    // 瞬时技能效果
    public virtual void Execute() {
        SmallMessage(EventPlayer(), "瞬时技能效果");
    }
    
    // 开关技能开启时
    public virtual void OnToggleStart()'sub开关技能开启时' {
        if(true){}
    }
    
    // 开关技能每Tick
    public virtual void OnToggleTick()'sub开关技能持续时' {
        if(true){}
    }
    public virtual Boolean BreakToggleCondition(){
        return false;
    }
    
    // 开关技能关闭时
    public virtual void OnToggleEnd()'sub开关技能关闭时' {
        if(true){}
    }
    
    // 引导技能开始时
    public virtual void OnChannelStart()'sub引导技能开始时' {
        if(true){}
    }
    
    // 引导技能每Tick
    public virtual void OnChannelTick()'sub引导技能持续时' {
        if(true){}
    }
    
    // 引导技能完成时
    public virtual void OnChannelComplete()'sub引导技能完成时' {
        SmallMessage(EventPlayer(), "引导完成!");
    }
    
    // 引导技能中断时
    public virtual void OnChannelInterrupted() {
        SmallMessage(EventPlayer(), "引导中断");
    }
    // 引导技能中途停止时
    public virtual void OnChannelAbort() {
        SmallMessage(EventPlayer(), "引导停止");
    }

    public virtual Boolean StartChannelCondition(){
        return true;
    }
    public virtual Boolean BreakChannelCondition(){
        return false;
    }
}

rule: '引导技能检测'
Event.OngoingPlayer
Team.All
Player.All
if(ChannelingSkill != 0 && !IsChanneling)
{
    // 开始引导逻辑
    IsChanneling = true;
    ChannelProgress = 0;
    Mana -= ChannelingSkill.ManaCost;
    
    // 调用技能的开始引导方法
    ChannelingSkill.OnChannelStart();

    {
        ForceThrottle(Player: EventPlayer(),MaxForward: 0.4,MaxBackward: 0.4,MaxSideways: 0.4);
        // 阶段1：蓄力阶段（按住按键累积进度）
        while(IsChanneling && 
            ((IsButtonHeld(Button: Button.SecondaryFire)&&CurrentButton!=Button.PrimaryFire)||(IsButtonHeld(Button: Button.PrimaryFire))&&CurrentButton==Button.PrimaryFire) && 
            IsAlive() && 
            ChannelProgress < 100) {
            if(ShouldForceInterrupt()) {
                ChannelingSkill.OnChannelInterrupted();
                break;
            }
            if(ChannelingSkill.BreakChannelCondition()){
                break;
            }
            PlayEffect(VisibleTo: EventPlayer(),Type: PlayEffect.ReaperWraithFormSound,Position: EyePosition(),Radius: Max(50,2*ChannelProgress));
            ChannelProgress = Min(100, ChannelProgress + (10/ChannelingSkill.ChannelTime));
            ChannelingSkill.OnChannelTick();
            Wait(0.1);
        }
        if(ChannelProgress < 100){
            ChannelingSkill.OnChannelAbort();
        }
        // ===== 阶段2：蓄满后处理 =====
        if(ChannelProgress >= 100 && IsChanneling) {
            define releaseWindowEnd! = TotalTimeElapsed() + 2.0;
            while(IsChanneling && 
                  ((IsButtonHeld(Button: Button.SecondaryFire)&&CurrentButton!=Button.PrimaryFire)) && 
                  TotalTimeElapsed() < releaseWindowEnd && 
                  IsAlive()) {
                
                PlayEffect(VisibleTo: EventPlayer(),Type: PlayEffect.ReaperWraithFormSound,Position: EyePosition(),Radius: Max(50,2*ChannelProgress));
                ChannelingSkill.OnChannelTick();
                if(ShouldForceInterrupt()) {
                ChannelingSkill.OnChannelInterrupted();
                break;
                }
                if(ChannelingSkill.BreakChannelCondition()){
                break;
                }
                Wait(0.1);
            }
            
            if(IsChanneling && 
               ((!IsButtonHeld(Button: Button.SecondaryFire)&&CurrentButton!=Button.PrimaryFire)||CurrentButton==Button.PrimaryFire) && 
               TotalTimeElapsed() < releaseWindowEnd) {
                ChannelingSkill.OnChannelComplete(); // ✅ 成功释放
                PlayEffect(VisibleTo: EventPlayer(),Type: PlayEffect.RingExplosionSound,Position: EyePosition(),Radius: 175);
            }
        }
    }
    ChannelingSkill.CurrentCooldown = ChannelingSkill.Cooldown;
    ChannelingSkill.IsActive = false;
    StopForcingThrottle(EventPlayer());
    SetPrimaryFireEnabled(Enabled: true);
    IsChanneling = false;
    ChannelProgress = 0;
    ChannelingSkill = 0; // 清除当前引导技能
}


