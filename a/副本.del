void BastionActionLoop(){
    bot_FacingUpdate();
    StartThrottleInDirection(Direction: DirectionTowards(EventPlayer(),bot_target),Magnitude: 1,Behavior: ThrottleBehavior.ReplaceExistingThrottle);
    while(bot_targetArray.Length>0){
        Wait(0.5);
        if(DistanceBetween(EventPlayer(),bot_target)<=3){
            StartHoldingButton(Button: Button.Melee);
        }else{
            StopHoldingButton(Button: Button.Melee);
        }
        
        if((DistanceBetween(EventPlayer(),bot_target)<=20&&DistanceBetween(EventPlayer(),bot_target)>7)||bot_target.Health<bot_target.Shuxings.MaxHealth.VirtualShuxing()){
            //PressButton(Button: Button.SecondaryFire);
            Skills[0].Trigger();
        }
    }
}
Number bot_ballistic_velocity:
    -0.003;
Number bot_aming_accuracy:
    0;
rule: '机器人行为管理-堡垒'
Event.OngoingPlayer
Team.All
Player.All
if(BotType.Bastion==bot_Aitype)
if(IsDummyBot() && IsAlive())
if(bot_target!=null)
{
    SetMoveSpeed(MoveSpeedPercent: 60);
    BastionActionLoop();
    Wait(1,WaitBehavior.RestartWhenTrue);

}

void bot_FacingUpdate()'sub更新朝向'{
    StartFacing(EventPlayer(),
    DirectionTowards(
        EyePosition(),
            EyePosition(bot_target)+Down()*DistanceBetween(EventPlayer(),bot_target)*0.01+VelocityOf(bot_target)*(DistanceBetween(EventPlayer(),bot_target)*bot_ballistic_velocity+0.2)
            +
            DirectionFromAngles(
                HorizontalFacingAngleOf()
                    +RandomReal(
                        DistanceBetween(EventPlayer(),bot_target)*AbsoluteValue(bot_aming_accuracy)*-1,
                        DistanceBetween(EventPlayer(),bot_target)*AbsoluteValue(bot_aming_accuracy)
                        ),
                VerticalFacingAngleOf()
                    +RandomReal(
                        DistanceBetween(EventPlayer(),bot_target)*AbsoluteValue(bot_aming_accuracy)*0.25*-1,
                        DistanceBetween(EventPlayer(),bot_target)*AbsoluteValue(bot_aming_accuracy)*0.25
                    )
            ) * 1
    ),
    1000,
    Relative.ToWorld,
    FacingRev.DirectionAndTurnRate
    );
}
playervar Number ImpulseCount;
playervar Player[] Targets;
class BastionStorm : Skill {
    public constructor() {
        Name = "炮弹风暴";
        Des = "疯了一样向目标随机发射弹道";
        Cooldown = 5;
        ManaCost = -1;
        Type = SkillType.Instant;
    }

    public override void Execute() {
        Storming();
    }

    public void Storming()''{
        Targets = AllLivingPlayers(Team.Team2).Filter(t=>DistanceBetween(t,EventPlayer())<=20);
        while(Targets.Length>0){
            CreateHomingProjectile(ProjectileType: ProjectileType.BastionA36TacticalGrenade,Speed: 15,Lifetime: 8,Player: EventPlayer(),Direction: 0.2*Up()+AccurateFacing(Targets[0]),AffectedTeam: Team.Team2,Amount: 400,AmountScalar: 1,ExplosionRadius: 3,Impulse: 10,HomingTarget: Targets[0],HomingStrength: 0.75);
            Targets.ModRemoveByIndex(0);
        }
        SetStatus(EventPlayer(),null,Status.Stunned,3);
    }
}

Vector AccurateFacing(in Player target){
    return DirectionTowards(
        EyePosition(),
            EyePosition(target)+Down()*DistanceBetween(EventPlayer(),target)*0.01+VelocityOf(target)*(DistanceBetween(EventPlayer(),target)*bot_ballistic_velocity+0.2)
            +
            DirectionFromAngles(
                HorizontalFacingAngleOf()
                    +RandomReal(
                        DistanceBetween(EventPlayer(),target)*AbsoluteValue(bot_aming_accuracy)*-1,
                        DistanceBetween(EventPlayer(),target)*AbsoluteValue(bot_aming_accuracy)
                        ),
                VerticalFacingAngleOf()
                    +RandomReal(
                        DistanceBetween(EventPlayer(),target)*AbsoluteValue(bot_aming_accuracy)*0.25*-1,
                        DistanceBetween(EventPlayer(),target)*AbsoluteValue(bot_aming_accuracy)*0.25
                    )
            ));
}

