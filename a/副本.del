    switch(CurrentRole){
        case Role.Fighter:
        {
            Skills = [new PowerStrike(),new Frenzy(),new Slash(),new JumpSkill()];
            // 初始化属性系统
            Shuxings = FighterShuxings;
            break;
        }
        case Role.Magician:
        {
            Skills = [new ArcaneMissiles(),new Flash(),new ManaShield(),new ElementSwitch()];
            PrimarySkill = new Missle();

            // 初始化属性系统
            Shuxings = MagicianShuxings;
            break;
        }
        case Role.Priest:
        {
            Skills = [new RainDrop(), new ElectricClaw(), new SwiftGrace(), new ThunderStorm()];
            PrimarySkill = new Pray();

            // 初始化属性系统
            Shuxings = PriestShuxings;
            break;
        }
    }
    Health = Shuxings.MaxHealth.VirtualShuxing();
    Shields = Shuxings.MaxShields.VirtualShuxing();
    Mana = Shuxings.MaxMana.VirtualShuxing();

    SetAbility1Enabled(Enabled: false);
    SetAbility2Enabled(Enabled: false);
    SetUltimateAbilityEnabled(Enabled: false);
