        Reevaluation: InworldTextRev.VisibleToPositionStringAndColor,
        TextColor: CustomColor(red: LocalPlayer().TextDatas[EvaluateOnce(i)].RGB[0],green: LocalPlayer().TextDatas[EvaluateOnce(i)].RGB[1],blue: LocalPlayer().TextDatas[EvaluateOnce(i)].RGB[2],
        //持续伤害文本0.5s消散，否则1s消散
        alpha: 255*(1-(LocalPlayer().TextDatas[EvaluateOnce(i)].IsSustained?(2*(TotalTimeElapsed()-LocalPlayer().TextDatas[EvaluateOnce(i)].TimeStamp)):(TotalTimeElapsed()-LocalPlayer().TextDatas[EvaluateOnce(i)].TimeStamp))))
        );
