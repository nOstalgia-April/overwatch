globalvar Number[][] DamageType_Colors_RGB! = [
    [UnfinishedColor_Red_R,UnfinishedColor_Red_G,UnfinishedColor_Red_B],
    [MagicDamage_Color_R,MagicDamage_Color_G,MagicDamage_Color_B],
    [RealDamage_Color_R,RealDamage_Color_G,RealDamage_Color_B]
];
rule: '处理伤害队列'
Event.OngoingPlayer
Team.All
Player.All
if(DamageQueue.Length>0)
{
    define DamageEvt! = DamageQueue[0];
    
    
    //音效
    Damage(EventPlayer(),DamageEvt.Source,1000);
    PlayEffect(Type: PlayEffect.BadExplosion,Color: Color.Red,Position: EventPlayer(),Radius: 0.02);
    // 计算暴击
    Number critMultiplier = CalculateCriticalBonus(DamageEvt.Source);
    Boolean isCrit = critMultiplier > 1.0 || DamageEvt.IsCritical;

    // 应用暴击视觉反馈
    if(isCrit) {
    }

    // 计算基础伤害
    Number baseDamage = DamageEvt.Amount * critMultiplier;
    
    // 护甲减免计算
    Number reduction = DamageEvt.Type == DamageType.Physical ? 
        Shuxings.Physic_Armor.VirtualShuxing() : 
        (DamageEvt.Type == DamageType.Magical ? Shuxings.Magic_Resist.VirtualShuxing() : 0);

    reduction = reduction / (100 + reduction); // 百分比换算

    // 最终伤害计算
    Number finalDamage = baseDamage * (1 - reduction);
    if(IsManaShieldActive){
        if(CurrentElement==ElementState.Arcane){
            Mana -= 0.5*finalDamage;
        }else{
            Mana -= 1*finalDamage;
        }
        finalDamage = 0;

        if(CurrentElement==ElementState.Frozen){
            if(RandomReal(0,1)>0.5){
                SetStatus(Player: DamageEvt.Source,Assister: null,Status: Status.Frozen,0.5);
            }
        }
    }
    // 护盾优先吸收
    Number remain = Max(0, finalDamage - Shields);
    Shields = Max(0, Shields - finalDamage);
    
    // 生命值扣除
    if(remain > 0) {
        Health = Max(0, Health - remain);
    }
    define DamageColor_RGB! = DamageType_Colors_RGB[<Number>DamageEvt.Type];
    //浮动文本
    AddCombatText(amount: finalDamage,rgb: [DamageColor_RGB[0],DamageColor_RGB[1],DamageColor_RGB[2]],source: DamageEvt.Source,iscritical: isCrit,target: EventPlayer());

    //机器人添加仇恨值逻辑
    if(IsDummyBot()){
        AddThreat(source: DamageEvt.Source,amount: finalDamage,type: ThreatType.Damage,target: [EventPlayer()]);
    }
    
    
    ModifyVariable(DamageQueue,Operation.RemoveFromArrayByIndex,0);
    MinWait();
    LoopIfConditionIsTrue();
}
void HealEffectPlay()'sub对玩家播放治疗特效'{
    PlayEffect(Type: PlayEffect.HealTargetActiveEffect,Position: EventPlayer(),Radius: 1);
    PlayEffect(Type: PlayEffect.BrigitteWhipShotHealAreaSound,Position: EventPlayer(),Radius: 150,VisibleTo: EventPlayer());
}
playervar define IsHealingTime!;
rule: '处理治疗队列'
Event.OngoingPlayer
Team.All
Player.All
if(HealQueue.Length>0)
{
    define HealEvt! = HealQueue[0];

    if (HealEvt.IsSustained) {
        if (RandomReal(0, 1) > 0.7) {
            HealEffectPlay();  // 只有随机成功时才执行
        }
    } else {
        HealEffectPlay();  // 非 Sustained 情况直接执行
    }

    // 更新施法者的IsHealingTime（如果施法者不是自己）
    if (HealEvt.Source != EventPlayer()) {
        HealEvt.Source.IsHealingTime = TotalTimeElapsed();
    }
    if (HealEvt.Source.isSwiftGrace){
        SwiftGrace.SwiftGraceAction(HealEvt.Source);
    }
                

    // 计算治疗暴击
    Number critMultiplier = CalculateCriticalBonus(HealEvt.Source);
    Boolean isCrit = critMultiplier > 1.0 || HealEvt.IsCritical;

    Number baseHeal = HealEvt.Amount * (Shuxings.HealModify.VirtualShuxing()/100) * critMultiplier;

    // 暴击视觉反馈
    if(isCrit) {
    }

    //治疗视觉反馈
    SetPlayerHealth(Amount: MaxHealth()-100);
    Heal(Player: EventPlayer(),Amount: 1,Healer: null);

    // 根据治疗类型分配
    switch(HealEvt.Type) {
        case HealType.HealthOnly:
            Health = Min(Shuxings.MaxHealth.VirtualShuxing(), Health + baseHeal);
            break;
            
        case HealType.ShieldOnly:
            Shields = Min(Shuxings.MaxShields.VirtualShuxing(), Shields + baseHeal);
            break;
            
        case HealType.Both:
            Number remainHeal = baseHeal-(Shuxings.MaxHealth.VirtualShuxing() - Health);
            Health = Min(Shuxings.MaxHealth.VirtualShuxing(), Health + baseHeal);
            if(remainHeal>0){
                Shields = Min(Shuxings.MaxShields.VirtualShuxing(), Shields + remainHeal);
            }
            
            break;
    }
    AddCombatText(amount: baseHeal,rgb: [FinishedColor_Gold_R,FinishedColor_Gold_G,FinishedColor_Gold_B],source: HealEvt.Source,iscritical: isCrit,issustained: HealEvt.IsSustained,target: EventPlayer());

    //机器人添加仇恨值逻辑
    AddThreat(source: HealEvt.Source,amount: baseHeal,type: ThreatType.Healing,target: AllPlayers().Filter(t=>IsInLineOfSight(HealEvt.Source,t)&&IsDummyBot(t)));

    ModifyVariable(HealQueue,Operation.RemoveFromArrayByIndex,0);
    MinWait();
    LoopIfConditionIsTrue();
}


