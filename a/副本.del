rule: '技能图标初始化'
{
    for(define i! = 0;i<Skill_Buttons.Length;i++){
        define X! = -1 + i*1;
        //技能按键1
        CreateInWorldText(
            VisibleTo: AllPlayers().Filter(t=>!t.isInMenu),
            Header: <'■'>,
            Position: MenuBigPosition_Local(EvaluateOnce(X),-1.5),
            Scale: 100,
            Clipping: Clipping.DoNotClip,
            Reevaluation: InworldTextRev.VisibleToPositionStringAndColor,
            TextColor: 
                LocalPlayer().Skills[EvaluateOnce(i)].ManaCost > LocalPlayer().Mana?Color.SkyBlue:
                LocalPlayer().Skills[EvaluateOnce(i)].CurrentCooldown>0 || HasStatus(LocalPlayer(),Status.Hacked)
                ?
                Color.Gray
                :
                    (IsButtonHeld(LocalPlayer(),Button:Buttons[EvaluateOnce(i)])||LocalPlayer().Skills[EvaluateOnce(i)].IsActive
                    ?
                    Color.Orange
                    :
                    LocalPlayer().IsChanneling?
                    Color.Gray:Color.White)
        );
        
        

        //技能按键1-名字
        CreateInWorldText(
            VisibleTo: AllPlayers().Filter(t=>!t.isInMenu),
            Header: <'<0>',LocalPlayer().Skills[EvaluateOnce(i)].Name>,
            Position: MenuBigPosition_Local(EvaluateOnce(X),-1.7),
            Scale: 2,
            Clipping: Clipping.DoNotClip,
            Reevaluation: InworldTextRev.VisibleToPositionStringAndColor,
            TextColor: Color.Yellow
        );
        //技能按键1
        CreateInWorldText(
            VisibleTo: AllPlayers().Filter(t=>!t.isInMenu),
            Header: LocalPlayer().Skills[EvaluateOnce(i)].CurrentCooldown==0?Skill_Buttons[EvaluateOnce(i)]:LocalPlayer().Skills[EvaluateOnce(i)].CurrentCooldown,
            Position: MenuBigPosition_Local(EvaluateOnce(X),-1.45),
            Scale: 1.5,
            Clipping: Clipping.DoNotClip,
            Reevaluation: InworldTextRev.VisibleToPositionStringAndColor,
            TextColor: Color.Black
        );
    }
}

