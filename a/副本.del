rule: '每秒刷新技能'
Event.OngoingPlayer
Team.All
Player.All
//if(!IsDummyBot())
if(IsAlive())
if(Skills.Length>0)
{
    for(define i! =0;i<Skills.Length;i++){
        if(Skills[i].CurrentCooldown > 0) {
            Skills[i].CurrentCooldown = Max(0, Skills[i].CurrentCooldown - 1);  // 每帧减少
        }
        MinWait();
    }
    Wait(1);
    LoopIfConditionIsTrue();
}

// 统一更新所有激活的开关技能
rule: '并行更新开关技能'
Event.OngoingPlayer
Team.All
Player.All
if(ActiveToggleSkills.Length > 0||false)
{
    // 并行处理所有激活技能
        for(define i! = 0; i < ActiveToggleSkills.Length; i++) {
        define skill! = ActiveToggleSkills[i];
        
        if(!IsAlive() || Mana < skill.ManaCost || skill.BreakToggleCondition()){
            skill.IsActive = false;
            IsToggling = false;
            skill.CurrentCooldown = skill.Cooldown;
            ActiveToggleSkills = ActiveToggleSkills.Filter(s => s != skill);
            skill.OnToggleEnd();
            continue;
        }
         // 执行每Tick逻辑
        Mana -= skill.ManaCost;
        skill.IsActive = true;
        IsToggling = true;
        skill.OnToggleTick();
        MinWait();
    }
    
    Wait(0.2);  // 每0.2秒更新一次
    LoopIfConditionIsTrue();
}

