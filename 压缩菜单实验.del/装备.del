import 'struct属性.del';
import '品质.del';
import '解压缩.del';
import '菜单.del';
enum PART{
    Head,
    Body,
    Foot,
    Hand,
    Neck
}
globalvar String[] PART_Names = ["头盔", "胸甲", "靴子","武器", "护符"];

single struct Equip {
    public String Name;
    public String Desc;
    public Number[] EquipShuxing;
    public Number EquipLevel;
    public QUALITY Quality;
    public PART Part;
}
globalvar String[] EquipData_to_Decompress = ["【s小刀∞s一把新手武器∞【~∞0∞5∞0∞0∞0∞0】∞1∞0∞3】∞【s布帽∞s一顶简单的布帽，提供基础保护∞【0∞+∞0∞0∞5∞0∞0】∞1∞0∞0】∞【s布甲∞s一件轻便的布制铠甲，适合新手∞【0∞:∞0∞0∞~∞0∞5】∞1∞0∞1】","【s布靴∞s一双轻便的布靴，提升移动舒适度∞【0∞~∞~∞0∞0∞0∞0】∞1∞0∞2】∞【s木质护符∞s一枚简单的木质护符，略微提升治疗效果∞【0∞0∞0∞~∞0∞5∞0】∞1∞0∞4】","【s铁盔∞s一顶坚固的铁质头盔，提供可靠保护∞【0∞f∞0∞0∞%∞0∞5】∞3∞0∞0】∞【s精金铠甲∞s一件精致的精金铠甲，兼具防御与威严∞【~∞T∞0∞0∞+∞~∞~】∞5∞1∞1】"];
globalvar Equip[] EquipData_Pool = [];
globalvar Any[] EquipData_DeCompressed;

void EquipData_Initialize() {
    EquipData_DeCompressed = Decompress(EquipData_to_Decompress);
    for (define i! = 0; i < EquipData_DeCompressed.Length; i++) {
        EquipData_Pool[EquipData_Pool.Length] = {
            Name: EquipData_DeCompressed[i][0],
            Desc: EquipData_DeCompressed[i][1],
            EquipShuxing: EquipData_DeCompressed[i][2],
            EquipLevel: EquipData_DeCompressed[i][3],
            Quality: EquipData_DeCompressed[i][4],
            Part: EquipData_DeCompressed[i][5]
        };
    }
}
String GetEquipShuxingString(Equip equip) {
    String output! = '\n【0】【1】【2】【3】【4】【5】【6】';

    for(define i! = 0; i < Shuxing_Names.Length; i++){
        if(equip.EquipShuxing[i] > 0){
            output = output.Replace('【'+i+'】', '  '+Shuxing_Names[i]+' '+equip.EquipShuxing[i]+'\n');
        }else{
            output = output.Replace('【'+i+'】', '');
        }
        
    }
    return output;
}

Color GetEquipColor(in Equip equip) {
    return QUALITY_Light_Colors[equip.Quality];
}

String GetEquipString(Equip equip)''{
    return equip.Name + '\n' +
    
    '[等级]: ' + equip.EquipLevel + '\n' +
    '[品质]: ' + QUAILITY_Names[equip.Quality] + ' ' +
    '[部位]: ' + PART_Names[equip.Part] + '\n' +
    GetEquipShuxingString(equip)+ '\n\n'+
    '"' + equip.Desc + '"'+'\n';
}
globalvar Number[] ShuxingIndex = [0,1,2,3,4,5];
playervar Number[] equip_Suit_Index = [];
playervar Equip[] equipBag = [];
void EquipItem(Player player, Equip equip)'穿戴子程序' {
    define test = equip_Suit_Index[<Number>equip.Part];
    if(test >= 0){
        UnequipItem(player, equipBag[equip_Suit_Index[equip.Part]]);
    }
    //赋值装备属性
    for(define i! = 0; i < equip.EquipShuxing.Length; i++){
        if(equip.EquipShuxing[i] != 0){
            player.shuxing[i].ModAbs(equip.EquipShuxing[i]);
        }
    }

    RevShuxing(player);
    Wait(0.1);
}

void UnequipItem(Player player, Equip equip)'卸下子程序' {
    //减去装备属性
    for(define i! = 0; i < equip.EquipShuxing.Length; i++){
        if(equip.EquipShuxing[i] != 0){
            player.shuxing[i].ModAbs(-equip.EquipShuxing[i]);
        }
    }
    RevShuxing(player);
    Wait(0.1);
}

void OpenEquipMenu() {
    updateEquipMenu();
}
void updateEquipMenu()'' {
    Button_LocalPool = ButtonData_Pool;
    define i = 0;
    for(i=0;i<5;i++){
      Button_LocalPool[GetButtonID('身上装备'+i)].Label = (selectEquipIndexOfBag==equip_Suit_Index[i]&&selectEquipIndexOfBag!=-1?IconString(Icon.ArrowRight):'')+equipBag[equip_Suit_Index[i]].Name.Replace('0','空');
      if(equip_Suit_Index[i]!=-1){
        Button_LocalPool[GetButtonID('身上装备'+i)].Interactable = true;
        Button_LocalPool[GetButtonID('身上装备'+i)].DefaultColor = GetEquipColor(equipBag[equip_Suit_Index[i]]);
        Button_LocalPool[GetButtonID('身上装备'+i)].HoverLabel = GetEquipString(equipBag[equip_Suit_Index[i]]);
      }else{
        Button_LocalPool[GetButtonID('身上装备'+i)].Interactable = false;
        Button_LocalPool[GetButtonID('身上装备'+i)].HoverLabel = '';
      }
    }
    for(i=0;i<6;i++){   
        Button_LocalPool[GetButtonID('装备箱'+i)].Label = (selectEquipIndexOfBag==i+page*6&&selectEquipIndexOfBag!=-1?IconString(Icon.ArrowRight):'')+equipBag[i+page*6].Name.Replace('0','空');
        if(equipBag[i+page*6]!=null){
        Button_LocalPool[GetButtonID('装备箱'+i)].Interactable = true;
        Button_LocalPool[GetButtonID('装备箱'+i)].DefaultColor = GetEquipColor(equipBag[i+page*6]);
        Button_LocalPool[GetButtonID('装备箱'+i)].HoverLabel = GetEquipString(equipBag[i+page*6]);
        }else{
            Button_LocalPool[GetButtonID('装备箱'+i)].Interactable = false;
            Button_LocalPool[GetButtonID('装备箱'+i)].HoverLabel = '';
        }
    }
}
