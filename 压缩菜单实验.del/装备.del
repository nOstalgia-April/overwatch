// 注册穿戴和卸下按钮点击
rule: '注册穿戴和卸下按钮'
if(isMenuInitialized)
{
    RegisterEquipMenu();
}   

rule: 'My Rule'
{
    CreateHudText(Header: LocalPlayer().MenuLoop);
    CreateHudText(Header: '指定按钮id'+GetButtonID('切换显示按钮'));
}

void RegisterEquipMenu(){
    // 穿戴按钮
    registerButtonClick(GetButtonID('穿戴按钮'), () => {
        if(selectEquipIndexOfBag != -1 && !equip_Suit_Index.Contains(selectEquipIndexOfBag)) {
            
            EquipItem(EventPlayer(), equipBag[selectEquipIndexOfBag]);
            equip_Suit_Index[equipBag[selectEquipIndexOfBag].Part] = selectEquipIndexOfBag;
            updateEquipMenu();
        }else{
            SmallMessage(EventPlayer(),'错误: 请先选择一件未穿戴的装备');
        }
    });

    // 卸下按钮
    registerButtonClick(GetButtonID('卸下按钮'), () => {
        if(selectEquipIndexOfBag != -1 && equip_Suit_Index.Contains(selectEquipIndexOfBag)) {
            UnequipItem(EventPlayer(), equipBag[selectEquipIndexOfBag]);
            equip_Suit_Index[equipBag[selectEquipIndexOfBag].Part] = -1;
            updateEquipMenu();
        }else{
            SmallMessage(EventPlayer(),'错误: 请选择已穿戴的装备');
        }
    });

    // 更新装备箱按钮点击，选择装备
    registerButtonGroupClick([GetButtonID('装备箱0'), GetButtonID('装备箱1'), GetButtonID('装备箱2'), 
    GetButtonID('装备箱3'), GetButtonID('装备箱4'), GetButtonID('装备箱5')], () => {
        selectEquipIndexOfBag = MenuLoop-GetButtonID('装备箱0')+page*6;
        updateEquipMenu();
        Button_LocalPool[MenuLoop].HoverLabel = GetEquipString(equipBag[selectEquipIndexOfBag]);
    });
    registerButtonGroupClick([GetButtonID('装备左翻页')], () => {
        page = Max(0,page-1);
        updateEquipMenu();
    });
    registerButtonGroupClick([GetButtonID('装备右翻页')], () => {
        page = Min(RoundToInteger(equipBag.Length/6,Rounding.Down),page+1);
        updateEquipMenu();
    });
    registerButtonGroupClick([4,5,6,7,8],()=>{
        define selectIndex = MenuLoop-4;
        if(equip_Suit_Index[selectIndex]!=-1){
            selectEquipIndexOfBag = equip_Suit_Index[selectIndex];
            Button_LocalPool[MenuLoop].Label = IconString(Icon.ArrowRight)+equipBag[equip_Suit_Index[selectIndex]].Name;
        }
        updateEquipMenu();
    });
}

