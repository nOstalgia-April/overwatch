/**
 * 打开角色菜单
 */
void OpenAreaMenu() {
    //update Text
    if(false){
        if(level<10){
        Button_LocalPool[GetButtonID('区域二按钮')].Interactable=false;
        Button_LocalPool[GetButtonID('区域二按钮')].DefaultColor=Color.Gray;
        }else{
            Button_LocalPool[GetButtonID('区域二按钮')].Interactable=true;
            Button_LocalPool[GetButtonID('区域二按钮')].DefaultColor=Color.White;
        }
        if(level<20){
            Button_LocalPool[GetButtonID('区域三按钮')].Interactable=false;
            Button_LocalPool[GetButtonID('区域三按钮')].DefaultColor=Color.Gray;
        }else{
            Button_LocalPool[GetButtonID('区域三按钮')].Interactable=true;
            Button_LocalPool[GetButtonID('区域三按钮')].DefaultColor=Color.White;
        }
    }
    
}


