rule: '菜单按钮函数注册'
{
    RegisterAllButtonClick();
}
/**
 * 注册所有按钮的点击事件
 */
void RegisterAllButtonClick() {
    registerButtonClick(0, () => {
        CloseMenu();
    });
    registerButtonGroupClick([1,2,3],()=>{
        Teleport(EventPlayer(), [Area_A,Area_B,Area_C][MenuLoop-1]);
        area = MenuLoop;
        CloseMenu();
        Update_Area_A_Bots();
    });
}
