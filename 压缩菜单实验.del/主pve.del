import '副本数据结构.del';

rule: '创建副本'
if(isInitialized)
if(false)
{
    InstanceData_Pool = [
        {
            Name: '叹息圣堂',
            Des: '此举将会召唤一个Level 6的精英怪\n击他可获得10金币',
            MinPlayers: 1,
            Time: 20,
            Pos: Area_A
        }
    ];
    Instances = [
        new TestInstance()
    ];
    Instances_Init = true;
}

class TestInstance: Instance{
    public constructor(){
        Data = InstanceData_Pool[0];
        isAvailable = true;
    }

    public override void Roominitialize(){
            CreateDummyBot(Hero.Zarya,Team.Team1,-1,Area_A);
            Areas_bots[Area.A] += LastCreatedEntity();
            LastCreatedEntity().level = 6;
            LastCreatedEntity().bot_type = BotType.CannonWalker;
            LastCreatedEntity().isElite = true;
    }

    public override void Roomend(){
        BigMessage(Header: '副本结束');
    }

}
