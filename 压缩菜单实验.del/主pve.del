Number CurrentBotNumber : AllPlayers(Team.Team1).Filter(t=>IsDummyBot(t)).Length;
Number CurrentSpecialSkinNumber(){
    define SpecialSkin = [];
    foreach(Player p! in AllPlayers()){
        if(!SpecialSkin.Contains(p.Hero())){
            SpecialSkin += p.Hero();
        }
    }
    return SpecialSkin.Length;
}

rule: '精英怪初始化'
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot())
if(isElite)
if(IsAlive())
{
    SetMaxHealth(EventPlayer(), 900);
    Resurrect();
    Wait(2,WaitBehavior.AbortWhenFalse);
    level = 1;
    DisableNameplates(EventPlayer(),AllPlayers());
    CreateProgressBarInWorldText(
        VisibleTo: PlayersWithinRadius(EventPlayer(), 20, Team.Team2, RadiusLOS.Off),
        NormalizedHealth()*100,
        <String>EventPlayer(),
        EventPlayer(),
        1,
        Clipping.ClipAgainstSurfaces,
        Color.Red,
        Color.Yellow
    );
    StartForcingPlayerOutlines(EventPlayer(),AllPlayers(),true,Color.Yellow,OutlineType.Default);
}

