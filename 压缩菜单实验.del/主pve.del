enum Area{
    Home,
    A,
    B,
    C
}
playervar Area area! = Area.Home;
globalvar Player[][] Areas_bots = [];
void Update_Area_A_Bots()
{
    BigMessage(Header: "区域1有人，生成怪物");
    Areas_bots[Area.A] = Areas_bots[Area.A].Filter(t=>EntityExists(t));
    Number Area_A_Player_Count! = AllPlayers(Team.Team2).Filter(t => t.area == Area.A).Length;
    Number Area_A_Bot_Count! : Areas_bots[Area.A].Length;
    if(Area_A_Bot_Count > Area_A_Player_Count*2){
        Player[] Bots_to_Destroy = Areas_bots[Area.A];
        if(Area_A_Player_Count>0){
            Bots_to_Destroy = Bots_to_Destroy.Filter(t=>t.IsDead()&&t.bot_type==BotType.Zombie);
        }
        foreach(Player bot! in Bots_to_Destroy){
            DestroyDummyBot(Team.Team1,SlotOf(bot));
            Areas_bots[Area.A] -= bot;
        }
    }
    while(Area_A_Bot_Count < Area_A_Player_Count*2+10)
    {
        CreateDummyBot(Hero.Reinhardt,Team.Team1,-1,Zombie_Spawn_Point);
        LastCreatedEntity().bot_type = BotType.Zombie;
        LastCreatedEntity().level = 3;
        Areas_bots[Area.A] += LastCreatedEntity();
    }
    define DeadBots = Areas_bots[Area.A].Filter(t=>t.IsDead());
    Respawn(DeadBots);
    Teleport(DeadBots, Zombie_Spawn_Point);
    async! Area_A_Elite_Bot();
}
void Area_A_Elite_Bot()''{
    while(Areas_bots[Area.A].IsTrueForAny(t=>!t.isElite)){
        Wait(RandomInteger(5,30));
        if(PlayersInArea(Area.A).Length>0 && Areas_bots[Area.A].IsTrueForAny(t=>!t.isElite)){
            CreateDummyBot(Hero.Zarya,Team.Team1,-1,Zombie_Spawn_Point);
            Areas_bots[Area.A] += LastCreatedEntity();
            LastCreatedEntity().level = 6;
            LastCreatedEntity().bot_type = BotType.CannonWalker;
            LastCreatedEntity().isElite = true;
            BigMessage(PlayersInArea(Area.A),'精英怪已生成');
            break;
        }
    }
    
}
void Update_Areas_Bots(){
    Update_Area_A_Bots();
}

rule: '做表情回主城'
