    globalvar Number Duquan_unique_ID = 0;
    rule: '毒炸弹效果创建'
    Event.OngoingPlayer
    Team.All
    Player.All
    {
        ChaseVariableAtRate(Duquan_CountDown,rate: 1,destination: 0,reevaluation: RateChaseReevaluation.DestinationAndRate);
        CreateEffect(VisibleTo: Duquan_CountDown>0?AllLivingPlayers():null,Type: Effect.EchoCloningEffect,Color: Color.Team2,EventPlayer(),Radius: 1,Reevaluation: EffectRev.VisibleToPositionRadiusAndColor);
        CreateInWorldText(VisibleTo: Duquan_CountDown>0?AllLivingPlayers():null,Header: <'毒炸弹<0>s',Duquan_CountDown>,Position: EventPlayer(),Scale: 1.5,Clipping: Clipping.DoNotClip,TextColor: Color.Green,Reevaluation: InworldTextRev.VisibleToPositionStringAndColor);

    }

    void _CreateDuQuan(in Vector location){
        
        CreateEffect(Color: Color.LimeGreen,Type: Effect.Cloud
        ,Position: EvaluateOnce(location),Radius: 5,Reevaluation: EffectRev.Color);
        define ID1! = LastCreatedEntity();

        CreateEffect(Color: Color.LimeGreen,Type: Effect.Ring
        ,Position:  EvaluateOnce(location),Radius: 5,Reevaluation: EffectRev.Color);
        define ID2! = LastCreatedEntity();

        Duquan_Locations += location;

        DuQuanPool[Duquan_unique_ID] = {Location:location,id1:ID1,id2:ID2}; 
        Duquan_unique_ID++;
    }

    rule: '毒炸弹倒数'
    Event.OngoingPlayer
    Team.All
    Player.All
    if(Duquan_CountDown > 0 && Duquan_CountDown >0)
    {
        while(Duquan_CountDown>0){
            SmallMessage(EventPlayer(),<'毒炸弹倒计时:<0>s',EventPlayer().Duquan_CountDown>);
            PlayEffect(EventPlayer(),PlayEffect.DebuffImpactSound,Position: PositionOf(),Radius: 150);
            Wait(1);
        }
        SetStatus(EventPlayer(),null,Status.KnockedDown,1);
        Damage(PlayersWithinRadius(Center: EventPlayer(),Radius: 5,Team: Team.Team2,LOSCheck: RadiusLOS.Surfaces),null,50);
        _CreateDuQuan(RayCastHitPosition(EventPlayer(),PositionOf(EventPlayer())+Vector(0,-20,0),PlayersToInclude: [],IncludePlayerOwnedObjects: []));

        if(Current_Boss.Entity.bot_State >= 2){
            FilteredArray(PlayersWithinRadius(Center: EventPlayer(),Radius: 5,Team: Team.Team2,LOSCheck: RadiusLOS.Surfaces),ArrayElement().Duquan_CountDown==0&&ArrayElement()!=EventPlayer()).Duquan_CountDown = RandomInteger(8,12);
        }
        

    }
    class Skill_JiXianBaoNu : BossSkill {
