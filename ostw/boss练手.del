    class Skill_BaoChiJuLi_Damaged : BossSkill {

        public constructor() 
        {
            Name = <'<0>保持距离',AbilityIconString(Hero.Winston,Button.Melee)>;
            Description = '猩猩会对近距离的敌人拳击\n造成巨额伤害\n并加速25%大招充能';
            Cooldown = 8;

            RequiredPhase = 1;

            RuleType = TriggerType.OnDamage;

            TriggerButton = Button.Melee;
        }
        
        
        // 实现效果
        public virtual override void OnActive(Player boss, Player target = Victim()) {
            
            // 特效：爆炸效果
            PlayEffect(
                Type: PlayEffect.BadExplosion,
                VisibleTo: AllLivingPlayers(),
                Color: Color.Red,
                Position: PositionOf(target),
                Radius: 3
            );

            // 击倒和击退
            SetStatus(target, boss, Status.KnockedDown, 1);
            ApplyImpulse(target, DirectionTowards(EyePosition(boss), EyePosition(target)), 150);

            // 禁用拳击以防止连续触发
            SetMeleeEnabled(boss,false);
            WaitUntil(IsOnGround(target), 3);

            // 造成伤害
            Damage(target, boss, 0.4*MaxHealth(target));

            SetUltimateCharge(boss, UltimateChargePercent(boss)+25);

            // 回复10%已损失生命值
            Heal(boss, null, 0.1*(MaxHealth(boss)-Health(boss)));
            PlayEffect(Type: PlayEffect.GoodPickupEffect,Color: Color.Green,Position: boss,Radius: 1);
            PlayEffect(Type: PlayEffect.HealTargetActiveEffect,Position: boss,Radius: 200);

            // 恢复拳击
            WaitAsync(5,()=>{SetMeleeEnabled(boss,true);});
        }
    }


    globalvar String BossPassiveSkillsText;

    void GenerateBossPassiveSkillsText(Boss boss!)'生成boss被动技能文本'{
        define message! = '————————\n';
        foreach(BossSkill skill! in boss.Skills.Filter(BossSkill => BossSkill.Cooldown == 0 && BossSkill.RequiredPhase <= boss.Entity.bot_State)){
            message = message + skill.Name + ':\n  ' + skill.Description + '\n\n';
        }
        BossPassiveSkillsText = message;
    }

    //从1到0的变化，0为完成态
    Color GradientColor(Number[] Start_RGB,Number[] End_RGB,Number Loader):
        CustomColor(
            End_RGB[0] - Loader*(End_RGB[0]-Start_RGB[0]),
            End_RGB[1] - Loader*(End_RGB[1]-Start_RGB[1]),
            End_RGB[2] - Loader*(End_RGB[2]-Start_RGB[2]),

            200 - Loader*(200-75)
        );

    Color UnfinishedColor_Red:
        CustomColor(178, 34, 34, 255);

        Number UnfinishedColor_Red_R:
            178;

        Number UnfinishedColor_Red_G:
            34;

        Number UnfinishedColor_Red_B:
            34;

    Color FinishedColor_Green:
        CustomColor(62, 220, 94, 255);

        Number FinishedColor_Gold_R:
            255;

        Number FinishedColor_Gold_G:
            215;

        Number FinishedColor_Gold_B:
            0;

    Color TextColor_Beige:
        CustomColor(245,245,220,255);

    Color SubheaderColor_SandyBrown:
        CustomColor(244,164,96,255);

    globalvar Any[] Current_BossActiveSkill_HUDids;

    rule: 'My Player Rule'
    Event.OnDeath
    Team.All
    Player.All
    if(IsDummyBot())
    {
        DestroyDummyBot(Team.Team1,SlotOf(EventPlayer()));
    }
    void GenerateBossActiveSkillsHUD(Boss boss!)'生成boss主动技能文本'{
        foreach(Any hud! in Current_BossActiveSkill_HUDids){
            DestroyHudText(hud);
        }
        Current_BossActiveSkill_HUDids = [];
        Number i! = 0;
        foreach(BossSkill skill! in boss.Skills.Filter(BossSkill => BossSkill.Cooldown > 0 && BossSkill.RequiredPhase <= boss.Entity.bot_State)){
            i++;
            CreateHudText(
                Header: <'\r\r\r\r\r\n\r\r<0>\n',EvaluateOnce(skill).Name>,
                Subheader: EvaluateOnce(skill).CurrentCooldown > 0 ? <'<0>未就绪',IconString(Icon.No)> : <'<0>已就绪',IconString(Icon.Checkmark)>,
                Text: <'<0>\n\n当前冷却:<1>s',EvaluateOnce(skill).Description,EvaluateOnce(skill).CurrentCooldown>,
                Location: Location.Left,
                Reevaluation: HudTextRev.VisibleToSortOrderStringAndColor,
                SortOrder: i,

                HeaderColor: 

                EvaluateOnce(skill).CurrentCooldown > 0 
                ? 
                GradientColor(
                    [UnfinishedColor_Red_R,UnfinishedColor_Red_G,UnfinishedColor_Red_B],
                    [FinishedColor_Gold_R,FinishedColor_Gold_G,FinishedColor_Gold_B],
                    EvaluateOnce(skill).CurrentCooldown/EvaluateOnce(skill).Cooldown
                    )
                :
                FinishedColor_Green

                    ,

                SubheaderColor: SubheaderColor_SandyBrown,
                TextColor: TextColor_Beige
            );
            Current_BossActiveSkill_HUDids += LastTextID();
        }
    }

    void RefreshBossTexts(Boss boss!)'刷新boss文本'{
        GenerateBossPassiveSkillsText(boss);
        GenerateBossActiveSkillsHUD(boss);
    }

    rule: 'Boss文本初始化'
    {
        CreateHudText(
            VisibleTo: AllLivingPlayers(),
            Text: BossPassiveSkillsText,
            Location: Location.Right,
            SortOrder: -9999,
            TextColor: Color.Orange,
            Reevaluation: HudTextRev.VisibleToSortOrderStringAndColor
        );
    }

