    enum TriggerType {
            Ongoing,    // 持续检测型
            OnDamage     // 伤害事件型
        }

    // 动态实例
    class Boss {
        public BossData Data;  // 引用配置
        public Player Entity;
        public BossSkill[] Skills;
        // 新增：英雄专属初始化委托
        public (Player)=>void HeroSpecificSetup;
        
        public constructor(BossData data, BossSkill[] skills, (Player)=>void heroSetup = null) {
            BossPool += this;

            Data = data;
            Skills = skills;
            HeroSpecificSetup = heroSetup;  // 保存委托

            // 基础初始化
            CreateDummyBot(
                Hero: Data.BossHero,
                Team: Team.Team1,
                Slot: -1,
                Position: NearestWalkablePosition(),
                Facing: Vector(0, 0, 0)
            );
            Entity = LastCreatedEntity();
            
            CreateBeamEffect(AllLivingPlayers(),BeamType.BadBeam,EyePosition(Entity),EyePosition(Entity.bot_target_player),Color.Red,EffectRev.VisibleToPositionRadiusAndColor);

            // 通用属性
            Entity.isBoss = true;
            Entity.bot_Name = Data.Name;
            Entity.bot_State = 1;

            WaitUntil(IsAlive(Entity) && HasSpawned(Entity) ,5);
            StartForcingDummyBotName(Entity, Data.Name);
            StartScalingPlayer(Entity, Data.Scale);
            AddHealthPoolToPlayer(Entity, HealthType.Health, Data.Health * (NumberOfPlayers(Team.Team2)/4), Recoverable: true, Reevaluation: true);
            SetDamageReceived(Entity, Data.Armor);

            Current_Boss = this;
            RefreshBossTexts(this);

            // 执行英雄专属逻辑（如果提供了委托）
            if (HeroSpecificSetup != null) {
                HeroSpecificSetup(Entity);
            }
            
            
        }

        public void CreateBoss(){
            // 基础初始化
            CreateDummyBot(
                Hero: Data.BossHero,
                Team: Team.Team1,
                Slot: -1,
                Position: Vector(0, 0, 0),
                Facing: Vector(0, 0, 0)
            );
            Entity = LastCreatedEntity();
            

            // 通用属性
            Entity.isBoss = true;
            Entity.bot_Name = Data.Name;
            Entity.bot_State = 1;

            WaitUntil(IsAlive(Entity) && HasSpawned(Entity) ,5);
            StartForcingDummyBotName(Entity, Data.Name);
            StartScalingPlayer(Entity, Data.Scale);
            AddHealthPoolToPlayer(Entity, HealthType.Health, Data.Health, Recoverable: true, Reevaluation: true);
            SetDamageReceived(Entity, Data.Armor);

            Current_Boss = this;
            RefreshBossTexts(this);

            // 执行英雄专属逻辑（如果提供了委托）
            if (HeroSpecificSetup != null) {
                HeroSpecificSetup(Entity);
            }
        }
        // 触发技能（外部调用入口）
        public void CastSkill(Number skillIndex, Player target) {
            if (skillIndex < Skills.Length) {
                Skills[skillIndex].Trigger(Entity, target);
            }
        }
        
        // 自动触发所有可用的技能
        public void AutoCastSkills_Ongoing(Player target) {
            define fiteredSkill_Ongoing = Skills.Filter(BossSkill => BossSkill.RuleType == TriggerType.Ongoing);
            foreach (BossSkill skill! in fiteredSkill_Ongoing) {
                skill.Trigger(Entity, target);
            }
        }

        public void AutoCastSkills_OnDamageDealt(Player target,Button eventButton) {
            define fiteredSkill_OnDamageDealt = Skills.Filter(BossSkill => BossSkill.RuleType == TriggerType.OnDamage);
            foreach (BossSkill skill! in fiteredSkill_OnDamageDealt) {
                if(skill.TriggerButton == eventButton){
                    skill.Trigger(Entity, target);
                }
            }
        }
    }

    single struct BossData {
        public String Name;
        public Hero BossHero;
        public Number Scale;
        public Number Health;
        public Number Armor;
    }

    class BossSkill {
        // 基础属性
        public String Name;
        public String Description;
        public Number Cooldown;
        public Number CurrentCooldown;
        public Number RequiredPhase = 1;
        public Button TriggerButton;
        public TriggerType RuleType = TriggerType.Ongoing;
        // 构造函数
        public constructor() {
        }
        
        // 公开方法：触发技能（管理冷却和条件检查）
        public void Trigger(Player boss, Player target) {
            if (CurrentCooldown <= 0 && RequiredPhase <= boss.bot_State && HasSpawned(boss) && CanTrigger(boss)) {
                    CurrentCooldown = Cooldown;
                OnActive(boss, target);  // 实际技能效果
            }
        }
        
        // 可覆盖的条件检查
        public virtual Boolean CanTrigger(Player boss) {
            return true;
        }
        
        // 虚方法：技能具体效果（子类必须实现）
        public virtual void OnActive(Player boss, Player target) {
            // 默认空实现（或抛出错误）
            SmallMessage(null, "技能未实现: " + Name);
        }
        
        // 更新冷却
        public void Update() {
            CurrentCooldown = Max(0, CurrentCooldown - 0.25);
        }
    }

    class Skill_YuanShiBaoNu : BossSkill {
        public Boolean _hasTriggered = false;  // 新增：标记是否已触发

        public constructor() 
        {
            Name = <'<0>原始暴怒',AbilityIconString(Hero.Winston,Button.Ultimate)>;
            Description = '低于1000血\n释放大招';
            Cooldown = 0;
            RequiredPhase = 1;
            
        }
        
        // 覆盖条件检查
        public override Boolean CanTrigger(Player boss) {
            return !_hasTriggered && Health(boss) < 1000;
        }
        
        // 实现效果
        public override void OnActive(Player boss, Player target) {
            _hasTriggered = true;  // 设置为已触发

            SetStatus(boss,boss,Status.Stunned,1);
            SetStatus(boss,boss,Status.Unkillable,10);
            Wait(1,WaitBehavior.IgnoreCondition);
            SetUltimateCharge(boss,100);
            NextBossPhase(boss);
            StartScalingPlayer(Player: boss,Scale: 1.6);
            SetMoveSpeed(boss,100);
        }
    }
