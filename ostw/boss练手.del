    class Skill_DuQuanZhaDan_Damaged : BossSkill{
        
        public constructor() 
        {
            Name = <'<0>毒圈炸弹',IconString(Icon.Poison2)>;
            Description = '猪的钩子带毒\n目标会附带一个定时炸弹\n在炸弹结束时被击倒\n并在原地留下一个永久的毒圈';
            Cooldown = 10;

            RuleType = TriggerType.OnDamage;

            TriggerButton = Button.Ability1;
        }

        // 实现效果
        public override void OnActive(Player boss, Player target) {
            target.Duquan_CountDown = RandomInteger(8,12);
            SetAbilityCooldown(boss,Button.Ability1,Cooldown+2);
        }
    }

    class Skill_DuNAiGuan : BossSkill{

        public constructor() 
        {
            Name = <'<0>毒奶罐',AbilityIconString(Hero.Roadhog,Button.SecondaryFire)>;
            Description = '释放毒奶罐时\n路霸会点名所有红圈外的玩家\n睡眠2s\n额外附带毒炸弹';
            Cooldown = 16;
        }
        // 实现效果
        public override void OnActive(Player boss, Player target) {
            BigMessage(Header: '快在它喝奶结束前靠近毒猪！');
            SetAbilityCharge(boss,Button.SecondaryFire,100);
            StartHoldingButton(boss,Button.SecondaryFire);
            Wait(1);
            WaitUntil(!IsFiringSecondary(boss),4);
                    Player[] player! = FilteredArray(AllLivingPlayers(Team.Team2),ArrayElement().Duquan_CountDown==0 && DistanceBetween(ArrayElement(),boss) >= 12);
                    SetStatus(player,null,Status.Asleep,2);
