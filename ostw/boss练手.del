                SetAbilityCooldown(boss,Button.Ability1,Min(
                Min(1.5,
                AbilityCooldown(boss,Button.Ability1) - (0.01*Min(UltimateChargePercent(boss),80))*AbilityCooldown(boss,Button.Ability1))
                ,AbilityCooldown(boss,Button.Ability1))
                );
            }
        }
    }

