    class Skill_JingPen : BossSkill {

        public constructor() 
        {
            Name = <'<0>井喷',IconString(Icon.Fire)>;
            Description = '在所有毒圈释放三次爆炸\n每次造成150伤害';
            Cooldown = 5;
            RequiredPhase = 2;
        }
        // 实现效果
        public override void OnActive(Player boss, Player target) {
            define count = 0;
            while(count < 3){
                Wait(1);
                count = count + 1;
                foreach(Vector duquan! in Duquan_Locations){
                Damage(PlayersWithinRadius(duquan,Radius: 5,Team: Team.Team2,LOSCheck: RadiusLOS.Surfaces),null,200);
                PlayEffect(Type: PlayEffect.JunkratFragLauncherExplosionEffect,Color: Team.Team1,Position: duquan,Radius: 5);
                PlayEffect(Type: PlayEffect.ExplosionSound,Color: Team.Team1,Position: duquan,Radius: 100);
                }
            }
            
            
        }
    }



