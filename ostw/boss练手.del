    void MonkeySetup(in Player p){
        WaitUntil(HasSpawned(),1);
        ForceThrottle(p,1);
        SetMoveSpeed(p,65);
        CreateEffect(IsAlive(EvaluateOnce(p))?AllLivingPlayers():null,Effect.Ring,Color.Red,UpdateEveryFrame(PositionOf(EvaluateOnce(p))),3,Reevaluation: EffectRev.VisibleToPositionRadiusAndColor);
        CreateEffect(IsAlive(EvaluateOnce(p))?AllLivingPlayers():null,Effect.Ring,Color.Red,UpdateEveryFrame(PositionOf(EvaluateOnce(p))),9,Reevaluation: EffectRev.VisibleToPositionRadiusAndColor);
        CreateInWorldText(Position: EvaluateOnce(p),Header: <'<0> <1>%',AbilityIconString(Hero.Winston,Button.Ultimate),UltimateChargePercent(EvaluateOnce(p))>,Scale: 2,Clipping: Clipping.DoNotClip,TextColor: Color.Rose,VisibleTo: IsAlive(EvaluateOnce(p))?AllLivingPlayers():null);
    }
    rule: '战斗Ai调用'
