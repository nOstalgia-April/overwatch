    struct DuQuan{
        public Vector Location;
        public Any id1;
        public Any id2;

        public void DestroyDuQuan(){
            Duquan_Locations -= Location;
            DestroyEffect(id1);
            DestroyEffect(id2);
        }
    }
    playervar Boolean Person3=false;
    rule: '第三人称'
    Event.OngoingPlayer
    Team.All
    Player.All
    if(IsButtonHeld(EventPlayer(),Button.Interact))
    {
        Wait(1,WaitBehavior.AbortWhenFalse);
        if(!Person3){
            StartCamera(EventPlayer(), RayCastHitPosition(EyePosition(EventPlayer()), EyePosition(EventPlayer()) + WorldVectorOf(Vector(0,
            1, 0), EventPlayer(), LocalVector.Rotation) + FacingDirectionOf(EventPlayer()) * -2, AllPlayers(), EventPlayer(), true),
            UpdateEveryFrame(RayCastHitPosition(EyePosition(EventPlayer()), EyePosition(EventPlayer()) + 100 * FacingDirectionOf(
            EventPlayer()), AllPlayers(), EventPlayer(), true)), 20);
        }
        else{
            StopCamera(EventPlayer());
        }
        
    }
    class Skill_DuQuanZao : BossSkill{

        public constructor() 
        {
            Name = <'<0>毒圈澡',IconString(Icon.Happy)>;
            Description = '当毒猪路过毒圈时\n消除毒圈\n并回复20%已损失生命值';
            Cooldown = 1;

            RequiredPhase = 2;
        }
        public override Boolean CanTrigger(Player boss) {
            return IsTrueForAny(Duquan_Locations,DistanceBetween(ArrayElement(),boss)<=5) && CountOf(Duquan_Locations)>0;
        }
        // 实现效果
        public override void OnActive(Player boss, Player target) {
            Heal(boss,null,0.2*(MaxHealth(boss)-Health(boss)));
            PlayEffect(Type: PlayEffect.BrigitteWhipShotHealAreaEffect,Position: boss,Radius: 2);

            Vector theDuquan = FirstOf(FilteredArray(Duquan_Locations,DistanceBetween(ArrayElement(),boss)<=5));
            FindDuQuanByLocation(theDuquan).DestroyDuQuan();
        }
    }

    DuQuan FindDuQuanByLocation(in Vector location){
        foreach(DuQuan f in DuQuanPool){
            if(f.Location == location){
                return f;
            }
        }
    }
    rule: '入侵毒圈内的人'
    if(CountOf(Duquan_Locations))
    {
        foreach(Vector duquan! in Duquan_Locations){
            SetStatus(Status: Status.Hacked,Duration: 1,Player: PlayersWithinRadius(Center: duquan,Radius: 5,Team: Team.Team2,LOSCheck: RadiusLOS.Surfaces),Assister: null);
        }
        Wait(1);
        LoopIfConditionIsTrue();
    }



    rule: '夹腿调试中'
    Event.OngoingPlayer
    Team.Team1
    Player.All
    if(IsButtonHeld(HostPlayer(),Button.Interact))
    {
        Current_Boss.Skills[0].Trigger(boss: Current_Boss.Entity,target: null);
    }

    playervar Any bot_target_array;
    playervar Any bot_target_player;

    rule: '机器人-寻找有效目标'
    Event.OngoingPlayer
    Team.All
    Player.All
    if(IsDummyBot() && HasSpawned() && IsAlive())
    {

        EventPlayer().bot_target_array = FilteredArray(AllLivingPlayers(OppositeTeamOf(TeamOf(EventPlayer()))),
                EventPlayer() != ArrayElement() && HasSpawned(ArrayElement()) && !IsDummyBot(ArrayElement())
                && IsInLineOfSight(EventPlayer(), ArrayElement(), Barriers: BarrierLOS.NoBarriersBlock));
        
        if(CountOf(EventPlayer().bot_target_array) > 0){
            EventPlayer().bot_target_player = FirstOf(SortedArray(EventPlayer().bot_target_array, DistanceBetween(EventPlayer(),
                    ArrayElement())));
        }
        Wait(1,WaitBehavior.AbortWhenFalse);
        LoopIfConditionIsTrue();
    }

    playervar Number bot_ballistic_velocity = -0.003;
    playervar Number bot_aiming_accuracy = 0;

    void botFacing(Player p)'sub 机器人开始朝向'{
        StartFacing(
            p, 
            DirectionTowards(
                EyePosition(p), 
                EyePosition(p.bot_target_player) 
                + Down() * DistanceBetween(p, p.bot_target_player) * 0.010 
                + VelocityOf(p.bot_target_player) 
                * (DistanceBetween(p, p.bot_target_player) * p.bot_ballistic_velocity + 0.200) 
                + DirectionFromAngles(
                    HorizontalFacingAngleOf(p) 
                    + RandomReal(
                        DistanceBetween(p, p.bot_target_player) * AbsoluteValue(p.bot_aiming_accuracy) * -1, 
                        DistanceBetween(p, p.bot_target_player) * AbsoluteValue(p.bot_aiming_accuracy)
                    ),
                    VerticalFacingAngleOf(p) 
                    + RandomReal(
                        DistanceBetween(p, p.bot_target_player) * AbsoluteValue(p.bot_aiming_accuracy) * 0.250 * -1, 
                        DistanceBetween(p, p.bot_target_player) * AbsoluteValue(p.bot_aiming_accuracy) * 0.250
                    )
                ) * 1
            ), 
            1000,
            Relative: Relative.ToWorld,
            FacingRev.DirectionAndTurnRate
        );
    }

    void MonkeyAi(Player bossEntity)'sub MonkeyAi'{
        botFacing(bossEntity);
        while(CountOf(bossEntity.bot_target_array) > 0){
            Wait(0.500, WaitBehavior.IgnoreCondition);
                if(DistanceBetween(EyePosition(bossEntity), EyePosition(bossEntity.bot_target_player)) < 9 || !IsFiringPrimary(
                    bossEntity)){
                        StartHoldingButton(bossEntity, Button.PrimaryFire);
                        StopHoldingButton(bossEntity,Button.SecondaryFire);
                        
                    }
                else{
                    StartHoldingButton(bossEntity, Button.SecondaryFire);
                    StopHoldingButton(bossEntity,Button.PrimaryFire);
                }

                if(DistanceBetween(EyePosition(bossEntity), EyePosition(bossEntity.bot_target_player)) < 3){
                        PressButton(bossEntity,Button.Melee);
                    }

                if(DistanceBetween(EyePosition(bossEntity), EyePosition(bossEntity.bot_target_player)) < 40 && (DistanceBetween(
                    EyePosition(bossEntity), EyePosition(bossEntity.bot_target_player)) > 9 || AbsoluteValue(YOf(PositionOf(
                    bossEntity)) - YOf(EyePosition(bossEntity.bot_target_player))) > 2) || IsUsingUltimate(bossEntity)){
                        PressButton(bossEntity, Button.Ability1);
                    }
                
                if(UltimateChargePercent(bossEntity) == 100){
                        PressButton(bossEntity, Button.Ability1);
                        Wait(0.500, WaitBehavior.IgnoreCondition);
                        PressButton(bossEntity, Button.Ultimate);
                        Wait(0.500, WaitBehavior.IgnoreCondition);
                        PressButton(bossEntity, Button.Ability1);
                    }
        }
        StopHoldingButton(bossEntity, Button.PrimaryFire);
        StopHoldingButton(bossEntity, Button.SecondaryFire);
        PressButton(bossEntity, Button.Reload);
    }

    void PoisionPigAi(Player bossEntity)'sub PoisionPig'{
        botFacing(bossEntity);
        while(CountOf(bossEntity.bot_target_array) > 0){
            Wait(0.500, WaitBehavior.IgnoreCondition);
                if(DistanceBetween(EyePosition(bossEntity), EyePosition(bossEntity.bot_target_player)) < 9 || !IsFiringPrimary(
                    bossEntity)){
                        StartHoldingButton(bossEntity, Button.PrimaryFire);
                    }
                else{
                    if(!IsUsingUltimate(bossEntity)){
                        StopHoldingButton(bossEntity,Button.PrimaryFire);
                    }
                    
                }

                if(!IsUsingUltimate(bossEntity)&&DistanceBetween(EyePosition(bossEntity), EyePosition(bossEntity.bot_target_player)) < 3){
                        PressButton(bossEntity,Button.Melee);
                    }

                if(!IsUsingUltimate(bossEntity)){
                    MinWait();
                        PressButton(bossEntity, Button.Ability1);
                    WaitUntil(!IsUsingAbility1(),1);
                    }
            

                if(RandomInteger(0,1)==0){
                    PressButton(bossEntity,Button.Reload);
                }
        }
        StopHoldingButton(bossEntity, Button.PrimaryFire);
        PressButton(bossEntity, Button.Reload);
    }

    void NextBossPhase(Player boss)'boss切换阶段'{
        boss.bot_State++;
        MinWait();
        BigMessage(AllLivingPlayers(),<'Boss进入<0>阶段，新增技能！',boss.bot_State>);
        RefreshBossTexts(GetBossByEntity(boss));
    }

    Boss GetBossByEntity(Any entity) 'sub根据实体获取boss数据'{
        foreach(Boss boss! in BossPool){
            if (boss.Entity == entity) {
                return boss;
            }
        }
        SmallMessage(Header: '获取boss失败');
        return null;
    }

    playervar Number RebirthCount;
    rule: '死亡玩家复活'
    Event.OngoingPlayer
    Team.Team2
    Player.All
    if(!IsAlive()&&HasSpawned())
    {
        RebirthCount = 10+NumberOfLivingPlayers();
        while(RebirthCount>0 && !IsAlive()){
            RebirthCount--;
            
            SmallMessage(VisibleTo: EventPlayer(),<'等待<0>复活...',RebirthCount>);
            Wait(1,WaitBehavior.IgnoreCondition);
        }
        Respawn();
    }

