variables
{
	player:
		101: bot_target_array
		106: bot_being_attack
		107: bot_target_player
}

subroutines
{
	74: soldier76
	103: Winston
}

rule("sub Winston")
{
	event
	{
		Subroutine;
		Winston;
	}

	actions
	{
		While(Count Of(Event Player.bot_target_array) > 0);
			Wait(0.500, Ignore Condition);
			If(Distance Between(Eye Position(Event Player), Eye Position(Event Player.bot_target_player)) < 9 || !Is Firing Primary(
				Event Player));
				Start Holding Button(Event Player, Button(Primary Fire));
				Stop Holding Button(Event Player, Button(Secondary Fire));
			Else;
				Start Holding Button(Event Player, Button(Secondary Fire));
				Stop Holding Button(Event Player, Button(Primary Fire));
			End;
			If(Distance Between(Eye Position(Event Player), Eye Position(Event Player.bot_target_player)) < 40 && (Distance Between(
				Eye Position(Event Player), Eye Position(Event Player.bot_target_player)) > 15 || Absolute Value(Y Component Of(Position Of(
				Event Player)) - Y Component Of(Eye Position(Event Player.bot_target_player))) > 2));
				Press Button(Event Player, Button(Ability 1));
			End;
			If(Event Player.bot_being_attack == True && Is On Ground(Event Player));
				Press Button(Event Player, Button(Ability 2));
			End;
			If(Ultimate Charge Percent(Event Player) == 100 && Ability Cooldown(Event Player, Button(Ability 1)) == 0 && Distance Between(
				Eye Position(Event Player), Eye Position(Event Player.bot_target_player)) <= 5);
				Press Button(Event Player, Button(Ability 1));
				Wait(0.500, Ignore Condition);
				Press Button(Event Player, Button(Ultimate));
				Wait(0.500, Ignore Condition);
				Press Button(Event Player, Button(Ability 1));
			End;
		End;
		Stop Holding Button(Event Player, Button(Primary Fire));
		Press Button(Event Player, Button(Reload));
	}
}

rule("sub soldier：76")
{
	event
	{
		Subroutine;
		soldier76;
	}

	actions
	{
		While(Count Of(Event Player.bot_target_array) > 0);
			Wait(0.500, Ignore Condition);
			Press Button(Event Player, Button(Primary Fire));
			If(Health(Event Player.bot_target_player) < 50);
				Press Button(Event Player, Button(Secondary Fire));
			End;
			If(Normalized Health(Event Player) < 0.500);
				Press Button(Event Player, Button(Ability 2));
			End;
			If(Ultimate Charge Percent(Event Player) == 100 && Distance Between(Eye Position(Event Player), Eye Position(
				Event Player.bot_target_player)) <= 30);
				Press Button(Event Player, Button(Ultimate));
			End;
		End;
		Stop Holding Button(Event Player, Button(Primary Fire));
		Press Button(Event Player, Button(Reload));
		Press Button(Event Player, Button(Ability 1));
	}
}

