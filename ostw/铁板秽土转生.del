String GetPartButtonLabel(Equipment_part part!) "获取部位按钮标签" {
    String partName!;
    switch (part) {
        case Equipment_part.Head: partName = "头"; break;
        case Equipment_part.Chest: partName = "身体"; break;
        case Equipment_part.boots: partName = "靴子"; break;
        case Equipment_part.talisman: partName = "护符"; break;
        case Equipment_part.weapon: partName = "武器"; break;
    }
    foreach (Equipment equip! in EventPlayer().equipped) {
        if (equip.Part == part) {
            return '(' + partName + ')' + "：" + equip.Name;
        }
    }
    return '(' + partName + ')' + "：" + '未装备';
}

String GetEquipButtonLabel(Number button_id!) "获取装备按钮标签" {
    if (EventPlayer().current_equip_list.Length > button_id) {
        Equipment equip! = EventPlayer().current_equip_list[button_id];
        String base_label = equip.Name;
        if (EventPlayer().equipped.Contains(equip)) {
            base_label = IconString(Icon.Asterisk) + base_label;
        }
        if (EventPlayer().current_selected_equip == equip) {
            base_label = base_label + "<=";
        }
        return base_label;
    }
    return "";
}

String GetEquipButtonHoverLabel(Number button_id) "获取装备按钮悬停标签" {
    if (EventPlayer().current_equip_list.Length > button_id) {
        return "选择" + EventPlayer().current_equip_list[button_id].Name;
    }
    return "";
}

String GetEquipmentDescriptionLabel(Equipment equip!) "生成装备格式化描述标签" {
    if (equip == null) {
        return "（未装备）";
    }
    
    // 获取品质名称
    String qualityName!;
    switch (equip.Quality) {
        case Equipment_quality.Average: qualityName = "普通"; break;
        case Equipment_quality.Rare: qualityName = "稀有"; break;
        case Equipment_quality.Epic: qualityName = "史诗"; break;
        case Equipment_quality.Ledgend: qualityName = "传奇"; break;
        case Equipment_quality.Mythic: qualityName = "神话"; break;
        case Equipment_quality.Mysterious: qualityName = "神秘"; break;
    }
    
    // 获取部位名称
    String partName!;
    switch (equip.Part) {
        case Equipment_part.Head: partName = "头部"; break;
        case Equipment_part.Chest: partName = "胸部"; break;
        case Equipment_part.boots: partName = "靴子"; break;
        case Equipment_part.talisman: partName = "护符"; break;
        case Equipment_part.weapon: partName = "武器"; break;
    }
    
    // 构建描述头部
    String result! = '[' + equip.Name + '] (' + qualityName + ')\n';
    result = result + '-' + partName + '\n\n';
    
    
    // 按 AllStatName_Ordered 顺序遍历属性
    foreach (String key! in AllStatName_Ordered) {
        if (equip.QuadriStats.Keys.Contains(key)) {
            result = result + key + ': ' + equip.QuadriStats.Get(key) + '\n';
        }
        MinWait();
    }
    
    // 添加描述
    result = result + '\n' + '“' + equip.Description + '”';
    
    return result;
}

void PartButtonOnClick(Equipment_part part!) "部位按钮点击处理" {
    EventPlayer().current_part = part;
    EventPlayer().current_selected_equip = null;
    foreach (Equipment equip! in EventPlayer().equipped) {
        if (equip.Part == part) {
            EventPlayer().current_selected_equip = equip;
            break;
        }
    }
    define bn! = GetButtonByName('介绍描述按钮');
    if (EventPlayer().current_selected_equip != null) {
        bn.SetLabel(GetEquipmentDescriptionLabel(EventPlayer().current_selected_equip));
        bn.SetDefaultColor(quality_Colors[<Number>EventPlayer().current_selected_equip.Quality]);
    } else {
        bn.SetLabel('（未装备）');
        bn.SetDefaultColor(Color.White);
    }
    UpdateEquipButtons();
}

void EquipButtonOnClick(Number button_id!) "装备按钮点击处理" {
    if (EventPlayer().current_equip_list.Length > button_id) {
        define DisplayModeBN! = GetButtonByName('介绍描述按钮');
        Equipment selected! = EventPlayer().current_equip_list[button_id];
        EventPlayer().current_selected_equip = selected;
        EventPlayer().current_description = GetEquipmentDescriptionLabel(selected);
        DisplayModeBN.SetLabel(current_description);
        DisplayModeBN.SetDefaultColor(quality_Colors[<Number>selected.Quality]);
        UpdateEquipButtons();
    }
}

void LeftPageOnClick() "左翻页按钮点击处理" {
    if (EventPlayer().current_page > 0) {
        EventPlayer().current_page -= 1;
        UpdateEquipButtons();
    }
}

void RightPageOnClick() "右翻页按钮点击处理" {
    Number total_pages! = RoundToInteger((FilteredEquipmentList().Length + 4) / 5, Rounding.Down);
    if (EventPlayer().current_page < total_pages - 1) {
        EventPlayer().current_page += 1;
        UpdateEquipButtons();
    }
}

void DisplayModeOnClick() "显示模式按钮点击处理" {
    String[] display_modes! = ["全部", "头", "身体", "靴子", "护符", "武器"];
    EventPlayer().current_display_mode_index = (EventPlayer().current_display_mode_index + 1) % display_modes.Length;
    EventPlayer().current_display_mode = display_modes[EventPlayer().current_display_mode_index];
    EventPlayer().current_page = 0;
    GetButtonByName('显示模式按钮').SetLabel('显示：' + current_display_mode);
    UpdateEquipButtons();
}

Equipment[] FilteredEquipmentList() "过滤和排序装备列表" {
    Equipment[] filtered!;
    if (EventPlayer().current_display_mode == "全部") {
        filtered = EventPlayer().equipment_got;
    } else {
        Equipment_part part!;
        switch (EventPlayer().current_display_mode) {
            case "头": part = Equipment_part.Head; break;
            case "身体": part = Equipment_part.Chest; break;
            case "靴子": part = Equipment_part.boots; break;
            case "护符": part = Equipment_part.talisman; break;
            case "武器": part = Equipment_part.weapon; break;
        }
        filtered = FilteredArray(EventPlayer().equipment_got, (<Equipment>ArrayElement()).Part == part);
        filtered = SortedArray(filtered, <Number>(<Equipment>ArrayElement()).Quality);
    }
    return filtered;
}

void UpdateEquipButtons() "更新装备按钮" {
    Equipment[] filtered_list! = FilteredEquipmentList();
    Number start_index! = EventPlayer().current_page * 5;
    Number end_index! = Min(start_index + 5, filtered_list.Length);
    EventPlayer().current_equip_list = ArraySlice(filtered_list, start_index, end_index);
    Number total_pages! = RoundToInteger((filtered_list.Length + 4) / 5, Rounding.Down);
    GetButtonByName("页码显示按钮").SetLabel(<String>(EventPlayer().current_page + 1) + "/" + total_pages);
    for (Number i! = 0; i < 5; i = i + 1) {
        String buttonName! = "装备按钮" + (i + 1);
        MenuButton button! = GetButtonByName(buttonName);
        if (EventPlayer().current_equip_list.Length > i) {
            Equipment equip! = EventPlayer().current_equip_list[i];
            button.SetLabel(GetEquipButtonLabel(i));
            button.SetDefaultColor(quality_Colors[<Number>equip.Quality]);
        } else {
            button.SetLabel("");
            button.SetDefaultColor(Color.White);
        }
    }
    String[] parts! = ["头", "身体", "靴子", "护符", "武器"];
    Equipment_part[] part_enums! = [Equipment_part.Head, Equipment_part.Chest, Equipment_part.boots, Equipment_part.talisman, Equipment_part.weapon];
    for (Number i! = 0; i < parts.Length; i = i + 1) {
        String buttonName! = parts[i] + "按钮";
        MenuButton button! = GetButtonByName(buttonName);
        button.SetLabel(GetPartButtonLabel(part_enums[i]));
        Boolean hasEquip! = false;
        foreach (Equipment equip! in EventPlayer().equipped) {
            if (equip.Part == part_enums[i]) {
                button.SetDefaultColor(quality_Colors[<Number>equip.Quality]);
                hasEquip = true;
                break;
            }
        }
        if (!hasEquip) {
            button.SetDefaultColor(Color.White);
        }
    }
}

void WearButtonOnClick() "穿戴按钮点击处理" {
    if (EventPlayer().current_selected_equip != null) {
        EquipItem(EventPlayer().current_selected_equip);
        UpdateEquipButtons();
        define bn! = GetButtonByName('介绍描述按钮');
        bn.SetLabel(GetEquipmentDescriptionLabel(EventPlayer().current_selected_equip));
        bn.SetDefaultColor(quality_Colors[<Number>EventPlayer().current_selected_equip.Quality]);
    } else {
        SmallMessage(EventPlayer(), "请先选择一件装备");
    }
}

void RemoveButtonOnClick() "卸下按钮点击处理" {
    if (EventPlayer().current_selected_equip != null) {
        if (EventPlayer().equipped.Contains(EventPlayer().current_selected_equip)) {
            UnequipItemByPart(EventPlayer().current_selected_equip.Part);
            UpdateEquipButtons();
        } else {
            SmallMessage(EventPlayer(), "选中的装备未装备");
        }
    } else {
        SmallMessage(EventPlayer(), "请先选择一个装备");
    }
}


Number GetStat(String statName!) "sub获取玩家属性值" {
    Number index! = EventPlayer().PlayerStats.Keys.IndexOf(statName);
    if (index != -1) {
        return EventPlayer().PlayerStats.Values[index];
    }
    return 0;
}

void SetStat(in String statName, in Number value!) {
    Number index! = EventPlayer().PlayerStats.Keys.IndexOf(statName);
    if (index != -1) {
        EventPlayer().PlayerStats.Values[index] = value;
    } else {
        EventPlayer().PlayerStats.Keys = EventPlayer().PlayerStats.Keys + [statName];
        EventPlayer().PlayerStats.Values = EventPlayer().PlayerStats.Values + [value];
    }
}

void EquipItem(Equipment newEquip!) "根据id给玩家穿戴装备" {
    
    // 检查装备是否存在
    if (newEquip == null) {
        MinWait();
        SmallMessage(EventPlayer(),  " 错误：装备不存在");
        return;
    }
    
    // 检查玩家是否拥有该装备
    if (!EventPlayer().equipment_got.Contains(newEquip)) {
        MinWait();
        SmallMessage(EventPlayer(), "你尚未拥有装备: " + newEquip.Name);
        return;
    }
    
    // 检查是否已装备在同一部位
    Number indexToReplace! = -1;
    foreach (Equipment equippedItem! in EventPlayer().equipped) {
        if (equippedItem.Part == newEquip.Part) {
            indexToReplace = EventPlayer().equipped.IndexOf(equippedItem);
            break;
        }
    }
    
    // 如果该部位已有装备，则卸下旧装备
    if (indexToReplace != -1) {
        Equipment oldEquip! = EventPlayer().equipped[indexToReplace];
        SmallMessage(EventPlayer(), "老装备index" + indexToReplace);
        // 如果新装备已经装备在此部位，则不重复操作
        if (oldEquip.ID == newEquip.ID) {
            MinWait();
            return;
        }
        // 卸下旧装备，更新属性
        foreach (String key! in oldEquip.QuadriStats.Keys) {
            SetStat(key, GetStat(key) - oldEquip.QuadriStats.Get(key));
        }
        MinWait();
        SmallMessage(EventPlayer(), "已卸下: " + oldEquip.Name);
        EventPlayer().equipped[indexToReplace] = newEquip;
    } else {
        // 如果部位为空，直接装备
        EventPlayer().equipped = EventPlayer().equipped + newEquip;
    }
    
    // 装备新装备，更新属性
    foreach (String key! in newEquip.QuadriStats.Keys) {
        SetStat(key, GetStat(key) + newEquip.QuadriStats.Get(key));
    }
    MinWait();
    SmallMessage(EventPlayer(), "已装备: " + newEquip.Name);
    
    // 更新当前选中装备
    EventPlayer().current_selected_equip = newEquip;
    
    // 更新按钮和描述
    UpdateEquipButtons();
    define bn! = GetButtonByName('介绍描述按钮');
    bn.SetLabel(GetEquipmentDescriptionLabel(newEquip));
    bn.SetDefaultColor(quality_Colors[<Number>newEquip.Quality]);
    
    // 更新玩家属性
    UpdateShuxing(EventPlayer());
}

void UnequipItemByPart(in Equipment_part part) {
    Number index! = -1;
    foreach (Equipment equip! in EventPlayer().equipped) {
        if (equip.Part == part) {
            index = EventPlayer().equipped.IndexOf(equip);
            break;
        }
        MinWait();
    }
    if (index != -1) {
        foreach (String key! in EventPlayer().equipped[index].QuadriStats.Keys) {
            SetStat(key, GetStat(key) - EventPlayer().equipped[index].QuadriStats.Get(key));
        }
        SmallMessage(EventPlayer(), "已卸下: " + EventPlayer().equipped[index].Name);
        Equipment[] newEquipped = [];
        for (Number i! = 0; i < EventPlayer().equipped.Length; i = i + 1) {
            if (i != index) {
                newEquipped = newEquipped + [EventPlayer().equipped[i]];
            }
            MinWait();
        }
        EventPlayer().equipped = newEquipped;
    }
    UpdateShuxing(EventPlayer());
}


Equipment GetEquipmentByName(String Name!) "sub获取装备镜像通过名字" {
    foreach (Equipment equip! in equipment_pool) {
        if (equip.Name == Name) {
            return new Equipment(
                name: equip.Name,
                stats: {Keys: equip.QuadriStats.Keys, Values: equip.QuadriStats.Values},
                description: equip.Description,
                part: equip.Part,
                quality: equip.Quality
            );
        }
        MinWait();
    }
    return null;
}

String GetPlayerStatsDebug() "sub属性按钮" {
    String[] debugMessage! = [];
    debugMessage = debugMessage + ["玩家属性:\n\n"];
    Number statCount! = AllStatName_Ordered.Length;
    
    for (Number i! = 0; i < statCount; i = i + 3) {
        String line! = "";
        if (i < statCount) {
            String key! = AllStatName_Ordered[i];
            line = line + key + ": " + (EventPlayer().PlayerStats.Keys.Contains(key) ? GetStat(key) : 0);
        }
        if (i + 1 < statCount) {
            String key! = AllStatName_Ordered[i + 1];
                line = line + ", " + key + ": " + (EventPlayer().PlayerStats.Keys.Contains(key) ? GetStat(key) : 0);
        }
        if (i + 2 < statCount) {
            String key! = AllStatName_Ordered[i + 2];
            line = line + ", " + key + ": " + (EventPlayer().PlayerStats.Keys.Contains(key) ? GetStat(key) : 0);
        }
        debugMessage = debugMessage + [line + "\n\n"];
    }
    String result! = "";
    foreach (String i! in debugMessage) {
        result = result + i;
    }
    return result;
}

