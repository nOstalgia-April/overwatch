// === 枚举定义 ===

enum MenuActive {
    MainMenu,
    EquipMenu
}

enum ButtonScale {
    Small = 2,
    Medium = 3,
    Large = 4
}

enum Equipment_quality {
    Average,
    Rare,
    Epic,
    Ledgend,
    Mythic,
    Mysterious
}

enum Equipment_part {
    Head,
    Chest,
    boots,
    talisman,
    weapon
}

// === 类和结构定义 ===

// 字典结构
struct Dictionary<K, V> {
    public K[] Keys;
    public V[] Values;
    public V Get(in K key) {
        return Values[Keys.IndexOf(key)];
    }
    public ref void Set(in K key, in V value) {
        Values[Keys.IndexOf(key)] = value;
    }
    public ref void Add(in K key, in V value) {
        Keys += key;
        Values += value;
    }
    public ref void SetOrAdd(in K key, in V value) {
        Number index! = Keys.IndexOf(key);
        if (index == -1) Add(key, value);
        else Values[index] = value;
    }
}

// 基底类
class BaseType {
    public String name;
    public Dictionary<String, Number> inherentStats;
    public Number dropWeight;
    public String rarity;
    public constructor(
        in String name,
        in Dictionary<String, Number> inherentStats,
        in Number dropWeight,
        in String rarity
    ) {
        this.name = name;
        this.inherentStats = inherentStats;
        this.dropWeight = dropWeight;
        this.rarity = rarity;
    }
}

// 词缀类
class Affix {
    public Number Tier;
    public Number[] Range;
    public Number AffixLevel;
    public constructor(in Number tier, in Number[] range, in Number affixLevel = 0) {
        this.Tier = tier;
        this.Range = range;
        this.AffixLevel = affixLevel;
    }
}

// 装备类
class Equipment {
    public String Name;
    public Dictionary<String, Number> QuadriStats;
    public String Description;
    public Equipment_part Part;
    public Number ID;
    public Equipment_quality Quality;
    public constructor(
        in String name = "default name",
        in Dictionary<String, Number> stats = {Keys: [], Values: []},
        in String description = '空',
        in Equipment_part part = Equipment_part.Head,
        in Equipment_quality quality = Equipment_quality.Average
    ) {
        EquipmentUniqueID = EquipmentUniqueID + 1;
        Name = name;
        QuadriStats = stats;
        Description = description;
        Part = part;
        Quality = quality;
        ID = EquipmentUniqueID;
        equipment_pool[ID] = this;
    }
}

// 菜单按钮类
class MenuButton {
    public String Label;
    public String HoverLabel;
    public Number PosX;
    public Number PosY;
    public ButtonScale Scale;
    public Color DefaultColor;
    public Color HoverColor;
    public Boolean Interactable;
    public MenuActive[] ofMenuActives;
    public Number ID;
    public String Name;
    public ()=>void OnClick;
    public Any Entity;
    public constructor(
        in String label = 'null',
        in String Hovevrlabel = '',
        in Number posX = 0,
        in Number posY = 0,
        in ButtonScale scale = ButtonScale.Medium,
        in Color defaultColor = Color.White,
        in Color hoverColor = Color.Yellow,
        in Boolean interactable = false,
        in MenuActive[] ofmenuActives,
        in String name = '无名氏按钮',
        in Any onclick = 0
    ) {
        uniqueButtonID++;
        Label = label;
        HoverLabel = Hovevrlabel;
        PosX = posX;
        PosY = posY;
        Scale = scale;
        Name = name;
        DefaultColor = defaultColor;
        HoverColor = hoverColor;
        Interactable = interactable;
        ofMenuActives = ofmenuActives;
        ID = uniqueButtonID;
        EventPlayer().Button_Pool[uniqueButtonID] = this;
    }
    public void SetOnClick(in ()=>void onClick) {
        OnClick = onClick;
    }
    public void SetLabel(in String newLabel) {
        Label = newLabel;
    }
    public void SetDefaultColor(in Color color) {
        DefaultColor = color;
    }
}

// === 菜单系统相关函数和规则 ===

void GetMenuBase() {
    EventPlayer().CameraNow = [EventPlayer().Eye, EventPlayer().Eye + DirectionTowards(EventPlayer().Eye, EventPlayer().Lookat)];
    EventPlayer().MenuFlatBase1 = -0.5 * Normalize(CrossProduct(Vector(0, 1, 0), DirectionTowards(EventPlayer().CameraNow[0], EventPlayer().CameraNow[1])));
    EventPlayer().MenuFlatBase2 = -0.5 * Normalize(CrossProduct(DirectionTowards(EventPlayer().CameraNow[0], EventPlayer().CameraNow[1]), EventPlayer().MenuFlatBase1));
}

void CreateMenuText() {
    MenuCreated = true;
    foreach (MenuButton bn in EventPlayer().Button_Pool) {
        CreateInWorldText(
            VisibleTo: LocalPlayer().isInMenu && ArrayContains(UpdateEveryFrame((EvaluateOnce(bn)).ofMenuActives), LocalPlayer().menuactive) ? LocalPlayer() : null,
            Header: UpdateEveryFrame((EvaluateOnce(bn)).Label),
            Position: UpdateEveryFrame(LocalPlayer().CameraNow[1] + LocalPlayer().MenuFlatBase1 * UpdateEveryFrame((EvaluateOnce(bn)).PosX) + LocalPlayer().MenuFlatBase2 * UpdateEveryFrame((EvaluateOnce(bn)).PosY)),
            Scale: <Number>UpdateEveryFrame((EvaluateOnce(bn)).Scale),
            Clipping: Clipping.DoNotClip,
            Reevaluation: InworldTextRev.VisibleToPositionStringAndColor,
            TextColor: UpdateEveryFrame((EvaluateOnce(bn)).Interactable) && LocalPlayer().MenuLoop == UpdateEveryFrame((EvaluateOnce(bn)).ID) ? <Color>UpdateEveryFrame((EvaluateOnce(bn)).HoverColor) : <Color>UpdateEveryFrame((EvaluateOnce(bn)).DefaultColor)
        );
        bn.Entity = LastTextID();
        MinWait();
    }
}

MenuButton GetButtonByID(Number id) "sub根据ID获取按钮" {
    foreach (MenuButton b! in EventPlayer().Button_Pool) {
        if (id == b.ID) {
            return b;
        }
    }
}

MenuButton GetButtonByName(String name) "sub根据名字获取按钮" {
    foreach (MenuButton b! in EventPlayer().Button_Pool) {
        if (name == b.Name) {
            return b;
        }
    }
}

Number CURSOR_X_LOCAL:
    -HorizontalFacingAngleOf(LocalPlayer()) / MenuCursorSensibility;
Number CURSOR_X:
    -HorizontalFacingAngleOf(EventPlayer()) / MenuCursorSensibility;
Number CURSOR_Y_LOCAL:
    -VerticalFacingAngleOf(LocalPlayer()) / MenuCursorSensibility;
Number CURSOR_Y:
    -VerticalFacingAngleOf(EventPlayer()) / MenuCursorSensibility;

void MainMenu_Initialize() {
    // 退出菜单按钮
    new MenuButton(
        ofmenuActives: [MenuActive.MainMenu, MenuActive.EquipMenu],
        label: "（X）",
        interactable: true,
        name: "推出菜单按钮",
        posX: 2,
        posY: 1.2,
        scale: ButtonScale.Medium,
        defaultColor: Color.White,
        hoverColor: Color.Yellow,
        Hovevrlabel: "退出菜单"
    ).SetOnClick(CloseMenu);

    // 装备菜单按钮
    new MenuButton(
        ofmenuActives: [MenuActive.MainMenu, MenuActive.EquipMenu],
        label: "装备菜单",
        interactable: true,
        name: "装备菜单按钮",
        posX: -1,
        posY: 1.0,
        scale: ButtonScale.Medium,
        defaultColor: Color.White,
        hoverColor: Color.Yellow,
        Hovevrlabel: "打开装备管理界面"
    ).SetOnClick(OpenEquipMenu_OnClick);

    // 主菜单按钮
    new MenuButton(
        ofmenuActives: [MenuActive.MainMenu, MenuActive.EquipMenu],
        label: "主菜单",
        interactable: true,
        name: "主菜单按钮",
        posX: 0,
        posY: 1.0,
        scale: ButtonScale.Medium,
        defaultColor: Color.White,
        hoverColor: Color.Yellow,
        Hovevrlabel: "返回主菜单"
    ).SetOnClick(OpenMainMenu_OnClick);

    // 分割线
    new MenuButton(
        ofmenuActives: [MenuActive.MainMenu, MenuActive.EquipMenu],
        label: "——————————————",
        interactable: false,
        name: "分割线",
        posX: 0,
        posY: 0.85,
        scale: ButtonScale.Medium,
        defaultColor: Color.White,
        hoverColor: Color.White
    );

    // 玩家属性 debug 按钮
    new MenuButton(
        ofmenuActives: [MenuActive.MainMenu],
        label: "玩家属性加载中...",
        interactable: false,
        name: "玩家属性按钮",
        posX: 0,
        posY: -0.6,
        scale: ButtonScale.Small,
        defaultColor: CustomColor(133, 188, 255, 255),
        hoverColor: Color.White
    );
}

void OpenMainMenu() {
    EventPlayer().Eye = Vector(0, 10, 2);
    EventPlayer().Lookat = Vector(3, 324, -22);
    GetButtonByName('玩家属性按钮').SetLabel(GetPlayerStatsDebug());
}

void OpenMenu(in MenuActive name) {
    EventPlayer().menuactive = name;
    if (!isInMenu) {
        AnchorFacing = FacingDirectionOf(EventPlayer());
        isInMenu = true;
        SetAimSpeed(EventPlayer(), 0.1);
        SetPrimaryFireEnabled(EventPlayer(), false);
        SetSecondaryFireEnabled(EventPlayer(), false);
        DisableHeroHud(EventPlayer());
        DisableGameModeHud(EventPlayer());
        SetFacing(EventPlayer(), Vector(0, 0, 1));
        EventPlayer().CameraNow[0] = Vector(0, 0, 0);
        EventPlayer().CameraNow[1] = Vector(0, 0, 1);
    }
    switch (name) {
        case MenuActive.MainMenu:
            OpenMainMenu();
            break;
        case MenuActive.EquipMenu:
            OpenEquipmenu();
            break;
    }
    GetMenuBase();
    StartCamera(EventPlayer(), EventPlayer().CameraNow[0], EventPlayer().CameraNow[1], 20);
}

void CloseMenu(){
    isInMenu = false;
    StopCamera();
    SetAimSpeed(EventPlayer(),100);
    SetPrimaryFireEnabled(EventPlayer(),true);
    SetSecondaryFireEnabled(EventPlayer(),true);
    EnableHeroHud(EventPlayer());
    EnableGameModeHud(EventPlayer());
    SetFacing(EventPlayer(),AnchorFacing);
}

void OpenEquipMenu_OnClick() {
    OpenMenu(MenuActive.EquipMenu);
}

void OpenMainMenu_OnClick() {
    OpenMenu(MenuActive.MainMenu);
}

Number[] GetButtonHitBox(in MenuButton b) {
    switch (b.Scale) {
        case ButtonScale.Small: return [0.2, 0.1]; break;
        case ButtonScale.Medium: return [0.2, 0.15]; break;
        case ButtonScale.Large: return [0.3, 0.25]; break;
    }
}

rule: '互动打开主菜单'
Event.OngoingPlayer
Team.All
Player.All
if(IsButtonHeld(EventPlayer(), Button.Interact))
{
    Wait(0.2,WaitBehavior.AbortWhenFalse);
    OpenMenu(MenuActive.MainMenu);
}

rule: "指针初始化" {
    CreateInWorldText(
        VisibleTo: LocalPlayer().isInMenu ? LocalPlayer() : null,
        Header: '(+)',
        Position: UpdateEveryFrame(LocalPlayer().CameraNow[1] + LocalPlayer().MenuFlatBase1 * CURSOR_X_LOCAL + LocalPlayer().MenuFlatBase2 * CURSOR_Y_LOCAL),
        Scale: 1.5,
        Clipping: Clipping.DoNotClip,
        Reevaluation: InworldTextRev.VisibleToPositionStringAndColor,
        TextColor: Color.White
    );
    CreateHudText(Header: LocalPlayer().MenuLoop);
}

rule: "悬停文本初始化" {
    define offset! = -0.1;
    CreateInWorldText(
        VisibleTo: LocalPlayer().isInMenu && LocalPlayer().HoverVisible ? LocalPlayer() : null,
        Header: LocalPlayer().HoverText,
        Position: UpdateEveryFrame(LocalPlayer().CameraNow[1] + LocalPlayer().MenuFlatBase1 * CURSOR_X_LOCAL + LocalPlayer().MenuFlatBase2 * (CURSOR_Y_LOCAL + offset)),
        Scale: 1.5,
        Clipping: Clipping.DoNotClip,
        Reevaluation: InworldTextRev.VisibleToPositionStringAndColor,
        TextColor: LocalPlayer().hovercolor
    );
}

rule: 'My Player Rule'
Event.OngoingPlayer
Team.All
Player.All
if(EventPlayer().isInMenu)
{
    EventPlayer().isButtonHovered = false;
        define bns = FilteredArray(EventPlayer().Button_Pool, ArrayContains((<MenuButton>ArrayElement()).ofMenuActives, EventPlayer().menuactive));
        foreach (MenuButton bn in bns) {
            define HitBox! = GetButtonHitBox(bn);
            define ClickWidth = HitBox[0];
            define ClickHeight = HitBox[1];
            if (bn.ID != 0) {
                if (AbsoluteValue(CURSOR_X - bn.PosX) < ClickWidth && AbsoluteValue(CURSOR_Y - bn.PosY) < ClickHeight) {
                    EventPlayer().MenuLoop = bn.ID;
                    EventPlayer().HoverVisible = bn.HoverLabel.Length > 0;
                    EventPlayer().HoverText = bn.HoverLabel;
                    EventPlayer().hovercolor = bn.HoverColor;
                    EventPlayer().isButtonHovered = true;
                }
            }
        }
        if (!EventPlayer().isButtonHovered) {
            EventPlayer().MenuLoop = 0;
            EventPlayer().HoverVisible = 0;
        }
        Wait(0.05);
        LoopIfConditionIsTrue();
}

rule: "按钮点击" 
Event.OngoingPlayer
Team.All
Player.All
if (EventPlayer().isInMenu && IsButtonHeld(EventPlayer(), Button.PrimaryFire))
{
    if (EventPlayer().MenuLoop != 0 && GetButtonByID(EventPlayer().MenuLoop).Interactable) {
            (<()=>void>GetButtonByID(EventPlayer().MenuLoop).OnClick).Invoke();
    }
}

rule: "近战重置指针" 
Event.OngoingPlayer
Team.All
Player.All
if (EventPlayer().isInMenu && IsButtonHeld(EventPlayer(), Button.Melee))
{
        SetFacing(EventPlayer(), Vector(0, 0, 1));
}

rule: "每个玩家初始化菜单" 
Event.OngoingPlayer
Team.All
Player.All
{
    MainMenu_Initialize();
    CreateEquipMenuButtons();
    if (!MenuCreated) {
        CreateMenuText();
    }
}

// === 装备系统相关函数 ===

void OpenEquipmenu() "打开装备菜单" {
    EventPlayer().Eye = Vector(0, 10, 2);
    EventPlayer().Lookat = Vector(3, 324, -22);
    EventPlayer().current_part = Equipment_part.Head;
    EventPlayer().current_selected_equip = null;
    EventPlayer().current_description = "未选中装备";
    EventPlayer().current_page = 0;
    EventPlayer().current_display_mode = "全部";
    EventPlayer().current_display_mode_index = 0;
    GetButtonByName("显示模式按钮").SetLabel("显示：全部");
    UpdateEquipButtons();
}

void CreateEquipMenuButtons() "创建装备菜单按钮" {
    String[] parts! = ["头", "身体", "靴子", "护符", "武器"];
    Equipment_part[] part_enums! = [Equipment_part.Head, Equipment_part.Chest, Equipment_part.boots, Equipment_part.talisman, Equipment_part.weapon];
    new MenuButton(
        ofmenuActives: [MenuActive.EquipMenu],
        label: "[装备槽]",
        interactable: false,
        name: "上方分隔线",
        posX: -1.5,
        posY: 0.5,
        scale: ButtonScale.Small,
        defaultColor: Color.White,
        hoverColor: Color.White
    );
    for (Number i! = 0; i < 5; i = i + 1) {
        new MenuButton(
            ofmenuActives: [MenuActive.EquipMenu],
            label: '待定',
            interactable: true,
            name: parts[i] + "按钮",
            posX: -1.6,
            posY: 0.3 - i * 0.2,
            scale: ButtonScale.Small,
            defaultColor: Color.White,
            hoverColor: Color.Yellow
        ).SetOnClick(()=>PartButtonOnClick(part_enums[i]));
    }
    new MenuButton(
        ofmenuActives: [MenuActive.EquipMenu],
        label: "—————",
        interactable: false,
        name: "下方分隔线",
        posX: -1.5,
        posY: -0.7,
        scale: ButtonScale.Small,
        defaultColor: Color.White,
        hoverColor: Color.White
    );
    new MenuButton(
        ofmenuActives: [MenuActive.EquipMenu],
        label: '待定',
        interactable: false,
        name: "介绍描述按钮",
        posX: 0,
        posY: -0.4,
        scale: ButtonScale.Small,
        defaultColor: Color.White,
        hoverColor: Color.White
    );
    for (Number i! = 0; i < 5; i = i + 1) {
        new MenuButton(
            ofmenuActives: [MenuActive.EquipMenu],
            label: '待定',
            interactable: true,
            name: "装备按钮" + (i + 1),
            posX: 1.5,
            posY: 0.6 - i * 0.2,
            scale: ButtonScale.Small,
            defaultColor: Color.White,
            hoverColor: Color.Yellow
        ).SetOnClick(()=>EquipButtonOnClick(i));
    }
    new MenuButton(
        ofmenuActives: [MenuActive.EquipMenu],
        label: "<——",
        interactable: true,
        name: "左翻页按钮",
        posX: 1.3,
        posY: -0.4,
        scale: ButtonScale.Small,
        defaultColor: Color.White,
        hoverColor: Color.Yellow,
        Hovevrlabel: "上一页"
    ).SetOnClick(LeftPageOnClick);
    new MenuButton(
        ofmenuActives: [MenuActive.EquipMenu],
        label: "——>",
        interactable: true,
        name: "右翻页按钮",
        posX: 1.7,
        posY: -0.4,
        scale: ButtonScale.Small,
        defaultColor: Color.White,
        hoverColor: Color.Yellow,
        Hovevrlabel: "下一页"
    ).SetOnClick(RightPageOnClick);
    new MenuButton(
        ofmenuActives: [MenuActive.EquipMenu],
        label: "1/1",
        interactable: false,
        name: "页码显示按钮",
        posX: 1.5,
        posY: -0.4,
        scale: ButtonScale.Small,
        defaultColor: Color.White,
        hoverColor: Color.White
    );
    new MenuButton(
        ofmenuActives: [MenuActive.EquipMenu],
        label: "显示：全部",
        interactable: true,
        name: "显示模式按钮",
        posX: 1.5,
        posY: -0.6,
        scale: ButtonScale.Small,
        defaultColor: Color.White,
        hoverColor: Color.Yellow,
        Hovevrlabel: "切换显示模式"
    ).SetOnClick(DisplayModeOnClick);
    new MenuButton(
        ofmenuActives: [MenuActive.EquipMenu],
        label: "穿戴",
        interactable: true,
        name: "穿戴按钮",
        posX: 1.3,
        posY: -0.8,
        scale: ButtonScale.Small,
        defaultColor: Color.White,
        hoverColor: Color.Yellow,
        Hovevrlabel: "穿戴选中的装备"
    ).SetOnClick(WearButtonOnClick);
    new MenuButton(
        ofmenuActives: [MenuActive.EquipMenu],
        label: "卸下",
        interactable: true,
        name: "卸下按钮",
        posX: 1.7,
        posY: -0.8,
        scale: ButtonScale.Small,
        defaultColor: Color.White,
        hoverColor: Color.Yellow,
        Hovevrlabel: "卸下当前部位的装备"
    ).SetOnClick(RemoveButtonOnClick);
}

rule: '玩家属性持续类'
