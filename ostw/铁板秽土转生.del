    new Equipment("坚韧头盔", stats: {Keys: ["护甲", "生命"], Values: [3, 5]}, "坚韧头盔\r\n保护头部并增强生存", part: Equipment_part.Head, quality: Equipment_quality.Average);
}

// 生成随机装备
Equipment GenerateRandomEquipment(
    Number itemLevel!, // 装备等级
    Equipment_part part!, // 部位
    Equipment_quality quality! = Equipment_quality.Average // 稀有度
    ) '生成随机装备'{
    // 1. 确定基底
    BaseType[] baseOptions = BaseTypes.Get(part);
    BaseType selectedBase;
    if (itemLevel < 10) {
        selectedBase = baseOptions[0]; // 低级只能roll普通基底
    } else if (itemLevel < 20) {
        selectedBase = RandomWeighted(<BaseType[]>ArraySlice(baseOptions,0,2)); // 可roll普通或高级
    } else {
        selectedBase = RandomWeighted(baseOptions); // 可roll所有基底
    }

    // 2. 确定词缀数量
    Number prefixCount! = 0;
    Number suffixCount! = 0;
    Number totalAffixes! = 0;
    switch (quality) {
        case Equipment_quality.Average:
            prefixCount = RandomInteger(0, 1);
            suffixCount = RandomInteger(0, 1);
            if (prefixCount == 0 && suffixCount == 0) prefixCount = 1; // 至少1条
            break;
        case Equipment_quality.Rare:
            totalAffixes = RandomInteger(2, 4);
            prefixCount = RandomInteger(0, Min(totalAffixes, 3));
            suffixCount = totalAffixes - prefixCount;
            break;
        case Equipment_quality.Epic:
            totalAffixes = RandomInteger(3, 6);
            prefixCount = RandomInteger(0, Min(totalAffixes, 3));
            suffixCount = totalAffixes - prefixCount;
            break;
        case Equipment_quality.Ledgend:
            // 传奇装备逻辑在下方单独处理
            break;
    }

    // 3. 确定可roll的词缀Tier
    Number maxTier = itemLevel >= 20 ? 1 : (itemLevel >= 10 ? 2 : 3);

    // 4. 生成前缀
    Dictionary<String, Number> stats! = {Keys: [], Values: []};
    //根据基底生成固定前缀
    for(Number i! = 0; i < selectedBase.inherentStats.Keys.Length; i = i + 1){
    stats.Add(selectedBase.inherentStats.Keys[i],selectedBase.inherentStats.Values[i]);
    }
    //随机roll前缀
    String prefixName = "";
    if (prefixCount > 0) {
        String[] availablePrefixes = PrefixPool.Keys;
        String[] selectedPrefixes = RandomSample(availablePrefixes, prefixCount);
        foreach (String prefix in selectedPrefixes) {
            Affix[] tiers! = PrefixPool.Get(prefix);
            Affix selectedTier! = RandomWeighted(tiers.Filter(t => t.Tier >= maxTier));
            Number value! = RandomInteger(selectedTier.Range[0], selectedTier.Range[1]);
            stats.Add(prefix, value);
            prefixName = GetPrefixName(prefix, selectedTier.Tier);
        }
    }

    // 5. 生成后缀
    String suffixName = "";
    if (suffixCount > 0) {
        String[] availableSuffixes = SuffixPool.Keys;
        String[] selectedSuffixes = RandomSample(availableSuffixes, suffixCount);
        foreach (String suffix in selectedSuffixes) {
            Affix[] tiers! = SuffixPool.Get(suffix);
            Affix selectedTier! = RandomWeighted(tiers.Filter(t => t.Tier >= maxTier));
            Number value! = RandomInteger(selectedTier.Range[0], selectedTier.Range[1]);
            stats.Add(suffix, value);
            suffixName = GetSuffixName(suffix, selectedTier.Tier);
        }
    }

    // 6. 生成装备名称
    String equipName = prefixName + selectedBase.name + suffixName;

    // 7. 创建装备
    return new Equipment(
        name: equipName,
        stats: stats,
        description: GenerateDescription(quality, selectedBase),
        part: part,
        quality: quality
    );
}

// 辅助函数：根据属性和Tier获取前缀名
String GetPrefixName(String stat!, Number tier!)'sub根据属性和Tier获取前缀名' {
    switch (stat) {
        case "攻击":
            return tier == 1 ? "狂暴" : (tier == 2 ? "锋利" : "粗糙");
        case "生命":
            return tier == 1 ? "不朽" : (tier == 2 ? "坚韧" : "厚实");
        case "护甲":
            return tier == 1 ? "精钢" : (tier == 2 ? "坚固" : "木头");
        case "敏捷":
            return tier == 1 ? "闪电" : (tier == 2 ? "迅捷" : "轻盈");
    }
    return "";
}

// 辅助函数：根据属性和Tier获取后缀名
String GetSuffixName(String stat, Number tier)'sub根据属性和Tier获取后缀名' {
    switch (stat) {
        case "再生":
            return tier == 1 ? "之复苏" : (tier == 2 ? "之恢复" : "之再生");
        case "护盾":
            return tier == 1 ? "之圣盾" : (tier == 2 ? "之护障" : "之屏障");
    }
    return "";
}

// 辅助函数：生成描述
String GenerateDescription(Equipment_quality quality!, BaseType selectedBase!)'sub根据品质生成描述' {
    String[] baseDescriptions = [
        "平凡的装备，适合初学者。",
        "蕴含魔力的稀有装备。",
        "史诗般的力量，改变战局。",
        "独特的神器，有着独特的效果。"
    ];
    String description = baseDescriptions[<Number>quality];

    return description;
}

// 辅助函数：加权随机选择
T RandomWeighted<T>(T[] options!, Number[] weights! = null)'sub加权随机选择' {
    if (weights == null) {
        weights = options.Map(_ => 1);
    }
    Number totalWeight = Sum_Number(weights);
    Number rand = RandomReal(0, 1);
    rand = totalWeight*rand;
    Number currentWeight = 0;
    for (Number i! = 0; i < options.Length; i++) {
        currentWeight += weights[i];
        if (rand <= currentWeight) {
            return options[i];
        }
    MinWait();
    }
    return options[0];
}

//辅助函数：数组数组求和
Number Sum_Number(Any[] shuzu)'sub数组数字求和'{
    Number result! = 0;
    foreach(Number n! in shuzu){
        result += n;
        MinWait();
    }
    return result;
}

//辅助函数：随机取样
Any[] RandomSample(in Any[] shuzu!, in Number count!){
    return ArraySlice(RandomizedArray(shuzu),0,count);
}


