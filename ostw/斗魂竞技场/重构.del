playervar Number RevivePercent;
playervar Boolean Revivable;

rule: '重置重生进度条'
Event.OnDeath
Team.All
Player.All
{
    RevivePercent = 0;
}

rule: '救人'
Event.OngoingPlayer
Team.All
Player.All
if(IsDead(TeamMate)&&CurrentGamePhase==GamePhase.Combat&&DistanceBetween(EventPlayer(),TeamMate)<=5&&TeamMate.Revivable&&IsAlive())
{
    PlayEffect(Type: PlayEffect.BrigitteWhipShotHealAreaSound,Position: TeamMate,Radius: 150);
    while(DistanceBetween(EventPlayer(),TeamMate)<=5&&TeamMate.RevivePercent<100&&IsAlive()&&TeamMate.Revivable){
        PlayEffect(VisibleTo: EventPlayer(),Position: PositionOf(TeamMate),Radius: 125,Type: PlayEffect.BrigitteWhipShotHealAreaSound);
        TeamMate.RevivePercent += 3.5;
        Wait(0.25);
    }
    if(TeamMate.RevivePercent >=100){
        TeamMate.Revivable = false;
        Resurrect(TeamMate);
        SetStatus(TeamMate,null,Status.Invincible,1);
    }
    Wait(0.25);
    LoopIfConditionIsTrue();
}

enum GamePhase {
  Initializing,   // 初始化
  Preparation,    // 准备
  Combat,         // 战斗
  RoundEnd,       // 回合结束
  GameOver        // 游戏结束
}

// 全局状态跟踪
globalvar GamePhase CurrentGamePhase;
globalvar Number CurrentStage;
playervar Boolean isKnockOut;
rule: 'Start Game'
if(IsGameInProgress()||IsButtonHeld(HostPlayer(),Button.Ability1))
{
    DivisionSetup();
    CurrentGamePhase = GamePhase.Initializing;
}

globalvar Boolean UsePreferTeam = WorkshopSettingToggle(
    Category: "个性化",
    Name: "分队时，优先创建4队（适合8人）",
    Default: true,
);

void DivisionSetup(){
    if(UsePreferTeam){
        // ======================
        // 模式1：优先创建4队
        // ======================

        // 1. 先创建4个空队伍
        for(Number i! = 0; i < Min(4, NumberOfPlayers()); i++){
            new PlayTeam([], i); // 传入空数组表示初始无成员
        }
        // 2. 轮询分配玩家到各队伍
        Number teamIndex! = 0;
        foreach(Player p! in AllPlayers()){
            Teams[teamIndex].AddMember(p);
            // 移动到下一个队伍（循环）
            teamIndex = (teamIndex + 1) % Teams.Length;
        }
    }
    else{
        // ======================
        // 模式2：经典2人小队
        // ======================

        // 1. 创建完整的2人队伍
        for(Number i! = 0;i < RoundToInteger(NumberOfPlayers(),Rounding.Down);i++){
            Number startIdx! = i * 2;
            new PlayTeam([AllPlayers()[startIdx],AllPlayers()[startIdx+1]],startIdx);
        }

        // 2. 处理剩余玩家（奇数情况）
        if(NumberOfPlayers()%2==1){
            Player lastPlayer = LastOf(AllPlayers());
            // 创建独狼队伍
                new PlayTeam([lastPlayer], Teams.Length);
                
        }
    }

    UpdateAllTeammates();
}

globalvar Color[] TeamColor_Pool = [Color.Aqua,Color.Green,Color.Purple,Color.Yellow];
globalvar PlayTeam[] Teams = [];
playervar Player TeamMate;
playervar PlayTeam playteam;
class PlayTeam{
    public Number ID;
    public Number Health;
    public Player[] Members;
    public PlayTeam Opponent;
    public Number ByeCount;
    public Color TeamColor;
    public Number PreviousArea = -1;

    public constructor(in Player[] members, in Number id){
        Members = members;
        ID = id;

        Teams += this;

        members.playteam = this;

        ByeCount = 0;

        this.TeamColor = TeamColor_Pool[0];
        TeamColor_Pool.ModRemoveByIndex(0);
    }

    public void AddMember(in Player extraPlayer){
        if(CountOf(this.Members)<2){
            this.Members += extraPlayer;

            extraPlayer.playteam = this;
            UpdateTeammate(extraPlayer);

            InitializeTeamEffects(extraPlayer);

            //AloneOff(this.Members[0]);
        }
    }

    public void InitializePlayer(){
        if(CountOf(Members)>=1){
            InitializeTeamEffects(Members[0]);
            UpdateTeammate(Members[0]);
            if(CountOf(Members)==2){
            InitializeTeamEffects(Members[1]);
            UpdateTeammate(Members[1]);
            }
        }
    }
}

void UpdateTeammate(in Player p){
    p.TeamMate = p.playteam.Members.Filter(t=>t!=p);
}

// 更新所有队伍的队友关系
void UpdateAllTeammates(){
    foreach(PlayTeam team in Teams){
        foreach(Player p in team.Members){
            p.TeamMate = team.Members.Filter(t => t != p).First; // 获取队友
            //如果是独狼，给独狼特效
            if(CountOf(team.Members)==1){
                AloneSet(p);
            }
            // 初始化特效（如果玩家已生成）
            InitializeTeamEffects(p);
        }
    }
}

void InitializeTeamEffects(Player p!)'sub 初始化队伍特效'{
        //队伍名称
        CreateInWorldText(
            Header: <'队伍<0>',EvaluateOnce(p).playteam.ID>,
            Position: EvaluateOnce(p),
            Scale: 2,
            Clipping: Clipping.ClipAgainstSurfaces,
            TextColor: EvaluateOnce(p).playteam.TeamColor,
            VisibleTo: EntityExists(EvaluateOnce(p))?AllPlayers():null
        );
        
        //CreateEffect(Type: Effect.Ring,Color: TeamColor,Position: (EvaluateOnce(p)),Radius: 1,VisibleTo: !IsDead(EvaluateOnce(p))?[EvaluateOnce(p),EvaluateOnce(p).TeamMate]:null);

        StartDamageModification(EvaluateOnce(p),EvaluateOnce(p).TeamMate,0,DamageModificationRev.ReceiversDamagersAndDamagePercent);
        MinWait();
        //笑脸队友特效
        CreateIcon(VisibleTo: EntityExists(EvaluateOnce(p))?EvaluateOnce(p).TeamMate:null,EvaluateOnce(p),Icon.Happy,IconRev.VisibleToPositionAndColor,EvaluateOnce(p).playteam.TeamColor,true);
        //复活圈特效
        CreateEffect(
            VisibleTo: IsDead(EvaluateOnce(p))&&EvaluateOnce(p).Revivable?AllPlayers():null,
            Type: Effect.Ring,
            Color: EvaluateOnce(p).playteam.TeamColor,
            Position: PositionOf(EvaluateOnce(p)),
            Radius: 5,
            Reevaluation: EffectRev.VisibleToPositionAndRadius
            );
        //复活进度条
        CreateProgressBarInWorldText(
            VisibleTo: IsDead(EvaluateOnce(p))&&EvaluateOnce(p).Revivable?AllPlayers().Filter(t=>DistanceBetween(t,EvaluateOnce(p))<=5):null,
            Value: EvaluateOnce(p).RevivePercent,
            Text: <'<0>等待被他的队友救活...',HeroIconString(HeroOf(EvaluateOnce(p)))>,
            Position: MenuButtonPosition_Local(0,-1.5),
            Scale: 1,
            Clipping: Clipping.DoNotClip,
            TextColor: Color.Orange,
            ProgressBarColor: GradientColor([54,133,2],[255,79,35],EvaluateOnce(EvaluateOnce(p)).RevivePercent/100),
            Reevaluation: ProgressBarWorldEvaluation.VisibleToPositionValuesAndColor
            );
        //显示表面复活进度
        CreateInWorldText(
            VisibleTo: IsDead(EvaluateOnce(EvaluateOnce(p)))&&EvaluateOnce(EvaluateOnce(p)).Revivable&&!EvaluateOnce(EvaluateOnce(p)).isKnockOut?AllPlayers():null,
            Header: 
                <'<2>-<0>: <1>%',
                    HeroIconString(HeroOf(EvaluateOnce(EvaluateOnce(p)))),
                    EvaluateOnce(EvaluateOnce(p)).RevivePercent,
                    AbilityIconString(Hero.Mercy,Button.Ability2)
                    >,
            Position: PositionOf(EvaluateOnce(EvaluateOnce(p)))+Vector(0,1,0),
            Scale: 2,
            Clipping: Clipping.ClipAgainstSurfaces,
            Spectators: Spectators.VisibleAlways
            );

        //观战可见血条
        CreateProgressBarInWorldText(
            VisibleTo: !IsDead(EvaluateOnce(EvaluateOnce(p)))?AllPlayers().Filter(t=>IsDead(t)):null,
            Value: 100*NormalizedHealth(EvaluateOnce(EvaluateOnce(p))),
            Text: '',
            Position: EvaluateOnce(EvaluateOnce(p)),
            Scale: 0.7,
            Clipping: Clipping.ClipAgainstSurfaces,
            ProgressBarColor: GradientColor([255,0,0],[124,205,124],1-(NormalizedHealth(EvaluateOnce(EvaluateOnce(p))))),
            NonteamSpectators: Spectators.VisibleAlways,
        );
        MinWait();
}

void AloneSet(Player p!)'sub 开始独狼'{
    p.shuxing.Attack.Abs += 50;
    p.shuxing.Drain.Abs += 20;
    p.shuxing.Armor.Abs += 200;
    RevShuxing(p);
}
void AloneOff(Player p!)'sub 关闭独狼'{
    p.shuxing.Attack.Abs -= 50;
    p.shuxing.Drain.Abs -= 20;
    p.shuxing.Armor.Abs -= 200;
    RevShuxing(p);
}

