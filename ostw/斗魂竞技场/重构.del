rule: '玩家中途退出'
Event.OnPlayerLeave
Team.All
Player.All
{
    PlayTeam LeftTeam = FirstOf(Teams.Filter(p=>p.Members.Contains(EventPlayer())));
    LeftTeam.Members.ModRemoveByValue(EventPlayer());
    switch(CountOf(LeftTeam.Members)){
        case 1:
        AloneSet(LeftTeam.Members[0]);
        case 0:
        Teams.ModRemoveByValue(LeftTeam);
    }
}

globalvar Player[] WaitQueue = [];
rule: '玩家中途加入'
Event.OnPlayerJoin
Team.All
Player.All
{
    WaitQueue += EventPlayer();
}

void JoinDetect() {
    // 更新等待队列，过滤掉已不存在的实体
    WaitQueue = WaitQueue.Filter(t => EntityExists(t));
    // 第一阶段：尝试将等待队列的玩家加入新队伍（最多4队）
    Number maxTeamsToCreate = Min(WaitQueue.Length, 4 - Teams.Length);
    for (Number i = 0; i < maxTeamsToCreate; i++) {
        Teams += new PlayTeam([WaitQueue[0]], Teams.Length);
        AloneSet(WaitQueue[0]);
        RemoveFromArrayAtIndex(WaitQueue, 0);
        MinWait();
    }

    // 第二阶段：尝试将剩余等待队列的玩家加入现有的单人队伍
    Number maxPlayersToAssign = WaitQueue.Length;
    for (Number i = 0; i < maxPlayersToAssign; i++) {
        PlayTeam aloneTeam = FirstOf(Teams.Filter(t => t.Members.Length == 1));
        if (aloneTeam == null) break; // 如果没有单人队伍，提前退出
        aloneTeam.AddMember(WaitQueue[0]);
        AloneOff(aloneTeam.Members[0]);
        RemoveFromArrayAtIndex(WaitQueue, 0);
        MinWait();
    }
}
globalvar Number PrepareTime = WorkshopSettingInteger(Category: '基础参数','准备阶段时间',Default: 45,15,90,1);
void StartPrepare(){
    Resurrect(AllPlayers());
    SetStatus(AllPlayers(),Assister: null,Status: Status.PhasedOut,Duration: 9999);

    MatchOpponentForAll();
    
    SetMatchTime(PrepareTime);  
}

globalvar PlayTeam ByeTeam;
globalvar PlayTeam[][] MatchUps;
void MatchOpponentForAll(){
    // 每回合重置轮空队伍
    ByeTeam = null;
    // 如果为奇数，则有一队轮空，选择 ByeCount 最低的
    if(Teams.Length % 2 == 1){
        ByeTeam = Teams.Sort(t=>t.ByeCount).First;
        ByeTeam.ByeCount++;
    }
    // 过滤轮空队伍
    define ActiveTeams = Teams.Filter(t=>t != ByeTeam);
    
    // 优化参数：最大尝试次数（有限循环，避免死循环）
    Number maxAttempts = 10;  // 可调，越大越可能找到无重复，但计算开销稍高
    Number bestScore = 999;   // 初始高分
    Any[] bestActive = [];    // 最佳队伍排列
    
    // 多次尝试随机打乱，找到重复对手最少的配置
    for(Number attempt = 0; attempt < maxAttempts; attempt++){
        Any[] tempActive = <Any[]>RandomizedArray(ActiveTeams);
        Number score = 0;  // 本次配置的重复分数
        
        // 计算分数：检查每个潜在配对是否重复上一轮对手
        for(Number i = 0; i < CountOf(tempActive) / 2; i++){
            PlayTeam teamA = tempActive[2 * i];
            PlayTeam teamB = tempActive[2 * i + 1];
            if(teamA.Opponent == teamB){  // Opponent 是上一轮的，用于检查重复
                score++;
            }
        }
        
        // 更新最佳
        if(score < bestScore){
            bestScore = score;
            bestActive = tempActive;
            if(score == 0){  // 完美无重复，提前停止
                break;
            }
        }
    }
    
    // 使用最佳配置进行配对（顺序配对，无循环风险）
    MatchUps = [];
    for(Number i = 0; i < CountOf(bestActive) / 2; i++){
        PlayTeam teamA = bestActive[2 * i];
        PlayTeam teamB = bestActive[2 * i + 1];
        
        MatchUps[CountOf(MatchUps)] = [teamA, teamB];
        
        // 更新当前对手（Opponent 用于本轮，下轮检查重复）
        teamA.Opponent = teamB;
        teamB.Opponent = teamA;
    }
    
    BigMessage(Header: '对手配备已完成！');
}

void ResetAllPlayersForCombat() {
    foreach (Player p in AllPlayers()) {
        // 重置状态
        ClearStatus(p, Status.PhasedOut);
        p.RevivePercent = 0;
        p.Revivable = true;
    }
    
    // 轮空队伍处理
    Kill(ByeTeam.Members,null);
    BigMessage(ByeTeam.Members,'你的队伍本回合轮空/n自动进入观战');
}
void StartAllMatchUps() {
    // 随机打乱可用场地，确保公平
    Any[] availableAreas = <Any[]>RandomizedArray(Areas);
    
    foreach (PlayTeam[] match in MatchUps) {
        PlayTeam teamA = match[0];
        PlayTeam teamB = match[1];
        
        // 优先：找双方都没用过的场地（PreviousArea）
        Area selected = FirstOf(FilteredArray(availableAreas, IndexOfArrayValue(Areas, ArrayElement()) != teamA.PreviousArea && IndexOfArrayValue(Areas, ArrayElement()) != teamB.PreviousArea));
        
        // 如果没有，次优：至少一方没用过
        if(selected == null){
            selected = FirstOf(FilteredArray(availableAreas, IndexOfArrayValue(Areas, ArrayElement()) != teamA.PreviousArea || IndexOfArrayValue(Areas, ArrayElement()) != teamB.PreviousArea));
        }
        
        // 如果还不行，随便选（Areas 少于对战数时可能）
        if(selected == null){
            selected = availableAreas[0];
        }
        
        // 移除已选，避免其他对战重复
        availableAreas = RemoveFromArray(availableAreas, selected);
        
        // 传送队伍到对应出生点
        Teleport(teamA.Members, selected.SpawnPosition1);
        Teleport(teamB.Members, selected.SpawnPosition2);
        
        // 设置区域关联，并更新 PreviousArea（用于下轮避免重复）
        Number areaIndex = IndexOfArrayValue(Areas, selected);
        foreach (Player p in Append(teamA.Members, teamB.Members)) {
            p.PlayerAreaIndex = areaIndex;
        }
        teamA.PreviousArea = areaIndex;
        teamB.PreviousArea = areaIndex;
    }
}

void PreparePhaseFlow(){
    CurrentGamePhase = GamePhase.Preparation;
    StartPrepare();
    MatchOpponentForAll(); 
}
void CombatPhaseFlow(){
    ResetAllPlayersForCombat();
    StartAllMatchUps();
}


rule: '处于对局中的玩家死亡触发本matchup的胜负检测'
Event.OnDeath
Team.All
Player.All
if(MatchUps.IsTrueForAny(t=>t.Contains(playteam)))
{
    PlayTeam[] currentMatch = FirstOf(MatchUps.Filter(m => m.Contains(playteam)));
    if(currentMatch==null) return;

    Boolean MyTeamDefeated = IsTeamDefeated(playteam);
    Boolean OpponentTeamDefeated = IsTeamDefeated(playteam.Opponent);
    
    Number isDraw = -1;
    if(MyTeamDefeated&&OpponentTeamDefeated){
        isDraw = 1;
    }
    if(MyTeamDefeated||OpponentTeamDefeated){
        isDraw = 0;
    }

    switch(isDraw){
        case -1:
        return;

        case 1:
            HandleDraw(playteam);
        break;

        case 0:
            PlayTeam winner;
            if(OpponentTeamDefeated){
                winner = playteam;
            }else{
                winner = playteam.Opponent;
            }
            HandleVictory(winner);
        break;
    }

    MatchUps.ModRemoveByValue(currentMatch);

    if(MatchUps.Length == 0){
        CurrentGamePhase = GamePhase.RoundEnd;
    }
}
rule: '当全部matchup结束了触发回合end检测'
if(CurrentGamePhase==GamePhase.RoundEnd)
{
    StartPrepare();
}
void HandleDraw(in PlayTeam team1){
    BigMessage(team1.Members.Append(team1.Opponent.Members),'平局');
}
Number DeductHealth:
    10;
void HandleVictory(in PlayTeam winner){
    PlayTeam loser = winner.Opponent;
    BigMessage(winner.Members,'获胜');

    BigMessage(loser.Members,'失败');
    loser.Health -= DeductHealth;
}
Boolean IsTeamDefeated(PlayTeam team) {
    return team.Members.IsTrueForAll(t=>IsDead(t)||!HasSpawned(t));
}

