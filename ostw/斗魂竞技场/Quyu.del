rule: '灵魂链接'
Event.OngoingPlayer
Team.All
Player.All
if(TeamID != -1)
if(HasHexName('灵魂链接') && IsDead(EventPlayer().TeamMate))
{
    Number Attack! = EventPlayer().TeamMate.shuxing.Attack.VirtualShuxing() * 0.5;
     Number Speed! = EventPlayer().TeamMate.shuxing.Speed.VirtualShuxing() * 0.5; 
     Number Health_! = EventPlayer().TeamMate.shuxing.Health.VirtualShuxing() * 0.5; 
     Number Armor! = EventPlayer().TeamMate.shuxing.Armor.VirtualShuxing() * 0.5; 
     Number Shields! = EventPlayer().TeamMate.shuxing.Shields.VirtualShuxing() * 0.5; 
     Number HealBoost! = EventPlayer().TeamMate.shuxing.HealBoost.VirtualShuxing() * 0.5;
      Number CoolDown! = EventPlayer().TeamMate.shuxing.CoolDown.VirtualShuxing() * 0.5;


    shuxing.Attack.Abs += Attack;
    shuxing.Speed.Abs += Speed;
    shuxing.Health.Abs += Health_;
    shuxing.Armor.Abs += Armor;
    shuxing.Shields.Abs += Shields;
    shuxing.HealBoost.Abs += HealBoost;
    shuxing.CoolDown.Abs += CoolDown;
    SmallMessage(VisibleTo: EventPlayer(),'灵魂链接已触发');
    RevShuxing();
    PlayEffect(AllPlayers(), PlayEffect.GoodPickupEffect, Color.Yellow, EventPlayer(), 2);
    WaitUntil(CurrentGamePhase == GamePhase.Preparation, 240);
    shuxing.Attack.Abs -= Attack;
    shuxing.Speed.Abs -= Speed;
    shuxing.Health.Abs -= Health_;
    shuxing.Armor.Abs -= Armor;
    shuxing.Shields.Abs -= Shields;
    shuxing.HealBoost.Abs -= HealBoost;
    shuxing.CoolDown.Abs -= CoolDown;
    RevShuxing();
}

