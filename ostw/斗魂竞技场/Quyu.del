playervar Player ViewingPlayer = EventPlayer();

Number ViewingHexCooldownBySlotLocal(in Number slot):
    LocalPlayer().ViewingPlayer.HexCurrentCooldowns[slot];

String ViewingHexStatusHeaderLocal(in Number slot){
    define id : LocalPlayer().ViewingPlayer.Hexes[slot];
    define baseCd : HexCooldownBaseById(id);
    define cdNow : ViewingHexCooldownBySlotLocal(slot);
    return HexNameById(id)
        + (baseCd == 0
            ? ''
            : (cdNow > 0
                ? <'(剩余 <0>)', cdNow>
                : <'(已就绪<0>)', IconString(Icon.Checkmark)>));
}

Color ViewingHexStatusColorLocal(in Number slot){
    define id : LocalPlayer().ViewingPlayer.Hexes[slot];
    define baseCd : HexCooldownBaseById(id);
    define cdNow : ViewingHexCooldownBySlotLocal(slot);
    return baseCd > 0 && cdNow > 0
        ? GradientColor(
            [UnfinishedColor_Red_R,UnfinishedColor_Red_G,UnfinishedColor_Red_B],
            [FinishedColor_Gold_R,FinishedColor_Gold_G,FinishedColor_Gold_B],
            cdNow / baseCd
        )
        : Quaility_Color[HexQualityById(id)][0];
}

