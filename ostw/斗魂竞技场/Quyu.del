playervar Any[] SwapTarget;
playervar Vector SwapPosition;
playervar Any SwapEffect;

rule: '生命之握'
Event.OngoingPlayer
Team.All
Player.All
if(TeamID != -1)
if(HeroOf(EventPlayer()) == Hero.Lifeweaver)
if(AbilityCooldown(EventPlayer(), Button.Ability2) == 0)
if(IsButtonHeld(EventPlayer(),Button.Ability2))
{
    // Find a valid target within 40 meters, alive, in view angle, and closest to reticle
    SwapTarget = FilteredArray(
        PlayersWithinRadius(EyePosition(EventPlayer()), 40, Team.All, RadiusLOS.Surfaces),
        IsAlive(ArrayElement()) &&
        HasSpawned(ArrayElement()) &&
        ArrayElement() != EventPlayer() &&
        IsInViewAngle(EventPlayer(), ArrayElement(), 45) &&
        ArrayElement() == PlayerClosestToReticle(EventPlayer(), Team.All)
    );

    // Check if a valid target was found
    if(SwapTarget[0] != null)
    {
        BigMessage(VisibleTo: SwapTarget[0],Header: '生命之握！');
        // Store the target's position
        SwapPosition = PositionOf(SwapTarget[0]);

        // Create a visual effect on the target
        CreateEffect(
            VisibleTo: AllPlayers(),
            Type: Effect.GoodAura,
            Color: Color.Rose,
            Position: SwapTarget[0],
            Radius: 1.5
        );
        SwapEffect = LastCreatedEntity();

        // Play sound effect
        PlayEffect(
            VisibleTo: AllPlayers(),
            Type: PlayEffect.MoiraFadeDisappearSound,
            Color: Color.White,
            Position: EyePosition(EventPlayer()),
            Radius: 100
        );

        // Freeze the target
        SetStatus(SwapTarget[0], EventPlayer(), Status.Frozen, 9999);

        // Deal minor damage to the target
        Damage(SwapTarget[0], EventPlayer(), 1);

        // Move the event player towards the target's position
        ChaseVariableAtRate(SwapPosition, PositionOf(EventPlayer()), 40, RateChaseReevaluation.DestinationAndRate);

        // Force the target to the player's original position
        StartForcingPlayerPosition(SwapTarget[0], SwapPosition, true);

        // Wait until the target is within 6 meters of the player
        WaitUntil(DistanceBetween(SwapTarget[0], EventPlayer()) < 6, 4);

        // Stop forcing the target's position
        StopForcingPlayerPosition(SwapTarget[0]);

        // Apply a small knockback to the target
        ApplyImpulse(
            Player: SwapTarget[0],
            Direction: DirectionTowards(PositionOf(EventPlayer()), PositionOf(SwapTarget[0])),
            Speed: 1,
            Relative: Relative.ToWorld,
            Motion: ContraryMotion.Cancel
        );

        // Clear the frozen status
        ClearStatus(SwapTarget[0], Status.Frozen);

        // Destroy the visual effect
        DestroyEffect(SwapEffect);

        // Play additional effects
        PlayEffect(
            VisibleTo: AllPlayers(),
            Type: PlayEffect.GoodExplosion,
            Color: Color.Rose,
            Position: SwapTarget[0],
            Radius: 3
        );
        PlayEffect(
            VisibleTo: AllPlayers(),
            Type: PlayEffect.MoiraFadeReappearSound,
            Color: Color.White,
            Position: EyePosition(EventPlayer()),
            Radius: 100
        );

        // Reset variables
        SwapTarget = [];
        SwapPosition = Vector(0, 0, 0);

        // Set ability cooldown
        SetAbilityCooldown(EventPlayer(), Button.Ability2, 12);
    }
    else
    {
        // Show message if no valid target is found
        SmallMessage(EventPlayer(), '无抓取玩家');
        Wait(0.5, WaitBehavior.IgnoreCondition);
    }
}
rule: '直视引力'
Event.OngoingPlayer
Team.All
Player.All
if(TeamID != -1)
if(HasHexName('直视引力'))
if(CurrentGamePhase == GamePhase.Combat)
if(IsUsingAbility1())
{
    Player[] Enemy = GetTeamofPlayer().Opponent.Members;
    foreach(Player p! in Enemy){
        if (IsInLineOfSight(EyePosition(p),EyePosition(),BarrierLOS.NoBarriersBlock) && IsInViewAngle(p,EventPlayer(),60)){
            StartFacing(EvaluateOnce(p),DirectionTowards(EvaluateOnce(p),EventPlayer()),1000,Reevaluation: FacingRev.DirectionAndTurnRate,Relative: Relative.ToWorld);
        }else{
            StopFacing(p);
        }
    }
    Wait(0.1);
    LoopIfConditionIsTrue();
    StopFacing(Enemy);
}

