// 回合淘汰扣血
Number deductHealth:
    (CurrentRound <= 4 && CurrentStage == 1) ? 15 : Min(15+10*(CurrentStage-1)+5*RoundToInteger(CurrentRound/4,Rounding.Nearest),30);

void AloneSet(Player p!)'sub单人成队加成'{
    BigMessage(p,'有玩家中途离开了你的队伍！已获得离队buff');
    p.shuxing.Attack.Abs += 20;
    p.shuxing.Attack.Pct += 15;
    p.shuxing.Reduction.Pct += 20;
    p.shuxing.Drain.Abs += 15;
    p.shuxing.Armor.Abs += 100;
    RevShuxing(p);
}
// 新规：单人成队队友加入时取消加成
void AloneOff(Player p!)'sub单人成队取消加成'{
    BigMessage(p,'有玩家中途加入了你的队伍！离队buff已取消');
    p.shuxing.Attack.Abs -= 20;
    p.shuxing.Drain.Abs -= 15;
    p.shuxing.Armor.Abs -= 100;
    p.shuxing.Attack.Pct -= 15;
    p.shuxing.Reduction.Pct -= 20;
    RevShuxing(p);
}

rule: 'BuffHUD'
{
