playervar Boolean Surrendered = false;
globalvar Boolean UseSurrender = WorkshopSettingToggle('功能','启用投降系统',true,0);

Number SurrenderDivider : 8;
rule: '投降'
Event.OngoingPlayer
Team.All
Player.All
if(CurrentGamePhase == GamePhase.Preparation)
if(CurrentStage >= 2)
if(IsCommunicating(EventPlayer(),Communication.GroupUp))
{
    Surrendered = !Surrendered;
    if(Surrendered)
    {
        BigMessage(VisibleTo: AllPlayers(),Header: HeroIconString(HeroOf())+EventPlayer()+'选择了投降！\n发送集合投降，详见右上角');
    }
    if(AllPlayers().Filter(t=>t.TeamID!=-1&&!t.isKnockOut&&t.Surrendered).Length>=(AllPlayers().Filter(t=>t.TeamID != -1 && !t.isKnockOut).Length/SurrenderDivider).Ceil()){
        //投降［束游戏，布??
        BigMessage(AllPlayers(), <"多数玩家放弃这把游戏!!\n队伍 <0> 吃鸡!!", Teams.Sort(t=>-1*t.Health).First.ID>);  // 俔Ｐ用activeTeams[0]
        DeclarePlayerVictory(Teams.Sort(t=>-1*t.Health).First.Members[0]);
        // 为获胜队伍创??
    }
}

