                (IsButtonHeld(EventPlayer(), Button.Ultimate)||IsButtonHeld(EventPlayer(), Button.Jump) ? 
                    (IsButtonHeld(EventPlayer(), Button.Ability1) ? 0.300 : 0.150) : 
                    0) +
                (IsButtonHeld(EventPlayer(), Button.Ability2)||IsButtonHeld(EventPlayer(), Button.Crouch) ? 
                    (IsButtonHeld(EventPlayer(), Button.Ability1) ? -0.300 : -0.150) : 
                    0),
                0
            ),
            EventPlayer(),
            <LocalVector>Transformation.RotationAndTranslation
        ) + WorldVectorOf(
            ThrottleOf(EventPlayer()) * 
            (IsButtonHeld(EventPlayer(), Button.Ability1) ? 0.300 : 0.100),
            EventPlayer(),
            <LocalVector>Transformation.Rotation
        ),
        Reevaluation: true
    );

    }
    else{
    LastSpectating_Position = PositionOf();
    StopCamera();
    SmallMessage(EventPlayer(), '已进入观战模式');
    PlayEffect(VisibleTo: EventPlayer(), Type: PlayEffect.BuffImpactSound, Position: EyePosition(), Radius: 150);
    // 观ѡ式：玩不能自由移劼位置由游戏辑控制
    EnableSpectate();
    StopForcingPlayerPosition(EventPlayer());
