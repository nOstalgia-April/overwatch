    ).SetOnClick(()=>{EventPlayer().roundReward_index=1;        });
    new MenuButton(
        header: <'<0>',HexOfferTitleLocal(2)>,
        posX: 2,
        posY: 0.8,
        ShowColor: HexOfferColorLocal(2),
        scale: ButtonScale.Large,
        interactable: true,
        ofmenuActives: [MenuActive.HexMenu]
    ).SetOnClick(()=>{EventPlayer().roundReward_index=2;        });
    new MenuButton(
        header: <'<0>',HexOfferDescriptionLocal()>,
        posX: -1.5,
        posY: -0.5,
        ShowColor: CustomColor(255, 233, 215, 255),
        scale: ButtonScale.Medium,
        ofmenuActives: [MenuActive.HexMenu]
    );
    new MenuButton(
        header: <'<0>确认选择',IconString(Icon.Happy)>,
        posX: 1.5,
        posY: 0,
        scale: ButtonScale.Medium,
        ShowColor: InteratableColor_Local(),
        interactable: true,
        ofmenuActives: [MenuActive.HexMenu]
    ).SetOnClick(()=>OnClickYesofRewards(EventPlayer()));
    new MenuButton(
        header: <'刷新(<0>)',LocalPlayer().RefreshCount>,
        posX: 1.5,
        posY: -0.5,
        scale: ButtonScale.Medium,
        ShowColor: InteratableColor_Local(),
        interactable: true,
        ofmenuActives: [MenuActive.HexMenu]
    ).SetOnClick(()=>{
        if(RefreshCount>0 && roundReward.Length > 0 && roundReward_index < roundReward.Length){
            HexId selectedHexId! = SelectedHexOfferId();
            HexId[] pool! = HexPool.Filter(
                id => id != selectedHexId
                    && !Hexes.Contains(id)
                    && !roundReward.Contains(id)
                    && HexQualityById(id) == HexQualityById(selectedHexId)
                    && HexAllowedForPlayer(id, EventPlayer())
            );
            if(pool.Length > 0){
                roundReward[roundReward_index] = RandomValueInArray(pool);
                RefreshCount--;
                PlayEffect(VisibleTo: EventPlayer(),Type: PlayEffect.Soldier76SprintStartSound,Position: CameraLookat,Radius: 200);
            }
        }
        
        });
}
void ApplyCurrentRewardStep(Player p!)'sub应用当前奖励步骤'{
    if(p.rewardFlowIndex >= p.rewardFlow.Length){
        return;
    }
    switch(CurrentRewardStep(p)){
        case RewardStepType.Hex:
            if(p.roundReward.Length > 0){
                if(p.roundReward_index >= p.roundReward.Length){
                    p.roundReward_index = 0;
                }
                GrantHexToPlayerById(p, p.roundReward[p.roundReward_index]);
            }
            p.roundReward = [];
            break;
        case RewardStepType.ForgeAverage:
        case RewardStepType.ForgeRare:
            if(p.forgeReward.Length > 0){
                if(p.forgeReward_index >= p.forgeReward.Length){
                    p.forgeReward_index = 0;
                }
                ShuxingForge selectedForge! = p.forgeReward[p.forgeReward_index];
                p.Forges += selectedForge;
                ApplyForge(selectedForge,p);
            }
            p.forgeReward = [];
            break;
    }
}

void OnClickYesofRewards(Player p!)'sub确认选择'{
    if(p.rewardFlowIndex >= p.rewardFlow.Length){
        CloseMenu(p);
        return;
    }

    ApplyCurrentRewardStep(p);
    p.rewardFlowIndex++;
    if(p.rewardFlowIndex < p.rewardFlow.Length){
        OpenCurrentRewardMenu(p);
        PlayEffect(VisibleTo: p,Type: PlayEffect.BuffImpactSound,Position: p,Radius: 150);
        return;
    }

    p.rewardFlow = [];
    p.rewardFlowIndex = 0;
    p.roundReward = [];
    p.forgeReward = [];
    CloseMenu(p);
    PlayEffect(VisibleTo: p,Type: PlayEffect.BuffImpactSound,Position: p,Radius: 150);
}
void ApplyForge(ShuxingForge selectedForge!,Player p! = EventPlayer())'sub应用属锻造器'{
        MinWait();
        switch(selectedForge.type){
        case ShuxingType.Attack:
        p.shuxing.Attack.Forge += selectedForge.absBonus;
        break;
        case ShuxingType.CoolDown:
        p.shuxing.CoolDown.Forge += selectedForge.absBonus;
        break;
        case ShuxingType.Speed:
        p.shuxing.Speed.Forge += selectedForge.absBonus;
        break;
        case ShuxingType.HealBoost:
        p.shuxing.HealBoost.Forge += selectedForge.absBonus;
        break;
        case ShuxingType.Drain:
        p.shuxing.Drain.Forge += selectedForge.absBonus;
        break;
        case ShuxingType.Reduction:
        p.shuxing.Reduction.Forge += selectedForge.absBonus;
        break;
        case ShuxingType.Armor:
        p.shuxing.Armor.Forge += selectedForge.absBonus;
        break;
        case ShuxingType.Health:
        p.shuxing.Health.Forge += selectedForge.absBonus;
        break;
        case ShuxingType.Shields:
        p.shuxing.Shields.Forge += selectedForge.absBonus;
        break;
    }
    RevShuxing(p);

}
