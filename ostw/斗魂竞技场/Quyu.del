        Text: '按下集合按键可 进行/取消 投降\n只要有一个玩家投降\n游戏就将提前结束',
        Subheader: <'当前投降人数:<0>/<1>',AllPlayers().Filter(t=>t.TeamID!=-1&&!t.isKnockOut&&t.Surrendered).Length,(AllPlayers().Filter(t=>t.TeamID != -1 && !t.isKnockOut).Length/SurrenderDivider).Ceil()>,
        VisibleTo: AllPlayers().Filter(t=>CurrentGamePhase == GamePhase.Preparation && CurrentStage >= 2),
        SortOrder: -999,
        Location: Location.Top,
        HeaderColor: LocalPlayer().Surrendered ? Color.Green : Color.Red,
