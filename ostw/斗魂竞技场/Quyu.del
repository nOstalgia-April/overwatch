enum ShuxingType {
Attack,
CoolDown,
Speed,
HealBoost,
Health,
Reduction,
Drain,
Armor,
Shields
}
globalvar Number[][] AverageForgeRanges = [
[12, 22],  // Attack
[10, 20],  // CoolDown 例范?
[6, 12],   // Speed 例
[10, 18],   // HealBoost 例
[100, 180],  //Health
[10,20]  //Reduction
// gerageForgetype顺t配
];
globalvar String[] ShuxingNames = [
'造成伤害',
'技能急速',
'移动速度',
'造成治疗',
'生命值',
'伤害抵抗',
'吸血',
'护甲',
'护盾'
];
globalvar ShuxingForge[] RareForgePool = [
new ShuxingForge(Quality.rare, ShuxingType.Drain, 20),  // 固?20 Abs Drain
new ShuxingForge(Quality.rare, ShuxingType.Shields, 200),  // 固?00 Abs 护?
new ShuxingForge(Quality.rare, ShuxingType.Armor, 250),  // 固?50 Abs 护?
new ShuxingForge(Quality.rare, ShuxingType.Attack, 40), // 固?0 Attack ^伤,
new ShuxingForge(Quality.rare, ShuxingType.CoolDown, 35), // 固?5 CoolDown 能?
new ShuxingForge(Quality.rare, ShuxingType.HealBoost, 40), // 固?0 HealBoost ^治疗,
new ShuxingForge(Quality.rare, ShuxingType.Speed, 35), // 固?5 Speed ??
new ShuxingForge(Quality.rare, ShuxingType.Reduction, 35) // 固?0 Reduction 伤,
];

class ShuxingForge{
    public Quality quality;
    public ShuxingType type;
    public Number absBonus;

    public constructor(in Quality _quality = Quality.average,in ShuxingType _type,in Number _absBonus){
    quality = _quality;
    type = _type;
    absBonus = _absBonus;
    }

    public String GetName() {
        return ShuxingNames[<Number>type];
    }

    public String GetDes() {
        return <'++<0>\n\r<1>', absBonus,quality==Quality.average?<'范围(<0> ~ <1>)',AverageForgeRanges[type][0],AverageForgeRanges[type][1]>:''>;
        
    }

}
    ShuxingForge GenerateAverageForge() 'sub生成average forge' {
        Number typeIndex! = RandomInteger(0, AverageForgeRanges.Length - 1);
        ShuxingType selectedType! = <ShuxingType>typeIndex;
        Number[] range! = AverageForgeRanges[typeIndex];
        Number absValue! = RandomInteger(range[0], range[1]);
        return new ShuxingForge(Quality.average, selectedType, absValue);
    }

globalvar ShuxingForge[] Forge_Pool = [];
playervar ShuxingForge[] Forges = [];
playervar ShuxingForge[] forgeReward;
playervar Number forgeReward_index;

single struct AsyncOperation {
    public Number time;
    public () => void callback;
}

playervar AsyncOperation[] operations = [];
playervar Number timeUntilNextOperation = 99999;

void WaitAsync(in Player | Player[] target, in Number time, in () => void callback) {
    ModifyVariable(target.timeUntilNextOperation, Operation.Min, TotalTimeElapsed() + time);
    target.operations += {
        time: TotalTimeElapsed() + time,
        callback: callback
    };
}

rule: 'Execute Next Async Operation'
Event.OngoingPlayer
if (TotalTimeElapsed() >= timeUntilNextOperation)
{
    Number opIndex = operations.Map((op, i) => i).Sort(i => operations[i].time).First;
    operations[opIndex].callback();
    operations.ModRemoveByIndex(opIndex);

    timeUntilNextOperation = operations.Length ? operations.Sort(op => op.time).First.time : 99999;
    MinWait();
    LoopIfConditionIsTrue();
}


rule: '房主传送'
Event.OngoingPlayer
Team.All
Player.All
if(HostPlayer()==EventPlayer()&&IsButtonHeld(EventPlayer(),Button.Reload)&&!IsGameInProgress())
{
    Teleport(EventPlayer(),EyePosition()+10*FacingDirectionOf());    
}

rule: '关闭各'
Event.OngoingPlayer
Team.All
Player.All
if(IsGameInProgress())
{
    DisableAnnouncer();
    DisableCompletion();
    DisableGameModeInworldUI();
    DisableMusic();
    DisableScoring();
    EnableSpectate();
}

rule: '忿游戏'
if(IsAssemblingHeroes())
{
    SetMatchTime(10);
}

playervar Area Player_Area;//归属区域
//区域结?
single struct Area{
    public Vector Center;
    public Number Radius;
    public Vector SpawnPosition1;
    public Vector SpawnPosition2;
}

globalvar Area[] Areas_static;

globalvar Number PhaseTime;
globalvar Number[] FireRingsRadius = [];

Color AreaColor: Color.Blue;
//区域效果创?
void CreateAreas(){
    for(define i=0;i<Areas_static.Length;i++){
        CreateEffect(
        VisibleTo: (CurrentGamePhase==GamePhase.Combat) && (LocalPlayer().Player_Area==EvaluateOnce(Areas_static[i])) || (IsDead(LocalPlayer()))?LocalPlayer():null,
        Type: Effect.Sphere,
        Color: AreaColor,
        Position: Areas_static[EvaluateOnce(i)].Center,
        Radius: FireRingsRadius[EvaluateOnce(i)],
        Reevaluation: EffectRev.VisibleToPositionRadiusAndColor);
        MinWait();
    }
}

rule: '区域初始化'
{
    CreateAreas();
}


globalvar PlayTeam[] Teams;  // 队伍敒R
globalvar Number MaxTeams = 4;  // 大队伍?(V???
playervar Number TeamID = -1;//-1表示月??
playervar Player TeamMate;
playervar Boolean isKnockOut;

globalvar Color[] Color_Pool = [Color.Aqua,Color.Green,Color.Purple,Color.Yellow,Color.Violet,Color.Turquoise,Color.Red];

void ResetTeamColorPool()
{
    Color_Pool = [Color.Aqua, Color.Green, Color.Purple, Color.Yellow, Color.Violet, Color.Turquoise, Color.Red];
}

Color AcquireTeamColor()
{
    if (Color_Pool.Length == 0)
    {
        ResetTeamColorPool();
    }
    Color nextColor! = Color_Pool[0];
    Color_Pool.ModRemoveByIndex(0);
    return nextColor;
}
rule: '队友头像显示'
{
    CreateInWorldText(VisibleTo: EntityExists(LocalPlayer().TeamMate)&&!IsDead(LocalPlayer())?LocalPlayer():null,
    Header: <'<0> <1><2>',IconString(Icon.Happy),HeroIconString(HeroOf(LocalPlayer().TeamMate)),LocalPlayer().TeamMate>,
    Position: MenuButtonPosition_Local(-3.2,-1.3),
    Scale: 2,
    Clipping: Clipping.DoNotClip,
    TextColor: GetTeamofPlayer(LocalPlayer()).TeamColor);

    MinWait();
}
globalvar Number TeamHealth = WorkshopSettingInteger(Category: '自定义(谨慎更改)',Name: '队伍生命值（扣血制）',Default: 100,Min: 30,Max: 300);
playervar Boolean isInvisible;
//区??
class PlayTeam {
    public Player[] Members;  // 队伍 (???
    public Number ID;     // 队伍ID
    public Number Health;  // 分数（可?
    public Color TeamColor;
    public PlayTeam Opponent;
    public Number ByeCount = 0; // 新：录轮空??

    public constructor(Player[] members, Number id) {
        Health = UsePointSystem?0:TeamHealth;

        Teams += this;
        Members = members;
        ID = id;
        TeamColor = AcquireTeamColor();
        // 为每丈罏??

        foreach (Player p! in Members) {
            p.isKnockOut = false;

            p.TeamMate = FirstOf(Members.Filter(t=>t!=p));
            p.TeamID = id;
            InitializeEffectText(p);
        }
    }

    public void AddMember(Player p!)'添加队员'{
        this.Members += p;
        p.isKnockOut = false;
        p.TeamMate = FirstOf(FilteredArray(Members, ArrayElement() != p));
        p.TeamMate.TeamMate = p;
        p.TeamID = this.ID;

        AloneOff(p.TeamMate);

        InitializeEffectText(p);
        MinWait();
    }

    public void InitializeEffectText(Player p!) '初始化特效'{
        CreateInWorldText(Header: <'队伍 <0>',EvaluateOnce(p).TeamID>,Position: EvaluateOnce(p),Scale: 2,Clipping: Clipping.ClipAgainstSurfaces,TextColor: EvaluateOnce(TeamColor),VisibleTo: (!EvaluateOnce(p).isInvisible&&IsAlive(EvaluateOnce(p)))?AllPlayers().Filter(t=>!t.FPSMode):null);
        CreateEffect(Type: Effect.Ring,Color: TeamColor,Position: (EvaluateOnce(p)),Radius: 1,VisibleTo: !IsDead(EvaluateOnce(p))?[EvaluateOnce(p),EvaluateOnce(p).TeamMate]:null);

        StartDamageModification(EvaluateOnce(p),EvaluateOnce(p).TeamMate,0,DamageModificationRev.ReceiversDamagersAndDamagePercent);
        MinWait();

        CreateIcon(VisibleTo: EntityExists(EvaluateOnce(p).TeamMate)?EvaluateOnce(p):null,EvaluateOnce(p).TeamMate,Icon.Happy,IconRev.VisibleToPositionAndColor,EvaluateOnce(TeamColor),true);
        CreateEffect(VisibleTo: !EvaluateOnce(p).isKnockOut?AllPlayers().Filter(t=>IsDead(EvaluateOnce(p))):null,Type: Effect.Ring,Color: EvaluateOnce(TeamColor), Position: PositionOf(EvaluateOnce(p)),Radius: 5,Reevaluation: EffectRev.VisibleToPositionRadiusAndColor);

        CreateProgressBarInWorldText(VisibleTo: !EvaluateOnce(p).isKnockOut?AllPlayers().Filter(t=>IsDead(EvaluateOnce(p))&&DistanceBetween(EvaluateOnce(p),t)<=5&&IsAlive(t)):null,Value: EvaluateOnce(p).RevivePercent,Text: <'<0>复活进',HeroIconString(HeroOf(EvaluateOnce(p)))>,Position: MenuButtonPosition_Local(0,-1.5),Scale: 1,Clipping: Clipping.DoNotClip,TextColor: Color.Orange,ProgressBarColor: GradientColor([54,133,2],[255,79,35],EvaluateOnce(p).RevivePercent/100),Reevaluation: ProgressBarWorldEvaluation.VisibleToPositionValuesAndColor);

        CreateInWorldText(VisibleTo: IsDead(EvaluateOnce(p))&&EvaluateOnce(p).Revivable&&!EvaluateOnce(p).isKnockOut?AllPlayers():null,Header: <'<2>-<0>: <1>%',HeroIconString(HeroOf(EvaluateOnce(p))),EvaluateOnce(p).RevivePercent,AbilityIconString(Hero.Mercy,Button.Ability2)>,Position: PositionOf(EvaluateOnce(p))+Vector(0,1,0),Scale: 2,Clipping: Clipping.ClipAgainstSurfaces,Spectators: Spectators.VisibleAlways);

        CreateProgressBarInWorldText(
            VisibleTo: !IsDead(EvaluateOnce(p))?AllPlayers().Filter(t=>IsDead(t)):null,
            Value: 100*NormalizedHealth(EvaluateOnce(p)),
            Text: '',
            Position: EvaluateOnce(p),
            Scale: 0.7,
            Clipping: Clipping.ClipAgainstSurfaces,
            ProgressBarColor: GradientColor([255,0,0],[0,255,0],1-(NormalizedHealth(EvaluateOnce(p)))),
            NonteamSpectators: Spectators.VisibleAlways,
        );
        MinWait();
    }

}

Boolean TeamDivisionCondition:
    IsGameInProgress();

rule: '当前分队逻辑'
{
    CreateHudText(Subheader: <'当前分队逻辑:<0>',UseAloneTeamUpto4?'优先创建队伍数量':'经典二人小队'>,SortOrder: -999,SubheaderColor: Color.Turquoise);
}
globalvar Boolean UseAloneTeamUpto4 = WorkshopSettingToggle('体验','在不满四人的时候单人成队',true,1);
globalvar Boolean UseAloneStartTeam = WorkshopSettingToggle('体验','分队时可以创建独狼队伍',true,0);
void DivisionSetup()'sub分队逻辑'{
    Player[] candidates! = <Player[]>RandomizedArray(AllLivingPlayers(Team.All));
    Teams = [];
    ResetTeamColorPool();

    if(CountOf(candidates)==0){
        return;
    }

    if(UseAloneTeamUpto4 && CountOf(candidates) <= 4){
        Number soloIndex! = 0;
        foreach(Player lone! in candidates){
            new PlayTeam([lone], soloIndex);
            AloneSet(lone);
            soloIndex++;
            MinWait();
        }
        BigMessage(AllPlayers(), '队伍已分好! 与你的队友打打招呼吧！');
        MinWait();
        return;
    }

    Number teamIndex! = 0;
    Number cursor! = 0;
    while(cursor + 1 < CountOf(candidates)){
        Player[] members = [candidates[cursor], candidates[cursor + 1]];
        new PlayTeam(members, teamIndex);
        cursor += 2;
        teamIndex++;
        MinWait();
    }

    if(cursor < CountOf(candidates)){
        Player leftover! = candidates[cursor];
        if(UseAloneStartTeam){
            new PlayTeam([leftover], teamIndex);
            AloneSet(leftover);
            MinWait();
        }else{
            SmallMessage(leftover, '因为人数原因，你被淘汰了');
            leftover.isKnockOut = true;
            WaitQueue += leftover;
        }
    }

    BigMessage(AllPlayers(), '队伍已分好! 与你的队友打打招呼吧！');
    MinWait();
}

globalvar PlayTeam byeTeam;
globalvar Number PrepareTime = WorkshopSettingInteger(Category: '流程设置',Name: '回合准备时间',Default: 40,Min: 15,Max: 90,SortOrder: 0);
single struct CombatPhaseConfig{
    public Number PrepareDuration;
    public Number CombatDuration;
    public Number ShrinkInterval;
    public Number ShrinkAmount;
    public Number BaseFireDamage;
    public Number FireDamagePerTick;
}

globalvar CombatPhaseConfig CurrentCombatConfig;
globalvar Number FireRingTickCount = 0;

CombatPhaseConfig ResolveCombatPhaseConfig(){
    CombatPhaseConfig config;
    config.PrepareDuration = CurrentStage > 0 ? PrepareTime : 15;
    config.CombatDuration = (CurrentRound == 1 && CurrentStage == 1) ? 20 : 40;
    config.ShrinkInterval = 5;
    config.ShrinkAmount = 3;
    config.BaseFireDamage = 50;
    config.FireDamagePerTick = 20;
    return config;
}

void UpdateCombatConfigForCurrentRound(){
    CurrentCombatConfig = ResolveCombatPhaseConfig();
}

void FireRing_InitializeCombatPhase(){
    UpdateCombatConfigForCurrentRound();
    FireRingTickCount = 0;
    FireRingsRadius = Areas_static.Map(Area => Area.Radius);
    SetMatchTime(CurrentCombatConfig.CombatDuration);
}

void FireRing_ApplyShrink(){
    FireRingTickCount++;
    if(CurrentCombatConfig.ShrinkAmount <= 0){
        return;
    }
    for(Number i! = 0; i < FireRingsRadius.Length; i++){
        if(FireRingsRadius[i] > 0){
            FireRingsRadius[i] = Max(0, FireRingsRadius[i] - CurrentCombatConfig.ShrinkAmount);
        }
    }
}

Number FireRing_CurrentDamage(){
    return CurrentCombatConfig.BaseFireDamage + FireRingTickCount * CurrentCombatConfig.FireDamagePerTick;
}


globalvar PlayTeam[] MatchUps;  // 存储当前回合对战组合
globalvar Number[] MatchHistory = [0, 0, 0, 0, 0, 0];  // 记录6种组合的历史次数

// 获取组合索引
Number GetMatchIndex(in Number teamA, in Number teamB) {
    Number minId! = Min(teamA, teamB);
    Number maxId! = Max(teamA, teamB);
    return minId == 0 ? maxId - 1 :
           minId == 1 ? maxId + 1 :
           minId == 2 ? 5 :
           -1;  // 无效队伍ID，返回-1
}

// 更新历史记录
void UpdateHistory(in Number teamA, in Number teamB) {
    Number index! = GetMatchIndex(teamA, teamB);
    if (index >= 0) {
        MatchHistory[index]++;
    }
}

// 选择对战组合
PlayTeam[][] SelectMatches(PlayTeam[] activeTeams) {
    Any[][] candidates! = [];
    Number candidateCount! = 0;

    // 生成所有可能组合及其历史次数
    for (Number i! = 0; i < CountOf(activeTeams); i++) {
        for (Number j! = i + 1; j < CountOf(activeTeams); j++) {
            Number a! = activeTeams[i].ID;
            Number b! = activeTeams[j].ID;
            Number history! = MatchHistory[GetMatchIndex(a, b)];
            candidates[candidateCount] = [activeTeams[i], activeTeams[j], history];
            candidateCount++;
        }
    }

    // 按历史次数升序排序
    candidates = candidates.Sort(t=>t[2]);

    // 贪心选择
    PlayTeam[][] selected! = [];
    Number selectedCount! = 0;
    Number[] matchedTeams! = [];

    for (Number i = 0; i < candidateCount; i++) {
        PlayTeam teamA! = candidates[i][0];
        PlayTeam teamB! = candidates[i][1];
        if (!ArrayContains(matchedTeams, teamA.ID) && !ArrayContains(matchedTeams, teamB.ID)) {
            selected[selectedCount] = [teamA, teamB];
            matchedTeams[CountOf(matchedTeams)] = teamA.ID;
            matchedTeams[CountOf(matchedTeams)] = teamB.ID;
            selectedCount++;
        }
    }
    return selected;
}

void StartPrepare_() 'sub开始准备'{
    byeTeam = null;  // 重置byeTeam

    SetStatus(AllPlayers(),null,Status.PhasedOut,9999);
    
    SetObjectiveDescription(
        Header: <
        '\r\r\r\r\r\r\r[阶段 <0>-<1>]\r\r\r\r\r\r\r                      获胜模式:<2>'
        ,CurrentStage
        ,CurrentRound
        ,UsePointSystem?'加分制(首个到达100分的队伍获胜)':'扣血制(存活到最后的队伍获胜)'>
        );
    MatchUps = [];  // 清空
    MinWait();
    // 获取当前活跃队伍（扣血制过滤已淘汰）

    PlayTeam[] activeTeams! = !UsePointSystem ? Teams.Filter(t=>t.Health>0) : Teams;
    // 如果队伍数量为奇数，选择一个轮空队伍
    if (CountOf(activeTeams) % 2 == 1) {
        // 找到轮空次数最少的队伍
        byeTeam = FirstOf(activeTeams.Sort((t => t.ByeCount)));
    
        byeTeam.ByeCount++;
        
        // 从活跃队伍中移除轮空队伍
        activeTeams = activeTeams.Filter(t=>t!=byeTeam);
        BigMessage(byeTeam.Members[0], 'Lucky！本回合轮空！将自动进入观战');
    }
    Wait(0.1);
    // 随机匹配其余队伍
    PlayTeam[] shuffledTeams = <PlayTeam[]>RandomizedArray(activeTeams);

    if(CountOf(shuffledTeams)==2){
        MatchUps[0] = [shuffledTeams[0],shuffledTeams[1]];
        SmallMessage(shuffledTeams[0].Members, <'对手: 队伍 <0>', shuffledTeams[0].ID>);
        SmallMessage(shuffledTeams[1].Members, <'对手: 队伍 <0>', shuffledTeams[0].ID>);
    }
    else{
        while(CountOf(MatchUps)<CountOf(shuffledTeams)/2){
        Wait(0.1);

        PlayTeam team1! = shuffledTeams.Random();
        PlayTeam[] availableTeams = shuffledTeams.Filter(t=>team1.Opponent!=t&&t!=team1);
        PlayTeam team2! = availableTeams.Random();
        Wait(0.1);
            MatchUps[MatchUps.Length] = [team1, team2];
            SmallMessage(team1.Members, <'对手: 队伍 <0>', team2.ID>);
            SmallMessage(team2.Members, <'对手: 队伍 <0>', team1.ID>);

        PlayTeam team3! = shuffledTeams.Filter(t=>t!=team1&&t!=team2)[0];
        PlayTeam team4! = shuffledTeams.Filter(t=>t!=team1&&t!=team2)[1];
        
            MatchUps[MatchUps.Length] = [team3, team4];
            SmallMessage(team3.Members, <'对手: 队伍 <0>', team3.ID>);
            SmallMessage(team4.Members, <'对手: 队伍 <0>', team4.ID>);
        }
    }
}

enum RewardStepType {
    Hex,
    ForgeAverage,
    ForgeRare
}

globalvar Quality[] AddupRoundQuaility = [];
RewardStepType CurrentRewardStep(in Player p):
    p.rewardFlow[p.rewardFlowIndex];

void PrepareCurrentRewardStepData(Player p!)'sub准备当前奖励步骤数据'{
    if(p.rewardFlowIndex >= p.rewardFlow.Length){
        return;
    }
    switch(CurrentRewardStep(p)){
        case RewardStepType.Hex:
            if(p.roundReward_index >= p.roundReward.Length){
                p.roundReward_index = 0;
            }
            break;
        case RewardStepType.ForgeAverage:
            if(p.forgeReward.Length <= 0){
                GenerateForgeRewards(p, false);
            }
            if(p.forgeReward_index >= p.forgeReward.Length){
                p.forgeReward_index = 0;
            }
            break;
        case RewardStepType.ForgeRare:
            if(p.forgeReward.Length <= 0){
                GenerateForgeRewards(p, true);
            }
            if(p.forgeReward_index >= p.forgeReward.Length){
                p.forgeReward_index = 0;
            }
            break;
    }
}

void OpenCurrentRewardMenu(Player p!)'sub打开当前奖励步骤菜单'{
    if(p.rewardFlowIndex >= p.rewardFlow.Length){
        return;
    }
    PrepareCurrentRewardStepData(p);
    switch(CurrentRewardStep(p)){
        case RewardStepType.Hex:
            OpenMenu(p: p, name: MenuActive.HexMenu);
            break;
        case RewardStepType.ForgeAverage:
        case RewardStepType.ForgeRare:
            OpenMenu(p: p, name: MenuActive.ForgeMenu);
            break;
    }
}

