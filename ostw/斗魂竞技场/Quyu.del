void AllShuxingPctBoost(Number Bonus)'sub全属性百分比加成管理'{
    shuxing.Health.Pct+=Bonus;
    shuxing.Attack.Pct+=Bonus;
    shuxing.Drain.Pct+=Bonus;
    shuxing.HealBoost.Pct+=Bonus;
    shuxing.Reduction.Pct+=Bonus;
    shuxing.Armor.Pct+=Bonus;
    shuxing.Shields.Pct+=Bonus;
    shuxing.CoolDown.Pct+=Bonus;
    shuxing.Speed.Pct+=Bonus;
    RevShuxing();
}

