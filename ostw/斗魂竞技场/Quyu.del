void Buff(){
    shuxing.Health.Abs += Max(250,550-MaxHealth());
    if(AllTankHeroes().Contains(HeroOf(EventPlayer()))){
        shuxing.Attack.Abs += 20;
        shuxing.Speed.Abs -= 10;
        shuxing.CoolDown.Abs -= 15;
        RevShuxing();
    }
    if(AllSupportHeroes().Contains(HeroOf(EventPlayer()))){
        shuxing.CoolDown.Abs += 25;
        shuxing.HealBoost.Abs -= 20;
        shuxing.Health.Abs += 0.5*MaxHealth();
        RevShuxing();
    }
    if(AllDamageHeroes().Contains(HeroOf(EventPlayer()))){
        shuxing.Health.Abs += 0.2*MaxHealth();
        shuxing.Attack.Abs += 10;
        RevShuxing();
    }
    Wait(0.03);
}

