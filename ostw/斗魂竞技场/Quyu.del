enum MenuActive {
    HexMenu,
    RuleMenu,
    ForgeMenu,
    GuideMenu
}

enum ButtonScale {
    Small = 2,
    Medium = 3,
    Large = 4
}
Vector MenuButtonPosition_Local_Visible(in Number PosX,in Number PosY):
    LocalPlayer().isInMenu?UpdateEveryFrame((CameraEye_Local+DirectionTowards(CameraEye_Local,CameraLookat_Local)) + MenuFlatBase1_Local * PosX + MenuFlatBase2_Local * PosY):null;
Vector MenuButtonPosition_Local(in Number PosX,in Number PosY):
    UpdateEveryFrame((CameraEye_Local+DirectionTowards(CameraEye_Local,CameraLookat_Local)) + MenuFlatBase1_Local * PosX + MenuFlatBase2_Local * PosY);

Vector MenuFlatBase1_Local:
    (-0.25 * Normalize(CrossProduct(Vector(0, 1, 0), CameraDir_Local)));

Vector MenuFlatBase2_Local:
    (-0.25 * Normalize(CrossProduct(CameraDir_Local, MenuFlatBase1_Local)))  ;

Vector CameraDir_Local:
    Normalize(CameraLookat_Local - CameraEye_Local);    

void OpenMenu(Player p! = EventPlayer(),MenuActive name)'sub打开菜单'{
    
    p.menuactive = name;
    if (!p.isInMenu) {
        SetFacing(p,Vector(0,0,1),Relative.ToPlayer);
        p.AnchorFacing = FacingDirectionOf(p);
        p.isInMenu = true;
        SetAimSpeed(p, 0.1);
        SetPrimaryFireEnabled(p, false);
        SetSecondaryFireEnabled(p, false);
        DisableHeroHud(p);
        DisableGameModeHud(p);
    }
    
    switch (name) {
        case MenuActive.HexMenu:
            OpenHexMenu();
            PlayEffect(VisibleTo: p,Type: PlayEffect.AnaBioticGrenadeIncreasedHealingSound,Position: CameraLookat,Radius: 200);
            break;
        case MenuActive.RuleMenu:
            p.ShowText_RuleMenu = WanfaText;
            break;
    }
    SetFacing(p,p.AnchorFacing);
}

