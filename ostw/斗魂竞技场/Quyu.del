}

enum ConditionType{
    IsAlive,
    KnockOut,
    InArea
}

Boolean isTrueForTeam(Player p!,ConditionType condition!)'队伍条件'{
    switch(condition){
        case ConditionType.IsAlive:
            return IsAlive(p)&&IsAlive(p.TeamMate);
        case ConditionType.KnockOut:
            return p.isKnockOut && p.TeamMate.isKnockOut;
    }
}

// 获取获胜队伍（回合内）
PlayTeam GetWinningTeam(in PlayTeam team1, in PlayTeam team2) {
    if(!ArrayContains(Teams, team1) && !ArrayContains(Teams, team2)) return null;
    if(!ArrayContains(Teams, team1)) return team2;
    if(!ArrayContains(Teams, team2)) return team1;

    Boolean team1Defeated! = team1.Members.All(t=>!IsAlive(t) || !HasSpawned(t));
    Boolean team2Defeated! = team2.Members.All(t=>!IsAlive(t) || !HasSpawned(t));

    if (team1Defeated && !team2Defeated) {
        return team2;
    } else if (team2Defeated && !team1Defeated) {
        return team1;
    }
    return null; // 平局：两队都失败或都未失败
}
Number WinPoint:
    CurrentRound < 4 && CurrentStage == 1 ? 10 : Min(25,10+5*RoundToInteger((CurrentRound+7*(CurrentStage-1))/4,Rounding.Nearest));
Number LosePoint:
    10;
// 回合结束处理
void HandleRoundEnd(in PlayTeam winner, in PlayTeam loser) {
    if (UsePointSystem) {
        // 加分制逻辑
        winner.Health += WinPoint;
        loser.Health = Max(0, loser.Health - LosePoint);
        
        BigMessage(winner.Members, <"胜利! +<0>分 (总分: <1>)", WinPoint, winner.Health>);
        BigMessage(loser.Members, <"失败! -<0>分 (总分: <1>)", LosePoint, loser.Health>);
        
        // 检查胜利条件
        if (winner.Health >= 100) {
            CurrentGamePhase = GamePhase.Ended;
            BigMessage(AllPlayers(), <"队伍 <0> 达到100分获胜!", winner.ID>);
            DeclarePlayerVictory(winner.Members[0]);
        }
    }
    else{
            // 扣除失败队伍生命
        loser.Health -= deductHealth;
        
        // 如果队伍生命<=0，整局淘汰
        if (loser.Health <= 0) {
            foreach (Player p! in loser.Members) {
                p.isKnockOut = true;
                Kill(p); // 立即淘汰玩家
                Wait(0.03);
            }
            BigMessage(loser.Members, "你的队伍被淘汰了！");
            // 从Teams移除淘汰队伍
            ModifyVariable(Teams, Operation.RemoveFromArrayByValue, loser); 
        }
        PlayEffect(VisibleTo: winner.Members,Type: PlayEffect.WreckingBallMinefieldExplosionSound,Position: PositionOf(FirstOf(winner.Members)),Radius: 150);
        PlayEffect(VisibleTo: winner.Members,Type: PlayEffect.WreckingBallMinefieldExplosionSound,Position: PositionOf(FirstOf(winner.Members)),Radius: 150);
        // 发送回合结果
        BigMessage(winner.Members, <"你的队伍赢得了本回合的胜利！">);
        BigMessage(loser.Members, <"你的队伍本回合遗憾告败!\n剩余生命: <0>", loser.Health>);
    }
    
    
    Wait(3);
    // 如果还有其他比赛，获胜队伍进入观战
    if (CountOf(MatchUps) > 1) {
        foreach (Player p! in winner.Members) {
            Wait(0.03);
            Kill(p);
            BigMessage(p, "由于其他比赛仍在进行，你已进入观战");
        }
    }
}
globalvar Boolean DetectEnd_Running = false;
void DetectEnd()'sub检测回合结束'{
    if(DetectEnd_Running)return;
    if(CurrentGamePhase != GamePhase.Combat)return;
    DetectEnd_Running = true;

    for (Number i! = 0; i < CountOf(MatchUps); i++) {
        PlayTeam team1! = MatchUps[i][0];
        PlayTeam team2! = MatchUps[i][1];
        PlayTeam winner! = GetWinningTeam(team1, team2);
        if (winner != null) {
            PlayTeam loser = (winner == team1) ? team2 : team1;
            HandleRoundEnd(winner, loser);
            
            // 从MatchUps移除这场比赛
            ModifyVariable(MatchUps, Operation.RemoveFromArrayByIndex, i);
            i--; // 因为数组长度已减少
        }
        Wait(0.025);
    }

    if (CountOf(MatchUps) == 0 && CurrentGamePhase==GamePhase.Combat) {
        Wait(0.025);
        if (UsePointSystem) {
            Wait(0.025);
            // 加分制下检查是否有队伍达到100分
            PlayTeam[] teamsWith100 = Teams.Filter(t => t.Health >= 100);
            if (CountOf(teamsWith100) > 0) {
                CurrentGamePhase = GamePhase.Ended;
                PlayTeam winner = FirstOf(teamsWith100);
                BigMessage(AllPlayers(), <"队伍 <0> 获得了100分，胜利!!", winner.ID>);
                DeclarePlayerVictory(winner.Members[0]);
            } else {
                Wait(0.025);
                async! GameFlow();
            }
        } else {
            // 检查游戏是否结束（只剩1队或无队）
            PlayTeam[] activeTeams! = Teams.Filter(t=>t.Health>0);  // 使用activeTeams判断
            if (CountOf(activeTeams) <= 1) {
                Wait(0.025);
                CurrentGamePhase = GamePhase.Ended;
                if (CountOf(activeTeams) == 1) {
                    BigMessage(AllPlayers(), <"队伍 <0> 吃鸡!!", activeTeams[0].ID>);
                    DeclarePlayerVictory(activeTeams[0].Members[0]);
                    // 为获胜队伍宣告胜利
                } else {
                    BigMessage(AllPlayers(), "比赛以平局结束，无胜者！");
                }
            } else {
                Wait(0.025);
                async! GameFlow();
            }
        }

    }
    
        if(IsTrueForAll(AllPlayers(),IsDead(ArrayElement()))){
                        BigMessage(AllPlayers(), "似乎有人触发了回合内平局...");
            Wait(0.025);
            async! GameFlow();

        }
    DetectEnd_Running = false;
}
// 检测对位组合的胜负
rule: 'DetectEnd - 玩家死亡'
