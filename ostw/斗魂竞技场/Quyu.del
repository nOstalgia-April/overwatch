struct HexDef{
    public HexId Id;
    public String Name;
    public String Description;
    public Hero[] AllowedHeroes;
    public HexQuality Quality;
    public Number Cooldown;
}
enum HexQuality{
    average,
    rare,
    epic,
    legend
}
playervar HexId[] Hexes = [];
playervar Number[] HexCurrentCooldowns = [];
globalvar HexId[] HexPool = [];

Number HexDefIndexByName(in String name):
    HexDefs.Map(h=>h.Name).IndexOf(name);

HexId HexIdByName(in String name){
    define idx : HexDefIndexByName(name);
    return HexDefs[idx].Id;
}

Boolean HasHexId(in HexId id, in Player p = EventPlayer()):
    p.Hexes.Contains(id);

Boolean HasHexName(in String name, in Player p = EventPlayer()):
    HasHexId(HexIdByName(name), p);

Number HexSlotIndex(in HexId id, in Player p = EventPlayer()):
    p.Hexes.IndexOf(id);

Number PlayerHexCooldownById(in HexId id, in Player p = EventPlayer()):
    p.HexCurrentCooldowns[HexSlotIndex(id, p)];

Boolean PlayerHexReadyById(in HexId id, in Player p = EventPlayer()):
    PlayerHexCooldownById(id, p) <= 0;

Boolean PlayerHexReadyByName(in String name, in Player p = EventPlayer()):
    PlayerHexReadyById(HexIdByName(name), p);

Number HexBaseCooldownById(in HexId id){
    return HexDefs[<Number>id].Cooldown;
}

void StartHexCooldownById(HexId id!, Player p! = EventPlayer()) 'sub开始Hex冷却ById'{
    p.HexCurrentCooldowns[HexSlotIndex(id, p)] = HexBaseCooldownById(id);
}

void StartHexCooldownByName(in String name, in Player p = EventPlayer()) {
    StartHexCooldownById(HexIdByName(name), p);
}

void TickPlayerHexCooldowns(Player p = EventPlayer(), Number step = 0.25) 'subTickHex冷却'{
    while(p.HexCurrentCooldowns.Length < p.Hexes.Length){
        p.HexCurrentCooldowns += 0;
    }
    for(define i! = 0; i < p.HexCurrentCooldowns.Length; i++){
        p.HexCurrentCooldowns[i] = Max(0, p.HexCurrentCooldowns[i] - step);
    }
}

void GrantHexToPlayerById(Player p, HexId hexId) 'sub授予HexById'{
    p.Hexes += hexId;
    p.HexCurrentCooldowns += 0;
}

String HexNameById(in HexId id){
    return HexDefs[<Number>id].Name;
}

String HexNameById(in Number id){
    return HexDefs[<Number>id].Name;
}

HexQuality HexQualityById(in HexId id){
    return HexDefs[<Number>id].Quality;
}

String HexDescriptionById(in HexId id){
    return HexDefs[<Number>id].Description;
}

Number HexCooldownBaseById(in HexId id){
    return HexDefs[<Number>id].Cooldown;
}

HexId SelectedHexOfferId(Player p = EventPlayer()):
    p.roundReward[p.roundReward_index];

String HexOfferTitleLocal(in Number idx){
    define id : LocalPlayer().roundReward[idx];
    return <'<1><0>', HexNameById(id), LocalPlayer().roundReward_index == idx ? IconString(Icon.ArrowRight) : ''>;
}

Color HexOfferColorLocal(in Number idx){
    define id : LocalPlayer().roundReward[idx];
    return InteratableColor_Local(
        Default: Quaility_Color[HexQualityById(id)][1],
        Hover: Quaility_Color[HexQualityById(id)][0],
        Visible: LocalPlayer().roundReward_index == idx
    );
}

String HexOfferDescriptionLocal():
    LocalPlayer().roundReward_index >= LocalPlayer().roundReward.Length ? '暂无描述' : HexDescriptionById(SelectedHexOfferId(LocalPlayer()));

Boolean HexAllowedForPlayer(in HexId id, in Player p){
    return HexDefs[<Number>id].AllowedHeroes.Contains(HeroOf(p));
}

HexId[] RollHexOffersByQualities(in Player p, in HexQuality[] qualities, in Number take = 3):
    ArraySlice(RandomizedArray(HexPool.Filter(id => !p.Hexes.Contains(id) && qualities.Contains(HexQualityById(id)) && HexAllowedForPlayer(id, p))), 0, take);

