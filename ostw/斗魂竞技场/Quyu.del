void void_ShenshengFLZ(){
    define hexName! = '艾莉莎的奇迹';
    
    if(PlayerHexReadyByName(hexName))
    {
        StartHexCooldownByName(hexName);
        
        // 计算附伤?(50 + 5%盠朧生命?
        define bonusDamage = 50 + (0.05 * MaxHealth(Victim()));
        
        PlayEffect(VisibleTo: EventPlayer(),Type: PlayEffect.BuffImpactSound,Position: EventPlayer(),Radius: 150);
        if(EventWasCriticalHit())
        {
            // 暴恢??0%附值的生命?
            Heal(EventPlayer(), EventPlayer(),  0.5 * bonusDamage);
            HealEffectPlay();
        }
        
        // ^附伤?
        Damage(Victim(), EventPlayer(), bonusDamage);
        
        PlayEffect(AllPlayers(), PlayEffect.BadPickupEffect, Color.Violet, Victim(), 2);
        YG_Shenshengfenlizhe = false;
    }
}
