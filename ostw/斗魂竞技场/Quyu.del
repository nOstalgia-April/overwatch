void RevShuxing(Player p! = EventPlayer())'sub刷新属性'{
    SetMoveSpeed(p,p.shuxing.Speed.VirtualShuxing(p)); 
    SetDamageDealt(p,p.shuxing.Attack.VirtualShuxing(p));
    SetDamageReceived(p,Max(20,100*100/(100+1.5 *p.shuxing.Reduction.VirtualShuxing(p))));
    SetHealingDealt(p,p.shuxing.HealBoost.VirtualShuxing(p));

    SetJumpVerticalSpeed(p,p.shuxing.JumpVerticalSpeed.VirtualShuxing(p));
}
Number CooldownReductionPerTick : 0.5 * (shuxing.CoolDown / (100 + shuxing.CoolDown));
