void OpenMenuAll() 'sub打开该回合菜单'{
    define RestPlayers = AllPlayers().Filter(t => !t.isKnockOut);
    foreach (Player p! in RestPlayers){
        Wait(0.2);
        if(p.Hexes.Length<6){
            if (CurrentRound == 7) {
                OpenMenu(p: p, name: MenuActive.HexMenu);
            }
            else{
                if ([3, 6].Contains(CurrentRound)) {
                    OpenMenu(p: p, name: MenuActive.ForgeMenu);
                }
                else{
                    if (CurrentRound == 2) {
                        OpenMenu(p: p, name: MenuActive.HexMenu);
                    }
                    else{
                        if (CurrentRound == 4) {
                            OpenMenu(p: p, name: MenuActive.HexMenu);

                        }
                        else{
                            if (CurrentRound == 5) {
                            OpenMenu(p: p, name: MenuActive.HexMenu);
                        }
                        }
                    }
                    
                }

            }

        }
        else {
            OpenMenu(p: p, name: MenuActive.ForgeMenu);
        }
    } 
}
void ApplyRoundRewards() 'sub决定回合奖励'{
    define RestPlayers = AllPlayers().Filter(t => !t.isKnockOut);
    PlayTeam[] compensTeams! = [];
    if(CurrentRound >= 2){
        PlayTeam[] activeTeams! = [];
        foreach(PlayTeam team! in Teams){
            if(team != null && team.Health > 0){
                Player[] validMembers! = team.Members.Filter(p=>EntityExists(p) && !p.isKnockOut);
                if(validMembers.Length > 0){
                    activeTeams += team;
                }
            }
        }
        if(activeTeams.Length > 0){
            Number lowestHealth! = activeTeams.Sort(t=>t.Health).First.Health;
            compensTeams = activeTeams.Filter(t=>t.Health == lowestHealth);
            foreach(PlayTeam team! in compensTeams){
                Player[] teamMembers! = team.Members.Filter(p=>EntityExists(p) && !p.isKnockOut);
                if(teamMembers.Length > 0){
                    BigMessage(teamMembers, '队伍生命值倒数\n获得额外锻体回合！');
                }
            }
        }
    }

    foreach (Player p! in RestPlayers){
        p.roundReward = [];
        p.forgeReward = [];
        p.roundReward_index = 0;
        p.forgeReward_index = 0;
        p.rewardFlow = [];
        p.rewardFlowIndex = 0;

        if(p.Hexes.Length<6){
            switch(CurrentRound){
                case 7:
                p.roundReward = RollHexOffersByQualities(p, [HexQuality.epic], 3);
                p.rewardFlow += RewardStepType.Hex;
                break;
                case 3:
                case 6:
                p.RefreshCount++;
                p.rewardFlow += RewardStepType.ForgeAverage;
                break;
                case 2:
                p.roundReward = RollHexOffersByQualities(p, [HexQuality.average, HexQuality.rare, HexQuality.epic], 3);
                p.rewardFlow += RewardStepType.Hex;
                break;
                case 4:
                p.roundReward = RollHexOffersByQualities(p, [HexQuality.average], 3);
                p.rewardFlow += RewardStepType.Hex;
                break;
                case 5:
                p.roundReward = RollHexOffersByQualities(p, [HexQuality.rare], 3);
                p.rewardFlow += RewardStepType.Hex;
                break;
            }
        }
        else{
            p.rewardFlow += RewardStepType.ForgeAverage;
        }

        PlayTeam playerTeam! = GetTeamofPlayer(p);
        if(CurrentRound >= 2 && playerTeam != 0 && compensTeams.Contains(playerTeam)){
            p.rewardFlow += RewardStepType.ForgeAverage;
        }

    } 
}


