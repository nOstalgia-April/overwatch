rule: '星陨打击'
Event.OngoingPlayer
Team.All
Player.All
if(TeamID != -1)
if(HasHexName('星陨打击'))
if(IsInAir())
{
    define hexName! = '星陨打击';
    Number Cap = 6;
    if(PlayerHexReadyByName(hexName))
    {
    
    Number[] Heights = [AltitudeOf()];
    while(IsInAir()){
        Heights += AltitudeOf();
        if(Heights.Sort(t=>t).First-Heights.First >= Cap){
            PlayEffect(
                EventPlayer(),
                PlayEffect.BuffExplosionSound,
                Position: PositionOf(),
                Radius: 100
            );
        }
        Wait(0.05);
    }
    StartHexCooldownByName(hexName);
    define Enemy = PlayersWithinRadius(EventPlayer(),8,Team.All,RadiusLOS.Surfaces).Filter(t=>t!=EventPlayer()&&t!=TeamMate);
    Damage(Enemy,EventPlayer(),Max(100,150*Min(1,(Heights.Sort(t=>t).First-Heights.First)/Cap)));
    if(Heights.Sort(t=>t).Last-Heights.First > Cap){
            SetStatus(Enemy,null,Status.KnockedDown,1);
            PlayEffect(
                Type: PlayEffect.RingExplosion,
                Position: PositionOf(),
                Radius: 8,
                Color: Color.Red
            );
        }else{
            PlayEffect(
                Type: PlayEffect.RingExplosion,
                Position: PositionOf(),
                Radius: 8,
                Color: Color.Yellow
            );
    }
    }
}

