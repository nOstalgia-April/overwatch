        ShowColor: InteratableColor_Local(Default:Quaility_Color[LocalPlayer().forgeReward[2].quality][1],Hover:Quaility_Color[LocalPlayer().forgeReward[2].quality][0],Visible: LocalPlayer().forgeReward_index==2),
        scale: ButtonScale.Large,
        interactable: true,
        ofmenuActives: [MenuActive.ForgeMenu]
    ).SetOnClick(()=>{EventPlayer().forgeReward_index=2;});
    new MenuButton(
        header: <'<0>',LocalPlayer().forgeReward[LocalPlayer().forgeReward_index].GetDes()>,
        posX: -1.5,
        posY: -0.5,
        ShowColor: CustomColor(255, 233, 215, 255),
        scale: ButtonScale.Medium,
        ofmenuActives: [MenuActive.ForgeMenu]
    );
    new MenuButton(
        header: <'<0>确认选择',IconString(Icon.Happy)>,
        posX: 1.5,
        posY: 0,
        scale: ButtonScale.Medium,
        ShowColor: InteratableColor_Local(),
        interactable: true,
        ofmenuActives: [MenuActive.ForgeMenu]
    ).SetOnClick(()=>OnClickYesofRewards(EventPlayer()));
    new MenuButton(
        header: <'刷新(<0>)',LocalPlayer().RefreshCount>,
        posX: 1.5,
        posY: -0.5,
        scale: ButtonScale.Medium,
        ShowColor: InteratableColor_Local(),
        interactable: true,
        ofmenuActives: [MenuActive.ForgeMenu]
    ).SetOnClick(()=>{
        if(RefreshCount>0){
               // 栍品质刷?
        Quality currentQuality! = forgeReward[forgeReward_index].quality;
        ShuxingForge newForge!;
        if(currentQuality == Quality.average){
        newForge = GenerateAverageForge();
        while(ArrayContains(forgeReward, newForge) || ArrayContains(Forges, newForge)){
        newForge = GenerateAverageForge();
        }
        } else {
        // 寺rare筼从池子随机，但排除已??
        newForge = RandomValueInArray(RareForgePool.Filter(t=>!ArrayContains(forgeReward,t) && !ArrayContains(Forges,t)));
        }
        forgeReward += forgeReward[forgeReward_index];
        forgeReward[forgeReward_index] = newForge;
        RefreshCount--;
        PlayEffect(VisibleTo: EventPlayer(),Type: PlayEffect.TracerRecallReappearSound,Position: CameraLookat,Radius: 150); 
        }

    });

        // 新：转为锻体按??
    new MenuButton(
        header: <'[转为锻体]'>,
        posX: 0,
        posY: 1.35,
        scale: ButtonScale.Medium,
        ShowColor: InteratableColor_Local(),
        interactable: true,
        ofmenuActives: [MenuActive.HexMenu]
    ).SetOnClick(() => {
        if(rewardFlowIndex < rewardFlow.Length && CurrentRewardStep(EventPlayer()) == RewardStepType.Hex){
            rewardFlow[rewardFlowIndex] = CurrentRound == 7 ? RewardStepType.ForgeRare : RewardStepType.ForgeAverage;
            roundReward = [];
            roundReward_index = 0;
            forgeReward = [];
            forgeReward_index = 0;
            OpenCurrentRewardMenu(EventPlayer());
            PlayEffect(VisibleTo: EventPlayer(), Type: PlayEffect.Soldier76SprintStartSound, Position: CameraEye, Radius: 200);
        }
    });
}

void GenerateForgeRewards(Player p, Boolean isRare) 'sub生成锻体奖励'{
    p.forgeReward = [];
    if(isRare){
        p.forgeReward = RareForgePool.Randomize().Slice(0,3);
    }
    else{
        p.forgeReward = Forge_Average_List.Randomize().Slice(0,3);
    }
}

ShuxingForge[] GetForgeRewards(Boolean isRare)'sub获取锻体奖励'{
    ShuxingForge[] forgeReward = [];
    for (Number i = 0; i < 3; i++) {
        ShuxingForge newForge!;
        if (isRare) {
            newForge = RareForgePool.Randomize().Slice(0,3);
        } else {
            newForge = GenerateAverageForge();
            while (ArrayContains(forgeReward.Map(t => t.type), newForge.type)) {
                newForge = GenerateAverageForge();
                MinWait();
            }
        }
        forgeReward += newForge;
    }
    return forgeReward;
}
void CloseMenu(Player p! =EventPlayer())'关闭菜单'{
    p.isInMenu = false;
    StopCamera(p);
    SetAimSpeed(p,100);
    SetPrimaryFireEnabled(p,true);
    SetSecondaryFireEnabled(p,true);
    EnableHeroHud(p);
    EnableGameModeHud(p);
    SetFacing(p,p.AnchorFacing);
    MinWait();
}

