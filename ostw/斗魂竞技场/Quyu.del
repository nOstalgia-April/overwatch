void FindButton()'sub选按钮'{
    EventPlayer().isButtonHovered = false;

        define bns! = Button_Pool.Filter(t=>t.Data.ofMenuActives.Contains(EventPlayer().menuactive));
        MenuButton thebn! = FirstOf(bns.Filter(t=>AbsoluteValue(CURSOR_X - t.Data.PosX) < GetButtonHitBox(t)[0] && AbsoluteValue(CURSOR_Y - t.Data.PosY) < GetButtonHitBox(t)[1]));
        
        if (thebn.Data.ID != 0) {
                    EventPlayer().MenuLoop = thebn.Data.ID;
                    EventPlayer().HoverVisible = thebn.HoverLabel != 0;
                    EventPlayer().HoverText = thebn.HoverLabel;
                    EventPlayer().isButtonHovered = true;
        }
