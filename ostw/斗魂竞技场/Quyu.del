if(HasSpawned())
if(BornHexes.Any(t => t.BadHero == HeroOf()))
{
    define bornHexId : (BornHexes.Filter(t => t.BadHero == HeroOf())).First.Hexid;
    if(!HasHexId(bornHexId)){
        GrantHexToPlayerById(EventPlayer(), bornHexId);
    }
}

