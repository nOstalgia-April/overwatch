globalvar Player[] WaitQueue = [];
globalvar PlayTeam[] LoneTeams = [];

globalvar Boolean UseLoneTeamAdd = WorkshopSettingToggle('体验',Name: '让等待队列单个玩家即可创建独狼队伍加入比赛',false,0);
void CreateAndSetupTeam(Player[] members!, Number teamId!, Boolean isLoneTeam!) 'sub设置队伍'{
    PlayTeam newTeam! = new PlayTeam(members: members, id: teamId);
    newTeam.Health = UsePointSystem ? FirstOf(Teams.Map(t => t.Health)) : Max(50, 100 - 25 * (CurrentStage - 1));
    foreach (Player p! in members) {
        CloseMenu(p);
        compens_Forge(p);
        if (isLoneTeam) {
            AloneSet(p);
        }
    }
    BigMessage(Header: '有新的队伍中途加入！！~');
    for (Number i! = 0; i < CountOf(members); i++) {
        WaitQueue.ModRemoveByIndex(0);
    }
    Teams += newTeam;
    Wait(0.1);
}
globalvar Number[] TeamIDs = [0,1,2,3];
void JoinDetect()'sub等待队列处理'{
    //先做??
    WaitQueue = WaitQueue.Filter(t=>EntityExists(t)&&CurrentStage<3&&t.TeamID==-1);

    LoneTeams = Teams.Filter(t=>CountOf(t.Members)==1);
    //队伍数量不?为，创建新狼队?
    while(UseAloneTeamUpto4&&CountOf(Teams)<4&&CountOf(WaitQueue) > 0){
            CloseMenu(WaitQueue[0]);
            PlayTeam NewLoneTeam! = new PlayTeam(members: [WaitQueue[0]],id: Teams.Length);
            NewLoneTeam.Health = UsePointSystem?FirstOf(Teams.Map(t=>t.Health)):TeamHealth-25*CurrentStage;
            compens_Forge(WaitQueue[0]);
            AloneSet(WaitQueue[0]);
            BigMessage(Header: '有新的队伍中途加入！！~');
            WaitQueue.ModRemoveByIndex(0);
    }
    MinWait();
    if (CountOf(WaitQueue) > 0){
        // 优先塡队?
        while (CountOf(LoneTeams) > 0 && CountOf(WaitQueue) > 0) {
            PlayTeam loneTeam! = FirstOf(LoneTeams);
            if (loneTeam != 0) {
                CloseMenu(WaitQueue[0]);
                compens_Forge(WaitQueue[0]);
                loneTeam.AddMember(WaitQueue[0]);
                WaitQueue.ModRemoveByIndex(0); // 秙匹配的玩
            }
            LoneTeams = Teams.Filter(t=>CountOf(t.Members)==1);
        }
        // 塡完了屸还有队伍不满，试s创建二人队?
        while (CountOf(WaitQueue)%2==0&&CountOf(WaitQueue)>0&&CountOf(Teams)<4) {
            PlayTeam NewTeam! = new PlayTeam(members: [WaitQueue[0],WaitQueue[1]],id: Teams.Length);
            NewTeam.Health = UsePointSystem?FirstOf(Teams.Map(t=>t.Health)):TeamHealth-25*CurrentStage;
            compens_Forge(WaitQueue[0]);
            compens_Forge(WaitQueue[1]);
            BigMessage(Header: '有新的队伍中途加入！！~');

            CloseMenu(WaitQueue[0]);
            CloseMenu(WaitQueue[1]);
            WaitQueue.ModRemoveByIndex(0);
            WaitQueue.ModRemoveByIndex(0);
        }
        if(CountOf(WaitQueue) == 1&&UseLoneTeamAdd&&CountOf(Teams)<4){
            CloseMenu(WaitQueue[0]);
            PlayTeam NewLoneTeam! = new PlayTeam(members: [WaitQueue[0]],id: Teams.Length);
            NewLoneTeam.Health = UsePointSystem?FirstOf(Teams.Map(t=>t.Health)):TeamHealth-25*CurrentStage;
            compens_Forge(WaitQueue[0]);
            AloneSet(WaitQueue[0]);
            BigMessage(Header: '有新的队伍中途加入！！~');
            WaitQueue.ModRemoveByIndex(0);
        }
    }
    LoneTeams = Teams.Filter(t=>CountOf(t.Members)==1);
    
    while(CountOf(LoneTeams)>0 && AllPlayers().Filter(p=>p.isKnockOut).Length>0){
        Player ReturnPlayer! = AllPlayers().Filter(p=>p.isKnockOut).Random();
        PlayTeam ReturnTeam! = LoneTeams[0];
        ReturnPlayer.isKnockOut = false;
        ReturnTeam.AddMember(ReturnPlayer);
        BigMessage(Header: '新带老，老带新\n有玩家被复活重组队伍啦！');
        LoneTeams = Teams.Filter(t=>CountOf(t.Members)==1);
    }
} 

Player[] RealWaitQueue:
    WaitQueue.Filter(t=>EntityExists(t));

rule: 'My Rule'
{
    CreateHudText(Text: <'————[等待下个准备回合]————\n <0>\n <1>\n <2>\n...\n\n\n[递补规则]:\n\n1:优先替补场上已存独狼队伍\n\n2:若替补结束后等待队列还剩下2名玩家\n则这两名玩家组成新队伍加入游戏',
    RealWaitQueue[0]!=0?<'<0><1>',HeroIconString(HeroOf(RealWaitQueue[0])),RealWaitQueue[0]>:'',
    RealWaitQueue[1]!=0?<'<0><1>',HeroIconString(HeroOf(RealWaitQueue[1])),RealWaitQueue[1]>:'',
    RealWaitQueue[2]!=0?<'<0><1>',HeroIconString(HeroOf(RealWaitQueue[2])),RealWaitQueue[2]>:''
    >
    ,
    Location: Location.Right,
    TextColor: CustomColor(255, 161, 197, 255),
    SortOrder: -998,
    VisibleTo: !LocalPlayer().isInMenu&&!LocalPlayer().FPSMode?(CurrentGamePhase == GamePhase.Preparation?AllPlayers():AllPlayers().Filter(t=>t.isKnockOut)):null
    );

}

void compens_Forge(Player p!)'上入锻体补偿'{
        // 补偿锻体
    Number compens = Min(15,(CurrentRound+8*(CurrentStage-1))+2);
    for(Number i = 0; i < compens; i++) {
        ShuxingForge forge = Forge_Average_List.Randomize()[i][0];
        ApplyForge(forge, p);
        MinWait();
    }
    BigMessage(VisibleTo: p,Header: '中途加入比赛\n已补偿属性锻造器！');
}

