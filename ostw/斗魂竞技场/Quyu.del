    Wait(0.03,WaitBehavior.AbortWhenFalse);
    DetectEnd();
}
playervar Boolean OpenMenuAction = false;
playervar RewardStepType[] rewardFlow;
playervar Number rewardFlowIndex;
void GameFlow()'sub游戏主流程'{
    
    if(!CurrentStage==0){
                        // 先处理等待队列
    WaitQueue = WaitQueue.Filter(t=>EntityExists(t)&&CurrentStage<3);
    Teams = Teams.Filter(t=>t!=null);
    if(WaitQueue.Length>0){
        SetSlowMotion(10);
        JoinDetect();
        SetSlowMotion(100);
    }
    }
    define RestPlayers! = AllPlayers().Filter(t=>!t.isKnockOut);
    Resurrect(RestPlayers);
    MinWait();
    // 进入下回合
    if(CurrentRound >= 7){
        CurrentStage++;
        CurrentRound=1;
    }
    Resurrect(RestPlayers);
    Teleport(RestPlayers,Hall);
    CurrentRound++;
    UpdateCombatConfigForCurrentRound();
    CurrentGamePhase = GamePhase.Preparation;
    SetMatchTime(CurrentCombatConfig.PrepareDuration);
    SetSlowMotion(10);
    StartPrepare_();
    SetSlowMotion(100);
    Wait(2);
    SetSlowMotion(10);
    ApplyRoundRewards();
    SetSlowMotion(100);
    Wait(3);
    SetSlowMotion(10);  
    RestPlayers.OpenMenuAction = true;
    Player[] NowPlayers = AllPlayers().Filter(t=>t.TeamID!=-1);
    Wait(0.1);
    SetSlowMotion(100);
    WaitUntil(MatchTime()==0||NowPlayers.IsTrueForAll(t=>!t.isKnockOut&&!t.isInMenu),60);
    BigMessage(Header: '正在前往战场...');
    Wait(3);
    foreach(Player p! in RestPlayers.Filter(t=>t.isInMenu)){
        AutoSelectReward(p);
        MinWait();
        Wait(0.03);
    }
    ResetHexEffects();  // 重置海克斯效果
    StartCombat();
    CurrentGamePhase = GamePhase.Combat;
}

