void AutoSelectReward(in Player p){
    Number guard! = 0;
    while(p.isInMenu && p.rewardFlowIndex < p.rewardFlow.Length && guard < 10){
        if(CurrentRewardStep(p) == RewardStepType.Hex){
            p.roundReward_index = 0;
        }
        else{
            p.forgeReward_index = 0;
        }
        OnClickYesofRewards(p);
        guard++;
        Wait(0.03, WaitBehavior.IgnoreCondition);
    }
    if(p.isInMenu){
        CloseMenu(p);
    }
}

