    void StartCombat() {
        
        FireRing_InitializeCombatPhase();
        SetStatus(AllPlayers().Filter(t=>HeroOf(t)==Hero.Tracer),null, Status.Hacked,4);
        ClearStatus(AllPlayers(),Status.PhasedOut);

        AllPlayers().Revivable = true;

        Kill(byeTeam.Members);

        BigMessage(AllPlayers(), <'阶段 <0>-<1> 战斗开始!', CurrentStage, CurrentRound>);
        Area[] shuffledAreas = <Area[]>RandomizedArray(Areas_static);

        for (Number i! = 0; i < CountOf(MatchUps); i++) {
            
            PlayTeam team1! = MatchUps[i][0];
            PlayTeam team2! = MatchUps[i][1];

            team1.Opponent = team2;
            team2.Opponent = team1;
            Area targetArea = shuffledAreas[i];
            foreach (Player p! in team1.Members) {
                p.Player_Area = targetArea;
                Teleport(p, targetArea.SpawnPosition1);
                SetStatus(p, null, Status.Invincible, 2);
            }
            foreach (Player p! in team2.Members) {
                p.Player_Area = targetArea;
                Teleport(p, targetArea.SpawnPosition2);
                SetStatus(p, null, Status.Invincible, 2);
            }
        }
    }

enum GamePhase {
    Preparation,  // 准备阶段
    Combat,       // 战斗阶段
    Ended         // 游戏结束
}

globalvar Number CurrentRound;
globalvar GamePhase CurrentGamePhase;

// 主流程
