playervar Number TearStacks;
playervar Player TearTarget;
rule: '撕裂伤口'
Event.OnDamageDealt
Team.All Player.All 
if(TeamID != -1)
if(HasHexName('撕裂伤口'))
if([Button.PrimaryFire,Button.SecondaryFire].Contains(EventAbility()))
{
    
    // 判断昐昐丠
    if(TearTarget != Victim()){
        TearStacks = 0;
    }
    TearTarget = Victim();
    // 秮数
    {
    TearStacks++;
        if(TearStacks>=3){
            StartDamageOverTime(Receivers: Victim(),Damagers: EventPlayer(),Duration: 2,DamagePerSecond: 30);
            PlayEffect(AllPlayers(), PlayEffect.SigmaHypersphereImplosionEffect, Color.Red, Victim(), 1);
            TearStacks = 0;
            SmallMessage(EventPlayer(), '撕裂伤口：已触发');
            Wait(0.2);
        }
    }
    // 内置CD
    Wait(0.1);
    Wait(2,WaitBehavior.RestartWhenTrue);
    // 层数重置 
    TearStacks = 0;
}
    
    
