variables
{
	global:
		0: nodes_location
		1: nodes_link
		2: nodes_basic_distance
		3: distance_preset
		4: prev_node_preset
		5: nodes_index_preset
		10: checking_nodes
		20: for_1
		21: for_2

	player:
		27: nodes_basic_distance
		30: start
		31: end
		32: path
		33: now_groups
		34: for_1
		35: now
		36: visited
		37: now_weight
		38: nodes_distance
		39: now_ID
		40: unvisited_nodes_distance
		41: nodes_preset_now
		42: is_first_iteration
		43: maybe_distance
		44: nodes_location
		45: nodes_link
		46: current
}

subroutines
{
	51: Sub51
	53: Sub53
	54: Sub54
}

