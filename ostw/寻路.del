rule("初始化")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Global.distance_preset = Empty Array;
		Global.prev_node_preset = Empty Array;
		Global.nodes_index_preset = Empty Array;
		For Global Variable(for_1, 0, Count Of(Global.nodes_location), 1);
			Modify Global Variable(distance_preset, Append To Array, 9999);
			Modify Global Variable(prev_node_preset, Append To Array, -1);
			Modify Global Variable(nodes_index_preset, Append To Array, Global.for_1);
		End;
		Global.nodes_basic_distance = Empty Array;
		For Global Variable(for_1, 0, Count Of(Global.nodes_location), 1);
			Global.nodes_basic_distance[Global.for_1] = Empty Array;
			Global.checking_nodes = Global.nodes_link[Global.for_1];
			For Global Variable(for_2, 0, Count Of(Global.checking_nodes), 1);
				Modify Global Variable At Index(nodes_basic_distance, Global.for_1, Append To Array, Distance Between(
					Global.nodes_location[Global.for_1], Global.nodes_location[Global.checking_nodes[Global.for_2]]));
			End;
		End;
	}
}

rule("沿路径移动")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		disabled Is Dummy Bot(Event Player) == True;
		Has Spawned(Event Player) == True;
		Is Button Held(Event Player, Button(Crouch)) == True;
	}

	actions
	{
		disabled Teleport(Event Player, Event Player.start);
		Wait(0.250, Ignore Condition);
		Start Throttle In Direction(Event Player, Direction Towards(Eye Position(Event Player), First Of(Event Player.path)), 1, To World,
			Replace existing throttle, Direction and Magnitude);
	}
}

rule("移除路径中已到达的节点")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		disabled Is Dummy Bot(Event Player) == True;
		Has Spawned(Event Player) == True;
		Count Of(Event Player.path) > 0;
		Distance Between(Eye Position(Event Player), Vector(X Component Of(First Of(Event Player.path)), Y Component Of(Eye Position(
			Event Player)), Z Component Of(First Of(Event Player.path)))) < 1;
	}

	actions
	{
		Modify Player Variable(Event Player, path, Remove From Array By Index, 0);
		If(Count Of(Event Player.path) == 0);
			Stop Throttle In Direction(Event Player);
		End;
	}
}

rule("sub53 最短路径模块Dijstra")
{
	event
	{
		Subroutine;
		Sub53;
	}

	actions
	{
		While(True);
			Wait(0.025, Ignore Condition);
			If(Event Player.is_first_iteration == True);
				Event Player.now = Event Player.start;
				Event Player.now_ID = Index Of Array Value(Event Player.nodes_location, Event Player.now);
				Event Player.is_first_iteration = False;
			Else;
				Event Player.unvisited_nodes_distance = Filtered Array(Event Player.nodes_distance, Event Player.visited[Index Of Array Value(
					Event Player.nodes_distance, Current Array Element)] == 0);
				If(Count Of(Event Player.unvisited_nodes_distance) == 0);
					Abort;
				End;
				Event Player.now_ID = Index Of Array Value(Event Player.nodes_distance, First Of(Sorted Array(
					Event Player.unvisited_nodes_distance, Current Array Element)));
				Event Player.now = Event Player.nodes_location[Event Player.now_ID];
			End;
			Event Player.visited[Event Player.now_ID] = 1;
			Event Player.now_groups = Event Player.nodes_link[Event Player.now_ID];
			For Player Variable(Event Player, for_1, 0, Count Of(Event Player.now_groups), 1);
				If(Event Player.visited[Event Player.now_groups[Event Player.for_1]] == 0);
					Event Player.now_weight = Event Player.nodes_basic_distance[Event Player.now_ID][Event Player.for_1];
					Event Player.maybe_distance = Event Player.nodes_distance[Event Player.now_ID] + Event Player.now_weight;
					If(Event Player.maybe_distance < Event Player.nodes_distance[Event Player.now_groups[Event Player.for_1]]);
						Event Player.nodes_distance[Event Player.now_groups[Event Player.for_1]] = Event Player.maybe_distance;
						Event Player.nodes_preset_now[Event Player.now_groups[Event Player.for_1]] = Event Player.now_ID;
					End;
				End;
			End;
			If(Event Player.visited[Index Of Array Value(Event Player.nodes_location, Event Player.end)] == 1);
				Abort;
			End;
		End;
	}
}

rule("sub51 玩家初始化寻路，即将调用最短路径模块")
{
	event
	{
		Subroutine;
		Sub51;
	}

	actions
	{
		Event Player.nodes_location = Global.nodes_location;
		Event Player.nodes_link = Global.nodes_link;
		Event Player.visited = Mapped Array(Event Player.nodes_location, 0);
		Event Player.nodes_distance = Mapped Array(Event Player.nodes_location, 9999);
		Event Player.nodes_distance[Index Of Array Value(Event Player.nodes_location, Event Player.start)] = 0;
		Event Player.nodes_preset_now = Mapped Array(Event Player.nodes_location, -1);
		Event Player.is_first_iteration = True;
		Event Player.nodes_basic_distance = Global.nodes_basic_distance;
		Call Subroutine(Sub53);
		Call Subroutine(Sub54);
	}
}

rule("sub54 生成路径图")
{
	event
	{
		Subroutine;
		Sub54;
	}

	actions
	{
		Event Player.path = Empty Array;
		Event Player.current = Event Player.end;
		While(Event Player.current != Event Player.start);
			Modify Player Variable(Event Player, path, Append To Array, Event Player.current);
			Event Player.current = Event Player.nodes_location[Event Player.nodes_preset_now[Index Of Array Value(Event Player.nodes_location,
				Event Player.current)]];
		End;
		Modify Player Variable(Event Player, path, Append To Array, Event Player.start);
		Event Player.path = Sorted Array(Event Player.path, Current Array Index * -1);
		For Player Variable(Event Player, for_1, 0, Count Of(Event Player.path) - 1, 1);
			Create Beam Effect(All Players(All Teams), Grapple Beam, Event Player.path[Event Player.for_1],
				Event Player.path[Event Player.for_1 + 1], Color(Sky Blue), Visible To);
		End;
	}
}