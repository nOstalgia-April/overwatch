		If(Event Player.YiXuanTianFu[58] && Ultimate Charge Percent(Event Player) >= 30 / Event Player.YiXuanTianFu[58]);
			Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) - 30 / Event Player.YiXuanTianFu[58]);
