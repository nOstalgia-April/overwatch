					!= 100 && Event Player.MeiLiDongReng == 0);
				Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) - 10 / Event Player.YiXuanTianFu[57]);
				Set Status(Event Player, Null, Frozen, 3);
				Set Status(Event Player, Null, Invincible, 3);
				Event Player.MeiLiDongReng = 1;
