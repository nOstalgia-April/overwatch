			Start Facing(Event Player, Direction From Angles(0, 0), Absolute Value(9999999.000), To World, Direction and Turn Rate);
			Wait(0.080, Ignore Condition);
			Event Player.Backpack_orientation[0] = Horizontal Facing Angle Of(Event Player);
			Event Player.Backpack_orientation[1] = Vertical Facing Angle Of(Event Player);
			Stop Facing(Event Player);
