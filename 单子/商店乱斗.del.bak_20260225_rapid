			Apply Impulse(Players Within Radius(Event Player, (Event Player.DX[0] + Event Player.DX[1]) * 5, All Teams, Off), Up, 10, To World,
				Cancel Contrary Motion);
		End;
		"美丽动人"
		If(Event Player.YiXuanTianFu[57] && Ultimate Charge Percent(Event Player) >= 10 && Ultimate Charge Percent(Event Player) != 100);
			If(Ultimate Charge Percent(Event Player) >= 20 && Event Player.MeiLiDongReng == 1);
				Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) - 20 / Event Player.YiXuanTianFu[57]);
				Clear Status(Event Player, Frozen);
