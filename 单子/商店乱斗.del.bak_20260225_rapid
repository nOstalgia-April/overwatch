rule("受到治疗|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Player Received Healing;
		All;
		All;
	}

	actions
	{
		"治疗包"
		If(Event Was Health Pack && Event Player.YiXuanTianFu[98]);
