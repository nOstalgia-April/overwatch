		Event Player.HD[0] -= 9999 / (Event Player.HD[1] + Event Player.HD[2]);
		Skip If(Event Player.HJ[0] * (Event Player.HJ[1] + Event Player.HJ[2]) < 9999, 2);
		Add Health Pool To Player(Event Player, Armor, 9999, True, True);
		Event Player.HJ[0] -= 9999 / (Event Player.HJ[1] + Event Player.HJ[2]);
