rule("升级子程序")
{
	event
	{
		Subroutine;
		ShengJi;
	}

	actions
	{
		Event Player.DJ[0] += 1;
		Event Player.DJ[1] = 0;
		Event Player.BS += 1;
		Event Player.JND += 0.340;
		If(Array Contains(All Tank Heroes, Hero Of(Event Player)) == True);
			Event Player.JC += 10 + 5 * Event Player.DJ[0];
			Set Max Health(Event Player, Event Player.JC);
			Event Player.GJ[0] += 1 + 1 * Event Player.DJ[0];
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.SS *= 0.990;
		Else If(Array Contains(All Damage Heroes, Hero Of(Event Player)) == True);
			Event Player.GJ[0] += 2 + 1 * Event Player.DJ[0];
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.JC += 5 + 1 * Event Player.DJ[0];
			Set Max Health(Event Player, Event Player.JC);
		Else If(Array Contains(All Support Heroes, Hero Of(Event Player)) == True);
			Event Player.JC += 5 + 1.500 * Event Player.DJ[0];
			Set Max Health(Event Player, Event Player.JC);
			Event Player.GJ[0] += 1 + 1 * Event Player.DJ[0];
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.ZL[0] += 2 + 1 * Event Player.DJ[0];
			Set Healing Dealt(Event Player, (Event Player.ZL[0] + Event Player.ZL[1]) * (Event Player.ZL[2] + Event Player.ZL[3]));
		End;
		"升级咯"
		If(Event Player.YiXuanTianFu[4]);
			If(Event Player.DJ[0] == 15 && !Event Player.YiXuanTianFu[0]);
				Event Player.ShengJiLou = Event Player.YiXuanTianFu[4] + 1;
				Abort;
			End;
			Event Player.ShengJiLou -= 1;
			Wait(0.250, Ignore Condition);
			Loop If(Event Player.ShengJiLou > 0);
			Event Player.ShengJiLou = Event Player.YiXuanTianFu[4] + 1;
		End;
	}
}

