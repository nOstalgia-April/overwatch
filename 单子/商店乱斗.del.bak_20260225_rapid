					Attacker.FQ[3] -= Attacker.DianCiPao;
					Attacker.DianCiPao = 0;
				End;
			End;
		End;
		"灭"
		If(Attacker.YiXuanTianFu[16]);
			Damage(Victim, Null, Max Health(Victim) * 0.005 * Attacker.YiXuanTianFu[16]);
			If(Normalized Health(Victim) <= 0.050 * Attacker.YiXuanTianFu[16]);
				Kill(Victim, Attacker);
			End;
		End;
		"火箭飞弹"
		If(Attacker.YiXuanTianFu[110] && Event Player.DD >= 300 && Distance Between(Attacker, Victim) >= 10);
			Create Homing Projectile(Pharah Rocket, Event Player, Null, Null, To World, Damage, All Teams, 50 * Attacker.YiXuanTianFu[110], 1,
				3, Bad Explosion, Explosion Sound, 0, 5, 5, 0, Victim, 0.800);
		End;
		"生命虹吸"
		If(Attacker.YiXuanTianFu[105] > 0);
			Attacker.SM[0] += Attacker.ZL[0] * 0.100 * Absolute Value(Attacker.YiXuanTianFu[105]);
			Attacker.YiXuanTianFu[105] *= -1;
			Start Rule(ShengMingHongXi, Do Nothing);
		End;
		"连锁闪电"
		If(Attacker.YiXuanTianFu[103]);
			Damage(Remove From Array(Closest Player To(Victim, All Teams), Event Player), Attacker,
				Event Damage * 0.500 * Attacker.YiXuanTianFu[103] / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (
				Attacker.GJ[2] + Attacker.GJ[3])));
		End;
		"火箭重锤"
		If(Attacker.YiXuanTianFu[15] && Event Ability == Button(Melee));
			Set Status(Victim, Attacker, Stunned, 0.300);
		End;
		"狂战士"
		If(Attacker.YiXuanTianFu[32]);
			If(Attacker.KuangZhanShi < 0.001 * Max Health(Attacker) * Attacker.YiXuanTianFu[32] * 0.500);
				Attacker.GJ[3] += 0.001 * Max Health(Attacker) * Attacker.YiXuanTianFu[32] * 0.010;
				Set Damage Dealt(Attacker, (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3]));
				Attacker.XX[1] += 0.001 * Max Health(Attacker) * Attacker.YiXuanTianFu[32] * 0.010;
				Attacker.KuangZhanShi += 0.001 * Max Health(Attacker) * Attacker.YiXuanTianFu[32] * 0.010;
			End;
			Start Rule(KuangZhanShi, Restart Rule);
		End;
		"超电磁炮"
		If(Attacker.YiXuanTianFu[74] && Event Ability == Button(Primary Fire));
			If(Attacker.DianCiPao < Attacker.YiXuanTianFu[74]);
				Attacker.FQ[3] += Attacker.YiXuanTianFu[74] * 0.010;
				Attacker.DianCiPao += Attacker.YiXuanTianFu[74] * 0.010;
			End;
		End;
		"龙锤"
		If(Attacker.YiXuanTianFu[91] && Event Ability == Button(Primary Fire));
			Set Status(Victim, Attacker, Stunned, 0.200);
			Damage(Victim, Attacker, Max Health(Victim) * Attacker.YiXuanTianFu[91] * 0.100 * Max Health Of Type(Attacker, Armor) * 0.001 / (
				0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
		End;
		"枯萎凋零"
		If(Attacker.YiXuanTianFu[33]);
			Start Rule(KuWei, Do Nothing);
		End;
		"冰冻冲击枪"
		If(Attacker.YiXuanTianFu[34]);
			If(Victim.BingDong < 100);
				Victim.BingDong += 1;
			Else If(Victim.BingDong == 100);
				Set Status(Victim, Attacker, Frozen, 1);
				Victim.BingDong = Is Match Complete;
			End;
			Start Rule(BingDong, Do Nothing);
		End;
		"超能之球"
		If(Attacker.YiXuanTianFu[40] && Attacker.DJ[0] >= 15);
			Start Rule(ChaoNeng, Do Nothing);
		End;
		"肘击！"
		If(Attacker.YiXuanTianFu[104] && Event Ability == Button(Melee));
			Damage(Victim, Attacker, Event Damage * Attacker.YiXuanTianFu[104] / ((Attacker.GJ[0] + Attacker.GJ[1]) * (
				Attacker.GJ[2] + Attacker.GJ[3]) / 100));
		End;
		"风"
		If(Event Was Critical Hit);
			Damage(Victim, Attacker, Event Damage * Random Real(Attacker.BJ, Attacker.YiXuanTianFu[47] + Attacker.BJ) / ((
				Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3]) / 100));
		End;
		"帕拉蒂尼之牙"
		If(Attacker.YiXuanTianFu[109] && Event Ability == Button(Melee));
			Damage(Victim, Attacker, Event Damage * Random Real(Attacker.BJ, Attacker.YiXuanTianFu[109] + Attacker.BJ) / ((
				Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3]) / 100));
		End;
		"律动连打"
		If(Attacker.YiXuanTianFu[63] && Event Ability == Button(Primary Fire));
			Set Ability Cooldown(Event Player, Button(Ability 2), Ability Cooldown(Event Player, Button(Ability 2))
				- 0.500 * Attacker.YiXuanTianFu[63]);
			Set Ability Cooldown(Event Player, Button(Ability 1), Ability Cooldown(Event Player, Button(Ability 1))
				- 0.500 * Attacker.YiXuanTianFu[63]);
			Set Ability Cooldown(Event Player, Button(Secondary Fire), Ability Cooldown(Event Player, Button(Secondary Fire))
				- 0.500 * Attacker.YiXuanTianFu[63]);
		End;
		"骨刺"
		If(Attacker.YiXuanTianFu[64] && Normalized Health(Victim) <= Attacker.YiXuanTianFu[64] * Max Health Of Type(Attacker, Armor)
			* 0.005 * 0.010);
			Kill(Victim, Attacker);
		End;
		"缚能电弧"
		If(Event Player.FuNengDianHu);
			Play Effect(All Players(All Teams), Bad Explosion, Color(Blue), Victim, 1);
			Set Status(Victim, Null, Stunned, 0.200);
		End;
		"轨道镭射"
		If(Attacker.YiXuanTianFu[76]);
			Start Rule(GuiDaoSheXian, Do Nothing);
		End;
		"破甲熔钉"
		If(Attacker.YiXuanTianFu[78]);
			If(Victim.RongDing == 1);
				Damage(Victim, Null, Health Of Type(Victim, Armor) * 0.300 * Attacker.YiXuanTianFu[78] / ((Attacker.GJ[0] + Attacker.GJ[1]) * (
					Attacker.GJ[2] + Attacker.GJ[3]) / 100));
				Clear Status(Victim, Burning);
				Victim.RongDing = Is Match Complete;
			Else If(Victim.RongDing == Is Match Complete);
				Set Status(Victim, Attacker, Burning, 5);
				Victim.RongDing = 1;
			End;
		End;
		"撼地猛刺"
		If(Victim.YiXuanTianFu[39] && Is Standing(Victim));
			Start Rule(HanDi, Do Nothing);
		End;
		"猪猪存钱罐"
		If(Victim.YiXuanTianFu[68] && Event Damage > 100);
			Victim.CunQianGuan += 1 * Victim.YiXuanTianFu[68];
		End;
		"实验护盾"
		If(Victim.YiCiXinShenMing[0] > 0);
			Victim.YiCiXinShenMing[0] -= Event Damage;
		End;
		"幽灵形态"
		If(Victim.YiXuanTianFu[99] && Event Damage >= 300);
			Set Status(Victim, Null, Phased Out, Victim.YiXuanTianFu[99] * 1);
		End;
		"维生立场"
		If(Victim.YiXuanTianFu[100]);
			Heal(Victim, Victim, Event Damage * 0.200 * Victim.YiXuanTianFu[100]);
		End;
		"充能屏障"
		If(Health Of Type(Victim, Shields) == Is Match Complete && Victim.YiXuanTianFu[101]);
			Set Ultimate Charge(Victim, Ultimate Charge Percent(Event Player) + 0.030 * Max Health Of Type(Victim, Shields)
				* Victim.YiXuanTianFu[101]);
		End;
		"粒子屏障"
		If(Health Of Type(Victim, Shields) == Is Match Complete && Victim.YiXuanTianFu[109]);
			Damage(Remove From Array(Players Within Radius(Victim, (Victim.DX[0] + Victim.DX[1]) * 5, Opposite Team Of(Team Of(Victim)), Off),
				Victim), Victim, Max Health Of Type(Victim, Shields) * 0.300 * Victim.YiXuanTianFu[109] / ((Victim.GJ[0] + Victim.GJ[1]) * (
				Victim.GJ[2] + Victim.GJ[3]) / 100));
		End;
	}
}

