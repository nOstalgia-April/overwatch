			Event Player.Backpack_orientation[1] = Vertical Facing Angle Of(Event Player);
		End;
		disabled Create Dummy Bot(Hero Of(Event Player), Team Of(Event Player), 11, Global.Backpack_spot + Vector(0, 5, 6.500), Vector(1, 0, 0));
		disabled Start Forcing Player Position(Players In Slot(11, Team Of(Event Player)), Vector(0, 5, 6.500) + Global.Backpack_spot, True);
		disabled Start Forcing Dummy Bot Name(Players In Slot(11, Team Of(Event Player)), Custom String("{0}", Event Player));
