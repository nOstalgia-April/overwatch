subroutines
{
	0: func_group
	1: OpenMenu
	2: GetButtonByID
	3: CloseMenu
}

rule("Initial Global")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Global.Items = Empty Array;
		Global.TFs = Empty Array;
		Global.BaseItems = Empty Array;
		Global.RefreshDes = Custom String("消耗一枚刷新骰子\n若没有骰子则消耗一枚宝石");
		Global._extendedGlobalCollection[0] = 1;
		Global.MenuCameraSet = Array(Vector(Empty Array, 100, Empty Array), Vector(Empty Array, Empty Array, 5));
		Global._classIndexes[0] = -1;
		Global.func_group = Empty Array;
	}
}

rule("Initial Player")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	actions
	{
		Event Player.tfs = Empty Array;
		Event Player.tf_3random = Empty Array;
		Event Player.items = Empty Array;
		Event Player.items_6random = Empty Array;
		Event Player.Gold = 999;
		Event Player.Gem = 999;
		Event Player.Dice = 9;
	}
}

