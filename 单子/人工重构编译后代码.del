			"酒酿葡萄"), Custom String("获得吸血值10%的吸血值"), 1, 0), Array(23, Custom String("往复柠檬"), Custom String("获得20%技能极速"), 1, 0), Array(24,
			Custom String("流星杨桃"), Custom String("获得5点百分比移动速度"), 1, 0), Array(25, Custom String("水绿宝石"), Custom String("下次天赋选择只会出现水绿色天赋"),
			1, 0), Array(26, Custom String("传说金币"), Custom String("下次天赋选择只会出现橙色天赋"), 1, 0), Array(27, Custom String("疗愈灵花"), Custom String(
			"获得5%百分比治疗量"), 500, 1), Array(28, Custom String("实验护盾"), Custom String("500点一次性生命值"), 200, 1), Array(29, Custom String("护甲包"),
			Custom String("100点护甲"), 300, 1), Array(30, Custom String("绝招加速器"), Custom String("获得30%终极技能能量"), 500, 1), Array(31,
			Custom String("治疗新星"), Custom String("根据本局治疗量获得各种属性值"), 2, 0), Array(32, Custom String("命运魔方"), Custom String("获得一次特殊的刷新"), 2,
			0), Array(33, Custom String("小袋宝石"), Custom String("随机获得0-2枚宝石"), 500, 1), Array(34, Custom String("小袋钱币"), Custom String(
			"随机获得0-500货币"), 200, 0), Array(35, Custom String("随机天赋"), Custom String("获得一个随机的天赋"), 4, 0), Array(36, Custom String("英雄币"),
			Custom String("获得一次重新选择英雄的机会"), 1, 0), Array(37, Custom String("速射弩箭"), Custom String("获得100弹道速度"), 1, 0), Array(38,
			Custom String("光子护盾"), Custom String("获得100%额外护盾"), 2, 0));
	}
}

rule("商店界面初始化")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Global.i = 0;
		While(Global.i < Count Of(Global.BaseItems));
			Global._extendedGlobalCollection[1] = Index Of Array Value(Global._classIndexes, 0);
			Global._extendedGlobalCollection[1] = Global._extendedGlobalCollection[1] == -1 ? Count Of(Global._classIndexes)
				: Global._extendedGlobalCollection[1];
			Global._classIndexes[Global._extendedGlobalCollection[1]] = 1;
			Global.uniqueButtonID += 1;
			Global._objectVariable_1[Global._extendedGlobalCollection[1]] = Array(-3 + 2 * (Evaluate Once(Global.i) - Round To Integer(
				Evaluate Once(Global.i) / 3, Down) * 3), 2.200 + -0.700 * Round To Integer(Evaluate Once(Global.i) / 3, Down), 1.500, True,
				Array(1), Global.uniqueButtonID, Evaluate Once(Global.i));
			Modify Global Variable(Button_Pool, Append To Array, Global._extendedGlobalCollection[1]);
			Create In-World Text(Local Player.isInMenu && Array Contains(Global._objectVariable_1[Global._extendedGlobalCollection[1]][4],
				Local Player.menuactive) ? Local Player : Null, Custom String("{0}{1}", Custom String("[{0}-{1}{2}",
				Global.BaseItems[Evaluate Once(Global.i)][1], Global.BaseItems[Evaluate Once(Global.i)][3], Global.BaseItems[Evaluate Once(
				Global.i)][4] == 1 ? Custom String("货币") : Custom String("宝石")), Custom String("]\n{0}", Global.BaseItems[Evaluate Once(
				Global.i)][2])), Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * (-3 + 2 * (Evaluate Once(Global.i)
				- Round To Integer(Evaluate Once(Global.i) / 3, Down) * 3)) + Global.Menu_Base2 * (2.200 + -0.700 * Round To Integer(
				Evaluate Once(Global.i) / 3, Down))), 1.500, Do Not Clip, Visible To Position String and Color,
				Local Player.MenuLoop == Evaluate Once(Global.uniqueButtonID) ? Color(Orange) : Color(White), Default Visibility);
			Global._objectVariable_2[Global._extendedGlobalCollection[1]] = Array(1, Null);
			Global.i += 1;
		End;
		Global.i_0 = 0;
		While(Global.i_0 < 6);
			Global._extendedGlobalCollection[2] = Index Of Array Value(Global._classIndexes, 0);
			Global._extendedGlobalCollection[2] = Global._extendedGlobalCollection[2] == -1 ? Count Of(Global._classIndexes)
				: Global._extendedGlobalCollection[2];
			Global._classIndexes[Global._extendedGlobalCollection[2]] = 1;
			Global.uniqueButtonID += 1;
			Global._objectVariable_1[Global._extendedGlobalCollection[2]] = Array(-2 + 2 * (Evaluate Once(Global.i_0) - Round To Integer(
				Evaluate Once(Global.i_0) / 2, Down) * 2), -0.800 + -0.500 * Round To Integer(Evaluate Once(Global.i_0) / 2, Down), 2.300,
				True, Array(1), Global.uniqueButtonID, Evaluate Once(Global.i_0));
			Modify Global Variable(Button_Pool, Append To Array, Global._extendedGlobalCollection[2]);
			Create In-World Text(Local Player.isInMenu && Array Contains(Global._objectVariable_1[Global._extendedGlobalCollection[2]][4],
				Local Player.menuactive) ? Local Player : Null, Custom String("|{0}-{1}{2}|", Local Player.items_6random[Evaluate Once(
				Global.i_0)][1], Local Player.items_6random[Evaluate Once(Global.i_0)][3], Local Player.items_6random[Evaluate Once(Global.i_0)
				][4] == 1 ? Custom String("货币") : Custom String("宝石")), Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * (-2 + 2 * (
				Evaluate Once(Global.i_0) - Round To Integer(Evaluate Once(Global.i_0) / 2, Down) * 2)) + Global.Menu_Base2 * (
				-0.800 + -0.500 * Round To Integer(Evaluate Once(Global.i_0) / 2, Down))), 2.300, Do Not Clip,
				Visible To Position String and Color, Local Player.MenuLoop == Evaluate Once(Global.uniqueButtonID) ? Color(Orange) : Color(
				White), Default Visibility);
			Global._objectVariable_2[Global._extendedGlobalCollection[2]] = Array(2, Global._extendedGlobalCollection[2]);
			Global._objectVariable_3[Global._extendedGlobalCollection[2]] = Array(3, Null);
			Global.i_0 += 1;
		End;
		Global._extendedGlobalCollection[3] = Index Of Array Value(Global._classIndexes, 0);
		Global._extendedGlobalCollection[3] = Global._extendedGlobalCollection[3] == -1 ? Count Of(Global._classIndexes)
			: Global._extendedGlobalCollection[3];
		Global._classIndexes[Global._extendedGlobalCollection[3]] = 1;
		Global.uniqueButtonID += 1;
		Global._objectVariable_1[Global._extendedGlobalCollection[3]] = Array(3, -1.500, 4, True, Array(1), Global.uniqueButtonID, 0);
		Modify Global Variable(Button_Pool, Append To Array, Global._extendedGlobalCollection[3]);
		Create In-World Text(Local Player.isInMenu && Array Contains(Global._objectVariable_1[Global._extendedGlobalCollection[3]][4],
			Local Player.menuactive) ? Local Player : Null, Custom String("刷新"), Update Every Frame(
			Global.Menu_Center + Global.Menu_Base1 * 3 + Global.Menu_Base2 * -1.500), 4, Do Not Clip, Visible To Position String and Color,
			Local Player.MenuLoop == Evaluate Once(Global.uniqueButtonID) ? Color(Orange) : Color(White), Default Visibility);
		Global._objectVariable_2[Global._extendedGlobalCollection[3]] = Array(4, Global._extendedGlobalCollection[3]);
		Global._objectVariable_3[Global._extendedGlobalCollection[3]] = Array(5, Null);
	}
}

rule("天赋界面初始化")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Global.i_1 = 0;
		While(Global.i_1 < 3);
			Global._extendedGlobalCollection[4] = Index Of Array Value(Global._classIndexes, 0);
			Global._extendedGlobalCollection[4] = Global._extendedGlobalCollection[4] == -1 ? Count Of(Global._classIndexes)
				: Global._extendedGlobalCollection[4];
			Global._classIndexes[Global._extendedGlobalCollection[4]] = 1;
			Global.uniqueButtonID += 1;
			Global._objectVariable_1[Global._extendedGlobalCollection[4]] = Array(-3 + 3 * Evaluate Once(Global.i_1), 0.500, 4, True, Array(0),
				Global.uniqueButtonID, Evaluate Once(Global.i_1));
			Modify Global Variable(Button_Pool, Append To Array, Global._extendedGlobalCollection[4]);
			Create In-World Text(Local Player.isInMenu && Array Contains(Global._objectVariable_1[Global._extendedGlobalCollection[4]][4],
				Local Player.menuactive) ? Local Player : Null, Custom String("|{0}|", Local Player.tf_3random[Evaluate Once(Global.i_1)][1]),
				Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * (-3 + 3 * Evaluate Once(Global.i_1)) + Global.Menu_Base2 * 0.500),
				4, Do Not Clip, Visible To Position String and Color, Local Player.MenuLoop == Evaluate Once(Global.uniqueButtonID) ? Color(
				Orange) : Color(White), Default Visibility);
			Global._objectVariable_2[Global._extendedGlobalCollection[4]] = Array(6, Global._extendedGlobalCollection[4]);
			Global._objectVariable_3[Global._extendedGlobalCollection[4]] = Array(7, Null);
			Global.i_1 += 1;
		End;
		Global._extendedGlobalCollection[5] = Index Of Array Value(Global._classIndexes, 0);
		Global._extendedGlobalCollection[5] = Global._extendedGlobalCollection[5] == -1 ? Count Of(Global._classIndexes)
			: Global._extendedGlobalCollection[5];
		Global._classIndexes[Global._extendedGlobalCollection[5]] = 1;
		Global.uniqueButtonID += 1;
		Global._objectVariable_1[Global._extendedGlobalCollection[5]] = Array(0, 2, 4, False, Array(0), Global.uniqueButtonID, 0);
		Modify Global Variable(Button_Pool, Append To Array, Global._extendedGlobalCollection[5]);
		Create In-World Text(Local Player.isInMenu && Array Contains(Global._objectVariable_1[Global._extendedGlobalCollection[5]][4],
			Local Player.menuactive) ? Local Player : Null, Custom String("升级了！选择你的下个天赋"), Update Every Frame(
			Global.Menu_Center + Global.Menu_Base2 * 2), 4, Do Not Clip, Visible To Position String and Color, Color(White),
			Default Visibility);
	}
}

rule("My Player Rule")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	actions
	{
		Event Player.items_6random = Array Slice(Randomized Array(Filtered Array(Global.Items, !Array Contains(Event Player.items,
			Current Array Element))), 0, 6);
		Event Player.tf_3random = Array Slice(Randomized Array(Filtered Array(Global.TFs, !Array Contains(Event Player.tfs,
			Current Array Element))), 0, 3);
	}
}

rule("钥匙插进去了吗")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Alive(Event Player) == True;
		Event Player.isInMenu == True;
	}

	actions
	{
		Wait(0.020, Ignore Condition);
		Event Player.isButtonHovered = False;
		Event Player.bns = Filtered Array(Global.Button_Pool, Array Contains(Global._objectVariable_1[Current Array Element][4],
			Event Player.menuactive));
		Event Player.bns_withinCURSOR = Filtered Array(Event Player.bns, Absolute Value(Horizontal Angle Towards(Event Player,
			Event Player.AnchorFacing + Eye Position(Event Player)) / First Of(Global._extendedGlobalCollection) - First Of(
			Global._objectVariable_1[Current Array Element])) < First Of(
			Global._objectVariable_1[Current Array Element][2] == 1.500 ? Array(0.300, 0.200) : (
			Global._objectVariable_1[Current Array Element][2] == 2.300 ? Array(0.400, 0.300) : Array(0.700, 0.500))) && Absolute Value((
			Vertical Facing Angle Of(Event Player) - Vertical Angle From Direction(Event Player.AnchorFacing)) * -1 / First Of(
			Global._extendedGlobalCollection) - Global._objectVariable_1[Current Array Element][1]) < (
			Global._objectVariable_1[Current Array Element][2] == 1.500 ? Array(0.300, 0.200) : (
			Global._objectVariable_1[Current Array Element][2] == 2.300 ? Array(0.400, 0.300) : Array(0.700, 0.500)))[1]);
		Event Player.thebn = First Of(Sorted Array(Event Player.bns_withinCURSOR, Absolute Value(Horizontal Angle Towards(Event Player,
			Event Player.AnchorFacing + Eye Position(Event Player)) / First Of(Global._extendedGlobalCollection) - First Of(
			Global._objectVariable_1[Current Array Element])) + Absolute Value((Vertical Facing Angle Of(Event Player)
			- Vertical Angle From Direction(Event Player.AnchorFacing)) * -1 / First Of(Global._extendedGlobalCollection)
			- Global._objectVariable_1[Current Array Element][1])));
		If(!Array Contains(Array(0), Global._objectVariable_1[Event Player.thebn][5]));
			Modify Global Variable(func_group, Append To Array, Array(Global._objectVariable_3[Event Player.thebn]));
			Call Subroutine(func_group);
			Event Player.MenuLoop = Global._objectVariable_1[Event Player.thebn][5];
			Event Player.HoverVisible = Global._objectVariable_0[Event Player.thebn] != 0;
			Event Player.HoverText = Global._objectVariable_0[Event Player.thebn];
			Event Player.isButtonHovered = True;
			Event Player.HoverLineCount = 1;
			If(Event Player.HoverText == Custom String(""));
				Event Player.HoverBack = Custom String("");
				Skip(24);
			End;
			Event Player.lines = String Split(Event Player.HoverText, Custom String("\n"));
			Event Player.rowCount = Count Of(Event Player.lines);
			Event Player.colCount = 0;
			For Player Variable(Event Player, line, 0, Count Of(Event Player.lines), 1);
				If(String Length(Event Player.lines[Event Player.line]) > Event Player.colCount);
					Event Player.colCount = String Length(Event Player.lines[Event Player.line]);
				End;
			End;
			Event Player.result = Custom String("");
			Event Player.i = 0;
			While(Event Player.i < Event Player.rowCount);
				Event Player.j = 0;
				While(Event Player.j < Event Player.colCount);
					Event Player.result = Custom String("{0}{1}", Event Player.result, Custom String("="));
					Event Player.j += 1;
				End;
				If(Event Player.i < Event Player.rowCount - 1);
					Event Player.result = Custom String("{0}{1}", Event Player.result, Custom String("\n"));
					Event Player.HoverLineCount += 1;
				End;
				Event Player.i += 1;
			End;
			Event Player.HoverBack = Event Player.result;
		End;
		If(!Event Player.isButtonHovered);
			Event Player.MenuLoop = 0;
			Event Player.HoverVisible = False;
			Event Player.HoverText = Custom String("");
		End;
		Loop If Condition Is True;
	}
}

rule("指针初始化")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Create In-World Text(Local Player.isInMenu ? Local Player : Null, Input Binding String(Button(Primary Fire)), Update Every Frame(
			Global.Menu_Center + Global.Menu_Base1 * (Horizontal Angle Towards(Local Player, Local Player.AnchorFacing + Eye Position(
			Local Player)) / First Of(Global._extendedGlobalCollection)) + Global.Menu_Base2 * ((Vertical Facing Angle Of(Local Player)
			- Vertical Angle From Direction(Local Player.AnchorFacing)) * -1 / First Of(Global._extendedGlobalCollection))), 1.800,
			Do Not Clip, Visible To Position String and Color, Color(White), Default Visibility);
	}
}

rule("sub打开菜单")
{
	event
	{
		Subroutine;
		OpenMenu;
	}

	actions
	{
		Start Camera(Event Player, First Of(Global.MenuCameraSet), Global.MenuCameraSet[1], 200);
		Global._extendedGlobalCollection[6].menuactive = Global.name;
		If(!Global._extendedGlobalCollection[6].isInMenu);
			Set Facing(Global._extendedGlobalCollection[6], Forward, To Player);
			Global._extendedGlobalCollection[6].AnchorFacing = Facing Direction Of(Global._extendedGlobalCollection[6]);
			Global._extendedGlobalCollection[6].isInMenu = True;
			Set Aim Speed(Global._extendedGlobalCollection[6], 0.100);
			Set Primary Fire Enabled(Global._extendedGlobalCollection[6], False);
			Set Secondary Fire Enabled(Global._extendedGlobalCollection[6], False);
			Disable Hero HUD(Global._extendedGlobalCollection[6]);
			Disable Game Mode HUD(Global._extendedGlobalCollection[6]);
		End;
		Skip(Array(0, 0)[Index Of Array Value(Array(0), Global.name) + 1]);
		Set Facing(Global._extendedGlobalCollection[6], Global._extendedGlobalCollection[6].AnchorFacing, To World);
	}
}

rule("My Player Rule")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Interact)) == True;
	}

	actions
	{
		Create HUD Text(All Players(All Teams), Event Player.MenuLoop, Null, Null, Left, 0, Color(White), Color(White), Color(White),
			Visible To and String, Default Visibility);
		Global.name = 0;
		Global._extendedGlobalCollection[6] = Event Player;
		Call Subroutine(OpenMenu);
	}
}

rule("初始化菜单向量")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Global.menuEye = First Of(Global.MenuCameraSet);
		Global.menuLookat = Global.MenuCameraSet[1];
		Global.menuDir = Direction Towards(Global.menuEye, Global.menuLookat);
		Global.Menu_Center = Global.menuEye + Global.menuDir;
		Global.Menu_Base1 = -0.250 * Normalize(Cross Product(Up, Global.menuDir));
		Global.Menu_Base2 = -0.250 * Normalize(Cross Product(Global.menuDir, Global.Menu_Base1));
	}
}

rule("sub根据ID获取按钮")
{
	event
	{
		Subroutine;
		GetButtonByID;
	}

	actions
	{
		Global._extendedGlobalCollection[7] = 0;
		While(Global._extendedGlobalCollection[7] < Count Of(Filtered Array(Global.Button_Pool, Array Contains(
			Global._objectVariable_1[Current Array Element][4], Event Player.menuactive))));
			If(Global.id == Global._objectVariable_1[Filtered Array(Global.Button_Pool, Array Contains(
				Global._objectVariable_1[Current Array Element][4], Event Player.menuactive))[Global._extendedGlobalCollection[7]]][5]);
				Global.returnValue_GetButtonByID = Filtered Array(Global.Button_Pool, Array Contains(
					Global._objectVariable_1[Current Array Element][4], Event Player.menuactive))[Global._extendedGlobalCollection[7]];
				Skip(4);
			End;
			Global._extendedGlobalCollection[7] += 1;
		End;
		Wait(0.016, Ignore Condition);
	}
}

rule("按钮点击")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		(Event Player.isInMenu && Is Button Held(Event Player, Button(Primary Fire))) == True;
	}

	actions
	{
		Global.id = Event Player.MenuLoop;
		Call Subroutine(GetButtonByID);
		If(Event Player.MenuLoop != 0 && Global._objectVariable_1[Global.returnValue_GetButtonByID][3]);
			Global.id = Event Player.MenuLoop;
			Call Subroutine(GetButtonByID);
			Modify Global Variable(func_group, Append To Array, Array(Global._objectVariable_2[Global.returnValue_GetButtonByID]));
			Call Subroutine(func_group);
		End;
	}
}

rule("悬停文本初始化")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Global._extendedGlobalCollection[8] = -0.200;
		Create In-World Text(Local Player.isInMenu && Local Player.HoverVisible ? Local Player : Null, Local Player.HoverBack,
			Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * (Horizontal Angle Towards(Local Player,
			Local Player.AnchorFacing + Eye Position(Local Player)) / First Of(Global._extendedGlobalCollection)) + Global.Menu_Base2 * ((
			Vertical Facing Angle Of(Local Player) - Vertical Angle From Direction(Local Player.AnchorFacing)) * -1 / First Of(
			Global._extendedGlobalCollection) + Global._extendedGlobalCollection[8] * Local Player.HoverLineCount)), 3, Do Not Clip,
			Visible To Position String and Color, Color(Black), Default Visibility);
		Create In-World Text(Local Player.isInMenu && Local Player.HoverVisible ? Local Player : Null, Local Player.HoverText,
			Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * (Horizontal Angle Towards(Local Player,
			Local Player.AnchorFacing + Eye Position(Local Player)) / First Of(Global._extendedGlobalCollection)) + Global.Menu_Base2 * ((
			Vertical Facing Angle Of(Local Player) - Vertical Angle From Direction(Local Player.AnchorFacing)) * -1 / First Of(
			Global._extendedGlobalCollection) + Global._extendedGlobalCollection[8] * Local Player.HoverLineCount)), 1.500, Do Not Clip,
			Visible To Position String and Color, Color(Yellow), Default Visibility);
	}
}

rule("My Rule")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Create HUD Text(All Players(All Teams), Is Button Held(Local Player, Button(Primary Fire)), Null, Null, Left, 0, Color(White),
			Color(White), Color(White), Visible To and String, Default Visibility);
	}
}

rule("关闭菜单")
{
	event
	{
		Subroutine;
		CloseMenu;
	}

	actions
	{
		Event Player.isInMenu = False;
		Stop Camera(Event Player);
		Set Aim Speed(Event Player, 100);
		Set Primary Fire Enabled(Event Player, True);
		Set Secondary Fire Enabled(Event Player, True);
		Enable Hero HUD(Event Player);
		Enable Game Mode HUD(Event Player);
		Set Facing(Event Player, Event Player.AnchorFacing, To World);
		Wait(0.016, Ignore Condition);
	}
}

rule("lambda")
{
	event
	{
		Subroutine;
		func_group;
	}

	actions
	{
		Skip(Array(35, 0, 2, 17, 19, 27, 29, 34)[Index Of Array Value(Array(1, 2, 3, 4, 5, 6, 7), First Of(Last Of(Global.func_group)))
			+ 1]);
		Small Message(All Players(All Teams), Global._objectVariable_1[Global.Button_Pool[Event Player.MenuLoop]][6]);
		Skip(33);
		Global.selected = Event Player.items_6random[Global._objectVariable_1[Global.Button_Pool[Event Player.MenuLoop]][6]];
		If(Global.selected[4] == 1 && Event Player.Gold < Global.selected[3]);
			Skip(30);
		End;
		If(Global.selected[4] == 0 && Event Player.Gem < Global.selected[3]);
			Skip(27);
		End;
		If(Global.selected[4] == 1);
			Event Player.Gold -= Global.selected[3];
		Else;
			Event Player.Gem -= Global.selected[3];
		End;
		Modify Player Variable(Event Player, items, Append To Array, Array(Global.selected));
		Event Player.items_6random = Array Slice(Randomized Array(Filtered Array(Global.Items, !Array Contains(Event Player.items,
			Current Array Element))), 0, 6);
		Skip(18);
		Global._objectVariable_0[Global.Button_Pool[Event Player.MenuLoop]] = Event Player.items_6random[Global._objectVariable_1[Global.Button_Pool[Event Player.MenuLoop]][6]][2];
		Skip(16);
		If(Event Player.Dice > 0);
			Event Player.Dice -= 1;
			Event Player.items_6random = Array Slice(Randomized Array(Filtered Array(Global.Items, !Array Contains(Event Player.items,
				Current Array Element))), 0, 6);
		Else If(Event Player.Gem > 0);
			Event Player.Gem -= 1;
			Event Player.items_6random = Array Slice(Randomized Array(Filtered Array(Global.Items, !Array Contains(Event Player.items,
				Current Array Element))), 0, 6);
		End;
		Skip(8);
		Global._objectVariable_0[Global.Button_Pool[Event Player.MenuLoop]] = Global.RefreshDes;
		Skip(6);
		Global.selected_0 = Event Player.tf_3random[Global._objectVariable_1[Global.Button_Pool[Event Player.MenuLoop]][6]];
		Modify Player Variable(Event Player, tfs, Append To Array, Array(Global.selected_0));
		Small Message(All Players(All Teams), Custom String("{0}{1}", Custom String("已获取"), Global.selected_0[1]));
		Event Player.menuactive = 1;
		Skip(1);
		Global._objectVariable_0[Global.Button_Pool[Event Player.MenuLoop]] = Event Player.tf_3random[Global._objectVariable_1[Global.Button_Pool[Event Player.MenuLoop]][6]][2];
		Modify Global Variable(func_group, Remove From Array By Index, Count Of(Global.func_group) - 1);
	}
}