import '地图文本菜单.del';
single struct Item {
    public Number ID;
    public String Name;
    public String Des;
    public Number Price;
    public PriceType PriceType;
}
single struct TF {
    public Number ID;
    public String Name;
    public String Des;
}

enum PriceType{
    Gem,
    Gold
}

globalvar Item[] Items = [];
globalvar TF[] TFs = [];
globalvar Item[] BaseItems = [];

