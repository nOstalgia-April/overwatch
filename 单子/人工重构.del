void BaseItemButtonsInit(){
    define start_x : -3;
    define start_y : 2.2;
    define x_gap : 2;
    define y_gap : -0.7;

    for(Number i = 0; i < BaseItems.Length; i++){
        define row : (EvaluateOnce(i) / 3).Floor();
        define col : EvaluateOnce(i) - row * 3;
        define x : start_x + x_gap * col;
        define y : start_y + y_gap * row;
        new MenuButton(
            header: <'[<0>-<1><2>]\n<3>',BaseItems[EvaluateOnce(i)].Name,BaseItems[EvaluateOnce(i)].Price,StringByPriceType(BaseItems[EvaluateOnce(i)].PriceType),BaseItems[EvaluateOnce(i)].Des>,
            posX: x,
            posY: y,
            scale: ButtonScale.Small,
            ShowColor: InteratableColor_Local(),
            interactable: true,
            ofmenuActives: [MenuActive.ShopMenu],
            _p: EvaluateOnce(i)
        ).SetOnClick(()=>BaseItemPurchase());
    }
}

void ItemButtonsInit(){
    define start_x : -2;
    define start_y : -0.8;
    define x_gap : 2;
    define y_gap : -0.5;

    for(Number i = 0; i < 6; i++){
        define row : (EvaluateOnce(i) / 2).Floor();
        define col : EvaluateOnce(i) - row * 2;
        define x : start_x + x_gap * col;
        define y : start_y + y_gap * row;
        new MenuButton(
            header: <'|<0>-<1><2>|',
            LocalPlayer().items_6random[EvaluateOnce(i)].Name,
            LocalPlayer().items_6random[EvaluateOnce(i)].Price,
            StringByPriceType(LocalPlayer().items_6random[EvaluateOnce(i)].PriceType)>,
            posX: x,
            posY: y,
            scale: ButtonScale.Medium,
            ShowColor: InteratableColor_Local(),
            interactable: true,
            ofmenuActives: [MenuActive.ShopMenu],
            _p: EvaluateOnce(i)
        ).SetOnClick(ItemPurchase).SetOnHover(()=>{
            Button_Pool[MenuLoop].HoverLabel = items_6random[GetParameter()].Des;
        });
    }
}
globalvar String RefreshDes = '消耗一枚刷新骰子\n若没有骰子则消耗一枚宝石';
void ShopRefreshButton(){
    new MenuButton(
        header: "刷新",
        posX: 3,
        posY: -1.5,
        scale: ButtonScale.Large,
        ShowColor: InteratableColor_Local(),
        interactable: true,
        ofmenuActives: [MenuActive.ShopMenu]
    ).SetOnClick(ShopRefresh).SetOnHover(()=>{
        Button_Pool[MenuLoop].HoverLabel = RefreshDes;
    });
}

void TFRefreshButton(){
    new MenuButton(
        header: "刷新",
        posX: 3,
        posY: -1.5,
        scale: ButtonScale.Large,
        ShowColor: InteratableColor_Local(),
        interactable: true,
        ofmenuActives: [MenuActive.ShopMenu]
    ).SetOnClick(ShopRefresh).SetOnHover(()=>{
        Button_Pool[MenuLoop].HoverLabel = RefreshDes;
    });
}

void TFButtonInit(){
    define start_x : -3;
    define x_gap : 3;
    define offset : -0.5;
    for(define i = 0; i<3;i++){
        new MenuButton(
            header: <"|<0>|",LocalPlayer().tf_3random[EvaluateOnce(i)].Name>,
            posX: start_x + x_gap * EvaluateOnce(i),
            posY: 0.5,
            scale: ButtonScale.Large,
            ShowColor: InteratableColor_Local(),
            interactable: true,
            ofmenuActives: [MenuActive.TFMenu],
            _p: EvaluateOnce(i)
        ).SetOnClick(TFSelect).SetOnHover(()=>{
            Button_Pool[MenuLoop].HoverLabel = tf_3random[GetParameter()].Des;
        });
    }
    new MenuButton(
        header: "升级了！选择你的下个天赋",
        posX: 0,
        posY: 2,
        scale: ButtonScale.Large,
        ShowColor: Color.White,
        interactable: false,
        ofmenuActives: [MenuActive.TFMenu]
    );
}

rule: '商店界面初始化'
{
    BaseItemButtonsInit();
    ItemButtonsInit();
    ShopRefreshButton();
}

rule: '天赋界面初始化'
{
    TFButtonInit();
}

String StringByPriceType(in PriceType type){
    return type == PriceType.Gold ? "货币" : "宝石";
}

void BaseItemPurchase(){
    SmallMessage(Header: GetParameter());
}


void ItemPurchase(){
    Item selected = items_6random[GetParameter()];
    if(selected.PriceType == PriceType.Gold && Gold < selected.Price)return;
    if(selected.PriceType == PriceType.Gem && Gem < selected.Price)return;
    if(selected.PriceType == PriceType.Gold){
        Gold -= selected.Price;
    }else{
        Gem -= selected.Price;
    }
    items.ModAppend(selected);
    Random6Items();
}

void TFSelect(){
    TF selected = tf_3random[GetParameter()];
    tfs.ModAppend(selected);
    SmallMessage(Header: '已获取'+selected.Name);
    menuactive = MenuActive.ShopMenu;
}

Number GetParameter(){
    return Button_Pool[MenuLoop].Data._P;
}

void Random6Items(){
    items_6random = Items.Filter(t=>!items.Contains(t)).Randomize().Slice(0,6);
}
void Random3TFs(){
    tf_3random = TFs.Filter(t=>!tfs.Contains(t)).Randomize().Slice(0,3);
}

void ShopRefresh(){
    if (Dice>0){
        Dice -= 1;
        Random6Items();
    }else if(Gem>0){
        Gem -= 1;
        Random6Items();
    }
}
playervar Number Gold = 999;
playervar Number Gem = 999;
playervar Number Dice = 9;  
rule: 'My Player Rule'
Event.OngoingPlayer
Team.All
Player.All
{
    Random6Items();
    Random3TFs();
}

void CloseMenu()'关闭菜单'{
    isInMenu = false;
    StopCamera();
    SetAimSpeed(EventPlayer(),100);
    SetPrimaryFireEnabled(EventPlayer(),true);
    SetSecondaryFireEnabled(EventPlayer(),true);
    EnableHeroHud(EventPlayer());
    EnableGameModeHud(EventPlayer());
    SetFacing(EventPlayer(),AnchorFacing);
    MinWait();
}