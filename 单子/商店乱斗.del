rule("猪神")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Normalized Health(Event Player) <= 0.700;
	}

	actions
	{
		"猪神"
		If(Event Player.YiXuanTianFu[20] > 0);
			Event Player.DX[1] += Absolute Value(Event Player.YiXuanTianFu[20]);
			Start Scaling Player(Event Player, Event Player.DX[0] + Event Player.DX[1], True);
			Wait Until(Normalized Health(Event Player) <= 0.500, 99999);
			Stop Scaling Player(Event Player);
			Event Player.DX[1] += Absolute Value(Event Player.YiXuanTianFu[20]);
			Start Scaling Player(Event Player, Event Player.DX[0] + Event Player.DX[1], True);
			Wait Until(Normalized Health(Event Player) <= 0.300, 99999);
			Stop Scaling Player(Event Player);
			Event Player.DX[1] += 4 * Absolute Value(Event Player.YiXuanTianFu[20]);
			Start Scaling Player(Event Player, Event Player.DX[0] + Event Player.DX[1], True);
			Heal(Event Player, Null, 1000000);
			Event Player.YiXuanTianFu[20] *= -1;
			Big Message(All Players(All Teams), Custom String("猪神降临！"));
			Wait Until(Is Dead(Event Player), 99999);
			Stop Scaling Player(Event Player);
			Event Player.DX[1] = 0;
			Start Scaling Player(Event Player, Event Player.DX[0] + Event Player.DX[1], True);
			Wait Until(Is Alive(Event Player), 99999);
			Event Player.YiXuanTianFu[20] *= -1;
	}
}

