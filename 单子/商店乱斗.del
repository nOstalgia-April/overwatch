rule("高级商店随机获取物品子程序")
{
	event
	{
		Subroutine;
		ShangPingShuaXin;
	}

	actions
	{
		If(Count Of(Event Player.ShangPing) == 0);
			Event Player.ShangPing = Array Slice(Mapped Array(Global.Items, First Of(Current Array Element)), 0, 39);
		End;
		If(Event Player.MingYunMoFang >= 1);
			Event Player.MingYunMoFang -= 1;
			Event Player.MenuRngId = Random Integer(1, 6);
			If(Event Player.MenuRngId == 1);
				Event Player.Shop6Items = Array(8, 9, 10, 11, 12, 13);
			Else If(Event Player.MenuRngId == 2);
				Event Player.Shop6Items = Array(18, 18, 18, 14, 15, 19);
			Else If(Event Player.MenuRngId == 3);
				Event Player.Shop6Items = Array(0, 1, 21, 22, 23, 24);
			Else If(Event Player.MenuRngId == 4);
				Event Player.Shop6Items = Array(39, 39, 39, 39, 39, 39);
			Else If(Event Player.MenuRngId == 5);
				Event Player.Shop6Items = Array(33, 33, 33, 33, 33, 33);
			Else If(Event Player.MenuRngId == 6);
				Event Player.Shop6Items = Array(35, 35, 35, 35, 35, 35);
			End;
		Else;
			Event Player.Shop6Items = Empty Array;
			While(Count Of(Event Player.Shop6Items) < 6);
				Event Player.MenuRngId = Random Value In Array(Event Player.ShangPing);
				Modify Player Variable(Event Player, Shop6Items, Append To Array, Event Player.MenuRngId);
			End;
		End;
		Event Player.items_6random = Event Player.Shop6Items;
	}
}

