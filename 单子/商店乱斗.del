rule("sub购买基础商店按钮")
{
	event
	{
		Subroutine;
		BuyBaseItemByButton;
	}

	actions
	{
		If(Event Player.Backpack_hitButton < 0 || Event Player.Backpack_hitButton >= Count Of(Global.BaseItems));
			Abort;
		End;
		If(Event Player.M < Global.BaseItems[Event Player.Backpack_hitButton][3]);
			Abort;
		End;
		Event Player.M -= Global.BaseItems[Event Player.Backpack_hitButton][3];
		If(Event Player.Backpack_hitButton == 0);
			Event Player.GJ[0] += Random Integer(1, 5);
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
		Else If(Event Player.Backpack_hitButton == 1);
			Event Player.FQ[2] += Random Integer(1, 5) * 0.010;
		Else If(Event Player.Backpack_hitButton == 2);
			Skip If(Event Player.SM[3] != 0, 2);
			Add Health Pool To Player(Event Player, Health, Event Player.SM[0] * (Event Player.SM[1] + Event Player.SM[2]), True, True);
			Event Player.SM[3] = Last Created Health Pool;
			Event Player.SM[0] += Random Integer(10, 100);
		Else If(Event Player.Backpack_hitButton == 3);
			Skip If(Event Player.HD[3] != 0, 2);
			Add Health Pool To Player(Event Player, Shields, Event Player.HD[0] * (Event Player.HD[1] + Event Player.HD[2]), True, True);
			Event Player.HD[3] = Last Created Health Pool;
			Event Player.HD[0] += Random Integer(20, 80);
		Else If(Event Player.Backpack_hitButton == 4);
			Skip If(Event Player.HJ[3] != 0, 2);
			Add Health Pool To Player(Event Player, Armor, Event Player.HJ[0] * (Event Player.HJ[1] + Event Player.HJ[2]), True, True);
			Event Player.HJ[3] = Last Created Health Pool;
			Event Player.HJ[0] += Random Integer(20, 60);
			Event Player.M += 100 * Event Player.YiXuanTianFu[107];
		Else If(Event Player.Backpack_hitButton == 5);
			Event Player.CD += Random Integer(1, 2) * 0.020;
		Else If(Event Player.Backpack_hitButton == 6);
			Event Player.ZL[0] += Random Integer(2, 6);
			Set Healing Dealt(Event Player, (Event Player.ZL[0] + Event Player.ZL[1]) * (Event Player.ZL[2] + Event Player.ZL[3]));
		Else If(Event Player.Backpack_hitButton == 7);
			Event Player.YS[0] += Random Integer(1, 5);
			Set Move Speed(Event Player, (Event Player.YS[0] + Event Player.YS[1]) * (Event Player.YS[2] + Event Player.YS[3]));
		Else If(Event Player.Backpack_hitButton == 8);
			Event Player.XX[0] += Random Integer(1, 3) * 0.010;
		Else If(Event Player.Backpack_hitButton == 9);
			Event Player.JT += Random Integer(5, 10);
			Set Knockback Dealt(Event Player, Event Player.JT);
		Else If(Event Player.Backpack_hitButton == 10);
			Event Player.BS += 1;
		End;
	}
}

rule("菜单系统初始化")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Global._objectVariable_0 = Empty Array;
		Global._objectVariable_1 = Empty Array;
		Global._objectVariable_2 = Empty Array;
		Global._objectVariable_3 = Empty Array;
		Global.Button_Pool = Empty Array;
		Global.func_group = Empty Array;
		Global.uniqueButtonID = 0;
		Global.RefreshDes = Custom String("消耗一枚刷新骰子\n若没有骰子则消耗一枚宝石");
		Global.Backpack_spot = Vector(0, 5, 0);
		Global.MenuCameraSet = Array(Vector(6.750, 4, 0) + Global.Backpack_spot, Vector(0, 4, 0) + Global.Backpack_spot);
		Global._extendedGlobalCollection[0] = 1;
		Global.menuEye = First Of(Global.MenuCameraSet);
		Global.menuLookat = Global.MenuCameraSet[1];
		Global.menuDir = Direction Towards(Global.menuEye, Global.menuLookat);
		Global.Menu_Center = Global.menuEye + Global.menuDir;
		Global.Menu_Base1 = -0.250 * Normalize(Cross Product(Up, Global.menuDir));
		Global.Menu_Base2 = -0.250 * Normalize(Cross Product(Global.menuDir, Global.Menu_Base1));
		Wait Until(Count Of(Global.BaseItems) > 0 && Count Of(Global.Items) > 0 && Count Of(Global.TFs) > 0, 99999);
		Global.i = 0;
		While(Global.i < Count Of(Global.BaseItems));
			Global.uniqueButtonID += 1;
			Global._objectVariable_1[Global.i] = Array(-3 + 2 * (Evaluate Once(Global.i) - Round To Integer(Evaluate Once(Global.i) / 3,
				Down) * 3), 2.200 + -0.700 * Round To Integer(Evaluate Once(Global.i) / 3, Down), 1.500, True, Array(1),
				Global.uniqueButtonID, Evaluate Once(Global.i));
			Global._objectVariable_2[Global.i] = Array(1, Evaluate Once(Global.i));
			Global._objectVariable_3[Global.i] = Array(0, 0);
			Global._objectVariable_0[Global.i] = Custom String("");
			Modify Global Variable(Button_Pool, Append To Array, Global.i);
			Create In-World Text(Local Player.isInMenu && Array Contains(Global._objectVariable_1[Evaluate Once(Global.i)][4],
				Local Player.menuactive) ? Local Player : Null, Custom String("{0}{1}", Custom String("[{0}-{1}{2}", Global.BaseItems[
				Evaluate Once(Global.i)][1], Global.BaseItems[Evaluate Once(Global.i)][3], Global.BaseItems[Evaluate Once(Global.i)][4] == 1
				? Custom String("货币") : Custom String("宝石")), Custom String("]\n{0}", Global.BaseItems[Evaluate Once(Global.i)][2])),
				Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * First Of(Global._objectVariable_1[Evaluate Once(Global.i)])
				+ Global.Menu_Base2 * Global._objectVariable_1[Evaluate Once(Global.i)][1]), Global._objectVariable_1[Evaluate Once(Global.i)][2],
				Do Not Clip, Visible To Position String and Color, Local Player.MenuLoop == Global._objectVariable_1[Evaluate Once(Global.i)][5]
				? Color(Orange) : Color(White), Default Visibility);
			Global.i += 1;
		End;
		Global.i_0 = 0;
		While(Global.i_0 < 6);
			Global.id = 11 + Evaluate Once(Global.i_0);
			Global.uniqueButtonID += 1;
			Global._objectVariable_1[Global.id] = Array(-2 + 2 * (Evaluate Once(Global.i_0) - Round To Integer(Evaluate Once(Global.i_0) / 2,
				Down) * 2), -0.800 + -0.500 * Round To Integer(Evaluate Once(Global.i_0) / 2, Down), 2.300, True, Array(1),
				Global.uniqueButtonID, Evaluate Once(Global.i_0));
			Global._objectVariable_2[Global.id] = Array(2, Evaluate Once(Global.i_0));
			Global._objectVariable_3[Global.id] = Array(0, 0);
			Global._objectVariable_0[Global.id] = Custom String("");
			Modify Global Variable(Button_Pool, Append To Array, Global.id);
			Create In-World Text(Local Player.isInMenu && Array Contains(Global._objectVariable_1[Evaluate Once(Global.id)][4],
				Local Player.menuactive) ? Local Player : Null, Count Of(Local Player.Shop6Items) > Evaluate Once(Global.i_0) ? Custom String(
				"|{0}-{1}{2}|", Global.Items[Local Player.Shop6Items[Evaluate Once(Global.i_0)]][1], Global.Items[Local Player.Shop6Items[
				Evaluate Once(Global.i_0)]][3], Global.Items[Local Player.Shop6Items[Evaluate Once(Global.i_0)]][4] == 1 ? Custom String(
				"货币") : Custom String("宝石")) : Custom String("|---|"), Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * First Of(
				Global._objectVariable_1[Evaluate Once(Global.id)]) + Global.Menu_Base2 * Global._objectVariable_1[Evaluate Once(Global.id)][1]),
				Global._objectVariable_1[Evaluate Once(Global.id)][2], Do Not Clip, Visible To Position String and Color,
				Local Player.MenuLoop == Global._objectVariable_1[Evaluate Once(Global.id)][5] ? Color(Orange) : Color(White),
				Default Visibility);
			Global.i_0 += 1;
		End;
		Global.uniqueButtonID += 1;
		Global._objectVariable_1[20] = Array(3, -1.500, 4, True, Array(1), Global.uniqueButtonID, 20);
		Global._objectVariable_2[20] = Array(3, 20);
		Global._objectVariable_3[20] = Array(0, 0);
		Global._objectVariable_0[20] = Global.RefreshDes;
		Modify Global Variable(Button_Pool, Append To Array, 20);
		Create In-World Text(Local Player.isInMenu && Array Contains(Global._objectVariable_1[20][4], Local Player.menuactive) ? Local Player
			: Null, Custom String("刷新"), Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * 3 + Global.Menu_Base2 * -1.500), 4,
			Do Not Clip, Visible To Position String and Color, Local Player.MenuLoop == Global._objectVariable_1[20][5] ? Color(Orange)
			: Color(White), Default Visibility);
		Global.uniqueButtonID += 1;
		Global._objectVariable_1[21] = Array(0, -1.500, 4, True, Array(0), Global.uniqueButtonID, 21);
		Global._objectVariable_2[21] = Array(3, 21);
		Global._objectVariable_3[21] = Array(0, 0);
		Global._objectVariable_0[21] = Global.RefreshDes;
		Modify Global Variable(Button_Pool, Append To Array, 21);
		Create In-World Text(Local Player.isInMenu && Array Contains(Global._objectVariable_1[21][4], Local Player.menuactive) ? Local Player
			: Null, Custom String("刷新"), Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * 0 + Global.Menu_Base2 * -1.500), 4,
			Do Not Clip, Visible To Position String and Color, Local Player.MenuLoop == Global._objectVariable_1[21][5] ? Color(Orange)
			: Color(White), Default Visibility);
		Global.i_1 = 0;
		While(Global.i_1 < 3);
			Global.id = 17 + Evaluate Once(Global.i_1);
			Global.uniqueButtonID += 1;
			Global._objectVariable_1[Global.id] = Array(-3 + 3 * Evaluate Once(Global.i_1), 0.500, 4, True, Array(0), Global.uniqueButtonID,
				Evaluate Once(Global.i_1));
			Global._objectVariable_2[Global.id] = Array(4, Evaluate Once(Global.i_1));
			Global._objectVariable_3[Global.id] = Array(0, 0);
			Global._objectVariable_0[Global.id] = Custom String("");
			Modify Global Variable(Button_Pool, Append To Array, Global.id);
			Create In-World Text(Local Player.isInMenu && Array Contains(Global._objectVariable_1[Evaluate Once(Global.id)][4],
				Local Player.menuactive) ? Local Player : Null, Custom String("|{0}|", Local Player.tf_3random[Evaluate Once(Global.i_1)][1]),
				Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * First Of(Global._objectVariable_1[Evaluate Once(Global.id)])
				+ Global.Menu_Base2 * Global._objectVariable_1[Evaluate Once(Global.id)][1]),
				Global._objectVariable_1[Evaluate Once(Global.id)][2], Do Not Clip, Visible To Position String and Color,
				Local Player.MenuLoop == Global._objectVariable_1[Evaluate Once(Global.id)][5] ? Color(Orange) : Color(White),
				Default Visibility);
			Global.i_1 += 1;
		End;
		Global._objectVariable_1[22] = Array(0, 2, 4, False, Array(0), 0, 22);
		Global._objectVariable_2[22] = Array(0, 22);
		Global._objectVariable_3[22] = Array(0, 0);
		Global._objectVariable_0[22] = Custom String("");
		Modify Global Variable(Button_Pool, Append To Array, 22);
		Create In-World Text(Local Player.isInMenu && Array Contains(Global._objectVariable_1[22][4], Local Player.menuactive) ? Local Player
			: Null, Custom String("升级了！选择你的下个天赋"), Update Every Frame(Global.Menu_Center + Global.Menu_Base2 * 2), 4, Do Not Clip,
			Visible To Position String and Color, Color(White), Default Visibility);
	}
}

rule("菜单玩家初始化")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	actions
	{
		Wait Until(Count Of(Global.Items) > 0 && Count Of(Global.TFs) > 0, 99999);
		Event Player.isInMenu = False;
		Event Player.menuactive = 1;
		Event Player.MenuLoop = 0;
		Event Player.HoverVisible = False;
		Event Player.HoverText = Custom String("");
		Event Player.HoverBack = Custom String("");
		Event Player.Backpack_open[1] = 0;
		Event Player.tfs = Empty Array;
		Event Player.tf_3random = Empty Array;
		Event Player.items = Empty Array;
		Event Player.items_6random = Empty Array;
		Event Player.Shop6Items = Empty Array;
		Call Subroutine(ShangPingShuaXin);
		Call Subroutine(TianFuShuaXin);
	}
}

rule("菜单喷漆开关")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Alive(Event Player) == True;
		Is Communicating Any Spray(Event Player) == True;
		Event Player.isInMenu == False;
	}

	actions
	{
		If(Event Player.Backpack_open[1]);
			Abort;
		End;
		Event Player.Backpack_open[1] = 1;
		If(Event Player.JND >= 1);
			Event Player.Backpack_open[0] = 2;
			Event Player.menuactive = 0;
		Else;
			Event Player.Backpack_open[0] = 1;
			Event Player.menuactive = 1;
		End;
		Global.name = Event Player.menuactive;
		Global._extendedGlobalCollection[6] = Event Player;
		Call Subroutine(OpenMenu);
		Event Player.Backpack_open[1] = 0;
		Wait Until(Is Communicating Any Spray(Event Player) == False, 99999);
		Wait Until(Is Communicating Any Spray(Event Player) == True, 99999);
		Call Subroutine(CloseMenu);
		Event Player.Backpack_open[0] = 0;
	}
}

rule("菜单悬停检测")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Alive(Event Player) == True;
		Event Player.isInMenu == True;
	}

	actions
	{
		Wait(0.020, Ignore Condition);
		Event Player.isButtonHovered = False;
		Event Player.bns = Filtered Array(Global.Button_Pool, Array Contains(Global._objectVariable_1[Current Array Element][4],
			Event Player.menuactive));
		Event Player.bns_withinCURSOR = Filtered Array(Event Player.bns, Absolute Value(Horizontal Angle Towards(Event Player,
			Event Player.AnchorFacing + Eye Position(Event Player)) / First Of(Global._extendedGlobalCollection) - First Of(
			Global._objectVariable_1[Current Array Element])) < First Of(
			Global._objectVariable_1[Current Array Element][2] == 1.500 ? Array(0.300, 0.200) : (
			Global._objectVariable_1[Current Array Element][2] == 2.300 ? Array(0.400, 0.300) : Array(0.700, 0.500))) && Absolute Value((
			Vertical Facing Angle Of(Event Player) - Vertical Angle From Direction(Event Player.AnchorFacing)) * -1 / First Of(
			Global._extendedGlobalCollection) - Global._objectVariable_1[Current Array Element][1]) < (
			Global._objectVariable_1[Current Array Element][2] == 1.500 ? Array(0.300, 0.200) : (
			Global._objectVariable_1[Current Array Element][2] == 2.300 ? Array(0.400, 0.300) : Array(0.700, 0.500)))[1]);
		Event Player.thebn = -1;
		If(Count Of(Event Player.bns_withinCURSOR) > 0);
			Event Player.thebn = First Of(Sorted Array(Event Player.bns_withinCURSOR, Absolute Value(Horizontal Angle Towards(Event Player,
				Event Player.AnchorFacing + Eye Position(Event Player)) / First Of(Global._extendedGlobalCollection) - First Of(
				Global._objectVariable_1[Current Array Element])) + Absolute Value((Vertical Facing Angle Of(Event Player)
				- Vertical Angle From Direction(Event Player.AnchorFacing)) * -1 / First Of(Global._extendedGlobalCollection)
				- Global._objectVariable_1[Current Array Element][1])));
		End;
		If(Event Player.thebn != -1 && !Array Contains(Array(0), Global._objectVariable_1[Event Player.thebn][5]));
			Event Player.MenuLoop = Global._objectVariable_1[Event Player.thebn][5];
			Event Player.isButtonHovered = True;
			Event Player.HoverText = Custom String("");
			If(First Of(Global._objectVariable_2[Event Player.thebn]) == 2 && Count Of(Event Player.Shop6Items) > Last Of(
				Global._objectVariable_2[Event Player.thebn]));
				Event Player.HoverText = Global.Items[Event Player.Shop6Items[Last Of(Global._objectVariable_2[Event Player.thebn])]][2];
			Else If(First Of(Global._objectVariable_2[Event Player.thebn]) == 4 && Count Of(Event Player.tf_3random) > Last Of(
				Global._objectVariable_2[Event Player.thebn]));
				Event Player.HoverText = Event Player.tf_3random[Last Of(Global._objectVariable_2[Event Player.thebn])][2];
			Else If(First Of(Global._objectVariable_2[Event Player.thebn]) == 3);
				Event Player.HoverText = Global.RefreshDes;
			End;
			Event Player.HoverVisible = Event Player.HoverText != Custom String("");
			Event Player.HoverLineCount = 1;
			If(Event Player.HoverVisible == True);
				Event Player.lines = String Split(Event Player.HoverText, Custom String("\n"));
				Event Player.rowCount = Count Of(Event Player.lines);
				Event Player.colCount = 0;
				For Player Variable(Event Player, line, 0, Count Of(Event Player.lines), 1);
					If(String Length(Event Player.lines[Event Player.line]) > Event Player.colCount);
						Event Player.colCount = String Length(Event Player.lines[Event Player.line]);
					End;
				End;
				Event Player.result = Custom String("");
				Event Player.i = 0;
				While(Event Player.i < Event Player.rowCount);
					Event Player.j = 0;
					While(Event Player.j < Event Player.colCount);
						Event Player.result = Custom String("{0}{1}", Event Player.result, Custom String("="));
						Event Player.j += 1;
					End;
					If(Event Player.i < Event Player.rowCount - 1);
						Event Player.result = Custom String("{0}{1}", Event Player.result, Custom String("\n"));
						Event Player.HoverLineCount += 1;
					End;
					Event Player.i += 1;
				End;
				Event Player.HoverBack = Event Player.result;
			End;
		End;
		If(!Event Player.isButtonHovered);
			Event Player.MenuLoop = 0;
			Event Player.HoverVisible = False;
			Event Player.HoverText = Custom String("");
			Event Player.HoverBack = Custom String("");
		End;
		Loop If Condition Is True;
	}
}

rule("菜单指针文本")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Create In-World Text(Local Player.isInMenu ? Local Player : Null, Input Binding String(Button(Interact)), Update Every Frame(
			Global.Menu_Center + Global.Menu_Base1 * (Horizontal Angle Towards(Local Player, Local Player.AnchorFacing + Eye Position(
			Local Player)) / First Of(Global._extendedGlobalCollection)) + Global.Menu_Base2 * ((Vertical Facing Angle Of(Local Player)
			- Vertical Angle From Direction(Local Player.AnchorFacing)) * -1 / First Of(Global._extendedGlobalCollection))), 1.800,
			Do Not Clip, Visible To Position String and Color, Color(White), Default Visibility);
	}
}

rule("菜单悬停文本")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Global._extendedGlobalCollection[8] = -0.200;
		Create In-World Text(Local Player.isInMenu && Local Player.HoverVisible ? Local Player : Null, Local Player.HoverBack,
			Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * (Horizontal Angle Towards(Local Player,
			Local Player.AnchorFacing + Eye Position(Local Player)) / First Of(Global._extendedGlobalCollection)) + Global.Menu_Base2 * ((
			Vertical Facing Angle Of(Local Player) - Vertical Angle From Direction(Local Player.AnchorFacing)) * -1 / First Of(
			Global._extendedGlobalCollection) + Global._extendedGlobalCollection[8] * Local Player.HoverLineCount)), 3, Do Not Clip,
			Visible To Position String and Color, Color(Black), Default Visibility);
		Create In-World Text(Local Player.isInMenu && Local Player.HoverVisible ? Local Player : Null, Local Player.HoverText,
			Update Every Frame(Global.Menu_Center + Global.Menu_Base1 * (Horizontal Angle Towards(Local Player,
			Local Player.AnchorFacing + Eye Position(Local Player)) / First Of(Global._extendedGlobalCollection)) + Global.Menu_Base2 * ((
			Vertical Facing Angle Of(Local Player) - Vertical Angle From Direction(Local Player.AnchorFacing)) * -1 / First Of(
			Global._extendedGlobalCollection) + Global._extendedGlobalCollection[8] * Local Player.HoverLineCount)), 1.500, Do Not Clip,
			Visible To Position String and Color, Color(Yellow), Default Visibility);
	}
}

rule("菜单按钮点击")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.isInMenu == True;
		Is Button Held(Event Player, Button(Interact)) == True;
	}

	actions
	{
		Global.id = Event Player.MenuLoop;
		Call Subroutine(GetButtonByID);
		If(Event Player.MenuLoop != 0 && Global._objectVariable_1[Global.returnValue_GetButtonByID][3]);
			Modify Global Variable(func_group, Append To Array, Array(Global._objectVariable_2[Global.returnValue_GetButtonByID]));
			Call Subroutine(MenuLambda);
		End;
	}
}

rule("菜单近战重置鼠标")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Event Player.isInMenu == True;
		Is Button Held(Event Player, Button(Melee)) == True;
	}

	actions
	{
		Set Facing(Event Player, Event Player.AnchorFacing, To World);
		Wait Until(Is Button Held(Event Player, Button(Melee)) == False, 99999);
	}
}

rule("sub打开菜单")
{
	event
	{
		Subroutine;
		OpenMenu;
	}

	actions
	{
		Start Camera(Event Player, First Of(Global.MenuCameraSet), Global.MenuCameraSet[1], 0);
		Global._extendedGlobalCollection[6].menuactive = Global.name;
		If(!Global._extendedGlobalCollection[6].isInMenu);
			Set Facing(Global._extendedGlobalCollection[6], Forward, To Player);
			Global._extendedGlobalCollection[6].AnchorFacing = Facing Direction Of(Global._extendedGlobalCollection[6]);
			Global._extendedGlobalCollection[6].isInMenu = True;
			Set Aim Speed(Global._extendedGlobalCollection[6], 0.100);
			Disable Hero HUD(Global._extendedGlobalCollection[6]);
			Disable Game Mode HUD(Global._extendedGlobalCollection[6]);
			Disable Text Chat(Global._extendedGlobalCollection[6]);
			Set Status(Global._extendedGlobalCollection[6], Null, Rooted, 9999);
			Set Primary Fire Enabled(Global._extendedGlobalCollection[6], False);
			Set Secondary Fire Enabled(Global._extendedGlobalCollection[6], False);
			Set Melee Enabled(Global._extendedGlobalCollection[6], False);
			Disable Movement Collision With Players(Global._extendedGlobalCollection[6]);
		End;
		Set Facing(Global._extendedGlobalCollection[6], Global._extendedGlobalCollection[6].AnchorFacing, To World);
	}
}

rule("sub根据ID获取按钮")
{
	event
	{
		Subroutine;
		GetButtonByID;
	}

	actions
	{
		Global._extendedGlobalCollection[7] = 0;
		While(Global._extendedGlobalCollection[7] < Count Of(Filtered Array(Global.Button_Pool, Array Contains(
			Global._objectVariable_1[Current Array Element][4], Event Player.menuactive))));
			If(Global.id == Global._objectVariable_1[Filtered Array(Global.Button_Pool, Array Contains(
				Global._objectVariable_1[Current Array Element][4], Event Player.menuactive))[Global._extendedGlobalCollection[7]]][5]);
				Global.returnValue_GetButtonByID = Filtered Array(Global.Button_Pool, Array Contains(
					Global._objectVariable_1[Current Array Element][4], Event Player.menuactive))[Global._extendedGlobalCollection[7]];
				Skip(4);
			End;
			Global._extendedGlobalCollection[7] += 1;
		End;
		Wait(0.016, Ignore Condition);
	}
}

rule("关闭菜单")
{
	event
	{
		Subroutine;
		CloseMenu;
	}

	actions
	{
		Event Player.isInMenu = False;
		Event Player.MenuLoop = 0;
		Event Player.HoverVisible = False;
		Event Player.HoverText = Custom String("");
		Event Player.HoverBack = Custom String("");
		Stop Camera(Event Player);
		Set Aim Speed(Event Player, 100);
		Clear Status(Event Player, Rooted);
		Set Primary Fire Enabled(Event Player, !Event Player.YiXuanTianFu[14]);
		Set Secondary Fire Enabled(Event Player, !Event Player.YiXuanTianFu[14]);
		Set Melee Enabled(Event Player, True);
		Enable Movement Collision With Players(Event Player);
		Enable Hero HUD(Event Player);
		Enable Game Mode HUD(Event Player);
		Enable Text Chat(Event Player);
		Set Facing(Event Player, Event Player.AnchorFacing, To World);
		Wait(0.016, Ignore Condition);
	}
}

rule("菜单lambda")
{
	event
	{
		Subroutine;
		MenuLambda;
	}

	actions
	{
		Global.selected = Last Of(Global.func_group);
		If(First Of(Global.selected) == 1);
			Event Player.Backpack_open[1] = 1;
			Event Player.Backpack_hitButton = Last Of(Global.selected);
			Call Subroutine(BuyBaseItemByButton);
			Event Player.Backpack_open[1] = 0;
		Else If(First Of(Global.selected) == 2);
			Event Player.Backpack_open[1] = 1;
			If(Count Of(Event Player.Shop6Items) > Last Of(Global.selected));
				Event Player.LinShi = Event Player.Shop6Items[Last Of(Global.selected)];
				Call Subroutine(GouMaiGaoJi);
				If(Event Player.LinShi == -1);
					Modify Player Variable(Event Player, items, Append To Array, Array(Event Player.Shop6Items[Last Of(Global.selected)]));
					If(Count Of(Event Player.ShangPing) == 0);
						Event Player.ShangPing = Array Slice(Mapped Array(Global.Items, First Of(Current Array Element)), 0, 39);
					End;
					Event Player.MenuRngType = Last Of(Global.selected);
					Event Player.MenuRngId = Random Value In Array(Event Player.ShangPing);
					Set Player Variable At Index(Event Player, Shop6Items, Event Player.MenuRngType, Event Player.MenuRngId);
					Event Player.items_6random = Event Player.Shop6Items;
				End;
			End;
			Event Player.Backpack_open[1] = 0;
		Else If(First Of(Global.selected) == 3);
			Event Player.Backpack_open[1] = 1;
			Event Player.MenuRngType = 0;
			If(Event Player.TouZi >= 1);
				Event Player.TouZi -= 1;
				Event Player.MenuRngType = 1;
			Else If(Event Player.BS >= 1);
				Event Player.BS -= 1;
				Event Player.MenuRngType = 1;
			End;
			If(Event Player.MenuRngType == 1);
				If(Event Player.menuactive == 1);
					Call Subroutine(ShangPingShuaXin);
				Else;
					Call Subroutine(TianFuShuaXin);
				End;
			End;
			Event Player.Backpack_open[1] = 0;
		Else If(First Of(Global.selected) == 4);
			Event Player.Backpack_open[1] = 1;
			If(Count Of(Event Player.tf_3random) > Last Of(Global.selected));
				Event Player.LinShi = Event Player.tf_3random[Last Of(Global.selected)][0];
				Call Subroutine(XuanZeTianFu);
				Modify Player Variable(Event Player, tfs, Append To Array, Array(Event Player.tf_3random[Last Of(Global.selected)][0]));
				Event Player.LinShi = 0;
				If(Event Player.JND >= 1);
					Event Player.JND -= 1;
				End;
				Call Subroutine(TianFuShuaXin);
			End;
			Event Player.menuactive = 1;
			Event Player.Backpack_open[0] = 1;
			Event Player.Backpack_open[1] = 0;
		End;
		Modify Global Variable(func_group, Remove From Array By Index, Count Of(Global.func_group) - 1);
	}
}

rule("技能1")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Using Ability 1(Event Player) == True;
	}

	actions
	{
		Wait Until(!Is Using Ability 1(Event Player), 99999);
		If(Event Player.YiXuanTianFu[82]);
			If(Hero Of(Event Player) == Hero(Genji));
				Set Ability Cooldown(Event Player, Button(Ability 1), 8 / (Event Player.CD * Event Player.YiXuanTianFu[82]));
			Else If(Hero Of(Event Player) == Hero(Zarya));
				Set Ability Cooldown(Event Player, Button(Ability 1), 11 / (Event Player.CD * Event Player.YiXuanTianFu[82]));
			Else If(Hero Of(Event Player) == Hero(Freja));
				Set Ability Cooldown(Event Player, Button(Ability 1), 4.500 / (Event Player.CD * Event Player.YiXuanTianFu[82]));
			Else If(Hero Of(Event Player) == Hero(Ramattra));
				Wait(0.500, Ignore Condition);
				Set Ability Cooldown(Event Player, Button(Ability 1), 8 / (Event Player.CD * Event Player.YiXuanTianFu[82]));
			Else If(Hero Of(Event Player) == Hero(Tracer));
				Set Ability Cooldown(Event Player, Button(Ability 1), 3 / (Event Player.CD * Event Player.YiXuanTianFu[82]));
			Else If(Hero Of(Event Player) == Hero(Anran));
				Event Player.AnRanLenQue = Ability Cooldown(Event Player, Button(Ability 2));
				Set Ability Cooldown(Event Player, Button(Ability 1), 8 / (Event Player.CD * Event Player.YiXuanTianFu[82]));
				Set Ability Cooldown(Event Player, Button(Ability 2), Event Player.AnRanLenQue);
			Else;
				Set Ability Cooldown(Event Player, Button(Ability 1), Ability Cooldown(Event Player, Button(Ability 1)) / (
					Event Player.CD * Event Player.YiXuanTianFu[82]));
			End;
		Else;
			If(Hero Of(Event Player) == Hero(Genji));
				Set Ability Cooldown(Event Player, Button(Ability 1), 8 / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(Zarya));
				Set Ability Cooldown(Event Player, Button(Ability 1), 11 / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(Freja));
				Set Ability Cooldown(Event Player, Button(Ability 1), 4.500 / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(Ramattra));
				Wait(0.500, Ignore Condition);
				Set Ability Cooldown(Event Player, Button(Ability 1), 8 / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(Tracer));
				Set Ability Cooldown(Event Player, Button(Ability 1), 3 / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(Anran));
				Event Player.AnRanLenQue = Ability Cooldown(Event Player, Button(Ability 2));
				Set Ability Cooldown(Event Player, Button(Ability 1), 8 / Event Player.CD);
				Set Ability Cooldown(Event Player, Button(Ability 2), Event Player.AnRanLenQue);
			Else;
				Set Ability Cooldown(Event Player, Button(Ability 1), Ability Cooldown(Event Player, Button(Ability 1)) / Event Player.CD);
			End;
		End;
	}
}

rule("技能2|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Using Ability 2(Event Player) == True;
	}

	actions
	{
		Wait Until(!Is Using Ability 2(Event Player), 99999);
		If(Event Player.YiXuanTianFu[83] * Event Player.YiXuanTianFu[83]);
			If(Hero Of(Event Player) == Hero(Tracer));
				Set Ability Cooldown(Event Player, Button(Ability 2), 12 / Event Player.CD * Event Player.YiXuanTianFu[83]);
			Else If(Hero Of(Event Player) == Hero(Zarya));
				Set Ability Cooldown(Event Player, Button(Ability 2), 11 / Event Player.CD * Event Player.YiXuanTianFu[83]);
			Else If(Hero Of(Event Player) == Hero(D.Va));
				Set Ability Cooldown(Event Player, Button(Ability 2), 7 / Event Player.CD * Event Player.YiXuanTianFu[83]);
			Else If(Hero Of(Event Player) == Hero(Baptiste));
				Set Ability Cooldown(Event Player, Button(Ability 2), 25 / Event Player.CD * Event Player.YiXuanTianFu[83]);
			Else If(Hero Of(Event Player) == Hero(Reinhardt));
				Set Ability Cooldown(Event Player, Button(Ability 2), 6 / Event Player.CD * Event Player.YiXuanTianFu[83]);
			Else If(Hero Of(Event Player) == Hero(Junker Queen));
				Wait(0.250, Ignore Condition);
				Set Ability Cooldown(Event Player, Button(Ability 2), Ability Cooldown(Event Player, Button(Ability 2)) / (
					Event Player.CD * Event Player.YiXuanTianFu[83]));
			Else If(Hero Of(Event Player) == Hero(Genji));
				Wait(0.180, Ignore Condition);
				Set Ability Cooldown(Event Player, Button(Ability 2), Ability Cooldown(Event Player, Button(Ability 2)) / (
					Event Player.CD * Event Player.YiXuanTianFu[83]));
			Else;
				Set Ability Cooldown(Event Player, Button(Ability 2), Ability Cooldown(Event Player, Button(Ability 2)) / (
					Event Player.CD * Event Player.YiXuanTianFu[83]));
			End;
		Else;
			If(Hero Of(Event Player) == Hero(Tracer));
				Set Ability Cooldown(Event Player, Button(Ability 2), 12 / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(Zarya));
				Set Ability Cooldown(Event Player, Button(Ability 2), 11 / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(D.Va));
				Set Ability Cooldown(Event Player, Button(Ability 2), 7 / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(Baptiste));
				Set Ability Cooldown(Event Player, Button(Ability 2), 25 / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(Reinhardt));
				Set Ability Cooldown(Event Player, Button(Ability 2), 6 / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(Junker Queen));
				Wait(0.250, Ignore Condition);
				Set Ability Cooldown(Event Player, Button(Ability 2), Ability Cooldown(Event Player, Button(Ability 2)) / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(Genji));
				Wait(0.180, Ignore Condition);
				Set Ability Cooldown(Event Player, Button(Ability 2), Ability Cooldown(Event Player, Button(Ability 2)) / Event Player.CD);
			Else;
				Set Ability Cooldown(Event Player, Button(Ability 2), Ability Cooldown(Event Player, Button(Ability 2)) / Event Player.CD);
			End;
		End;
	}
}

rule("右键|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Firing Secondary(Event Player) == False;
	}

	actions
	{
		Wait Until(!Is Firing Secondary(Event Player), 99999);
		If(Event Player.YiXuanTianFu[84]);
			If(Hero Of(Event Player) == Hero(Soldier: 76));
				Set Ability Cooldown(Event Player, Button(Secondary Fire), 6 / (Event Player.CD * Event Player.YiXuanTianFu[84]));
			Else If(Hero Of(Event Player) == Hero(Bastion));
				Wait(0.600, Ignore Condition);
				Set Ability Cooldown(Event Player, Button(Secondary Fire), 8 / (Event Player.CD * Event Player.YiXuanTianFu[84]));
			Else;
				Set Ability Cooldown(Event Player, Button(Secondary Fire), Ability Cooldown(Event Player, Button(Secondary Fire)) / (
					Event Player.CD * Event Player.YiXuanTianFu[84]));
			End;
		Else;
			If(Hero Of(Event Player) == Hero(Soldier: 76));
				Set Ability Cooldown(Event Player, Button(Secondary Fire), 6 / Event Player.CD);
			Else If(Hero Of(Event Player) == Hero(Bastion));
				Wait(0.600, Ignore Condition);
				Set Ability Cooldown(Event Player, Button(Secondary Fire), 8 / Event Player.CD);
			Else;
				Set Ability Cooldown(Event Player, Button(Secondary Fire), Ability Cooldown(Event Player, Button(Secondary Fire))
					/ Event Player.CD);
			End;
	}
}

rule("正在使用终极技能|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Using Ultimate(Event Player) == True;
	}

	actions
	{
		"保底"
		If(Event Player.YiXuanTianFu[113]);
			Event Player.M += Event Player.YiXuanTianFu[113] * 1000;
		End;
		"眼镜"
		If(Event Player.YiXuanTianFu[112]);
			Event Player.SM[1] += Event Player.YiXuanTianFu[112] * 100;
		End;
		"圣"
		If(Event Player.YiXuanTianFu[17]);
			Start Rule(Sheng, Do Nothing);
		End;
		"诛"
		If(Event Player.YiXuanTianFu[45]);
			Start Rule(ZhuMie, Do Nothing);
		End;
		"激素"
		If(Event Player.YiXuanTianFu[46]);
			Start Rule(JiSu, Do Nothing);
		End;
		"桎梏灼日"
		If(Event Player.YiXuanTianFu[53]);
			Start Rule(ZhuoRi, Do Nothing);
		End;
		"涅槃"
		If(Event Player.YiXuanTianFu[102]);
			Wait Until(Is Dead(Event Player) || Is Using Ultimate(Event Player) == False, 99999);
			If(Is Dead(Event Player));
				Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) + Event Player.YiXuanTianFu[102] * 50);
				Resurrect(Event Player);
			End;
		End;
	}
}

rule("跳跃|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Jump)) == True;
	}

	actions
	{
		If(Is Button Held(Event Player, Button(Crouch)) && Event Player.Backpack_open[0] == 0);
			Start Rule(DiSan, Do Nothing);
		End;
		"兔子跳"
		If(Event Player.YiXuanTianFu[13] && Is Jumping(Event Player));
			Heal(Event Player, Event Player, 30 * Event Player.YiXuanTianFu[13]);
		End;
		"忍者足具1"
		If(Event Player.YiXuanTianFu[12] == 1 && Is In Air(Event Player));
			Start Rule(RenZheZuJu1, Do Nothing);
		"忍者足具2"
		Else If(Event Player.YiXuanTianFu[12] > 1 && Is In Air(Event Player));
			Start Rule(RenZheZuJu2, Do Nothing);
		End;
		"重踏"
		If(Event Player.YiXuanTianFu[28] > 0 && Is Alive(Event Player) == True);
			Start Rule(ZhongTa, Do Nothing);
		End;
		"女武神"
		If(Event Player.YiXuanTianFu[75] > 0 && Is Alive(Event Player) == True);
			Start Rule(NvWuShen, Do Nothing);
		End;
	}
}

rule("蹲下|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Crouch)) == True;
	}

	actions
	{
		If(Is Button Held(Event Player, Button(Jump)) && Event Player.Backpack_open[0] == 0);
			Start Rule(DiSan, Do Nothing);
		End;
	}
}

rule("第三人称")
{
	event
	{
		Subroutine;
		DiSan;
	}

	actions
	{
		Event Player.DiSan = !Event Player.DiSan;
		If(Event Player.DiSan);
			Start Camera(Event Player, Ray Cast Hit Position(Eye Position(Event Player) + 0.500 * Direction From Angles(
				Horizontal Facing Angle Of(Event Player), Vertical Facing Angle Of(Event Player) - 120), Eye Position(Event Player)
				+ 0.500 * Direction From Angles(Horizontal Facing Angle Of(Event Player), Vertical Facing Angle Of(Event Player) - 120)
				+ Facing Direction Of(Event Player) * Absolute Value(Eye Position(Event Player) - Event Player) * -2, Null, Event Player,
				False), Eye Position(Event Player) + 0.500 * Direction From Angles(Horizontal Facing Angle Of(Event Player),
				Vertical Facing Angle Of(Event Player) - 120) + Facing Direction Of(Event Player) * Absolute Value(Eye Position(Event Player)
				- Event Player) * 80 + Down, 666);
		Else;
			Stop Camera(Event Player);
		End;
		Wait(0.250, Ignore Condition);
	}
}

rule("造成伤害|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Player Dealt Damage;
		All;
		All;
	}

	actions
	{
		"吸血"
		Heal(Attacker, Null, Event Damage * (Attacker.XX[0] + Attacker.XX[1]));
		"技能额外伤害"
		If(Attacker.FQ[0] + Attacker.FQ[1] + Attacker.FQ[2] + Attacker.FQ[3]);
			If(Event Ability == Button(Ability 1));
				If(Attacker.ShanShuXing == Color(Violet));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Green));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Heal(Attacker, Attacker, Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (Attacker.FQ[2] + Attacker.FQ[3]));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Red));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + 0.002 * (Attacker.FQ[2] + Attacker.FQ[3])
						* Max Health(Victim)) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Aqua));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Set Status(Victim, Null, Stunned, 0.010);
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Black));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / Victim.SS / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (
						Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				End;
				"超电磁炮"
				If(Attacker.YiXuanTianFu[74]);
					Attacker.FQ[3] -= Attacker.DianCiPao;
					Attacker.DianCiPao = 0;
				End;
			Else If(Event Ability == Button(Ability 2));
				If(Attacker.ShanShuXing == Color(Violet));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Green));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Heal(Attacker, Attacker, Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (Attacker.FQ[2] + Attacker.FQ[3]));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Red));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + 0.002 * (Attacker.FQ[2] + Attacker.FQ[3])
						* Max Health(Victim)) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Aqua));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Set Status(Victim, Null, Stunned, 0.010);
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Black));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / Victim.SS / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (
						Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				End;
				"超电磁炮"
				If(Attacker.YiXuanTianFu[74]);
					Attacker.FQ[3] -= Attacker.DianCiPao;
					Attacker.DianCiPao = 0;
				End;
			Else If(Event Ability == Button(Ultimate));
				If(Attacker.ShanShuXing == Color(Violet));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Green));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Heal(Attacker, Attacker, Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (Attacker.FQ[2] + Attacker.FQ[3]));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Red));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + 0.002 * (Attacker.FQ[2] + Attacker.FQ[3])
						* Max Health(Victim)) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Aqua));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Set Status(Victim, Null, Stunned, 0.010);
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Black));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / Victim.SS / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (
						Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				End;
				"超电磁炮"
				If(Attacker.YiXuanTianFu[74]);
					Attacker.FQ[3] -= Attacker.DianCiPao;
					Attacker.DianCiPao = 0;
				End;
			Else If(Event Ability == Button(Secondary Fire) && Array Contains(Array(Hero(Lúcio), Hero(Echo), Hero(Sojourn), Hero(Bastion),
					Hero(Soldier: 76), Hero(Orisa), Hero(Venture), Hero(Doomfist), Hero(Juno), Hero(Reaper), Hero(Junker Queen), Hero(Junkrat),
					Hero(Wrecking Ball)), Hero Of(Attacker)));
				If(Attacker.ShanShuXing == Color(Violet));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Green));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Heal(Attacker, Attacker, Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (Attacker.FQ[2] + Attacker.FQ[3]));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Red));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + 0.002 * (Attacker.FQ[2] + Attacker.FQ[3])
						* Max Health(Victim)) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Aqua));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
					Set Status(Victim, Null, Stunned, 0.010);
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				Else If(Attacker.ShanShuXing == Color(Black));
					Damage(Remove From Array(Victim, Attacker), Attacker, (Attacker.FQ[0] + Attacker.FQ[1] + Event Damage * (
						Attacker.FQ[2] + Attacker.FQ[3])) / Victim.SS / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (
						Attacker.GJ[2] + Attacker.GJ[3])));
					Play Effect(All Players(All Teams), Bad Explosion, Attacker.ShanShuXing, Victim, 1);
				End;
				"超电磁炮"
				If(Attacker.YiXuanTianFu[74]);
					Attacker.FQ[3] -= Attacker.DianCiPao;
					Attacker.DianCiPao = 0;
				End;
			End;
		End;
		"灭"
		If(Attacker.YiXuanTianFu[16]);
			Damage(Victim, Null, Max Health(Victim) * 0.005 * Attacker.YiXuanTianFu[16]);
			If(Normalized Health(Victim) <= 0.050 * Attacker.YiXuanTianFu[16]);
				Kill(Victim, Attacker);
			End;
		End;
		"火箭飞弹"
		If(Attacker.YiXuanTianFu[110] && Event Player.DD >= 300 && Distance Between(Attacker, Victim) >= 10);
			Create Homing Projectile(Pharah Rocket, Event Player, Null, Null, To World, Damage, All Teams, 50 * Attacker.YiXuanTianFu[110], 1,
				3, Bad Explosion, Explosion Sound, 0, 5, 5, 0, Victim, 0.800);
		End;
		"生命虹吸"
		If(Attacker.YiXuanTianFu[105] > 0);
			Attacker.SM[0] += Attacker.ZL[0] * 0.100 * Absolute Value(Attacker.YiXuanTianFu[105]);
			Attacker.YiXuanTianFu[105] *= -1;
			Start Rule(ShengMingHongXi, Do Nothing);
		End;
		"连锁闪电"
		If(Attacker.YiXuanTianFu[103]);
			Damage(Remove From Array(Closest Player To(Victim, All Teams), Event Player), Attacker,
				Event Damage * 0.500 * Attacker.YiXuanTianFu[103] / (0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (
				Attacker.GJ[2] + Attacker.GJ[3])));
		End;
		"火箭重锤"
		If(Attacker.YiXuanTianFu[15] && Event Ability == Button(Melee));
			Set Status(Victim, Attacker, Stunned, 0.300);
		End;
		"狂战士"
		If(Attacker.YiXuanTianFu[32]);
			If(Attacker.KuangZhanShi < 0.001 * Max Health(Attacker) * Attacker.YiXuanTianFu[32] * 0.500);
				Attacker.GJ[3] += 0.001 * Max Health(Attacker) * Attacker.YiXuanTianFu[32] * 0.010;
				Set Damage Dealt(Attacker, (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3]));
				Attacker.XX[1] += 0.001 * Max Health(Attacker) * Attacker.YiXuanTianFu[32] * 0.010;
				Attacker.KuangZhanShi += 0.001 * Max Health(Attacker) * Attacker.YiXuanTianFu[32] * 0.010;
			End;
			Start Rule(KuangZhanShi, Restart Rule);
		End;
		"超电磁炮"
		If(Attacker.YiXuanTianFu[74] && Event Ability == Button(Primary Fire));
			If(Attacker.DianCiPao < Attacker.YiXuanTianFu[74]);
				Attacker.FQ[3] += Attacker.YiXuanTianFu[74] * 0.010;
				Attacker.DianCiPao += Attacker.YiXuanTianFu[74] * 0.010;
			End;
		End;
		"龙锤"
		If(Attacker.YiXuanTianFu[91] && Event Ability == Button(Primary Fire));
			Set Status(Victim, Attacker, Stunned, 0.200);
			Damage(Victim, Attacker, Max Health(Victim) * Attacker.YiXuanTianFu[91] * 0.100 * Max Health Of Type(Attacker, Armor) * 0.001 / (
				0.010 * (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3])));
		End;
		"枯萎凋零"
		If(Attacker.YiXuanTianFu[33]);
			Start Rule(KuWei, Do Nothing);
		End;
		"冰冻冲击枪"
		If(Attacker.YiXuanTianFu[34]);
			If(Victim.BingDong < 100);
				Victim.BingDong += 1;
			Else If(Victim.BingDong == 100);
				Set Status(Victim, Attacker, Frozen, 1);
				Victim.BingDong = Is Match Complete;
			End;
			Start Rule(BingDong, Do Nothing);
		End;
		"超能之球"
		If(Attacker.YiXuanTianFu[40] && Attacker.DJ[0] >= 15);
			Start Rule(ChaoNeng, Do Nothing);
		End;
		"肘击！"
		If(Attacker.YiXuanTianFu[104] && Event Ability == Button(Melee));
			Damage(Victim, Attacker, Event Damage * Attacker.YiXuanTianFu[104] / ((Attacker.GJ[0] + Attacker.GJ[1]) * (
				Attacker.GJ[2] + Attacker.GJ[3]) / 100));
		End;
		"风"
		If(Event Was Critical Hit);
			Damage(Victim, Attacker, Event Damage * Random Real(Attacker.BJ, Attacker.YiXuanTianFu[47] + Attacker.BJ) / ((
				Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3]) / 100));
		End;
		"帕拉蒂尼之牙"
		If(Attacker.YiXuanTianFu[109] && Event Ability == Button(Melee));
			Damage(Victim, Attacker, Event Damage * Random Real(Attacker.BJ, Attacker.YiXuanTianFu[109] + Attacker.BJ) / ((
				Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3]) / 100));
		End;
		"律动连打"
		If(Attacker.YiXuanTianFu[63] && Event Ability == Button(Primary Fire));
			Set Ability Cooldown(Event Player, Button(Ability 2), Ability Cooldown(Event Player, Button(Ability 2))
				- 0.500 * Attacker.YiXuanTianFu[63]);
			Set Ability Cooldown(Event Player, Button(Ability 1), Ability Cooldown(Event Player, Button(Ability 1))
				- 0.500 * Attacker.YiXuanTianFu[63]);
			Set Ability Cooldown(Event Player, Button(Secondary Fire), Ability Cooldown(Event Player, Button(Secondary Fire))
				- 0.500 * Attacker.YiXuanTianFu[63]);
		End;
		"骨刺"
		If(Attacker.YiXuanTianFu[64] && Normalized Health(Victim) <= Attacker.YiXuanTianFu[64] * Max Health Of Type(Attacker, Armor)
			* 0.005 * 0.010);
			Kill(Victim, Attacker);
		End;
		"缚能电弧"
		If(Event Player.FuNengDianHu);
			Play Effect(All Players(All Teams), Bad Explosion, Color(Blue), Victim, 1);
			Set Status(Victim, Null, Stunned, 0.200);
		End;
		"轨道镭射"
		If(Attacker.YiXuanTianFu[76]);
			Start Rule(GuiDaoSheXian, Do Nothing);
		End;
		"破甲熔钉"
		If(Attacker.YiXuanTianFu[78]);
			If(Victim.RongDing == 1);
				Damage(Victim, Null, Health Of Type(Victim, Armor) * 0.300 * Attacker.YiXuanTianFu[78] / ((Attacker.GJ[0] + Attacker.GJ[1]) * (
					Attacker.GJ[2] + Attacker.GJ[3]) / 100));
				Clear Status(Victim, Burning);
				Victim.RongDing = Is Match Complete;
			Else If(Victim.RongDing == Is Match Complete);
				Set Status(Victim, Attacker, Burning, 5);
				Victim.RongDing = 1;
			End;
		End;
		"撼地猛刺"
		If(Victim.YiXuanTianFu[39] && Is Standing(Victim));
			Start Rule(HanDi, Do Nothing);
		End;
		"猪猪存钱罐"
		If(Victim.YiXuanTianFu[68] && Event Damage > 100);
			Victim.CunQianGuan += 1 * Victim.YiXuanTianFu[68];
		End;
		"实验护盾"
		If(Victim.YiCiXinShenMing[0] > 0);
			Victim.YiCiXinShenMing[0] -= Event Damage;
		End;
		"幽灵形态"
		If(Victim.YiXuanTianFu[99] && Event Damage >= 300);
			Set Status(Victim, Null, Phased Out, Victim.YiXuanTianFu[99] * 1);
		End;
		"维生立场"
		If(Victim.YiXuanTianFu[100]);
			Heal(Victim, Victim, Event Damage * 0.200 * Victim.YiXuanTianFu[100]);
		End;
		"充能屏障"
		If(Health Of Type(Victim, Shields) == Is Match Complete && Victim.YiXuanTianFu[101]);
			Set Ultimate Charge(Victim, Ultimate Charge Percent(Event Player) + 0.030 * Max Health Of Type(Victim, Shields)
				* Victim.YiXuanTianFu[101]);
		End;
		"粒子屏障"
		If(Health Of Type(Victim, Shields) == Is Match Complete && Victim.YiXuanTianFu[109]);
			Damage(Remove From Array(Players Within Radius(Victim, (Victim.DX[0] + Victim.DX[1]) * 5, Opposite Team Of(Team Of(Victim)), Off),
				Victim), Victim, Max Health Of Type(Victim, Shields) * 0.300 * Victim.YiXuanTianFu[109] / ((Victim.GJ[0] + Victim.GJ[1]) * (
				Victim.GJ[2] + Victim.GJ[3]) / 100));
		End;
	}
}

rule("参与消灭|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Player Earned Elimination;
		All;
		All;
	}

	actions
	{
		Attacker.M += 500;
		"赏金猎人"
		Attacker.M += 100 * Attacker.LieRen;
		"辅助低保"
		Players On Hero(All Support Heroes, Team Of(Event Player)).M += 500;
		"经验"
		Event Player.DJ[1] += 150;
		"升级/古夫"
		If(Event Player.DJ[1] >= 50 * Event Player.DJ[0] && Event Player.DJ[0] < 15);
			Start Rule(ShengJi, Do Nothing);
		Else If(Event Player.DJ[1] >= 750 && Event Player.DJ[0] >= 15 && Event Player.YiXuanTianFu[0]);
			Start Rule(ShengJi, Do Nothing);
		End;
		"太阳光塔"
		If(Attacker.YiXuanTianFu[19] && Is Using Ultimate(Attacker) == False);
			Set Ultimate Charge(Attacker, Ultimate Charge Percent(Attacker) + Attacker.YiXuanTianFu[19] * 20);
		End;
		"龙魂"
		If(Attacker.YiXuanTianFu[23]);
			Set Ability Cooldown(Attacker, Button(Ability 1), 0);
			Set Ability Cooldown(Attacker, Button(Ability 2), 0);
			Set Ability Cooldown(Attacker, Button(Jump), 0);
			Set Ability Cooldown(Attacker, Button(Crouch), 0);
			Set Ability Cooldown(Attacker, Button(Secondary Fire), 0);
		End;
		"死亡绽放"
		If(Attacker.YiXuanTianFu[55]);
			Heal(Attacker, Attacker, 500 * Attacker.YiXuanTianFu[55]);
		End;
		"猪猪存钱罐"
		If(Attacker.YiXuanTianFu[68]);
			Attacker.JC += Attacker.CunQianGuan * 50;
			Set Max Health(Attacker, Attacker.JC);
			Attacker.YiXuanTianFu[68] = 0;
			Attacker.CunQianGuan = 0;
		End;
	}
}

rule("造成最后一击、阵亡|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Player Died;
		All;
		All;
	}

	actions
	{
		Detach Players(Victim);
		"无情连打攻击清零"
		Victim.GJ[1] = 0;
		Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
		"自爆"
		If(Victim.YiXuanTianFu[25]);
			Play Effect(All Players(All Teams), Bad Explosion, Color(Red), Victim, (Victim.DX[0] + Victim.DX[1]) * 5);
			Damage(Players Within Radius(Victim, (Victim.DX[0] + Victim.DX[1]) * 5, Opposite Team Of(Team Of(Event Player)), Off), Victim,
				500 * Victim.YiXuanTianFu[25]);
		End;
		If(Attacker != Victim);
			"百合之吻"
			If(Attacker.YiXuanTianFu[26] && Event Was Critical Hit);
				Attacker.GJ[0] += 5 * Attacker.YiXuanTianFu[26];
				Set Damage Dealt(Attacker, (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3]));
			End;
			"毒蛇"
			If(Attacker.YiXuanTianFu[54]);
				Attacker.M += 100 * Attacker.LieRen * Attacker.YiXuanTianFu[54];
				Victim.M -= 100 * Attacker.LieRen * Attacker.YiXuanTianFu[54];
			End;
			"连败"
			Victim.LianBai += 1;
			Attacker.LianBai = 0;
			If(Victim.LianBai < 3);
				Victim.DJ[1] += 50;
			Else If(Victim.LianBai >= 3);
				Victim.DJ[1] += 50 + 10 * Victim.LianBai;
			End;
			"升级/古夫"
			If(Victim.DJ[1] >= 50 * Victim.DJ[0] && Victim.DJ[0] < 15);
				Start Rule(ShengJi, Do Nothing);
			Else If(Victim.DJ[1] >= 750 && Victim.DJ[0] >= 15 && Victim.YiXuanTianFu[0]);
				Start Rule(ShengJi, Do Nothing);
			End;
			If(Victim.LianBai < 5 && Victim.LianBai > 2);
				Victim.M += 50 * Victim.LianBai;
			Else If(Victim.LianBai >= 5);
				Event Player.LinShi2 = Random Integer(1, 20);
				If(Event Player.LinShi2 >= 1 && Event Player.LinShi2 <= 2);
					Event Player.GJ[2] += 5 * 0.010;
					Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
					Small Message(Event Player, Custom String("力量石榴"));
				Else If(Event Player.LinShi2 >= 3 && Event Player.LinShi2 <= 4);
					Event Player.FQ[2] += 6 * 0.010;
					Small Message(Event Player, Custom String("威能蓝莓"));
				Else If(Event Player.LinShi2 >= 5 && Event Player.LinShi2 <= 6);
					Event Player.SM[1] += 0.400;
					Small Message(Event Player, Custom String("方糖苹果"));
				Else If(Event Player.LinShi2 >= 7 && Event Player.LinShi2 <= 8);
					Event Player.XX[0] += Event Player.XX[0] * 0.100;
					Small Message(Event Player, Custom String("酒酿葡萄"));
				Else If(Event Player.LinShi2 >= 9 && Event Player.LinShi2 <= 10);
					Event Player.CD += Event Player.CD * 0.200;
					Small Message(Event Player, Custom String("往复柠檬"));
				Else If(Event Player.LinShi2 >= 11 && Event Player.LinShi2 <= 12);
					Event Player.YS[2] += 0.050;
					Set Move Speed(Event Player, (Event Player.YS[0] + Event Player.YS[1]) * (Event Player.YS[2] + Event Player.YS[3]));
					Small Message(Event Player, Custom String("流星杨桃"));
				Else If(Event Player.LinShi2 >= 13 && Event Player.LinShi2 <= 14);
					Event Player.BS += 1;
					Small Message(Event Player, Custom String("1宝石"));
				Else If(Event Player.LinShi2 >= 15 && Event Player.LinShi2 <= 16);
					Event Player.GJ[0] += 1;
					Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
					Event Player.SM[0] += 10;
					If(Event Player.YiXuanTianFu[2]);
						Event Player.JC += 1;
						Set Max Health(Event Player, Event Player.JC);
						Event Player.DX[0] += 0.100;
						Stop Scaling Player(Event Player);
						Start Scaling Player(Event Player, Event Player.DX[0] + Event Player.DX[1], True);
					End;
					Small Message(Event Player, Custom String("香蕉"));
				Else If(Event Player.LinShi2 >= 17 && Event Player.LinShi2 <= 18);
					Event Player.TouZi += 1;
					Small Message(Event Player, Custom String("刷新骰子*1"));
				Else If(Event Player.LinShi2 >= 19 && Event Player.LinShi2 <= 30);
					Event Player.M += 300;
					Small Message(Event Player, Custom String("300额外货币"));
				Else If(Event Player.LinShi2 == 31);
					Event Player.FuZhiQi += 1;
					Small Message(Event Player, Custom String("终极大奖"));
					Small Message(Event Player, Custom String("天赋复制器！！！"));
				End;
				Victim.M += 75 * Victim.LianBai;
			End;
			"悬赏"
			Attacker.XuanShang += 100;
			If(Attacker.XuanShang >= 4500);
				Attacker.XuanShang += 2900;
			Else If(Attacker.XuanShang >= 3000);
				Attacker.XuanShang += 400;
			Else If(Attacker.XuanShang >= 1000);
				Attacker.XuanShang += 150;
			End;
			If(Attacker.XuanShang >= 4500 && (Attacker.XuanShangDengJi == 1 || Attacker.XuanShangDengJi == 2));
				Attacker.XuanShangDengJi = 3;
				Attacker.XuanShang = Attacker.XuanShang * 2;
				Wait(0.250, Ignore Condition);
				Big Message(All Players(All Teams), Custom String("\n\n\n三级悬赏:{0}\n\n\n\n击杀获得{1}+货币", Attacker, Attacker.XuanShang));
				Big Message(All Players(All Teams), Custom String("天罚"));
				Big Message(All Players(All Teams), Custom String("疲劳，虚弱效果持续增强", Attacker));
			Else If(Attacker.XuanShang >= 2000 && (Attacker.XuanShangDengJi == 0 || Attacker.XuanShangDengJi == 1));
				Attacker.XuanShangDengJi = 2;
				Attacker.XuanShang = Attacker.XuanShang * 1.500;
				Wait(0.250, Ignore Condition);
				Big Message(All Players(All Teams), Custom String("\n\n\n二级悬赏:{0}\n\n\n\n击杀获得{1}+货币", Attacker, Attacker.XuanShang));
				Big Message(All Players(All Teams), Custom String("天罚"));
				Big Message(All Players(All Teams), Custom String("{0}进入虚弱状态", Attacker));
				Big Message(All Players(All Teams), Custom String("死亡解除"));
			Else If(Attacker.XuanShang >= 400 && Attacker.XuanShangDengJi == 0);
				Attacker.XuanShangDengJi = 1;
				Attacker.XuanShang = Attacker.XuanShang * 2.500;
				Wait(0.250, Ignore Condition);
				Big Message(All Players(All Teams), Custom String("\n\n\n一级悬赏:{0}\n\n\n\n击杀获得{1}+货币", Attacker, Attacker.XuanShang));
			End;
			If(Attacker.XuanShang > 2000);
				If(Attacker.TianFaCengShu < 9);
					Attacker.GJ[3] -= 0.100;
					Set Damage Dealt(Attacker, (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3]));
					Attacker.SS = Attacker.SS * 1.200;
					Set Damage Received(Attacker, Attacker.SS);
					Attacker.TianFaCengShu += 1;
					If(Attacker.TianFaCengShu == 9);
						Big Message(All Players(All Teams), Custom String("\n\n\n终极悬赏:{0}\n\n\n\n击杀获得{1}+货币", Attacker, Attacker.XuanShang));
						Big Message(All Players(All Teams), Custom String("终极天罚", Attacker, Attacker.XuanShang));
						Big Message(All Players(All Teams), Custom String("{0}虚弱效果达到最高", Attacker));
						Create HUD Text(Attacker, Custom String("{0} {1}", Custom String("灭绝"), Ability Icon String(Hero(Cassidy), Button(Ultimate))),
							Null, Null, Right, 3, Color(Violet), Null, Null, Visible To, Default Visibility);
						Attacker.GJ[2] += 30 * 0.010;
						Set Damage Dealt(Attacker, (Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3]));
						Attacker.FQ[2] += 30 * 0.010;
						Attacker.XuanShang = Attacker.XuanShang * 2;
					End;
				End;
			End;
			"悬赏"
			Attacker.M += Victim.XuanShang;
			If(Victim.XuanShang >= 2000);
				Victim.GJ[3] += 0.100 * Victim.TianFaCengShu;
				Set Damage Dealt(Victim, (Victim.GJ[0] + Victim.GJ[1]) * (Victim.GJ[2] + Victim.GJ[3]));
				Victim.SS = Victim.SS / 1.200 ^ Victim.TianFaCengShu;
				Set Damage Received(Victim, Victim.SS);
				Big Message(All Players(All Teams), Custom String("{0}虚弱解除", Victim));
				Victim.TianFaCengShu = 0;
			End;
			Victim.XuanShang = 0;
			If(Victim.YiXuanTianFu[81]);
				Victim.XuanShang = -1000 * Victim.YiXuanTianFu[81];
			End;
			Victim.XuanShangDengJi = 0;
		End;
	}
}

rule("造成治疗|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Player Dealt Healing;
		All;
		All;
	}

	actions
	{
		"灵符"
		If(Event Player.YiXuanTianFu[49]);
			Set Ultimate Charge(Healer, Ultimate Charge Percent(Healer) + 1 * Event Player.YiXuanTianFu[49]);
		End;
		"愈合冲击"
		If(Event Player.YiXuanTianFu[51]);
			Damage(Remove From Array(Players Within Radius(Event Player, (Event Player.DX[0] + Event Player.DX[1]) * 5, Opposite Team Of(
				Team Of(Event Player)), Off), Event Player), Event Player, Event Healing * Event Player.YiXuanTianFu[51] / ((
				Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]) / 100));
		End;
		"呼吸器"
		If(Event Player.YiXuanTianFu[50]);
			Event Player.SM[0] += 0.150 * Event Player.YiXuanTianFu[50] * Event Healing;
		End;
		"生命之握"
		If(Event Player.YiXuanTianFu[79] && Normalized Health(Healee) <= 0.300);
			Event Player.ZL[1] += Event Player.YiXuanTianFu[79] * 0.300 * Healee.ZL[0];
			Set Healing Dealt(Event Player, (Event Player.ZL[0] + Event Player.ZL[1]) * (Event Player.ZL[2] + Event Player.ZL[3]));
			Event Player.ShengMingZhiWo += Event Player.YiXuanTianFu[79] * 0.300 * Healee.ZL[0];
			Start Rule(ShengMingZhiWo, Restart Rule);
		End;
	}
}

rule("受到治疗|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Player Received Healing;
		All;
		All;
	}

	actions
	{
		"治疗包"
		If(Event Was Health Pack && Event Player.YiXuanTianFu[98]);
			Event Player.LinShi2 = Random Integer(1, 6);
			If(Event Player.LinShi2 == 1);
				Event Player.GJ[0] += 5 * Event Player.YiXuanTianFu[98];
				Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
				Small Message(Event Player, Custom String("5攻击力"));
			Else If(Event Player.LinShi2 == 2);
				Event Player.JC += 5 * Event Player.YiXuanTianFu[98];
				Set Max Health(Event Player, Event Player.JC);
				Small Message(Event Player, Custom String("5%基础生命值"));
			Else If(Event Player.LinShi2 == 3);
				Event Player.SZ[0] += 5 * Event Player.YiXuanTianFu[98];
				Set Healing Received(Event Player, (Event Player.SZ[0] + Event Player.SZ[1]) * (Event Player.SZ[2] + Event Player.SZ[3]));
				Small Message(Event Player, Custom String("5受治疗量"));
			Else If(Event Player.LinShi2 == 4);
				Event Player.CD += 0.100 * Event Player.YiXuanTianFu[98];
				Small Message(Event Player, Custom String("5技能极速"));
			Else If(Event Player.LinShi2 == 5);
				Event Player.YS[0] += 5 * Event Player.YiXuanTianFu[98];
				Set Move Speed(Event Player, (Event Player.YS[0] + Event Player.YS[1]) * (Event Player.YS[2] + Event Player.YS[3]));
				Small Message(Event Player, Custom String("5移动速度"));
			Else If(Event Player.LinShi2 == 6);
				Event Player.YS[0] += 5 * Event Player.YiXuanTianFu[98];
				Set Move Speed(Event Player, (Event Player.YS[0] + Event Player.YS[1]) * (Event Player.YS[2] + Event Player.YS[3]));
				Event Player.GJ[0] += 5 * Event Player.YiXuanTianFu[98];
				Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
				Event Player.JC += 5 * Event Player.YiXuanTianFu[98];
				Set Max Health(Event Player, Event Player.JC);
				Event Player.SZ[0] += 5 * Event Player.YiXuanTianFu[98];
				Set Healing Received(Event Player, (Event Player.SZ[0] + Event Player.SZ[1]) * (Event Player.SZ[2] + Event Player.SZ[3]));
				Event Player.CD += 0.100 * Event Player.YiXuanTianFu[98];
				Small Message(Event Player, Custom String("爱上彩虹，吃定彩虹"));
				Small Message(Event Player, Custom String("获得全部种类的彩虹治疗包！"));
			End;
		End;
	}
}

rule("造成击退|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Player Dealt Knockback;
		All;
		All;
	}

	actions
	{
		"无情连打"
		If(Event Player.YiXuanTianFu[31]);
			Event Player.GJ[0] += 1 * Event Player.YiXuanTianFu[31];
			Event Player.GJ[1] += 2 * Event Player.YiXuanTianFu[31];
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
		End;
		"猛击"
		If(Event Player.YiXuanTianFu[29]);
			Damage(Victim, Attacker, Max Health(Victim) * Event Player.YiXuanTianFu[29] * 0.050 * (Attacker.JT / 100) / ((
				Attacker.GJ[0] + Attacker.GJ[1]) * (Attacker.GJ[2] + Attacker.GJ[3]) / 100));
		End;
		"流水禅杖"
		If(Event Player.YiXuanTianFu[30]);
			Heal(Players Within Radius(Event Player, (Event Player.DX[0] + Event Player.DX[1]) * 5, Team Of(Event Player), Off), Event Player,
				50 * Event Player.YiXuanTianFu[30] * (Attacker.JT / 100));
		End;
	}
}

