			Custom String("灵狐"), Custom String("获得50点技能极速")), Array(53, Custom String("桎梏灼日"), Custom String("使用大招后\n返还50%\n终极技能能量")),
			Array(54, Custom String("毒蛇"), Custom String("击杀敌人夺取\n赏金猎人层数×100货币")), Array(55, Custom String("死亡绽放"), Custom String(
			"参与击杀回复500点血量")), Array(56, Custom String("再来"), Custom String("下一个天赋\n永久留在\n第一个天赋位")), Array(57, Custom String("美丽冻人"),
