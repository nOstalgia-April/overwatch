				Ability 1))), Null, Null, Right, 3, Color(Violet), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[99] += 1;
		Else If(Event Player.LinShi == 100);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("维生立场"), Ability Icon String(Hero(Baptiste), Button(
				Ability 2))), Null, Null, Right, 3, Color(White), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[100] += 1;
		Else If(Event Player.LinShi == 101);
