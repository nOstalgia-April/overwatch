rule("终极技能|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Ultimate)) == True;
	}

	actions
	{
		"双龙"
		If(Event Player.YiXuanTianFu[80] % 1 != 0 && Event Player.YiXuanTianFu[80] > 3);
			Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) + 100);
		End;
		"锻造"
		If(Event Player.YiXuanTianFu[61] && Ultimate Charge Percent(Event Player) >= 25);
			Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) - 25 / Event Player.YiXuanTianFu[61]);
			Event Player.HJ[0] += 50;
		End;
		"跃"
		If(Event Player.YiXuanTianFu[62] && Ultimate Charge Percent(Event Player) >= 5);
			Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) - 5 / Event Player.YiXuanTianFu[62]);
			Apply Impulse(Event Player, Up, 5, To Player, Cancel Contrary Motion);
			Apply Impulse(Event Player, Throttle Of(Event Player), 20, To Player, Cancel Contrary Motion);
		End;
		"归于大地"
		If(Event Player.YiXuanTianFu[60] && Ultimate Charge Percent(Event Player) >= 25 && Is Alive(Event Player)
			&& Event Player.GuiYuDaDi == 0);
			Start Rule(GuiYuDaDi, Do Nothing);
		End;
		"地壳震击"
		If(Event Player.YiXuanTianFu[58] && Ultimate Charge Percent(Event Player) >= 30 / Event Player.YiXuanTianFu[58]);
			Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) - 30 / Event Player.YiXuanTianFu[58]);
			Play Effect(All Players(All Teams), Ring Explosion, Color(Yellow), Event Player, 1);
			Set Status(Remove From Array(Players Within Radius(Event Player, (Event Player.DX[0] + Event Player.DX[1]) * 5, All Teams, Off),
				Event Player), Event Player, Stunned, 2);
			Apply Impulse(Players Within Radius(Event Player, (Event Player.DX[0] + Event Player.DX[1]) * 5, All Teams, Off), Up, 10, To World,
				Cancel Contrary Motion);
		End;
		"美丽动人"
		If(Event Player.YiXuanTianFu[57] && Ultimate Charge Percent(Event Player) >= 10 && Ultimate Charge Percent(Event Player) != 100);
			If(Ultimate Charge Percent(Event Player) >= 20 && Event Player.MeiLiDongReng == 1);
				Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) - 20 / Event Player.YiXuanTianFu[57]);
				Clear Status(Event Player, Frozen);
				Set Status(Event Player, Null, Invincible, 5);
				Create Effect(All Players(All Teams), Mei Frozen Effect, Color(White), Event Player, 1, Visible To Position and Radius);
				Event Player.MeiLiDongReng = Last Created Entity;
			Else If(Ultimate Charge Percent(Event Player) >= 10 && Ultimate Charge Percent(Event Player)
					!= 100 && Event Player.MeiLiDongReng == 0);
				Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) - 10 / Event Player.YiXuanTianFu[57]);
				Set Status(Event Player, Null, Frozen, 3);
				Set Status(Event Player, Null, Invincible, 3);
				Event Player.MeiLiDongReng = 1;
			End;
			Start Rule(MeiLiDongReng, Do Nothing);
		End;
		"引力装置"
		If(Event Player.YiXuanTianFu[66] != 0 && Ultimate Charge Percent(Event Player) >= 10);
			Start Rule(YinLiZhuangZhi, Do Nothing);
		End;
		"细胞能量"
		If(Event Player.YiXuanTianFu[59] && Ultimate Charge Percent(Event Player) != 100);
			Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) + 1 * Event Player.YiXuanTianFu[59]);
			Damage(Event Player, Event Player, 0.010 * Max Health(Event Player) / ((Event Player.GJ[0] + Event Player.GJ[1]) * (
				Event Player.GJ[2] + Event Player.GJ[3]) / 100));
			Wait(0.100, Abort When False);
			Loop;
		End;
	}
}

rule("引力装置")
{
	event
	{
		Subroutine;
		YinLiZhuangZhi;
	}

	actions
	{
		Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) - 10 / Event Player.YiXuanTianFu[66]);
		Play Effect(All Players(All Teams), Ring Explosion, Color(Blue), Event Player, (Event Player.DX[0] + Event Player.DX[1]) * 5);
		Players Within Radius(Event Player, (Event Player.DX[0] + Event Player.DX[1]) * 5, All Teams, Off).YinLiZhuangZhi -= 90;
		Players Within Radius(Event Player, (Event Player.DX[0] + Event Player.DX[1]) * 5, All Teams, Off).YL[1] -= 90;
		Set Gravity(Filtered Array(All Players(All Teams), Current Array Element.YinLiZhuangZhi != 0), Filtered Array(All Players(
			All Teams), Current Array Element.YinLiZhuangZhi != 0).YL[0] + Filtered Array(All Players(All Teams),
			Current Array Element.YinLiZhuangZhi != 0).YL[1]);
		Wait(10, Ignore Condition);
		Filtered Array(All Players(All Teams), Current Array Element.YinLiZhuangZhi != 0).YL[1] += 90;
		Set Gravity(Filtered Array(All Players(All Teams), Current Array Element.YinLiZhuangZhi != 0), Filtered Array(All Players(
			All Teams), Current Array Element.YinLiZhuangZhi != 0).YL[0] + Filtered Array(All Players(All Teams),
			Current Array Element.YinLiZhuangZhi != 0).YL[1]);
		Filtered Array(All Players(All Teams), Current Array Element.YinLiZhuangZhi != 0).YinLiZhuangZhi += 90;
	}
}

rule("美丽冻人")
{
	event
	{
		Subroutine;
		MeiLiDongReng;
	}

	actions
	{
		Wait(5, Ignore Condition);
		Destroy Effect(Event Player.MeiLiDongReng);
		Event Player.MeiLiDongReng = 0;
	}
}

rule("归于大地")
{
	event
	{
		Subroutine;
		GuiYuDaDi;
	}

	actions
	{
		Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) - 20 / Event Player.YiXuanTianFu[60]);
		Event Player.GuiYuDaDi = Players in View Angle(Event Player, Opposite Team Of(Team Of(Event Player)), 45);
		Cancel Primary Action(Event Player.GuiYuDaDi);
		Apply Impulse(Event Player.GuiYuDaDi, Down, 70, To World, Cancel Contrary Motion);
		Play Effect(All Players(All Teams), Bad Pickup Effect, Color(Violet), Event Player.GuiYuDaDi, 1);
		Event Player.GuiYuDaDi.YS[1] -= 30;
		Set Move Speed(Victim, (Event Player.GuiYuDaDi.YS[0] + Event Player.GuiYuDaDi.YS[1]) * (
			Event Player.GuiYuDaDi.YS[2] + Event Player.GuiYuDaDi.YS[3]));
		Event Player.GuiYuDaDi.YL[1] += 1000;
		Set Gravity(Event Player.GuiYuDaDi, Event Player.GuiYuDaDi.YL[0] + Event Player.GuiYuDaDi.YL[1]);
		Wait(2, Ignore Condition);
		Event Player.GuiYuDaDi.YS[1] += 30;
		Set Move Speed(Victim, (Event Player.GuiYuDaDi.YS[0] + Event Player.GuiYuDaDi.YS[1]) * (
			Event Player.GuiYuDaDi.YS[2] + Event Player.GuiYuDaDi.YS[3]));
		Event Player.GuiYuDaDi.YL[1] -= 1000;
		Set Gravity(Event Player.GuiYuDaDi, Event Player.GuiYuDaDi.YL[0] + Event Player.GuiYuDaDi.YL[1]);
		Event Player.GuiYuDaDi = 0;
	}
}

rule("缚能电弧")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Communicating(Event Player, Acknowledge) == True;
	}

	actions
	{
		Event Player.YiXuanTianFu[73] *= -1;
		Create Effect(All Players(All Teams), Mercy Damage Boosted Effect, Color(White), Event Player, 1, Visible To Position and Radius);
		Event Player.FuNengDianHu = Last Created Entity;
		Wait(12, Ignore Condition);
		Destroy Effect(Event Player.FuNengDianHu);
		Event Player.FuNengDianHu = 0;
		Wait(60 / Absolute Value(Event Player.YiXuanTianFu[73]), Ignore Condition);
		Event Player.YiXuanTianFu[73] *= -1;
		Small Message(Event Player, Custom String("缚能电弧已冷却"));
	}
}

rule("女武神")
{
	event
	{
		Subroutine;
		NvWuShen;
	}

	actions
	{
		Apply Impulse(Event Player, Up, 35, To Player, Cancel Contrary Motion);
		Apply Impulse(Event Player, Forward, 35, To Player, Cancel Contrary Motion);
		Heal(Event Player, Event Player, Max Health(Event Player) * 0.200);
		Event Player.YiXuanTianFu[75] *= -1;
		Wait(15 / Absolute Value(Event Player.YiXuanTianFu[75]), Ignore Condition);
		Event Player.YiXuanTianFu[75] *= -1;
		Small Message(Event Player, Custom String("女武神已冷却"));
	}
}

rule("轨道射线")
{
	event
	{
		Subroutine;
		GuiDaoSheXian;
	}

	actions
	{
		Create Beam Effect(All Players(All Teams), Bad Beam, Victim, Victim + Vector(0, 50, 0), Color(Red),
			Visible To Position and Radius);
		Attacker.GuiDaoSheXian = Last Created Entity;
		Attacker.YiXuanTianFu[76] *= -1;
		Start Damage Over Time(Victim, Attacker, 5, 100 * Absolute Value(Event Player.YiXuanTianFu[76]));
		Destroy Effect(Attacker.GuiDaoSheXian);
		Wait(60 / Absolute Value(Event Player.YiXuanTianFu[76]), Ignore Condition);
		Attacker.YiXuanTianFu[76] *= -1;
		Small Message(Attacker, Custom String("轨道射线已冷却"));
	}
}

rule("动能俘获")
{
	event
	{
		Subroutine;
		DongNeng;
	}

	actions
	{
		Event Player.DongNeng = Player Closest To Reticle(Event Player, Opposite Team Of(Team Of(Event Player)));
		Apply Impulse(Event Player.DongNeng, -1 * Facing Direction Of(Event Player), 50, To World, Cancel Contrary Motion);
		Set Environment Credit Player(Event Player.DongNeng, Event Player);
		Event Player.YiXuanTianFu[77] *= -1;
		Wait(5 / Absolute Value(Event Player.YiXuanTianFu[77]), Ignore Condition);
		Set Environment Credit Player(Event Player.DongNeng, Null);
		Event Player.YiXuanTianFu[77] *= -1;
		Small Message(Event Player, Custom String("动能俘获已冷却"));
	}
}

rule("负载降温")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		(Server Load Average >= 255 || Server Load >= 255 || Server Load Peak >= 255) == True;
	}

	actions
	{
		Global.Z = Is Match Complete;
		Set Slow Motion(Is Match Complete);
	}
}

rule("负载降温")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		(Server Load Average < 255 && Server Load < 255 && Server Load Peak < 255) == True;
		Global.Z < 100;
	}

	actions
	{
		Global.Z += 10;
		Wait(Is Match Complete, Abort When False);
		Set Slow Motion(Global.Z);
		Loop;
	}
}

rule("重开游戏")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Is Match Complete == True;
	}

	actions
	{
		Wait(2.850, Ignore Condition);
		Restart Match;
	}
}

rule("赏金")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	actions
	{
		Wait(Random Real(0.200, 1), Ignore Condition);
		Create In-World Text(Hero Of(Event Player) != Hero(Sombra) ? All Players(All Teams) : Event Player, Custom String("\n		赏金：{0}",
			Event Player.XuanShang), Event Player, 1, Clip Against Surfaces, Visible To Position and String, Color(White),
			Default Visibility);
		Create Icon(Local Player.YiXuanTianFu[90] && Is Alive(Event Player) == True ? Local Player : Null, Event Player, Arrow: Down,
			Visible To and Position, Color(White), False);
	}
}

rule("|全局设置|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		"代码受到保护，请尊重作者劳动成果"
		Disable Inspector Recording;
		Set Match Time(False);
		Disable Built-In Game Mode Announcer;
		Disable Built-In Game Mode Music;
	}
}

rule("集结时间")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Is Assembling Heroes == True;
	}

	actions
	{
		Set Match Time(False);
		Wait(65, Ignore Condition);
		Set Match Time(Match Time + 300);
		Wait Until(Is Objective Complete(0), 99999);
		Set Match Time(Match Time + 300);
		Wait Until(Is Objective Complete(1), 99999);
		Set Match Time(Match Time + 300);
	}
}

rule("新手补偿")
{
	event
	{
		Player Joined Match;
		All;
		All;
	}

	actions
	{
		Wait(5, Ignore Condition);
		Event Player.M += Number Of Eliminations(Last Of(Sorted Array(All Players(All Teams), Number Of Eliminations(
			Current Array Element)))) * 1500;
	}
}

rule("Rule 71")
{
	event
	{
		Subroutine;
		ShuxingInit;
	}

	actions
	{
		"(攻击力+临时攻击力)*(百分比攻击力+临时百分比攻击力)"
		Event Player.GJ[0] = 100;
		Event Player.GJ[1] = 0;
		Event Player.GJ[2] = 1;
		Event Player.GJ[3] = 0;
		"(法强+临时法强)+技能伤害*(百分比法强+临时百分比法强)"
		Event Player.FQ[0] = 0;
		Event Player.FQ[1] = 0;
		Event Player.FQ[2] = 0;
		Event Player.FQ[3] = 0;
		"(额外生命值)*(百分比额外生命值+临时百分比额外生命值)"
		Event Player.SM[0] = 0;
		Event Player.SM[1] = 1;
		Event Player.SM[2] = 0;
		"(额外护盾)*(百分比额外护盾+临时百分比额外护盾)"
		Event Player.HD[0] = 0;
		Event Player.HD[1] = 1;
		Event Player.HD[2] = 0;
		"(额外护甲)*(百分比额外护甲+临时百分比额外护甲)"
		Event Player.HJ[0] = 0;
		Event Player.HJ[1] = 1;
		Event Player.HJ[2] = 0;
		"基础生命值百分比"
		Event Player.JC = 100;
		"受到伤害"
		Event Player.SS = 100;
		"cd"
		Event Player.CD = 1;
		"(移速+临时移速)*(百分比移速+百分比临时移速)"
		Event Player.YS[0] = 100;
		Event Player.YS[1] = 0;
		Event Player.YS[2] = 1;
		Event Player.YS[3] = 0;
		"吸血+临时吸血"
		Event Player.XX[0] = 0;
		Event Player.XX[1] = 0;
		"(治疗量+临时治疗量)*(百分比治疗量+临时百分比治疗量)"
		Event Player.ZL[0] = 100;
		Event Player.ZL[1] = 0;
		Event Player.ZL[2] = 1;
		Event Player.ZL[3] = 0;
		"(受到治疗量+临时受治疗量)*(百分比受治疗量+临时百分比受治疗量)"
		Event Player.SZ[0] = 100;
		Event Player.SZ[1] = 0;
		Event Player.SZ[2] = 1;
		Event Player.SZ[3] = 0;
		"暴击倍率"
		Event Player.BJ = 0;
		"弹道速度"
		Event Player.DD = 100;
		"引力+临时引力"
		Event Player.YL[0] = 100;
		Event Player.YL[1] = 0;
		"击退"
		Event Player.JT = 100;
		"大小+临时大小"
		Event Player.DX[0] = 1;
		Event Player.DX[1] = 0;
		"钱"
		Event Player.M = 1000;
		"宝石"
		Event Player.BS = 1;
		"技能点"
		Event Player.JND = 1;
		"等级经验"
		Event Player.DJ[0] = 1;
		Event Player.DJ[1] = 0;
		"商店随机池（ID池）"
		Event Player.ShangPing = Array Slice(Mapped Array(Global.Items, First Of(Current Array Element)), 0, 39);
		"闪属性"
		Event Player.ShanShuXing = Color(Violet);
		"刷新骰子"
		Event Player.TouZi = 1;
	}
}

rule("Rule 71")
{
	event
	{
		Ongoing - Global;
	}

