rule("使用主要武器|——————————————————————————————————————————————————————————————————")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Firing Primary(Event Player) == True;
	}

	actions
	{
		"火箭重锤"
		If(Event Player.YiXuanTianFu[15] && Hero Of(Event Player) == Hero(Reinhardt));
			Create Projectile(Reinhardt Fire Strike, Event Player, Eye Position(Event Player), Null, To World, Damage, Opposite Team Of(
				Team Of(Event Player)), 50 * Event Player.YiXuanTianFu[15], 2, 0, Bad Explosion, Explosion Sound, 0, 25, 5, 0, 0, 0);
		Else If(Event Player.YiXuanTianFu[15] && Hero Of(Event Player) == Hero(Brigitte));
			Create Projectile(Reinhardt Fire Strike, Event Player, Eye Position(Event Player), Null, To World, Damage, Opposite Team Of(
				Team Of(Event Player)), 50 * Event Player.YiXuanTianFu[15], 2, 0, Bad Explosion, Explosion Sound, 0, 25, 5, 0, 0, 0);
		End;
		"维和者"
		If(Event Player.YiXuanTianFu[21] && Event Player.M >= 10000);
			Start Rule(ShenSheShou, Do Nothing);
		End;
		"动能俘获"
		If(Event Player.YiXuanTianFu[77] > 0);
			Start Rule(DongNeng, Do Nothing);
		End;
		"战术目镜"
		If(Event Player.YiXuanTianFu[24] == 1);
			Skip If(Is In Line of Sight(Event Player, Player Closest To Reticle(Event Player, Opposite Team Of(Team Of(Event Player))),
				Barriers Do Not Block LOS) == False, 1);
			Event Player.ZhanShuMuJing = Player Closest To Reticle(Event Player, Opposite Team Of(Team Of(Event Player)));
			Skip If(Event Player.ZhanShuMuJing != Event Player && Event Player.ZhanShuMuJing != 0 && Is Alive(Event Player.ZhanShuMuJing), 1);
			Event Player.ZhanShuMuJing = First Of(Sorted Array(Filtered Array(All Living Players(Opposite Team Of(Team Of(Event Player))),
				Is In Line of Sight(Event Player, Current Array Element, Barriers Do Not Block LOS)), Distance Between(Current Array Element,
				Event Player)));
			Skip If(Event Player.ZhanShuMuJing == Event Player || Event Player.ZhanShuMuJing == 0, 1);
			Start Facing(Event Player, Vector Towards(Eye Position(Event Player), Eye Position(Event Player.ZhanShuMuJing) + World Vector Of(
				Up, Event Player.ZhanShuMuJing, Rotation) * 0.020 + World Vector Of(Vector(Speed Of In Direction(Event Player.ZhanShuMuJing,
				World Vector Of(Left, Event Player, Rotation)) / 32 / 1, 0, 0), Event Player, Rotation)), Absolute Value(9999999.000),
				To World, Direction and Turn Rate);
			disabled Wait(0.233, Ignore Condition);
			disabled Loop If Condition Is True;
			Wait Until(!Is Firing Primary(Event Player), 99999);
			Stop Facing(Event Player);
			Event Player.ZhanShuMuJing = 0;
		End;
	}
}

rule("重踏")
{
	event
	{
		Subroutine;
		ZhongTa;
	}

	actions
	{
		Wait(0.250, Ignore Condition);
		Apply Impulse(Event Player, Down, 70, To World, Cancel Contrary Motion);
		Wait(0.250, Ignore Condition);
		Damage(Remove From Array(Players Within Radius(Event Player, (Event Player.DX[0] + Event Player.DX[1]) * 7, Opposite Team Of(
			Team Of(Event Player)), Off), Event Player), Event Player, Max Health(Event Player) * 0.100);
		If(Max Health(Event Player) * 0.002 < 5);
			Set Status(Remove From Array(Players Within Radius(Event Player, (Event Player.DX[0] + Event Player.DX[1]) * 7, Opposite Team Of(
				Team Of(Event Player)), Off), Event Player), Null, Knocked Down, Max Health(Event Player) * 0.002);
		Else If(Max Health(Event Player) * 0.002 >= 5);
			Set Status(Remove From Array(Players Within Radius(Event Player, (Event Player.DX[0] + Event Player.DX[1]) * 7, Opposite Team Of(
				Team Of(Event Player)), Off), Event Player), Null, Knocked Down, 5);
		End;
		Play Effect(All Players(All Teams), Ring Explosion, Color(White), Event Player + Vector(0, 0, 0), (
			Event Player.DX[0] + Event Player.DX[1]) * 7);
		Event Player.YiXuanTianFu[28] *= -1;
		Wait(30 / Absolute Value(Event Player.YiXuanTianFu[28]), Ignore Condition);
		Event Player.YiXuanTianFu[28] *= -1;
		Small Message(Event Player, Custom String("重踏已冷却"));
	}
}

rule("两颗心脏")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Normalized Health(Event Player) <= 0.500;
	}

	actions
	{
		If(Event Player.YiXuanTianFu[27] > 0);
			Add Health Pool To Player(Event Player, Armor, Player Stat(Event Player, Eliminations) * 80 * Absolute Value(
				Event Player.YiXuanTianFu[27]), False, True);
			Event Player.LiangKeXin = Last Created Health Pool;
			Play Effect(All Players(All Teams), Heal Target Active Effect, Color(White), Event Player, 1);
			Wait(2, Ignore Condition);
			Play Effect(All Players(All Teams), Heal Target Active Effect, Color(White), Event Player, 1);
			Wait(2, Ignore Condition);
			Play Effect(All Players(All Teams), Heal Target Active Effect, Color(White), Event Player, 1);
			Wait(2, Ignore Condition);
			Play Effect(All Players(All Teams), Heal Target Active Effect, Color(White), Event Player, 1);
			Wait(2, Ignore Condition);
			Play Effect(All Players(All Teams), Heal Target Active Effect, Color(White), Event Player, 1);
			Remove Health Pool From Player(Event Player.LiangKeXin);
			Event Player.YiXuanTianFu[27] *= -1;
			Wait(25 / Absolute Value(Event Player.YiXuanTianFu[27]), Ignore Condition);
			Event Player.YiXuanTianFu[27] *= -1;
			Small Message(Event Player, Custom String("两颗心脏已冷却"));
			Wait(1, Ignore Condition);
		End;
	}
}

