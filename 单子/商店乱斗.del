			Event Player.YiXuanTianFu[108] += 1;
			Event Player.BJ += 1;
		Else If(Event Player.LinShi == 109);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("粒子屏障"), Ability Icon String(Hero(Wrecking Ball), Button(
				Ability 2))), Null, Null, Right, 3, Color(Blue), Null, Null, Visible To, Default Visibility);
