			Event Player.FuZhiQi -= 1;
			Wait(0.100, Ignore Condition);
			Loop;
		End;
	}
}

rule("选择天赋的子程序")
{
	event
	{
		Subroutine;
		XuanZeTianFu2;
	}

	actions
	{
		If(Event Player.LinShi == 76);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("轨道镭射"), Ability Icon String(Hero(Juno), Button(Ultimate))),
				Null, Null, Right, 3, Color(Violet), Null, Null, Visible To, Default Visibility);
			If(Event Player.YiXuanTianFu[76] >= 0);
