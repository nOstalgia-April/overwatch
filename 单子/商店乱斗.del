				Set Healing Dealt(Event Player, (Event Player.ZL[0] + Event Player.ZL[1]) * (Event Player.ZL[2] + Event Player.ZL[3]));
			Else If(Event Player.ZL[0] >= 200);
				Event Player.GJ[0] += Event Player.ZL[0];
				Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			End;
		Else If(Event Player.LinShi == 98);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("彩虹恢复包"), Ability Icon String(Hero(Brigitte), Button(
				Ability 2))), Null, Null, Right, 3, Color(White), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[98] += 1;
		Else If(Event Player.LinShi == 99);
