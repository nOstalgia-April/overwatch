			If(Event Player.DJ[1] >= 50 * Event Player.DJ[0] && Event Player.DJ[0] < 15);
				Start Rule(ShengJi, Do Nothing);
			Else If(Event Player.DJ[1] >= 750 && Event Player.DJ[0] >= 15 && Event Player.YiXuanTianFu[1]);
				Start Rule(ShengJi, Do Nothing);
			End;
			Wait(0.250, Ignore Condition);
			"经验"
			Event Player.DJ[1] += 50 * Event Player.DJ[0];
			"升级/古夫"
			If(Event Player.DJ[1] >= 50 * Event Player.DJ[0] && Event Player.DJ[0] < 15);
				Start Rule(ShengJi, Do Nothing);
			Else If(Event Player.DJ[1] >= 750 && Event Player.DJ[0] >= 15 && Event Player.YiXuanTianFu[1]);
				Start Rule(ShengJi, Do Nothing);
			End;
			Wait(0.250, Ignore Condition);
			"经验"
			Event Player.DJ[1] += 50 * Event Player.DJ[0];
			"升级/古夫"
			If(Event Player.DJ[1] >= 50 * Event Player.DJ[0] && Event Player.DJ[0] < 15);
				Start Rule(ShengJi, Do Nothing);
			Else If(Event Player.DJ[1] >= 750 && Event Player.DJ[0] >= 15 && Event Player.YiXuanTianFu[1]);
				Start Rule(ShengJi, Do Nothing);
			End;
			Wait(0.250, Ignore Condition);
			"经验"
			Event Player.DJ[1] += 50 * Event Player.DJ[0];
			"升级/古夫"
			If(Event Player.DJ[1] >= 50 * Event Player.DJ[0] && Event Player.DJ[0] < 15);
				Start Rule(ShengJi, Do Nothing);
			Else If(Event Player.DJ[1] >= 750 && Event Player.DJ[0] >= 15 && Event Player.YiXuanTianFu[1]);
				Start Rule(ShengJi, Do Nothing);
