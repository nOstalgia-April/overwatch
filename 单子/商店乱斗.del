			Else If(Event Player.YiXuanTianFu[76] < 0);
				Event Player.YiXuanTianFu[76] -= 1;
			End;
		Else If(Event Player.LinShi == 77);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("动能俘获"), Ability Icon String(Hero(Sigma), Button(Ability 1))),
				Null, Null, Right, 3, Color(White), Null, Null, Visible To, Default Visibility);
