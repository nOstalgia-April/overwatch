				Ability 2))), Null, Null, Right, 3, Color(Blue), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[101] += 1;
			Event Player.HD[1] += 1;
		Else If(Event Player.LinShi == 102);
