rule("人物属性初始化")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	actions
	{
		Call Subroutine(ShuxingInit);
	}
}

rule("升级子程序")
{
	event
	{
		Subroutine;
		ShengJi;
	}

	actions
	{
		Event Player.DJ[0] += 1;
		Event Player.DJ[1] = 0;
		Event Player.BS += 1;
		Event Player.JND += 0.340;
		If(Event Player.JND >= 1 && Event Player.JND - 0.340 < 1 && Count Of(Global.TFs) > 0);
			Call Subroutine(TianFuShuaXin);
		End;
		If(Array Contains(All Tank Heroes, Hero Of(Event Player)) == True);
			Event Player.JC += 10 + 5 * Event Player.DJ[0];
			Set Max Health(Event Player, Event Player.JC);
			Event Player.GJ[0] += 1 + 1 * Event Player.DJ[0];
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.SS *= 0.990;
		Else If(Array Contains(All Damage Heroes, Hero Of(Event Player)) == True);
			Event Player.GJ[0] += 2 + 1 * Event Player.DJ[0];
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.JC += 5 + 1 * Event Player.DJ[0];
			Set Max Health(Event Player, Event Player.JC);
		Else If(Array Contains(All Support Heroes, Hero Of(Event Player)) == True);
			Event Player.JC += 5 + 1.500 * Event Player.DJ[0];
			Set Max Health(Event Player, Event Player.JC);
			Event Player.GJ[0] += 1 + 1 * Event Player.DJ[0];
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.ZL[0] += 2 + 1 * Event Player.DJ[0];
			Set Healing Dealt(Event Player, (Event Player.ZL[0] + Event Player.ZL[1]) * (Event Player.ZL[2] + Event Player.ZL[3]));
		End;
		"升级咯"
		If(Event Player.YiXuanTianFu[4]);
			If(Event Player.DJ[0] == 15 && !Event Player.YiXuanTianFu[0]);
				Event Player.ShengJiLou = Event Player.YiXuanTianFu[4] + 1;
				Abort;
			End;
			Event Player.ShengJiLou -= 1;
			Wait(0.250, Ignore Condition);
			Loop If(Event Player.ShengJiLou > 0);
			Event Player.ShengJiLou = Event Player.YiXuanTianFu[4] + 1;
		End;
	}
}

rule("hud文本")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Create HUD Text(Local Player.Backpack_open[0] == 0 ? Local Player : Null, Null, Custom String(
			"欢迎来到天赋角斗场，代码6d7v5\n击杀敌人或被击杀获得经验和货币\n被击杀时会叠加连败层数，连败越高死亡获得的奖励越高\n喷漆打开天赋选择/商店界面，互动选择\n商店出bug面朝空旷方向重新开启即可\n{0}", Custom String(
			"升级获得宝石，每三级获得一个天赋，满级15级\n蹲加跳切换人称")), Null, Left, -1, Color(White), Color(Rose), Color(Yellow), Visible To and String,
			Default Visibility);
		Create HUD Text(Local Player, Null, Null, Custom String("{0}\n{1}\n{2}", Custom String("{0}\n{1}\n{2}", Custom String(
			"攻击力：{0}|{1}%", (Local Player.GJ[0] + Local Player.GJ[1]) * (Local Player.GJ[2] + Local Player.GJ[3]), (
			Local Player.GJ[3] + Local Player.GJ[2] - 1) * 100), Custom String("技能伤害：{0}|{1}%", Local Player.FQ[0] + Local Player.FQ[1], (
			Local Player.FQ[3] + Local Player.FQ[2] + 1) * 100), Custom String("生命值：{0}|{1}%", Max Health Of Type(Local Player, Health), (
			Local Player.SM[1] + Local Player.SM[2] - 1) * 100)), Custom String("{0}\n{1}\n{2}", Custom String("护盾：{0}|{1}%",
			Max Health Of Type(Local Player, Shields), 100 * (Local Player.HD[1] + Local Player.HD[2] - 1)), Custom String("护甲：{0}|{1}%",
			Max Health Of Type(Local Player, Armor), 100 * (Local Player.HJ[1] + Local Player.HJ[2] - 1)), Custom String("冷却：{0}%",
			100 * 1 / Local Player.CD)), Custom String("{0}\n{1}\n{2}", Custom String("{0}\n{1}\n{2}", Custom String("移速：{0}", (
			Local Player.YS[0] + Local Player.YS[1]) * (Local Player.YS[2] + Local Player.YS[3])), Custom String("治疗量：{0}|{1}%", (
			Local Player.ZL[0] + Local Player.ZL[1]) * (Local Player.ZL[2] + Local Player.ZL[3]), (
			Local Player.ZL[2] + Local Player.ZL[3] - 1) * 100), Custom String("受治疗量：{0}", (Local Player.SZ[0] + Local Player.SZ[1]) * (
			Local Player.SZ[2] + Local Player.SZ[3]))), Custom String("{0}\n{1}\n{2}", Custom String("吸血：{0}%", (
			Local Player.XX[0] + Local Player.XX[1]) * 100), Custom String("弹道速度：{0}%", Local Player.DD), Custom String("受伤害量：{0}%",
			Local Player.SS)), Custom String("{0}\n	{1}\n{2}", Custom String("击退倍率：{0}%", Local Player.JT), Custom String("引力：{0}",
			Local Player.YL[0] + Local Player.YL[1]), Custom String("{0}\n	{1}", Custom String("基础生命值：{0}%", Local Player.JC),
			Custom String("暴伤倍率：{0}%", 100 * (1 + Local Player.BJ)))))), Right, -1, Color(White), Color(White), Custom Color(255, 142, 12,
			200), Visible To Sort Order String and Color, Default Visibility);
		Create HUD Text(Local Player, Null, Null, Custom String("货币：{0}宝石：{1}等级：{2}", Local Player.M, Local Player.BS, Local Player.DJ[0]),
			Right, 1, Null, Null, Color(White), Visible To and String, Default Visibility);
		Create HUD Text(Local Player.YiXuanTianFu[3] >= 1 ? Local Player : Null, Custom String("{0} {1}{2}", Custom String("冰香蕉"),
			Ability Icon String(Hero(Winston), Button(Ultimate)), Round To Integer(Local Player.YiXuanTianFu[3], Down)), Null, Null, Right,
			2, Color(Aqua), Null, Null, Visible To and String, Default Visibility);
		Create HUD Text(Local Player.TouZi >= 1 ? Local Player : Null, Custom String("{0} {1}", Custom String("刷新骰子{0}", Round To Integer(
			Local Player.TouZi, Down)), Ability Icon String(Hero(Cassidy), Button(Ability 1))), Null, Null, Right, 2, Color(White), Null,
			Null, Visible To and String, Default Visibility);
		Create HUD Text(Local Player.DX[0] + Local Player.DX[1] >= 2.500 ? Local Player : Null, Custom String("{0} {1}", Custom String(
			"战争巨兽"), Ability Icon String(Hero(Bastion), Button(Ultimate))), Null, Null, Right, 2, Color(White), Null, Null,
			Visible To and String, Default Visibility);
		Create HUD Text(Local Player.TeDingTianTu[0] >= 1 ? Local Player : Null, Custom String("{0} {1}", Custom String("水绿宝石{0}",
			Local Player.TeDingTianTu[0]), Ability Icon String(Hero(Kiriko), Button(Ability 2))), Null, Null, Right, 2, Color(White), Null,
			Null, Visible To and String, Default Visibility);
		Create HUD Text(Local Player.TeDingTianTu[1] >= 1 ? Local Player : Null, Custom String("{0} {1}", Custom String("传说金币{0}",
			Local Player.TeDingTianTu[1]), Ability Icon String(Hero(Kiriko), Button(Ability 2))), Null, Null, Right, 2, Color(White), Null,
			Null, Visible To and String, Default Visibility);
		Create HUD Text(Local Player.LieRen != 0 ? Local Player : Null, Custom String("{0} {1}", Custom String("赏金猎人{0}", Round To Integer(
			Local Player.LieRen, Down)), Ability Icon String(Hero(Cassidy), Button(Ultimate))), Null, Null, Right, 2, Custom Color(205,
			133, 63, 200), Null, Null, Visible To and String, Default Visibility);
		Create HUD Text(Local Player.YiXuanTianFu[68] ? Local Player : Null, Custom String("{0} {1}", Custom String("猪猪存钱罐{0}",
			Local Player.CunQianGuan), Ability Icon String(Hero(Roadhog), Button(Ultimate))), Null, Null, Right, 2, Color(White), Null,
			Null, Visible To and String, Default Visibility);
		Create HUD Text(Local Player.LianBai >= 3 ? Local Player : Null, Custom String("{0} {1}", Custom String("连败 {0}", Round To Integer(
			Local Player.LianBai, Down)), Ability Icon String(Hero(Ashe), Button(Ultimate))), Null, Null, Right, 2, Color(White), Null,
			Null, Visible To and String, Default Visibility);
	}
}

rule("选择天赋的子程序")
{
	event
	{
		Subroutine;
		XuanZeTianFu;
	}

	actions
	{
		If(Event Player.YiXuanTianFu[56] == -1);
			Event Player.YiXuanTianFu[56] = Event Player.LinShi;
		End;
		If(Event Player.LinShi == 0);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("成长，生命，幸福，还有朋友"), Ability Icon String(Hero(Mercy), Button(
				Ability 2))), Null, Null, Right, 3, Color(Aqua), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[0] = 1;
		Else If(Event Player.LinShi == 1);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("宝石批发"), Ability Icon String(Hero(Sombra), Button(Ultimate))),
				Null, Null, Right, 3, Color(Aqua), Null, Null, Visible To, Default Visibility);
			Event Player.BS += Random Integer(1, 15);
		Else If(Event Player.LinShi == 2);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("猿神启动"), Ability Icon String(Hero(Winston), Button(
				Ultimate))), Null, Null, Right, 3, Color(Aqua), Null, Null, Visible To, Default Visibility);
			Start Forcing Player To Be Hero(Event Player, Hero(Winston));
			Event Player.JC += 100;
			Set Max Health(Event Player, Event Player.JC);
			Event Player.YS[0] += 15;
			Set Move Speed(Event Player, (Event Player.YS[0] + Event Player.YS[1]) * (Event Player.YS[2] + Event Player.YS[3]));
			Event Player.DX[0] += 0.500;
			Start Scaling Player(Event Player, Event Player.DX[0] + Event Player.DX[1], True);
			Event Player.YiXuanTianFu[2] += 1;
		Else If(Event Player.LinShi == 3);
			Modify Player Variable(Event Player, ShangPing, Append To Array, 39);
			Modify Player Variable(Event Player, ShangPing, Append To Array, 39);
			Modify Player Variable(Event Player, ShangPing, Append To Array, 39);
			Event Player.YiXuanTianFu[3] += 1.010;
		Else If(Event Player.LinShi == 4);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("升级咯"), Ability Icon String(Hero(Mercy), Button(Ability 2))),
				Null, Null, Right, 3, Color(Aqua), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[4] += 1;
			Event Player.ShengJiLou = Event Player.YiXuanTianFu[4] + 1;
		Else If(Event Player.LinShi == 5);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("高级会员"), Ability Icon String(Hero(Sigma), Button(
				Secondary Fire))), Null, Null, Right, 3, Color(Aqua), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[5] += 1;
		Else If(Event Player.LinShi == 6);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("无中生有"), Ability Icon String(Hero(Moira), Button(
				Primary Fire))), Null, Null, Right, 3, Color(Aqua), Null, Null, Visible To, Default Visibility);
			Event Player.JND += 2;
		Else If(Event Player.LinShi == 7);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("龙神之刃"), Ability Icon String(Hero(Genji), Button(Ultimate))),
				Null, Null, Right, 3, Color(Orange), Null, Null, Visible To, Default Visibility);
			Event Player.GJ[0] += 65;
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.YiXuanTianFu[80] += 1;
			If(Event Player.YiXuanTianFu[80] % 1 && Event Player.YiXuanTianFu[80] > 3);
				Event Player.LinShi2 = Random Integer(1, 2);
				Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) + 100);
				If(Event Player.LinShi2 == 1);
					Start Forcing Player To Be Hero(Event Player, Hero(Genji));
					Event Player.CD += 100;
				Else If(Event Player.LinShi2 == 2);
					Start Forcing Player To Be Hero(Event Player, Hero(Hanzo));
					Event Player.GJ[0] += 500;
					Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
				End;
			End;
		Else If(Event Player.LinShi == 8);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("防御矩阵"), Ability Icon String(Hero(D.Va), Button(
				Secondary Fire))), Null, Null, Right, 3, Color(Blue), Null, Null, Visible To, Default Visibility);
			Event Player.SS = Event Player.SS * 0.600;
			Set Damage Received(Event Player, Event Player.SS);
		Else If(Event Player.LinShi == 9);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("屏障与巨甲"), Ability Icon String(Hero(Reinhardt), Button(
				Secondary Fire))), Null, Null, Right, 3, Color(White), Null, Null, Visible To, Default Visibility);
			Event Player.HD[0] += 600;
			Event Player.HJ[0] += 600;
		Else If(Event Player.LinShi == 10);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("地狱火"), Ability Icon String(Hero(Reaper), Button(
				Primary Fire))), Null, Null, Right, 3, Color(Violet), Null, Null, Visible To, Default Visibility);
			Event Player.XX[0] += 0.500;
		Else If(Event Player.LinShi == 11);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("能量标枪"), Ability Icon String(Hero(Orisa), Button(
				Secondary Fire))), Null, Null, Right, 3, Color(White), Null, Null, Visible To, Default Visibility);
			Event Player.FQ[2] += 0.700;
		Else If(Event Player.LinShi == 12);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("忍者足具"), Ability Icon String(Hero(Kiriko), Button(
				Ability 1))), Null, Null, Right, 3, Color(White), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[12] += 1;
			Event Player.YiXuanTianFu[80] += 1;
			If(Event Player.YiXuanTianFu[80] % 1 && Event Player.YiXuanTianFu[80] > 3);
				Event Player.LinShi2 = Random Integer(1, 2);
				Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) + 100);
				If(Event Player.LinShi2 == 1);
					Start Forcing Player To Be Hero(Event Player, Hero(Genji));
					Event Player.CD += 100;
				Else If(Event Player.LinShi2 == 2);
					Start Forcing Player To Be Hero(Event Player, Hero(Hanzo));
					Event Player.GJ[0] += 500;
					Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
				End;
			End;
		Else If(Event Player.LinShi == 13);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("兔子跳"), Ability Icon String(Hero(D.Va), Button(Ultimate))),
				Null, Null, Right, 3, Color(Rose), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[13] += 1;
		Else If(Event Player.LinShi == 14);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("一拳"), Ability Icon String(Hero(Doomfist), Button(
				Secondary Fire))), Null, Null, Right, 3, Color(Orange), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[14] += 1;
			Set Primary Fire Enabled(Event Player, !Event Player.YiXuanTianFu[14]);
			Set Secondary Fire Enabled(Event Player, !Event Player.YiXuanTianFu[14]);
			Event Player.GJ[2] += 1;
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
		Else If(Event Player.LinShi == 15);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("火箭重锤"), Ability Icon String(Hero(Reinhardt), Button(
				Ability 2))), Null, Null, Right, 3, Color(Orange), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[15] += 1;
		Else If(Event Player.LinShi == 16);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("灭"), Ability Icon String(Hero(Zenyatta), Button(Ability 2))),
				Null, Null, Right, 3, Color(Violet), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[16] += 1;
		Else If(Event Player.LinShi == 17);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("圣"), Ability Icon String(Hero(Zenyatta), Button(Ability 1))),
				Null, Null, Right, 3, Color(White), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[17] += 1;
		Else If(Event Player.LinShi == 18);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("熔火核心"), Ability Icon String(Hero(Torbjörn), Button(
				Ultimate))), Null, Null, Right, 3, Color(Orange), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[18] += 1;
		Else If(Event Player.LinShi == 19);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("太阳光塔"), Ability Icon String(Hero(Illari), Button(
				Ability 2))), Null, Null, Right, 3, Color(Blue), Null, Null, Visible To, Default Visibility);
			Event Player.YiXuanTianFu[19] += 1;
		Else If(Event Player.LinShi == 20);
			Event Player.JC += 300;
			Set Max Health(Event Player, Event Player.JC);
			Event Player.SS = Event Player.SS * 0.800;
			Set Damage Received(Event Player, Event Player.SS);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("猪神"), Ability Icon String(Hero(Roadhog), Button(Ultimate))),
				Null, Null, Right, 3, Color(Orange), Null, Null, Visible To, Default Visibility);
			If(Event Player.YiXuanTianFu[20] >= 0);
				Event Player.YiXuanTianFu[20] += 1;
			Else If(Event Player.YiXuanTianFu[20] < 0);
				Event Player.YiXuanTianFu[20] -= 1;
			End;
		Else If(Event Player.LinShi == 21);
			Create HUD Text(Event Player, Custom String("{0} {1}", Custom String("神射手"), Ability Icon String(Hero(Cassidy), Button(
				Primary Fire))), Null, Null, Right, 3, Color(Orange), Null, Null, Visible To, Default Visibility);
