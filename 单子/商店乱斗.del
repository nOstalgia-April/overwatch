rule("购买高级商品的子程序")
{
	event
	{
		Subroutine;
		GouMaiGaoJi;
	}

	actions
	{
		Create HUD Text(All Players(All Teams), Custom String(""), Null, Null, Left, 0, Color(White), Color(White), Color(White),
			Visible To and String, Default Visibility);
		"镜像增殖"
		If(Event Player.YiXuanTianFu[96]);
			Event Player.LinShi2 = 0;
			While(Event Player.LinShi2 < Event Player.YiXuanTianFu[96]);
				Modify Player Variable(Event Player, ShangPing, Append To Array, Event Player.LinShi);
				Event Player.LinShi2 += 1;
			End;
		End;
		Event Player.LinShi2 = 0;
		"子程序"
		If(Event Player.LinShi == 0 && Event Player.BS >= 1);
			Event Player.LinShi = -1;
			Event Player.GJ[2] += 5 * 0.010;
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.BS -= 1;
		Else If(Event Player.LinShi == 1 && Event Player.BS >= 1);
			Event Player.LinShi = -1;
			Event Player.FQ[0] += 10;
			Event Player.BS -= 1;
		Else If(Event Player.LinShi == 2 && Event Player.BS >= 2);
			Event Player.LinShi = -1;
			Event Player.CD += 0.400;
			Event Player.YS[0] += 20;
			Set Move Speed(Event Player, (Event Player.YS[0] + Event Player.YS[1]) * (Event Player.YS[2] + Event Player.YS[3]));
			Event Player.BS -= 2;
		Else If(Event Player.LinShi == 3 && Event Player.BS >= 2);
			Event Player.GJ[0] += (Event Player.DX[0] + Event Player.DX[1] - 1) * Max Health(Event Player) * 0.005;
			Event Player.LinShi = -1;
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.BS -= 2;
		Else If(Event Player.LinShi == 4 && Event Player.BS >= 1);
			Event Player.LinShi = -1;
			Event Player.BS -= 1;
			Event Player.JC += 50;
			Set Max Health(Event Player, Event Player.JC);
		Else If(Event Player.LinShi == 5 && Event Player.BS >= 3);
			Event Player.BS -= 3;
			If(Event Player.YiXuanTianFu[67]);
				If(Event Player.YiXuanTianFu[71]);
					Event Player.LinShi2 = 12;
				Else;
					Event Player.LinShi2 = Random Integer(1, 12);
				End;
			Else;
				If(Event Player.YiXuanTianFu[71]);
					Event Player.LinShi2 = 6;
				Else;
					Event Player.LinShi2 = Random Integer(1, 6);
				End;
			End;
			Event Player.JC += Event Player.LinShi2 * 50;
			Set Max Health(Event Player, Event Player.JC);
			Wait(0.500, Ignore Condition);
			Small Message(Event Player, Custom String("{0}", Event Player.LinShi2));
			Event Player.LinShi = -1;
		Else If(Event Player.LinShi == 6 && Event Player.M >= 100);
			Event Player.M -= 100;
			Event Player.GJ[0] += 1;
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.SM[0] += 10;
			If(Event Player.YiXuanTianFu[2]);
				Event Player.JC += 1;
				Set Max Health(Event Player, Event Player.JC);
				Event Player.DX[0] += 0.100;
				Stop Scaling Player(Event Player);
				Start Scaling Player(Event Player, Event Player.DX[0] + Event Player.DX[1], True);
			End;
			Event Player.LinShi = -1;
		Else If(Event Player.LinShi == 7 && Event Player.BS >= 5);
			Event Player.BS -= 5;
			Event Player.LinShi = -1;
			Event Player.YS[0] += 50;
			Set Move Speed(Event Player, (Event Player.YS[0] + Event Player.YS[1]) * (Event Player.YS[2] + Event Player.YS[3]));
		Else If(Event Player.LinShi == 8 && Event Player.BS >= 2);
			Event Player.BS -= 2;
			Event Player.LinShi = -1;
			Event Player.GJ[0] += 30;
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.YiXuanTianFu[80] += 1;
			If(Event Player.YiXuanTianFu[80] % 1 && Event Player.YiXuanTianFu[80] > 3);
				Event Player.LinShi2 = Random Integer(1, 2);
				Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) + 100);
				If(Event Player.LinShi2 == 1);
					Start Forcing Player To Be Hero(Event Player, Hero(Genji));
					Event Player.CD += 100;
				Else If(Event Player.LinShi2 == 2);
					Start Forcing Player To Be Hero(Event Player, Hero(Hanzo));
					Event Player.GJ[0] += 500;
					Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
				End;
			End;
		Else If(Event Player.LinShi == 9 && Event Player.BS >= 2);
			Event Player.BS -= 2;
			Event Player.LinShi = -1;
			Event Player.SS *= 0.850;
			Set Damage Received(Event Player, Event Player.SS);
		Else If(Event Player.LinShi == 10 && Event Player.BS >= 2);
			Event Player.BS -= 2;
			Event Player.LinShi = -1;
			Event Player.HD[0] += 200;
			Event Player.HJ[0] += 200;
		Else If(Event Player.LinShi == 11 && Event Player.BS >= 2);
			Event Player.BS -= 2;
			Event Player.LinShi = -1;
			Event Player.XX[0] += 0.200;
		Else If(Event Player.LinShi == 12 && Event Player.BS >= 2);
			Event Player.BS -= 2;
			Event Player.LinShi = -1;
			Event Player.FQ[2] += 0.400;
		Else If(Event Player.LinShi == 13 && Event Player.BS >= 2);
			Event Player.BS -= 2;
			Event Player.LinShi = -1;
			Event Player.YS[0] += 20;
			Set Move Speed(Event Player, (Event Player.YS[0] + Event Player.YS[1]) * (Event Player.YS[2] + Event Player.YS[3]));
		Else If(Event Player.LinShi == 14 && Event Player.BS >= 1);
			Event Player.BS -= 1;
			Event Player.LinShi = -1;
			Event Player.TouZi += 2;
		Else If(Event Player.LinShi == 15 && Event Player.BS >= 2);
			Event Player.BS -= 2;
			Event Player.LinShi = -1;
			Event Player.TouZi += 5;
		Else If(Event Player.LinShi == 16 && Event Player.BS >= 1);
			Event Player.BS -= 1;
			Event Player.LinShi = -1;
			Event Player.LieRen += 1;
		Else If(Event Player.LinShi == 17 && Event Player.M >= 1000);
			Event Player.M -= 1000;
			Event Player.LinShi = -1;
			If(Array Contains(All Damage Heroes, Hero Of(Event Player)) == True);
				Event Player.GJ[0] += 10;
				Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Else If(Array Contains(All Tank Heroes, Hero Of(Event Player)) == True);
				Event Player.SS *= 0.900;
				Set Damage Received(Event Player, Event Player.SS);
			Else If(Array Contains(All Support Heroes, Hero Of(Event Player)) == True);
				Event Player.ZL[0] += 20;
				Set Healing Dealt(Event Player, (Event Player.ZL[0] + Event Player.ZL[1]) * (Event Player.ZL[2] + Event Player.ZL[3]));
			End;
		Else If(Event Player.LinShi == 18 && Event Player.BS >= 5);
			Event Player.BS -= 5;
			Event Player.LinShi = -1;
			Event Player.FuZhiQi += 1;
		Else If(Event Player.LinShi == 19 && Event Player.BS >= 5);
			Event Player.BS -= 5;
			Event Player.LinShi = -1;
			Event Player.JND += 1;
		Else If(Event Player.LinShi == 20 && Event Player.BS >= 1);
			Event Player.BS -= 1;
			Event Player.LinShi = -1;
			Event Player.DX[0] -= 0.200;
			Stop Scaling Player(Event Player);
			Start Scaling Player(Event Player, Event Player.DX[0] + Event Player.DX[1], True);
		Else If(Event Player.LinShi == 21 && Event Player.BS >= 1);
			Event Player.BS -= 1;
			Event Player.LinShi = -1;
			Event Player.SM[1] += 0.400;
		Else If(Event Player.LinShi == 22 && Event Player.BS >= 1);
			Event Player.BS -= 1;
			Event Player.LinShi = -1;
			Event Player.XX[0] += Event Player.XX[0] * 0.100;
		Else If(Event Player.LinShi == 23 && Event Player.BS >= 1);
			Event Player.BS -= 1;
			Event Player.LinShi = -1;
			Event Player.CD += Event Player.CD * 0.200;
		Else If(Event Player.LinShi == 24 && Event Player.BS >= 1);
			Event Player.BS -= 1;
			Event Player.LinShi = -1;
			Event Player.YS[2] += 0.050;
			Set Move Speed(Event Player, (Event Player.YS[0] + Event Player.YS[1]) * (Event Player.YS[2] + Event Player.YS[3]));
		Else If(Event Player.LinShi == 25 && Event Player.BS >= 1);
			Event Player.BS -= 1;
			Event Player.LinShi = -1;
			Event Player.TeDingTianTu[0] += 1;
			If(Event Player.JND >= 1);
				Call Subroutine(TianFuShuaXin);
			End;
		Else If(Event Player.LinShi == 26 && Event Player.BS >= 1);
			Event Player.BS -= 1;
			Event Player.LinShi = -1;
			Event Player.TeDingTianTu[1] += 1;
			If(Event Player.JND >= 1);
				Call Subroutine(TianFuShuaXin);
			End;
		Else If(Event Player.LinShi == 27 && Event Player.M >= 500);
			Event Player.M -= 500;
			Event Player.LinShi = -1;
			Event Player.ZL[2] += 0.050;
			Set Healing Dealt(Event Player, (Event Player.ZL[0] + Event Player.ZL[1]) * (Event Player.ZL[2] + Event Player.ZL[3]));
			If(Event Player.YiXuanTianFu[95]);
				Event Player.SZ[2] += 0.050 * Event Player.YiXuanTianFu[95];
				Set Healing Received(Event Player, (Event Player.SZ[0] + Event Player.SZ[1]) * (Event Player.SZ[2] + Event Player.SZ[3]));
			End;
		Else If(Event Player.LinShi == 28 && Event Player.M >= 200);
			Event Player.M -= 200;
			Event Player.LinShi = -1;
			Event Player.YiCiXinShenMing[0] += 500;
			Remove Health Pool From Player(Event Player.YiCiXinShenMing[1]);
			Add Health Pool To Player(Event Player, Health, Event Player.YiCiXinShenMing[0], False, True);
			Event Player.YiCiXinShenMing[1] = Last Created Health Pool;
		Else If(Event Player.LinShi == 29 && Event Player.M >= 300);
			Event Player.M -= 300;
			Event Player.LinShi = -1;
			Event Player.HJ[0] += 100;
		Else If(Event Player.LinShi == 30 && Event Player.M >= 500);
			Event Player.M -= 500;
			Event Player.LinShi = -1;
			Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) + 30);
		Else If(Event Player.LinShi == 31 && Event Player.BS >= 2);
			Event Player.BS -= 2;
			Event Player.LinShi = -1;
			Event Player.GJ[0] += Round To Integer(Player Stat(Event Player, Healing Dealt) / 5000, Down) * 20;
			Set Damage Dealt(Event Player, (Event Player.GJ[0] + Event Player.GJ[1]) * (Event Player.GJ[2] + Event Player.GJ[3]));
			Event Player.FQ[0] += Round To Integer(Player Stat(Event Player, Healing Dealt) / 5000, Down) * 20;
			Event Player.YS[0] += Round To Integer(Player Stat(Event Player, Healing Dealt) / 5000, Down) * 20;
			Set Move Speed(Event Player, (Event Player.YS[0] + Event Player.YS[1]) * (Event Player.YS[2] + Event Player.YS[3]));
			Event Player.SM[1] += Round To Integer(Player Stat(Event Player, Healing Dealt) / 5000, Down) * 200;
		Else If(Event Player.LinShi == 32 && Event Player.BS >= 2);
			Event Player.BS -= 2;
			Event Player.LinShi = -1;
			Event Player.TouZi += 1;
			Event Player.MingYunMoFang += 1;
		Else If(Event Player.LinShi == 33 && Event Player.M >= 500);
			Event Player.M -= 500;
			Event Player.LinShi = -1;
			Event Player.BS += Random Integer(0, 2);
		Else If(Event Player.LinShi == 34 && Event Player.M >= 200);
			Event Player.M -= 200;
			Event Player.LinShi = -1;
			Event Player.M += Random Integer(0, 500);
		Else If(Event Player.LinShi == 35 && Event Player.BS >= 4);
			Event Player.BS -= 4;
			Event Player.LinShi = Random Integer(0, 113);
			Call Subroutine(XuanZeTianFu);
			Call Subroutine(TianFuShuaXin);
			Event Player.LinShi = -1;
		Else If(Event Player.LinShi == 36 && Event Player.BS >= 1);
			Event Player.BS -= 1;
			Event Player.LinShi = -1;
			Set Player Allowed Heroes(Event Player, Remove From Array(All Heroes, Hero Of(Event Player)));
		Else If(Event Player.LinShi == 37 && Event Player.BS >= 1);
			Event Player.BS -= 1;
			Event Player.DD += 100;
			Event Player.LinShi = -1;
		Else If(Event Player.LinShi == 38 && Event Player.BS >= 2);
			Event Player.BS -= 2;
			Event Player.LinShi = -1;
			Event Player.HD[1] += 1;
		Else If(Event Player.LinShi == 39 && Event Player.M >= 100);
			Event Player.M -= 100;
			Event Player.LinShi = -1;
			Event Player.YiXuanTianFu[3] += 1;
		Else If(Event Player.LinShi == 40 && Event Player.M >= 100);
			Event Player.M -= 100;
			Event Player.LinShi = -1;
			Event Player.JC += 10;
			Set Max Health(Event Player, Event Player.JC);
		Else If(Event Player.LinShi == 41 && Event Player.BS >= 4);
			Event Player.BS -= 4;
			Event Player.LinShi = -1;
			Start Forcing Player To Be Hero(Event Player, Hero(Torbjörn));
			Set Ammo(Event Player, 0, 0);
			Set Max Ammo(Event Player, 0, 0);
			Set Ability 1 Enabled(Event Player, False);
			Event Player.YiXuanTianFu[91] += 1;
			Modify Player Variable(Event Player, ShangPing, Remove From Array By Value, 41);
		End;
		"高级会员"
		Skip If(Event Player.LinShi != -1, 3);
		If(Event Player.YiXuanTianFu[5]);
			Event Player.M += Event Player.YiXuanTianFu[5] * 500;
		End;
	}
}

rule("天赋界面随机获取天赋子程序")
{
	event
	{
		Subroutine;
		TianFuShuaXin;
	}

	actions
	{
		Event Player.MenuRngType = 0;
		If(Event Player.TeDingTianTu[0]);
			Event Player.TeDingTianTu[0] -= 1;
			Event Player.MenuRngType = 1;
		Else If(Event Player.TeDingTianTu[1]);
			Event Player.TeDingTianTu[1] -= 1;
			Event Player.MenuRngType = 2;
		End;
		If(Event Player.YiXuanTianFu[56] != -1 && Event Player.YiXuanTianFu[56] != 0);
			Event Player.LinShi3 = Event Player.YiXuanTianFu[56];
		Else If(Event Player.MenuRngType == 1);
			Event Player.LinShi3 = Random Value In Array(Array(0, 1, 2, 3, 4, 5, 6, 56));
		Else If(Event Player.MenuRngType == 2);
			Event Player.LinShi3 = Random Value In Array(Array(7, 14, 15, 18, 20, 21, 23, 24, 35, 49, 55, 63, 72, 73, 80));
		Else;
			Event Player.LinShi3 = Random Integer(0, Count Of(Global.TFs) - 1);
		End;
		If(Event Player.MenuRngType == 1);
			Event Player.LinShi = Random Value In Array(Array(0, 1, 2, 3, 4, 5, 6, 56));
			While(Event Player.LinShi == Event Player.LinShi3);
				Event Player.LinShi = Random Value In Array(Array(0, 1, 2, 3, 4, 5, 6, 56));
			End;
		Else If(Event Player.MenuRngType == 2);
			Event Player.LinShi = Random Value In Array(Array(7, 14, 15, 18, 20, 21, 23, 24, 35, 49, 55, 63, 72, 73, 80));
			While(Event Player.LinShi == Event Player.LinShi3);
				Event Player.LinShi = Random Value In Array(Array(7, 14, 15, 18, 20, 21, 23, 24, 35, 49, 55, 63, 72, 73, 80));
			End;
		Else;
			Event Player.LinShi = Random Integer(0, Count Of(Global.TFs) - 1);
			While(Event Player.LinShi == Event Player.LinShi3);
				Event Player.LinShi = Random Integer(0, Count Of(Global.TFs) - 1);
			End;
		End;
		If(Event Player.MenuRngType == 1);
			Event Player.MenuRngId = Random Value In Array(Array(0, 1, 2, 3, 4, 5, 6, 56));
			While(Event Player.MenuRngId == Event Player.LinShi3 || Event Player.MenuRngId == Event Player.LinShi);
				Event Player.MenuRngId = Random Value In Array(Array(0, 1, 2, 3, 4, 5, 6, 56));
			End;
		Else If(Event Player.MenuRngType == 2);
			Event Player.MenuRngId = Random Value In Array(Array(7, 14, 15, 18, 20, 21, 23, 24, 35, 49, 55, 63, 72, 73, 80));
			While(Event Player.MenuRngId == Event Player.LinShi3 || Event Player.MenuRngId == Event Player.LinShi);
				Event Player.MenuRngId = Random Value In Array(Array(7, 14, 15, 18, 20, 21, 23, 24, 35, 49, 55, 63, 72, 73, 80));
			End;
		Else;
			Event Player.MenuRngId = Random Integer(0, Count Of(Global.TFs) - 1);
			While(Event Player.MenuRngId == Event Player.LinShi3 || Event Player.MenuRngId == Event Player.LinShi);
				Event Player.MenuRngId = Random Integer(0, Count Of(Global.TFs) - 1);
			End;
		End;
		Event Player.tf_3random = Array(Global.TFs[Event Player.LinShi3], Global.TFs[Event Player.LinShi], Global.TFs[Event Player.MenuRngId]);
	}
}

