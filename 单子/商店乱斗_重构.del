        {ID: 7, Header: '移速碎片-500货币\n随机获得1-5点移动速度', CostMoney: 500, CostGem: 0, RewardType: <Number>ItemRewardType.AddAttr, RewardAttrID: <Number>AttrId.Speed, RewardMin: 1, RewardMax: 5},
        {ID: 8, Header: '吸血碎片-500货币\n随机获得1%-3%吸血', CostMoney: 500, CostGem: 0, RewardType: <Number>ItemRewardType.AddAttr, RewardAttrID: <Number>AttrId.LifeSteal, RewardMin: 1, RewardMax: 3},
