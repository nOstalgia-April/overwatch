// 商店乱斗（轻量重构版）
// 设计目标：
// 1) 属性 / 物品 / 天赋 三套独立数据结构
// 2) 界面只负责按钮配置与点击分发
// 3) 保留关键旧变量名（Backpack_* / ShangPing / TianFu / YiXuanTianFu / LinShi）

enum BackpackMode {
    Closed = 0,
    Shop = 1
}

enum ShopButtonKind {
    None = 0,
    BuyItem = 1,
    Refresh = 3
}

enum ButtonScale {
    Small = 2,
    Medium = 3,
    Large = 4
}

enum AttrId {
    Attack = 0,
    SkillDamage = 1,
    Health = 2,
    Shield = 3,
    Armor = 4,
    Cooldown = 5,
    Healing = 6,
    Speed = 7,
    LifeSteal = 8,
    Knockback = 9
}

enum ItemRewardType {
    AddAttr = 1,
    AddGem = 2,
    AddDice = 3,
    AddTalentPoint = 4,
    AddPercentAttr = 5,
    AddFinalBlowMoney = 6,
    AddDamageReduction = 7,
    SetFlag = 8
}

enum TalentEffectType {
    AddAttr = 1,
    AddDice = 2,
    AddTalentPoint = 3,
    AddItemToPool = 4,
    PassiveFlag = 5
}

single struct AttrDef {
    public Number ID;
    public String Name;
    public Number BaseValue;
}

single struct ItemDef {
    public Number ID;
    public String Header;
    public Number CostMoney;
    public Number CostGem;
    public Number RewardType;
    public Number RewardAttrID;
    public Number RewardMin;
    public Number RewardMax;
}

single struct TalentDef {
    public Number ID;
    public String Header;
    public Color Color;
    public Number EffectType;
    public Number EffectAttrID;
    public Number EffectValue;
    public Number MaxStack;
}

single struct ShopButtonDef {
    public Number Kind;
    public Number RefID;
    public String Header;
    public Color DefaultColor;
    public Color HoverColor;
    public Number PosX;
    public Number PosY;
    public Number Scale;
}

globalvar Boolean Backpack_GlobalInited = false;
globalvar Vector Backpack_spot = Vector(0, 5, 0);
globalvar AttrDef[] AttrDefs = [];
globalvar ItemDef[] ItemDefs = [];
globalvar TalentDef[] TalentDefs = [];

playervar Number[] Backpack_open = [0, 0];
playervar Number Backpack_sensitivity = 2;
playervar Number[] Backpack_orientation = [0, 0];
playervar ShopButtonDef[] Backpack_button = [];
playervar ShopButtonDef[] Backpack_page = [];

playervar Number Backpack_action_id = 0;
playervar Number Backpack_action_param = 0;
playervar Number Backpack_cursorX = 0;
playervar Number Backpack_cursorY = 0;
playervar Number Backpack_hitButton = -1;

playervar Number[] Backpack_offerItemByButton = [];
playervar Number[] Backpack_itemFlags = [];

playervar Number[] AttrValue = [];
playervar Number[] ShangPing = [];
playervar Number[] TianFu = [];
playervar Number[] YiXuanTianFu = [];

playervar Number M = 1000;
playervar Number BS = 1;
playervar Number JND = 1;
playervar Number TouZi = 1;
playervar Number BountyMoney = 0;
playervar Number DamageReductionPct = 0;

playervar String LinShi = '';
playervar Number LinShi2 = 0;
playervar Number LinShi3 = 0;
playervar Boolean Backpack_inited = false;

ShopButtonDef MakeButton(
    in Number kind,
    in Number refID,
    in String header,
    in Number posX,
    in Number posY,
    in Number scale = <Number>ButtonScale.Medium,
    in Color defaultColor = Color.White,
    in Color hoverColor = Color.Yellow
):
    {
        Kind: kind,
        RefID: refID,
        Header: header,
        DefaultColor: defaultColor,
        HoverColor: hoverColor,
        PosX: posX,
        PosY: posY,
        Scale: scale
    };

Number[] GetButtonHitBox(in ShopButtonDef b):
    b.Scale == <Number>ButtonScale.Small ? [0.32, 0.16] : (b.Scale == <Number>ButtonScale.Medium ? [0.38, 0.24] : [0.5, 0.3]);

Number CursorX(in Player p):
    ((HorizontalFacingAngleOf(p) - p.Backpack_orientation[0] + 540) % 360 - 180) / p.Backpack_sensitivity;

Number CursorY(in Player p):
    -(VerticalFacingAngleOf(p) - p.Backpack_orientation[1]) / p.Backpack_sensitivity;

Boolean InRect(in Number x, in Number y, in ShopButtonDef b):
    AbsoluteValue(x - b.PosX) < GetButtonHitBox(b)[0]
    && AbsoluteValue(y - b.PosY) < GetButtonHitBox(b)[1];

Number DistSq(in Number x, in Number y, in ShopButtonDef b):
    (x - b.PosX) * (x - b.PosX)
    + (y - b.PosY) * (y - b.PosY);

Boolean IsHoveringLocal(in Number index):
    LocalPlayer().Backpack_open[0] >= <Number>BackpackMode.Shop
    && LocalPlayer().Backpack_page.Length > index
    && InRect(
        ((HorizontalFacingAngleOf(LocalPlayer()) - LocalPlayer().Backpack_orientation[0] + 540) % 360 - 180) / LocalPlayer().Backpack_sensitivity,
        -(VerticalFacingAngleOf(LocalPlayer()) - LocalPlayer().Backpack_orientation[1]) / LocalPlayer().Backpack_sensitivity,
        LocalPlayer().Backpack_page[index]
    );

String ButtonHeaderLocal(in Number index):
    LocalPlayer().Backpack_page.Length > index ? LocalPlayer().Backpack_page[index].Header : '';

Vector ButtonPosLocal(in Number index):
    LocalPlayer().Backpack_page.Length > index
    ? Vector(0, 4 + LocalPlayer().Backpack_page[index].PosY, LocalPlayer().Backpack_page[index].PosX) + Backpack_spot
    : Backpack_spot;

Color ButtonColorLocal(in Number index):
    LocalPlayer().Backpack_page.Length > index
    ? (IsHoveringLocal(index) ? LocalPlayer().Backpack_page[index].HoverColor : LocalPlayer().Backpack_page[index].DefaultColor)
    : Color.White;

Boolean ButtonSlotVisibleLocal(in Number index):
    LocalPlayer().Backpack_open[0] >= <Number>BackpackMode.Shop
    && LocalPlayer().Backpack_page.Length > index;

Number ButtonScaleLocal(in Number index):
    LocalPlayer().Backpack_page.Length > index ? LocalPlayer().Backpack_page[index].Scale : <Number>ButtonScale.Medium;

Number ButtonTextScaleLocal(in Number index):
    ButtonScaleLocal(index) == <Number>ButtonScale.Small ? 0.9 : (ButtonScaleLocal(index) == <Number>ButtonScale.Medium ? 1.0 : 1.1);

Vector CursorPosLocal:
    Vector(
        0,
        4 + (-(VerticalFacingAngleOf(LocalPlayer()) - LocalPlayer().Backpack_orientation[1]) / LocalPlayer().Backpack_sensitivity),
        ((HorizontalFacingAngleOf(LocalPlayer()) - LocalPlayer().Backpack_orientation[0] + 540) % 360 - 180) / LocalPlayer().Backpack_sensitivity
    ) + Backpack_spot;

