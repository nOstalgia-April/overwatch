        {ID: 2, Header: '生命碎片-300货币\n随机获得10-100点生命值', CostMoney: 300, CostGem: 0, RewardType: <Number>ItemRewardType.AddAttr, RewardAttrID: <Number>AttrId.Health, RewardMin: 10, RewardMax: 100},
