        {ID: 5, Header: '再训练\n+1天赋点', Color: Color.Green, EffectType: <Number>TalentEffectType.AddTalentPoint, EffectAttrID: -1, EffectValue: 1, MaxStack: 5},
        {ID: 6, Header: '补给\n+2刷新骰子', Color: Color.Blue, EffectType: <Number>TalentEffectType.AddDice, EffectAttrID: -1, EffectValue: 2, MaxStack: 5},
        {ID: 7, Header: '冰香蕉\n商店池追加特殊物品', Color: Color.White, EffectType: <Number>TalentEffectType.AddItemToPool, EffectAttrID: 4, EffectValue: 1, MaxStack: 1}
