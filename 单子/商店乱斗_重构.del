        {ID: 4, Header: '护甲碎片-400货币\n随机获得20-60点护甲', CostMoney: 400, CostGem: 0, RewardType: <Number>ItemRewardType.AddAttr, RewardAttrID: <Number>AttrId.Armor, RewardMin: 20, RewardMax: 60},
