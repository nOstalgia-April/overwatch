rule: "F切换玩家功能菜单"
Event.OngoingPlayer
Team.All
Player.All
if (!IsButtonHeld(EventPlayer(), Button.Crouch))
if (IsButtonHeld(EventPlayer(), Button.Interact))
{
    if (EventPlayer().isInMenu && EventPlayer().menuactive == MenuActive.PlayerFunctionMenu) {
        CloseMenu(EventPlayer());
    } else {
        OpenMenu(EventPlayer(), MenuActive.PlayerFunctionMenu);
    }
    Wait(0.1, WaitBehavior.IgnoreCondition);
}

rule: "蹲加互动切换英雄"
Event.OngoingPlayer
Team.All
Player.All
if (IsButtonHeld(EventPlayer(), Button.Crouch))
if (IsButtonHeld(EventPlayer(), Button.Interact))
{
    if (EventPlayer().isInMenu) {
        SmallMessage(
            VisibleTo: EventPlayer(),
            Header: '请先关闭菜单，再切换英雄'
        );
        Wait(0.1, WaitBehavior.IgnoreCondition);
        return;
    }
    SetAllowedHeroes(Hero: AllowedHeroes().Filter(t => t != HeroOf(EventPlayer())));
    Wait(0.2, WaitBehavior.IgnoreCondition);
    ResetHeroAvailability();
    Wait(0.1, WaitBehavior.IgnoreCondition);
}

