Team.All
Player.All
if (CurrentStoryPhase == StoryPhase.RATING)
if (!EventPlayer().StoryScoreConfirmed)
if (TotalTimeElapsed() - RatingMenuTimestamp >= STORY_RATING_DURATION)
{
    FinalizeStoryRating(EventPlayer());
}

rule: "飞行模式跳跃上升"
Event.OngoingPlayer
Team.All
Player.All
if (HasSpawned())
if (IsAlive())
if (EventPlayer().PlayerMenuFlightEnabled)
if (!EventPlayer().isInMenu)
if (IsButtonHeld(EventPlayer(), Button.Jump))
{
    ApplyPlayerMenuGravity(EventPlayer());
    ApplyImpulse(
        EventPlayer(),
        WorldVectorOf(Up(), EventPlayer(), <LocalVector>Transformation.Rotation),
        PLAYER_MENU_FLIGHT_VERTICAL_IMPULSE,
        Motion: ContraryMotion.Cancel
    );
    Wait(0.1, WaitBehavior.IgnoreCondition);
    LoopIfConditionIsTrue();
    ApplyImpulse(EventPlayer(), Down(), 0.001, Motion: ContraryMotion.Cancel);
}

