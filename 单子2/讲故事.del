rule: "房主长按Q开始讲故事"
Event.OngoingPlayer
Team.All
Player.All
if (EventPlayer() == HostPlayer())
if (CurrentStoryPhase == StoryPhase.IDLE)
if (!EventPlayer().isInMenu)
if (IsButtonHeld(EventPlayer(), Button.Ultimate))
{
    if (!IsStoryStartHolding) {
        IsStoryStartHolding = true;
        StoryHoldStartTimestamp = TotalTimeElapsed();
        PlayEffect(
            VisibleTo: EventPlayer(),
            Type: PlayEffect.BuffExplosionSound,
            Position: EyePosition(EventPlayer()),
            Radius: 200
        );
    }

    if (TotalTimeElapsed() - StoryHoldStartTimestamp >= 3) {
        ClearStoryRatingResultHuds();
        StoryHost = EventPlayer();
        IsStoryStartHolding = false;
        StoryHoldStartTimestamp = 0;
        PlayEffect(
            VisibleTo: EventPlayer(),
            Type: PlayEffect.ExplosionSound,
            Position: EyePosition(EventPlayer()),
            Radius: 200
        );
        IsStoryBigMessageShowing = true;
        BigMessage(
            VisibleTo: AllPlayers(),
            Header: <'<0><1>\n要开始讲故事啦，准备坐好板凳哦。', HeroIconString(HeroOf(EventPlayer())), EventPlayer()>
        );
        foreach (Player p! in AllPlayers()) {
            PlayEffect(
                VisibleTo: AllPlayers(),
                Type: PlayEffect.GoodPickupEffect,
                Color: Color.Green,
                Position: p
            );
        }
        Wait(3);
        IsStoryBigMessageShowing = false;
        CurrentStoryPhase = StoryPhase.ACTIVE;
    }

    Wait(0.05, WaitBehavior.AbortWhenFalse);
    LoopIfConditionIsTrue();
}

rule: "房主取消长按Q开始讲故事"
Event.OngoingPlayer
Team.All
Player.All
if (EventPlayer() == HostPlayer())
if (CurrentStoryPhase == StoryPhase.IDLE)
if (!IsButtonHeld(EventPlayer(), Button.Ultimate))
if (IsStoryStartHolding)
{
    IsStoryStartHolding = false;
    StoryHoldStartTimestamp = 0;
}

