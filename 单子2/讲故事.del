enum StoryPhase
{
    IDLE,
    ACTIVE,
    RATING
}

enum MenuActive
{
    StoryMenu,
    RatingMenu,
    PlayerFunctionMenu
}

enum ButtonScale
{
    Small = 2,
    Medium = 3,
    Large = 4
}

globalvar StoryPhase CurrentStoryPhase = StoryPhase.IDLE;
globalvar Number uniqueButtonID;
globalvar MenuButton[] Button_Pool;
globalvar Number MenuCursorSensibility! = 2;
globalvar Number RatingMenuTimestamp;
globalvar Any[] StoryRatingResultHudIds = [];
globalvar Number[] StoryRatingScores = [];
globalvar Number StoryRatingAverage = 0;
globalvar Player StoryHost = HostPlayer();
globalvar Boolean IsStoryBigMessageShowing = false;
globalvar Boolean IsStoryStartHolding = false;
globalvar Boolean IsStoryRatingHolding = false;
globalvar Number StoryHoldStartTimestamp = 0;

playervar Number StoryScore = 5;
playervar Boolean StoryScoreConfirmed;
playervar Boolean isInMenu;
playervar MenuActive menuactive;
playervar Vector AnchorFacing;
playervar Number MenuLoop;
playervar Boolean HoverVisible;
playervar Boolean isButtonHovered;
playervar String HoverText;
playervar String HoverBack;
playervar Number HoverLineCount;
playervar Boolean PlayerMenuFlightEnabled = false;
playervar Boolean PlayerMenuGlideEnabled = false;
playervar Number PlayerMenuScalePct = 100;
playervar Number PlayerMenuProjectileSpeedPct = 100;

String CurrentStoryPhaseText_Local():
    CurrentStoryPhase == StoryPhase.IDLE ? 'IDLE' : (CurrentStoryPhase == StoryPhase.ACTIVE ? 'ACTIVE' : 'RATING');

String STAR_FILLED: '★';
String STAR_EMPTY: '☆';
String STAR_FILLED_10: '★★★★★★★★★★';
String STAR_EMPTY_10: '☆☆☆☆☆☆☆☆☆☆';
Color STORY_RATING_GOOD_COLOR: CustomColor(144, 214, 118, 255);
Color STORY_RATING_BAD_COLOR: CustomColor(214, 124, 124, 255);
Color STORY_RATING_TABLE_COLOR: CustomColor(255, 208, 165, 255);
Color STORY_STATUS_START_COLOR: CustomColor(144, 214, 118, 255);
Color STORY_STATUS_RATING_COLOR: CustomColor(214, 124, 124, 255);
Number STORY_RATING_DURATION: 30;
Number PLAYER_MENU_SCALE_STEP: 10;
Number PLAYER_MENU_SCALE_MIN: 10;
Number PLAYER_MENU_SCALE_MAX: 200;
Number PLAYER_MENU_PROJECTILE_SPEED_STEP: 10;
Number PLAYER_MENU_PROJECTILE_SPEED_MIN: 10;
Number PLAYER_MENU_PROJECTILE_SPEED_MAX: 500;
Number PLAYER_MENU_FLIGHT_VERTICAL_IMPULSE: 6;
String STORY_PROGRESS_DOTS: '......';

String RatingStarsText(in Number rating):
    STAR_FILLED_10.Slice(0, Min(10, Max(0, rating))) + STAR_EMPTY_10.Slice(0, 10 - Min(10, Max(0, rating)));

String RatingNumberText_Local():
    <'<0>/10', Min(10, Max(0, LocalPlayer().StoryScore))>;

String ConfirmRatingText_Local():
    <'确定评分（<0>）', Max(0, STORY_RATING_DURATION - RoundToInteger(TotalTimeElapsed() - RatingMenuTimestamp, Rounding.Down))>;

String PlayerMenuFlightText_Local():
    <'飞行模式：<0>', LocalPlayer().PlayerMenuFlightEnabled ? '开' : '关'>;

String PlayerMenuGlideText_Local():
    <'滑行模式：<0>', LocalPlayer().PlayerMenuGlideEnabled ? '开' : '关'>;

String PlayerMenuScaleText_Local():
    <'体型调整\n<0>%', LocalPlayer().PlayerMenuScalePct>;

String PlayerMenuProjectileSpeedText_Local():
    <'弹道速度\n<0>%', LocalPlayer().PlayerMenuProjectileSpeedPct>;

String StoryHoldDotsText_Local():
    STORY_PROGRESS_DOTS.Slice(0, Min(6, Max(0, RoundToInteger(TotalTimeElapsed() / 6, Rounding.Down))));

Player[] StoryParticipatingPlayers():
    AllPlayers().Filter(t => HasSpawned(t));

Boolean AreAllStoryParticipantsConfirmed():
    StoryParticipatingPlayers().Length > 0 && StoryParticipatingPlayers().IsTrueForAll(t => t.StoryScoreConfirmed);

String StoryRatingTableText_Local():
    <'——————故事评分表 平均：<0>——————', StoryRatingAverage>;

String StoryStatusText_Local():
    IsStoryStartHolding ? <'正在上麦<0>', StoryHoldDotsText_Local()> : (IsStoryRatingHolding ? <'正在进入评分<0>', StoryHoldDotsText_Local()> : (CurrentStoryPhase == StoryPhase.ACTIVE ? <'<0><1> 正在讲故事', HeroIconString(HeroOf(StoryHost)), StoryHost> : '目前无人讲故事 长按（Q）上麦'));

Color StoryStatusTextColor_Local():
    IsStoryStartHolding ? STORY_STATUS_START_COLOR : (IsStoryRatingHolding ? STORY_STATUS_RATING_COLOR : Color.White);

Color StoryRatingTextColor(in Number rating):
    rating >= 7 ? STORY_RATING_GOOD_COLOR : (rating <= 3 ? STORY_RATING_BAD_COLOR : Color.White);

Color InteratableColor_Local(in Color Default = Color.White, in Color Hover = Color.Orange, in Boolean Visible = false):
    (LocalPlayer().MenuLoop == EvaluateOnce(<Color>uniqueButtonID)) || Visible ? Hover : Default;

Number CURSOR_X_LOCAL:
    HorizontalAngleTowards(LocalPlayer(), LocalPlayer().AnchorFacing + EyePosition(LocalPlayer())) / MenuCursorSensibility;

Number CURSOR_X:
    HorizontalAngleTowards(EventPlayer(), EventPlayer().AnchorFacing + EyePosition(EventPlayer())) / MenuCursorSensibility;

Number CURSOR_Y_LOCAL:
    -(VerticalFacingAngleOf(LocalPlayer()) - VerticalAngleFromDirection(LocalPlayer().AnchorFacing)) / MenuCursorSensibility;

Number CURSOR_Y:
    -(VerticalFacingAngleOf(EventPlayer()) - VerticalAngleFromDirection(EventPlayer().AnchorFacing)) / MenuCursorSensibility;

Vector CameraEye_Local:
    EyePosition(LocalPlayer());

Vector CameraLookat_Local:
    EyePosition(LocalPlayer()) + FacingDirectionOf(LocalPlayer());

Vector CameraEye:
    EyePosition();

Vector CameraLookat:
    EyePosition() + FacingDirectionOf();

Vector CameraDir_Local:
    Normalize(CameraLookat_Local - CameraEye_Local);

Vector MenuFlatBase1_Local:
    (-0.25 * Normalize(CrossProduct(Vector(0, 1, 0), CameraDir_Local)));

Vector MenuFlatBase2_Local:
    (-0.25 * Normalize(CrossProduct(CameraDir_Local, MenuFlatBase1_Local)));

Vector MenuButtonPosition_Local(in Number PosX, in Number PosY):
    UpdateEveryFrame((CameraEye_Local + DirectionTowards(CameraEye_Local, CameraLookat_Local)) + MenuFlatBase1_Local * PosX + MenuFlatBase2_Local * PosY);

Number[] GetButtonHitBox(in MenuButton b):
    b.Data.Scale == ButtonScale.Small ? [0.4, 0.2] : (b.Data.Scale == ButtonScale.Medium ? [0.4, 0.3] : [0.6, 0.4]);

single struct MenuButton_Data
{
    public Number PosX;
    public Number PosY;
    public ButtonScale Scale;
    public Boolean Interactable;
    public MenuActive[] ofMenuActives;
    public Number ID;
    public String Name = '';
}

class MenuButton
{
    public String HoverLabel;
    public MenuButton_Data Data;
    public ()=>void OnClick;

    public constructor(
        in Any header = 'null',
        in Number posX = 0,
        in Number posY = 0,
        in ButtonScale scale = ButtonScale.Medium,
        in Color ShowColor = Color.White,
        in Boolean interactable = false,
        in MenuActive[] ofmenuActives,
        in String name = '无名氏按钮',
        in String hover = ''
    ) {
        uniqueButtonID++;
        this.Data = {ID: uniqueButtonID, Interactable: interactable, Name: name, PosX: posX, PosY: posY, ofMenuActives: ofmenuActives, Scale: scale};
        HoverLabel = hover;
        Button_Pool += this;
        CreateInWorldText(
            VisibleTo: LocalPlayer().isInMenu && ArrayContains(Data.ofMenuActives, LocalPlayer().menuactive) ? LocalPlayer() : null,
            Header: header,
            Position: MenuButtonPosition_Local(Data.PosX, Data.PosY),
            Scale: <Number>scale,
            Clipping: Clipping.DoNotClip,
            Reevaluation: InworldTextRev.VisibleToPositionStringAndColor,
            TextColor: ShowColor
        );
    }

    public void SetOnClick(in ()=>void onClick) {
        OnClick = onClick;
    }

    public void SetHoverlabel(in String HoverString) {
        HoverLabel = HoverString;
    }
}

void OpenMenu(Player p! = EventPlayer(), MenuActive name) "sub打开菜单"
{
    p.menuactive = name;
    if (!p.isInMenu) {
        SetFacing(p, Vector(0, 0, 1), Relative.ToPlayer);
        p.AnchorFacing = FacingDirectionOf(p);
        p.isInMenu = true;
        SetAimSpeed(p, 0.1);
        SetPrimaryFireEnabled(p, false);
        SetSecondaryFireEnabled(p, false);
        DisableHeroHud(p);
        DisableGameModeHud(p);
    }
    SetFacing(p, p.AnchorFacing);
}

void CloseMenu(in Player p! = EventPlayer())
{
    p.isInMenu = false;
    p.MenuLoop = 0;
    p.HoverVisible = false;
    p.HoverText = '';
    p.HoverBack = '';
    SetAimSpeed(p, 100);
    SetPrimaryFireEnabled(p, true);
    SetSecondaryFireEnabled(p, true);
    EnableHeroHud(p);
    EnableGameModeHud(p);
    SetFacing(p, p.AnchorFacing);
    MinWait();
}

MenuButton GetButtonByID(Number id) "sub根据ID获取按钮"
{
    foreach (MenuButton b! in Button_Pool.Filter(t => t.Data.ofMenuActives.Contains(EventPlayer().menuactive))) {
        if (id == b.Data.ID) {
            return b;
        }
    }
    MinWait();
}

MenuButton GetButtonByName(String name) "sub根据名字获取按钮"
{
    foreach (MenuButton b! in Button_Pool.Filter(t => t.Data.ofMenuActives.Contains(EventPlayer().menuactive))) {
        if (name == b.Data.Name) {
            return b;
        }
        MinWait();
    }
}

void UpdateHoverBack()
{
    HoverLineCount = 1;
    if (HoverText == '') {
        HoverBack = '';
        return;
    }

    String[] lines = HoverText.Split("\n");
    Number rowCount = lines.Length;
    Number colCount = 0;

    foreach (String line in lines) {
        if (line.Length > colCount) {
            colCount = line.Length;
        }
    }

    String result = '';
    for (define i! = 0; i < rowCount; i++) {
        for (define j! = 0; j < colCount; j++) {
            result = result + '███';
        }
        if (i < rowCount - 1) {
            result = result + '\n';
            HoverLineCount++;
        }
    }

    HoverBack = result;
}

void CreateTestDebugHud()
{

}

void ClearStoryRatingResultHuds() "清理讲故事评分结果HUD"
{
    foreach (Any hud! in StoryRatingResultHudIds) {
        DestroyHudText(hud);
    }
    StoryRatingResultHudIds = [];
    StoryRatingScores = [];
    StoryRatingAverage = 0;
}

void UpdateStoryRatingAverage() "更新故事评分平均值"
{
    Number totalScore! = 0;

    foreach (Number score! in StoryRatingScores) {
        totalScore += score;
    }

    StoryRatingAverage = StoryRatingScores.Length > 0 ? RoundToInteger(totalScore / StoryRatingScores.Length * 10, Rounding.Nearest) / 10 : 0;
}

void CreateStoryRatingResultHud(Player p! = EventPlayer()) "创建讲故事评分结果HUD"
{
    CreateHudText(
        VisibleTo: AllPlayers(),
        Text: <'<0><1> <2>/10 ：<3>', HeroIconString(HeroOf(p)), p, p.StoryScore, RatingStarsText(p.StoryScore)>,
        Location: Location.Left,
        SortOrder: p.StoryScore * -1,
        TextColor: StoryRatingTextColor(p.StoryScore)
    );
    StoryRatingResultHudIds += LastTextID();
    StoryRatingScores += p.StoryScore;
    UpdateStoryRatingAverage();
}

void FinalizeStoryRating(Player p! = EventPlayer()) "结算讲故事评分"
{
    if (p.StoryScoreConfirmed) {
        return;
    }

    p.StoryScoreConfirmed = true;
    CreateStoryRatingResultHud(p);
    CloseMenu(p);
    if (CurrentStoryPhase == StoryPhase.RATING && AreAllStoryParticipantsConfirmed()) {
        CurrentStoryPhase = StoryPhase.IDLE;
    }
}

void ApplyPlayerMenuScale(Player p! = EventPlayer())
{
    StartScalingPlayer(p, p.PlayerMenuScalePct / 100);
}

void ApplyPlayerMenuProjectileSpeed(Player p! = EventPlayer())
{
    SetProjectileSpeed(p, ProjectileSpeedPercent: p.PlayerMenuProjectileSpeedPct);
}

void ResetPlayerMenuScaleAndProjectile(Player p! = EventPlayer())
{
    p.PlayerMenuScalePct = 100;
    p.PlayerMenuProjectileSpeedPct = 100;
    ApplyPlayerMenuScale(p);
    ApplyPlayerMenuProjectileSpeed(p);
}

void ApplyPlayerMenuFlightCompatibility(Player p! = EventPlayer())
{
    SetCrouchEnabled(p, !(HeroOf(p) == Hero.WreckingBall && p.PlayerMenuFlightEnabled));
}

void ApplyPlayerMenuGravity(Player p! = EventPlayer())
{
    SetGravity(p, p.PlayerMenuFlightEnabled || p.PlayerMenuGlideEnabled ? 0 : 100);
}

