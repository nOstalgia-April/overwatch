import '解压缩.del';

// 全局变量定义：用于路径规划和 Dijkstra 算法
globalvar Vector[] nodes_location; // 地图节点坐标数组
globalvar define nodes_link; // 节点间的连接关系（邻接表）
globalvar define nodes_basic_distance; // 节点间的基础距离矩阵
globalvar define checking_nodes; // 当前检查的节点邻居列表
globalvar define for_1; // 外层循环索引
globalvar define for_2; // 内层循环索引
globalvar define path_matrix;
globalvar define g_visited; // Dijkstra 中节点访问标记
globalvar define g_nodes_distance; // Dijkstra 中到各节点的距离
globalvar define g_nodes_succ_now; // Dijkstra 中当前后驱节点
globalvar define for_start; // Dijkstra 起点索引
globalvar define g_is_first_iteration; // Dijkstra 是否首次迭代
globalvar define g_now_ID; // 当前处理的节点 ID
globalvar define g_now_groups; // 当前节点的邻居列表
globalvar define g_now_weight; // 当前边权重
globalvar define g_maybe_distance; // 可能的路径距离
globalvar define g_unvisited_nodes_distance; // 未访问节点的距离数组
globalvar define g_predecessor;
globalvar String[] BOT_STATE_LABELS = ["待机","游荡","追踪","战斗"]; // 状态名称映射

// 玩家变量定义：用于玩家和机器人的路径及状态管理
playervar define path; // 当前路径（节点索引数组）
playervar define p_for_1; // 玩家循环索引
playervar define nodes_succ_now; // 玩家当前后驱节点
playervar define p_nodes_location; // 玩家本地节点坐标
playervar define p_nodes_link; // 玩家本地节点连接
playervar define current_ID; // 当前所在节点 ID
playervar Boolean is_pathfinding; // 是否在寻路状态
playervar Vector destination; // 目标位置
playervar Player test_player = HostPlayer(); // 测试玩家（默认主机玩家）
playervar Player[] bot_targetArray; // 可视范围内的敌人数组
playervar Player bot_target; // 当前目标敌人
playervar Boolean is_fighting; // 是否在战斗状态
playervar Number LateralScale; // 横向缩放（未使用）
playervar Number LockCounter = 0; // 卡住跳跃计数器
playervar Number BOT_STATE_IDLE = 0;
playervar Number BOT_STATE_WANDER = 1;
playervar Number BOT_STATE_CHASE = 2;
playervar Number BOT_STATE_COMBAT = 3;
playervar Number bot_state = BOT_STATE_IDLE; // 当前机器人状态
playervar Vector bot_lastKnownTargetPos; // 目标最后一次出现的位置
playervar Number bot_wanderCandidatePool = 20; // 游荡候选节点数量
playervar Number bot_wanderMaxRetries = 5; // 游荡路径生成失败重试次数
playervar Boolean bot_wanderAllowTeleport = true; // 是否允许游荡失败时传送修正
playervar Number bot_pathStepLimit = 999; // 寻路默认步数上限
playervar Number bot_pathRepathThreshold = 1; // 重新寻路触发位移阈值
playervar Boolean bot_pathFallbackToWander = true; // 寻路失败时是否回退游荡
playervar Number bot_hateDuration = 8; // 失去视野后保持仇恨的秒数

