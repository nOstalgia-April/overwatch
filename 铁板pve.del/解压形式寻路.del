// 子程序：解压 King's Row 地图的节点和连接数据
void Initialize_pf() {
    nodes_location = Decompress(Nodes_location_to_DeCompress); // 解压节点坐标
    nodes_link = Decompress(Nodes_link_to_DeCompress); // 解压节点连接
    CreateHudText(Header: CountOf(nodes_link), Text: "已解压pfNodes"); // 显示解压完成的 HUD
    Init_Optimize_PreCalculate_next_node_matrix();
}

// 枚举：机器人状态
enum pf_State {
    Wander, // 扫荡（随机巡逻）
    Chase,  // 追踪目标
    Other   // 其他状态（未使用）
}

void Init_Optimize_PreCalculate_next_node_matrix() ''{
    path_matrix = []; // 初始化路径矩阵（替换原 next_node_matrix）
    nodes_basic_distance = []; // 初始化距离矩阵（不变）
    define nodeCount = CountOf(nodes_location); // 节点总数（不变）
    
    // 初始化节点间距离矩阵（不变）
    for (for_1 = 0; nodeCount; 1)
    {
        nodes_basic_distance[for_1] = []; // 为每个节点创建空距离数组
        checking_nodes = nodes_link[for_1]; // 获取当前节点的邻居
        for (for_2 = 0; CountOf(checking_nodes); 1)
        {
            ModifyVariable(nodes_basic_distance[for_1], Operation.AppendToArray, 
                DistanceBetween(nodes_location[for_1], nodes_location[checking_nodes[for_2]])); // 计算并存储两节点间距离
        }
    }
    
    // 初始化路径矩阵（默认空数组，表示无路径）
    for (for_1 = 0; nodeCount; 1)
    {
        path_matrix[for_1] = MappedArray(nodes_location, []); // 每个[start][end] 默认空路径
    }
    
    // 为每个节点运行 Dijkstra，计算最短路径并构建路径矩阵
    for (for_1 = 0; nodeCount; 1)
    {
        g_visited = MappedArray(nodes_location, 0); // 初始化访问标记
        g_nodes_distance = MappedArray(nodes_location, 9999); // 初始化距离为无穷大
        g_nodes_distance[for_1] = 0; // 起点距离为 0
        g_predecessor = MappedArray(nodes_location, -1); // 初始化前驱数组
        g_is_first_iteration = true; // 标记首次迭代
        for_start = for_1; // 设置起点
        SubGlobalDijkstra(); // 运行 Dijkstra 算法
        
        // 构建从 start 到所有 end 的路径
        define WaitCountBuild = 0;
        for (define end_id = 0; nodeCount; 1)
        {
            if (WaitCountBuild >= 10)
            {
                WaitCountBuild = 0;
                MinWait();
            }
            else
            {
                WaitCountBuild += 1;
            }
            
            if (g_nodes_distance[end_id] == 9999) continue; // 无路径
            define temp_path = [];
            define curr = end_id;
            while (curr != for_1)
            {
                if (curr == -1) break;
                ModifyVariable(temp_path, Operation.AppendToArray, curr); // 从终点向前构建
                curr = g_predecessor[curr];
            }
            temp_path = temp_path.Sort(t => -1 * temp_path.IndexOf(t)); // 反转路径
            path_matrix[for_1][end_id] = temp_path;
        }
    }
}

void SubGlobalDijkstra() ''{
    define WaitCount = 0; // 等待计数器，防止服务器过载
    while (true)
    {
        if (WaitCount >= 10)
        {
            WaitCount = 0;
            MinWait();
        }
        else
        {
            WaitCount += 1;
        }
        
        if (g_is_first_iteration) // 首次迭代设置起点
        {
            g_now_ID = for_start;
            g_is_first_iteration = false;
        }
        else
        {
            // 筛选未访问节点的距离
            g_unvisited_nodes_distance = FilteredArray(g_nodes_distance, 
                g_visited[IndexOfArrayValue(g_nodes_distance, ArrayElement())] == 0);
            if (CountOf(g_unvisited_nodes_distance) == 0) break; // 所有节点已访问
            // 选择未访问节点中距离最小的节点
            g_now_ID = IndexOfArrayValue(g_nodes_distance, 
                FirstOf(SortedArray(g_unvisited_nodes_distance, ArrayElement())));
        }
        g_visited[g_now_ID] = 1; // 标记当前节点已访问
        g_now_groups = nodes_link[g_now_ID]; // 获取邻居节点
        
        for (for_2 = 0; CountOf(g_now_groups); 1)
        {
            define neighbor = g_now_groups[for_2]; // 当前邻居节点
            if (neighbor >= 0 && neighbor < CountOf(nodes_location) && g_visited[neighbor] == 0)
            {
                g_now_weight = nodes_basic_distance[g_now_ID][for_2]; // 边权重
                g_maybe_distance = g_nodes_distance[g_now_ID] + g_now_weight; // 可能距离
                if (g_maybe_distance < g_nodes_distance[neighbor]) // 更新更短路径
                {
                    g_nodes_distance[neighbor] = g_maybe_distance;
                    g_predecessor[neighbor] = g_now_ID; // 记录前驱
                }
            }
        }
        
        if (CountOf(FilteredArray(g_visited, ArrayElement() == 0)) == 0) break; // 全部访问完毕
    }
}

// 规则：机器人或玩家沿路径移动
rule: "MoveAlongPath"
Event.OngoingPlayer
if (is_pathfinding)
if (HasSpawned(EventPlayer()) == true)
if (CountOf(path) > 0)
if (IsAlive())
{
    Wait(0.25, WaitBehavior.IgnoreCondition); // 每 0.25 秒更新移动
    StopForcingThrottle(); // 停止现有节流
    bot_FacingUpdate();
    StartThrottleInDirection(EventPlayer(), DirectionTowards(EyePosition(EventPlayer()), nodes_location[FirstOf(path)]), 1, Relative.ToWorld, ThrottleBehavior.ReplaceExistingThrottle, ThrottleRev.DirectionAndMagnitude); // 朝路径第一个节点移动
}

// 规则：移除已到达的路径节点并处理到达终点
rule: "RemoveReachedNode"
Event.OngoingPlayer
if (is_pathfinding)
if (HasSpawned(EventPlayer()) == true)
if (CountOf(path) > 0)
if (DistanceBetween(EyePosition(EventPlayer()), Vector(XOf(nodes_location[FirstOf(path)]), YOf(EyePosition(EventPlayer())), ZOf(nodes_location[FirstOf(path)]))) < 1)
{
    ModifyVariable(path, Operation.RemoveFromArrayByIndex, 0); // 移除路径第一个节点
    if (CountOf(path) == 0) // 路径为空
    {
        if (IsDummyBot())
        {
            if (bot_state == BOT_STATE_CHASE)
            {
                define repathThreshold = Max(0.1, bot_pathRepathThreshold);
                Boolean chaseContinues = false;
                if (bot_target != null)
                {
                    chaseContinues = BotPathToPlayer(bot_target, bot_lastKnownTargetPos, stepLimit: bot_pathStepLimit, fallbackToWander: false, reason: "追踪目标：路径中断重连", updateLastKnown: true);
                }
                else if (bot_lastKnownTargetPos != null && DistanceBetween(PositionOf(), bot_lastKnownTargetPos) > repathThreshold)
                {
                    chaseContinues = BotPathToPlayer(null, bot_lastKnownTargetPos, stepLimit: bot_pathStepLimit, fallbackToWander: false, reason: "追踪最后位置：路径中断重连", updateLastKnown: false);
                }
                if (!chaseContinues)
                {
                    BotStartWander(reason: "追踪失败，改为游荡");
                }
                return;
            }
        }
        if (DistanceBetween(EyePosition(EventPlayer()), Vector(XOf(destination), YOf(EyePosition(EventPlayer())), ZOf(destination))) > 1)
        {
            is_pathfinding = CalculateSteps(RandomInteger(1,4), end: destination); // 未到达目标，生成 1-4 步路径
            if (IsDummyBot() && !is_pathfinding)
            {
                BotStartWander(reason: "短程补路失败，改为游荡");
            }
        }
        else
        {
            if (IsDummyBot())
            {
                BotStartWander(reason: "到达目标，进入游荡");
                return; 
            }
            StopThrottleInDirection(EventPlayer()); // 非机器人停止移动
        }
    }
}

// 函数：获取距离指定位置最近的节点
Any NearestNode(in Any vector)
{
    return FirstOf(SortedArray(nodes_location, DistanceBetween(ArrayElement(), vector))); // 返回最近节点
}

// 规则：调试显示后驱矩阵尺寸
rule: "DebugMatrixDimensions"
{
    //CreateHudText(Header: <"后驱矩阵横向长度<0>", CountOf(path_matrix[0])>); // 显示矩阵行数
    //CreateHudText(Header: <"后驱矩阵竖向长度<0>", CountOf(path_matrix)>); // 显示矩阵列数
}

// 规则：主机玩家按 Ultimate 键显示所有节点
rule: "VisualizeNodes"
if(IsButtonHeld(HostPlayer(), Button.Ultimate))
{
    //CreateHudText(Header: '已生成节点显示');
    for(define i = 0; i < CountOf(nodes_location); i++) {
        CreateEffect(Type: Effect.Sphere, Position: nodes_location[i], Color: Color.White, Radius: 0.5, Reevaluation: EffectRev.Color); // 在每个节点位置创建白色球体
    }
}

// 规则：显示路径长度和服务器负载
rule: "DebugPathAndServerLoad"
{
    //CreateHudText(Header: CountOf(LocalPlayer().path)); // 显示玩家路径长度
    CreateHudText(Header: ServerLoad(), Subheader: ServerLoadAverage()); // 显示服务器负载
}

// 子程序：计算从起点到终点的路径
Boolean CalculateSteps(Number steps = 1, Vector end, Vector start = PositionOf()) playervar 'CalculatePath' {
    start = PositionOf();
    p_nodes_location = nodes_location;
    p_nodes_link = nodes_link;
    CreateIcon(Icon: Icon.ArrowDown, Position: end, IconColor: Color.Red, VisibleTo: EventPlayer());
    define start_ID = IndexOfArrayValue(p_nodes_location, FirstOf(SortedArray(FilteredArray(nodes_location, IsInLineOfSight(ArrayElement(), EyePosition())), DistanceBetween(ArrayElement(), EyePosition()))));
    define end_ID = IndexOfArrayValue(p_nodes_location, NearestNode(end));
    path = []; // 清空路径
    current_ID = start_ID;
    
    // 直接获取预计算路径
    define full_path = path_matrix[start_ID][end_ID];
    if (CountOf(full_path) == 0) { // 无路径
        return false;
    }
    // 处理起点：如果不在起点且视线不通，添加当前节点
    if (DistanceBetween(EyePosition(EventPlayer()), Vector(XOf(nodes_location[start_ID]), YOf(EyePosition(EventPlayer())), ZOf(nodes_location[start_ID]))) > 1 && !IsInLineOfSight(nodes_location[start_ID], PositionOf()+Vector(0,0.5,0)) && (SpeedOfInDirection(EventPlayer(), VectorTowards(nodes_location[start_ID], nodes_location[FirstOf(full_path)]))/SpeedOf()) < 0.75 ) {
        ModifyVariable(path, Operation.AppendToArray, start_ID);
    }
    
    // 截取路径：根据 steps 限制长度（steps=1 只取下一个，9999 取全）
    define limited_path = ArraySlice(full_path, 0, Min(steps, CountOf(full_path)));
    path = Append(path, limited_path); // 追加到 path
    
    if (CountOf(path) > 0) {
        return true;
    }
    return false;
}

// 规则：主机玩家按副键创建机器人
rule: "SpawnDummyBots"
if(IsButtonHeld(HostPlayer(), Button.SecondaryFire) && true)
{
    while(CountOf(AllPlayers(Team.Team1)) < 2) {
        CreateDummyBot(Hero: Hero.Reinhardt, Team: Team.Team1, Slot: -1, Position: HostPlayer()); // 创建 Reinhardt 机器人
    }
}

// 规则：机器人按交互键显示路径长度并禁用玩家碰撞
rule: "BotDebugPath"
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot())
if(IsAlive())
if(IsButtonHeld(HostPlayer(), Button.Interact))
if(false)
{
    BigMessage( Header: '已生成路径显示');
    CreateInWorldText(Header: CountOf(path), Position: EventPlayer(), Scale: 1.5, TextColor: Color.Orange, Clipping: Clipping.DoNotClip, VisibleTo: AllPlayers()); // 显示路径长度
    CreateInWorldText(Header: <'寻路<0>,战斗<1>', EventPlayer().is_pathfinding, EventPlayer().is_fighting>, Position: EventPlayer(), Scale: 2, Clipping: Clipping.DoNotClip); // 显示机器人状态
    DisableMovementCollisionWithPlayers(EventPlayer()); // 禁用玩家碰撞
}

// 规则：处理机器人卡住，尝试跳跃或传送
rule: "处理机器人卡住，尝试跳跃或传送"
Event.OngoingPlayer
Team.All
Player.All
if(is_pathfinding)
if(SpeedOf() <= 3.5)
{
    Wait(3, WaitBehavior.AbortWhenFalse); // 等待 3 秒
    AbortIf(IsDead() || HasStatus(Status: Status.Frozen) || HasStatus(Status: Status.Stunned) || HasStatus(Status: Status.Asleep) || HasStatus(Status: Status.KnockedDown) || HasStatus(Status: Status.Rooted)); // 中止如果异常状态
    LockCounter++; // 增加卡住计数
    PressButton(Button: Button.Jump); // 尝试跳跃
    if(LockCounter > 2) {
        if(CountOf(path)>0){
            Teleport(EventPlayer(), nodes_location[path[0]]); // 传送到路径第一个节点
        }else{
            BotStartWander(reason: "卡住后重新游荡");
        }
        LockCounter = 0; // 重置计数
    }
    LoopIfConditionIsTrue(); // 循环检查
}

// 子程序：生成游荡路径（不直接修改状态）
Boolean BotBuildWanderPath(Number candidatePool = 20, Number maxRetries = 5, Boolean allowTeleportFallback = true) 'BotBuildWanderPath'{
    define startPos = PositionOf(EventPlayer()); // 记录起点
    define attemptCount = 0;
    define lastDestination = null;
    if(candidatePool <= 0) {
        candidatePool = 1;
    }
    while(attemptCount < Max(1, maxRetries)) {
        define nearbyNodes = ArraySlice(SortedArray(nodes_location, DistanceBetween(ArrayElement(), EventPlayer())), 0, candidatePool); // 从附近节点中抽样
        if(CountOf(nearbyNodes) == 0) {
            break;
        }
        lastDestination = RandomValueInArray(nearbyNodes);
        destination = lastDestination;
        if(CalculateSteps(9999, end: lastDestination, start: startPos)) { // 生成全路径
            return true;
        }
        attemptCount += 1;
    }
    if(allowTeleportFallback && lastDestination != null) {
        Teleport(EventPlayer(), lastDestination);
        return BotBuildWanderPath(candidatePool, maxRetries, false);
    }
    destination = null;
    return false;
}

// 子程序：机器人开始游荡（包含状态切换）
Boolean BotStartWander(Number candidatePool = 0, Number maxRetries = 0, Boolean allowTeleportFallback = true, Boolean resetTarget = true, String reason = "开始游荡") 'BotStartWander'{
    String wanderReason = reason;
    if(wanderReason == null || wanderReason == "") {
        wanderReason = "开始游荡";
    }
    if(candidatePool <= 0) {
        candidatePool = bot_wanderCandidatePool;
    }
    if(maxRetries <= 0) {
        maxRetries = bot_wanderMaxRetries;
    }
    allowTeleportFallback = allowTeleportFallback && bot_wanderAllowTeleport;
    if(resetTarget) {
        BotClearTarget(true);
    }
    is_fighting = false;
    LockCounter = 0;
    Boolean hasPath = BotBuildWanderPath(candidatePool, maxRetries, allowTeleportFallback);
    is_pathfinding = hasPath;
    if(hasPath) {
        BotSetState(BOT_STATE_WANDER, wanderReason);
    } else {
        BotSetState(BOT_STATE_IDLE, <"游荡失败：<0>", wanderReason>);
    }
    if(!hasPath) {
        StopThrottleInDirection();
    }
    return hasPath;
}

String BotStateName(Number state) {
    if(state >= 0 && state < CountOf(BOT_STATE_LABELS)) {
        return BOT_STATE_LABELS[state];
    }
    return "未知";
}

void BotShowStateChange(Number newState, String reason) {
    String label = BotStateName(newState);
    String detail = reason;
    if(detail == null) {
        detail = "";
    }
    SmallMessage(VisibleTo: AllPlayers(), Header: <"状态：<0>,<1>", label,detail>);
}

void BotSetState(Number newState, String reason) 'BotSetState' {
    if(newState == null) {
        return;
    }
    if(bot_state == newState) {
        if(reason != null && reason != "") {
            BotShowStateChange(newState, reason);
        }
        return;
    }
    bot_state = newState;
    BotShowStateChange(newState, reason);
}

void BotSetTarget(Player newTarget) 'BotSetTarget' {
    bot_target = newTarget;
    if(newTarget != null) {
        bot_lastKnownTargetPos = PositionOf(newTarget); // 更新最后一次看到的位置
    }
}

void BotClearTarget(Boolean resetLastKnown) 'BotClearTarget' {
    bot_target = null;
    if(resetLastKnown) {
        bot_lastKnownTargetPos = null;
    }
}

Boolean BotPathToPlayer(Player target, Vector fallbackPosition = null, Number stepLimit = 0, Boolean fallbackToWander = false, String reason = "追踪目标", Boolean updateLastKnown = true) 'BotPathToPlayer'{
    String chaseReason = reason;
    if(chaseReason == null || chaseReason == "") {
        chaseReason = "追踪目标";
    }
    Number resolvedStepLimit = stepLimit;
    if(resolvedStepLimit <= 0) {
        resolvedStepLimit = bot_pathStepLimit;
    }
    if(resolvedStepLimit <= 0) {
        resolvedStepLimit = 1;
    }
    Vector desiredDestination = null;
    if(target != null && HasSpawned(target) && IsAlive(target)) {
        desiredDestination = PositionOf(target);
    }
    if(desiredDestination == null) {
        if(fallbackPosition != null) {
            desiredDestination = fallbackPosition;
        } else if(bot_lastKnownTargetPos != null) {
            desiredDestination = bot_lastKnownTargetPos;
        }
    }
    if(desiredDestination == null) {
        if(fallbackToWander && bot_pathFallbackToWander) {
            BotStartWander(resetTarget: false, reason: <"追踪失败（<0>）", chaseReason>);
        }
        return false;
    }
    destination = desiredDestination;
    Boolean pathReady = CalculateSteps(resolvedStepLimit, end: desiredDestination, start: PositionOf());
    if(pathReady) {
        is_pathfinding = true;
        is_fighting = false;
        LockCounter = 0;
        if(target != null) {
            BotSetTarget(target);
        }
        if(updateLastKnown) {
            bot_lastKnownTargetPos = desiredDestination;
        }
        BotSetState(BOT_STATE_CHASE, chaseReason);
    } else if(fallbackToWander && bot_pathFallbackToWander) {
        BotStartWander(resetTarget: false, reason: <"追踪失败（<0>）", chaseReason>);
    }
    return pathReady;
}

void BotEnterCombatState(Player focusTarget, String reason = "进入战斗") 'BotEnterCombatState' {
    String combatReason = reason;
    if(combatReason == null || combatReason == "") {
        combatReason = "进入战斗";
    }
    if(focusTarget != null && bot_state == BOT_STATE_COMBAT && focusTarget == bot_target) {
        BotSetTarget(focusTarget);
        BotSetState(BOT_STATE_COMBAT, combatReason);
        return;
    }
    if(focusTarget != null) {
        BotSetTarget(focusTarget);
    }
    is_fighting = true;
    is_pathfinding = false;
    LockCounter = 0;
    path = [];
    StopThrottleInDirection();
    BotSetState(BOT_STATE_COMBAT, combatReason);
    bot_FacingUpdate();
}

Boolean BotEnterChaseState(Player chaseTarget, Vector fallbackPosition, String reason = "") 'BotEnterChaseState' {
    String chaseReason = reason;
    if(chaseReason == null || chaseReason == "") {
        chaseReason = chaseTarget != null ? "追踪目标" : "追踪最后位置";
    }
    return BotPathToPlayer(chaseTarget, fallbackPosition, stepLimit: bot_pathStepLimit, fallbackToWander: false, reason: chaseReason, updateLastKnown: true);
}

void BotEnterWanderState(String reason = "开始游荡") 'BotEnterWanderState' {
    BotStartWander(reason: reason);
}

// 规则：机器人获取目标
rule: "机器人获取目标"
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot() && IsAlive())
{
    bot_targetArray = AllPlayers(Team.Team2).Filter(t => IsInLineOfSight(t, EventPlayer()) && (DistanceBetween(t, EventPlayer()) <= 12 && AbsoluteValue(YOf(PositionOf(t))-YOf(PositionOf(EventPlayer())))<=3) && IsAlive(t) && HasSpawned(t)); // 筛选 12 米内可见敌人
    if (CountOf(bot_targetArray) > 0) {
        BotSetTarget(bot_targetArray.Sort(t => DistanceBetween(t, EventPlayer())).First); // 选择最近敌人并更新记录
    }
    Wait(0.25); // 更频繁地刷新目标信息
    LoopIfConditionIsTrue();
}

// 规则：机器人进入战斗状态
rule: "机器人进入战斗状态"
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot() && IsAlive())
if(CountOf(bot_targetArray) > 0)
if(bot_target != null)
{
    BotEnterCombatState(bot_target, "锁定可见目标进入战斗");
}

// 规则：机器人结束战斗，进入扫荡
rule: "机器人结束战斗，进入扫荡"
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot() && IsAlive())
if(CountOf(bot_targetArray) == 0)
if(bot_target == null)
if(bot_state != BOT_STATE_WANDER)
{
    Wait(0.5, WaitBehavior.AbortWhenFalse); // 确认周围无威胁
    BotStartWander(reason: "战斗结束，恢复游荡");
    LoopIfConditionIsTrue();
}

// 规则：机器人结束战斗，进入追踪
rule: "机器人结束战斗，进入追踪"
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot() && IsAlive())
if(CountOf(bot_targetArray) == 0)
if(bot_target != null)
if(bot_state != BOT_STATE_CHASE)
{
    if(!IsAlive(bot_target))
    {
        BotStartWander(reason: "目标已死亡，改为游荡");
    } else {
        Wait(0.2, WaitBehavior.AbortWhenFalse); // 稍作等待确认视野丢失
        if(!BotEnterChaseState(bot_target, bot_lastKnownTargetPos, "追踪失去视野后补路")) {
            BotStartWander(reason: "追踪失败，改为游荡");
        }
        Wait(bot_hateDuration, WaitBehavior.AbortWhenFalse); // 延长失去视野后的仇恨保持时间
        if(CountOf(bot_targetArray) == 0 && bot_state == BOT_STATE_CHASE) {
            BotClearTarget(true);
        }
    }
    LoopIfConditionIsTrue();
}

// 规则：机器人追踪状态下刷新路径
rule: "机器人追踪状态下刷新路径"
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot() && IsAlive())
if(bot_state == BOT_STATE_CHASE)
{
    if(bot_target != null && IsAlive(bot_target))
    {
        define latestPos = PositionOf(bot_target);
        define repathThreshold = Max(2, bot_pathRepathThreshold);
        if(DistanceBetween(latestPos, bot_lastKnownTargetPos) > repathThreshold)
        {
            BotPathToPlayer(bot_target, latestPos, stepLimit: bot_pathStepLimit, fallbackToWander: false, reason: "追踪中：目标移动，刷新路径", updateLastKnown: true);
        }
    }
    Wait(0.5);
    LoopIfConditionIsTrue();
}

rule: '机器人受到攻击的时候，开始追踪'
Event.OnDamageTaken
Team.All
Player.All
if(IsDummyBot() && IsAlive())
{
    define damageSource = Attacker();
    if(damageSource != null)
    {
        if(IsInLineOfSight(damageSource, EventPlayer()))
        {
            BotEnterCombatState(damageSource, "受到攻击：进入战斗");
        }
        else
        {
            if(!BotEnterChaseState(damageSource, PositionOf(damageSource), "受到攻击：追击攻击者")) {
                if(bot_state != BOT_STATE_WANDER) {
                    BotStartWander(reason: "追击失败，改为游荡");
                }
            }
        }
    }
    Wait(1);
}

// 子程序：机器人更新朝向（瞄准目标）
void bot_FacingUpdate() 'UpdateBotFacing' {
    if(is_pathfinding && CountOf(path) > 0){
        StartFacing(EventPlayer(),
            DirectionTowards(
                EyePosition(),
                Vector(XOf(nodes_location[path[0]]),YOf(EyePosition()),ZOf(nodes_location[path[0]]))
            ),
            1000,
            Relative.ToWorld,
        );
    }else if(bot_target != null){
        StartFacing(EventPlayer(),
            DirectionTowards(
                EyePosition(),
                EyePosition(bot_target) + Down() * DistanceBetween(EventPlayer(), bot_target) * 0.01 + VelocityOf(bot_target) * (DistanceBetween(EventPlayer(), bot_target) * bot_ballistic_velocity + 0.2)
                +
                DirectionFromAngles(
                    HorizontalFacingAngleOf() + RandomReal(
                        DistanceBetween(EventPlayer(), bot_target) * AbsoluteValue(bot_aming_accuracy) * -1,
                        DistanceBetween(EventPlayer(), bot_target) * AbsoluteValue(bot_aming_accuracy)
                    ),
                    VerticalFacingAngleOf() + RandomReal(
                        DistanceBetween(EventPlayer(), bot_target) * AbsoluteValue(bot_aming_accuracy) * 0.25 * -1,
                        DistanceBetween(EventPlayer(), bot_target) * AbsoluteValue(bot_aming_accuracy) * 0.25
                    )
                ) * 1
            ),
            1000,
            Relative.ToWorld,
            FacingRev.DirectionAndTurnRate
        ); // 调整机器人朝向，考虑目标速度和距离
    }
    
}

// 常量：机器人瞄准参数
Number bot_ballistic_velocity: -0.003; // 子弹轨迹补偿
Number bot_aming_accuracy: 0; // 瞄准精度（当前无随机偏移）
playervar Number bot_attackRange = 5;
// 规则：机器人战斗时移动
rule: "机器人战斗时移动"
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot() && IsAlive())
if(bot_target != null)
if(is_fighting) 
{
    StartThrottleInDirection(
        Player: EventPlayer(),
        Direction: Vector(
            DistanceBetween(EventPlayer(), bot_target)>bot_attackRange ?
            0:
            EvaluateOnce(RandomValueInArray([-1,0,1])),
            0,
            DistanceBetween(EventPlayer(), bot_target)>bot_attackRange ?
            1:
            EvaluateOnce(RandomValueInArray([-1,0,1])),
        ),
        Magnitude: 1,
        Relative: Relative.ToPlayer,
        Behavior: ThrottleBehavior.ReplaceExistingThrottle,
        Reevaluation: ThrottleRev.DirectionAndMagnitude
    );
    Wait(RandomReal(0.5,1),WaitBehavior.AbortWhenFalse);
    LoopIfConditionIsTrue();
}

// 规则：机器人非战斗时停止移动
rule: "机器人非战斗时停止移动"
Event.OngoingPlayer
Team.All
Player.All
if(IsDummyBot() && IsAlive())
if(!is_fighting)
{
    StopThrottleInDirection();
}

rule: 'My Rule'
{
    Initialize_pf();
}
