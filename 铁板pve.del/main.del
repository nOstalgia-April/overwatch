if(IsDummyBot())
{
    switch(bot_type){
        case BotType.Zombie:
            SetDamageDealt(EventPlayer(), 50);
            break;
        case BotType.CannonWalker:
            //AddHealthPoolToPlayer(EventPlayer(), HealthType.Health, 600,1,1);
            break;
    }
}
playervar BotType bot_type;
enum BotType{
    Zombie = 1,
    CannonWalker = 2
}

rule: 'My Player Rule'
